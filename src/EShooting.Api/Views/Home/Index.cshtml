</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    const athleteNameInput = document.getElementById("athleteName");
    const isSubscriberInput = document.getElementById("isSubscriber");
    const laneNumberInput = document.getElementById("laneNumber");
    const durationMinutesInput = document.getElementById("durationMinutes");
    const isOpenEndedInput = document.getElementById("isOpenEnded");
    const sessionIdInput = document.getElementById("sessionId");
    const roundNumberInput = document.getElementById("roundNumber");
    const scoreValueInput = document.getElementById("scoreValue");
    const dashboardRows = document.getElementById("dashboardRows");
    const sessionInfo = document.getElementById("sessionInfo");
    const laneGrid = document.getElementById("laneGrid");
    const connectionBadge = document.getElementById("connectionBadge");
    const subscriptionAthleteNameInput = document.getElementById("subscriptionAthleteName");
    const subscriptionDayPatternInput = document.getElementById("subscriptionDayPattern");
    const subscriptionVisitsCountInput = document.getElementById("subscriptionVisitsCount");
    const subscriptionStartTimeInput = document.getElementById("subscriptionStartTime");
    const subscriptionDurationMinutesInput = document.getElementById("subscriptionDurationMinutes");
    const subscriptionStartDateInput = document.getElementById("subscriptionStartDate");
    const subscriptionRows = document.getElementById("subscriptionRows");
    const subscriptionInfo = document.getElementById("subscriptionInfo");
    const upcomingSubscriptionRows = document.getElementById("upcomingSubscriptionRows");
    const upcomingSubscriptionInfo = document.getElementById("upcomingSubscriptionInfo");
    const groupAthleteNamesInput = document.getElementById("groupAthleteNames");
    const groupLaneNumberInput = document.getElementById("groupLaneNumber");
    const groupDurationMinutesInput = document.getElementById("groupDurationMinutes");
    const groupInfo = document.getElementById("groupInfo");

    const totalLanesEl = document.getElementById("totalLanes");
    const activeSessionsEl = document.getElementById("activeSessions");
    const scheduledSessionsEl = document.getElementById("scheduledSessions");
    const completedSessionsEl = document.getElementById("completedSessions");
    let latestLanes = [];
    const laneScoreDraft = {};
    let countdownTimerId = null;
    let upcomingCountdownTimerId = null;
    let subscriptionSchedulesCache = [];
    const dayNames = ["Bazar", "Bazar ertəsi", "Çərşənbə axşamı", "Çərşənbə", "Cümə axşamı", "Cümə", "Şənbə"];

    function refreshStats(lanes) {
        totalLanesEl.textContent = String(lanes.length);
        activeSessionsEl.textContent = String(lanes.filter(x => x.status === "Active").length);
        scheduledSessionsEl.textContent = String(lanes.filter(x => x.status === "Scheduled").length);
        completedSessionsEl.textContent = String(lanes.filter(x => x.status === "Completed").length);
    }

    const COUNTDOWN_WARN_SEC = 60;
    const COUNTDOWN_CRIT_SEC = 10;
    function applyRingRemaining(circle, fractionRemaining) {
        const f = Math.max(0, Math.min(1, fractionRemaining));
        const r = circle instanceof SVGCircleElement ? circle.r.baseVal.value : 42;
        const len = 2 * Math.PI * r;
        circle.style.strokeDasharray = String(len);
        circle.style.strokeDashoffset = String(len * (1 - f));
    }

    function formatSeconds(milliseconds) {
        const totalSeconds = Math.floor(milliseconds / 1000);
        const hours = Math.floor(totalSeconds / 3600);
        const minutes = Math.floor((totalSeconds % 3600) / 60);
        const seconds = totalSeconds % 60;

        if (hours > 0) {
            return `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
        }

        return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
    }

    function parseApiDate(value) {
        if (!value) {
            return new Date(0);
        }

        const needsUtcSuffix = typeof value === "string" && !/[zZ]|[+-]\d{2}:\d{2}$/.test(value);
        return new Date(needsUtcSuffix ? `${value}Z` : value);
    }

    function hasValidTimeWindow(startMs, endMs) {
        return Number.isFinite(startMs) && Number.isFinite(endMs) && endMs > startMs;
    }

    function syncOpenEndedMode() {
        if (!(durationMinutesInput instanceof HTMLInputElement) || !(isOpenEndedInput instanceof HTMLInputElement)) {
            return;
        }

        if (isOpenEndedInput.checked) {
            durationMinutesInput.dataset.prevValue = durationMinutesInput.value;
            durationMinutesInput.value = "0";
            durationMinutesInput.disabled = true;
            sessionInfo.textContent = "Vaxtsız sessiya seçildi: sayğac 00:01-dən başlayıb Stop-a qədər artır.";
            return;
        }

        durationMinutesInput.disabled = false;
        const prev = durationMinutesInput.dataset.prevValue;
        durationMinutesInput.value = prev && Number(prev) > 0 ? prev : "3";
    }

    async function apiFetch(input, init = {}) {
        const response = await fetch(input, { ...init, credentials: "same-origin" });
        if (response.status === 401) {
            window.location.assign("/Account/Login?returnUrl=" + encodeURIComponent(window.location.pathname + window.location.search));
            throw new Error("İcazə yoxdur");
        }

        return response;
    }

    async function readErrorMessage(response) {
        const raw = await response.text();
        if (!raw) {
            return "Naməlum xəta";
        }

        try {
            const parsed = JSON.parse(raw);
            return parsed?.error ?? parsed?.title ?? raw;
        } catch {
            return raw;
        }
    }

    function getExceptionMessage(error) {
        if (error instanceof Error && error.message) {
            return error.message;
        }

        return "Naməlum xəta";
    }

    function updateCountdownRings() {
        document.querySelectorAll("[data-countdown-ring]").forEach(el => {
            if (!(el instanceof HTMLElement)) {
                return;
            }

            const start = el.dataset.start ?? "";
            const end = el.dataset.end ?? "";
            const status = el.dataset.status ?? "";
            const timerEl = el.querySelector("[data-role=\"timer\"]");
            const captionEl = el.querySelector("[data-role=\"caption\"]");
            const progressEl = el.querySelector(".countdown-ring__progress");
            if (!timerEl || !(progressEl instanceof SVGGraphicsElement)) {
                return;
            }

            el.classList.remove("is-live", "is-pending", "is-warn", "is-critical", "is-done", "is-idle");

            const startMs = parseApiDate(start).getTime();
            const endMs = parseApiDate(end).getTime();
            const nowMs = Date.now();
            const timedSession = hasValidTimeWindow(startMs, endMs);
            const totalMs = timedSession ? endMs - startMs : 0;

            if (!start || !end || !timedSession) {
                if (status === "Completed") {
                    el.classList.add("is-done");
                    timerEl.textContent = "Bitib";
                    if (captionEl) {
                        captionEl.textContent = "Sessiya";
                    }
                    applyRingRemaining(progressEl, 0);
                    return;
                }

                if (status === "Scheduled") {
                    el.classList.add("is-pending");
                    const untilStartMs = Number.isFinite(startMs) ? Math.max(0, startMs - nowMs) : 0;
                    timerEl.textContent = untilStartMs > 0 ? formatSeconds(untilStartMs) : "—";
                    if (captionEl) {
                        captionEl.textContent = untilStartMs > 0 ? "Başlayır" : "Planlı";
                    }
                    applyRingRemaining(progressEl, 1);
                    return;
                }

                if (status === "Active") {
                    el.classList.add("is-live");
                    const elapsedMs = Number.isFinite(startMs)
                        ? Math.max(1000, nowMs - startMs)
                        : 1000;
                    timerEl.textContent = formatSeconds(elapsedMs);
                    if (captionEl) {
                        captionEl.textContent = "Keçən vaxt";
                    }
                    applyRingRemaining(progressEl, 1);
                    return;
                }

                el.classList.add("is-idle");
                timerEl.textContent = "—";
                if (captionEl) {
                    captionEl.textContent = "Boş";
                }
                applyRingRemaining(progressEl, 0);
                return;
            }

            if (status === "Completed") {
                el.classList.add("is-done");
                timerEl.textContent = "Bitib";
                if (captionEl) {
                    captionEl.textContent = "Sessiya";
                }
                applyRingRemaining(progressEl, 0);
                return;
            }

            if (nowMs < startMs) {
                el.classList.add("is-pending");
                timerEl.textContent = formatSeconds(startMs - nowMs);
                if (captionEl) {
                    captionEl.textContent = "Başlayır";
                }
                applyRingRemaining(progressEl, 1);
                return;
            }

            if (nowMs >= endMs) {
                el.classList.add("is-done");
                timerEl.textContent = "00:00";
                if (captionEl) {
                    captionEl.textContent = "Vaxt bitib";
                }
                applyRingRemaining(progressEl, 0);
                return;
            }

            const remainingMs = endMs - nowMs;
            const remainingSec = Math.floor(remainingMs / 1000);
            const frac = totalMs > 0 ? remainingMs / totalMs : 0;
            el.classList.add("is-live");
            if (remainingSec <= COUNTDOWN_CRIT_SEC) {
                el.classList.add("is-critical");
            } else if (remainingSec <= COUNTDOWN_WARN_SEC) {
                el.classList.add("is-warn");
            }

            timerEl.textContent = formatSeconds(remainingMs);
            if (captionEl) {
                captionEl.textContent = "Qalan vaxt";
            }
            applyRingRemaining(progressEl, frac);
        });
    }

    function restoreLaneDrafts() {
        document.querySelectorAll(".lane-score-input").forEach(input => {
            const sid = input.getAttribute("data-session-id");
            if (!sid) {
                return;
            }

            const key = `session-${sid}`;
            if (Object.prototype.hasOwnProperty.call(laneScoreDraft, key)) {
                input.value = laneScoreDraft[key];
            }
        });
    }

    function bindLaneEvents() {
        document.querySelectorAll(".lane-score-input").forEach(input => {
            input.addEventListener("input", event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLInputElement)) {
                    return;
                }

                const laneNumber = target.getAttribute("data-lane-number");
                const sessionId = target.getAttribute("data-session-id");
                if (!laneNumber && !sessionId) {
                    return;
                }

                const key = sessionId ? `session-${sessionId}` : `lane-${laneNumber}`;
                laneScoreDraft[key] = target.value;
            });
        });

        document.querySelectorAll("[data-submit-lane-score]").forEach(button => {
            button.addEventListener("click", async event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLButtonElement)) {
                    return;
                }

                const sessionId = target.getAttribute("data-session-id");
                const laneNumber = Number(target.getAttribute("data-lane-number"));
                const nextRound = Number(target.getAttribute("data-next-round"));

                if (!sessionId) {
                    alert("Bu zolaqda aktiv sessiya yoxdur.");
                    return;
                }

                const key = `session-${sessionId}`;
                const rawValue = laneScoreDraft[key] ?? "";
                const value = Number(rawValue);

                if (!Number.isFinite(value) || value < 0 || value > 10) {
                    alert("Xal 0 ilə 10 arasında olmalıdır.");
                    return;
                }

                await submitLaneScore(sessionId, laneNumber, nextRound, value);
            });
        });

        document.querySelectorAll(".pick-session").forEach(button => {
            button.addEventListener("click", event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLElement)) {
                    return;
                }

                const selected = target.getAttribute("data-session-id");
                if (!selected) {
                    return;
                }

                sessionIdInput.value = selected;
                sessionInfo.textContent = `Seçilmiş sessiya: ${selected}`;
            });
        });

        document.querySelectorAll("[data-stop-session]").forEach(button => {
            button.addEventListener("click", async event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLElement)) {
                    return;
                }

                const selected = target.getAttribute("data-stop-session");
                if (!selected) {
                    return;
                }

                await stopSession(selected);
            });
        });
    }

    function startCountdownTicker() {
        if (countdownTimerId) {
            clearInterval(countdownTimerId);
        }

        const tick = () => {
            const wall = document.getElementById("wallClock");
            if (wall) {
                wall.textContent = new Date().toLocaleTimeString("az-AZ", {
                    hour: "2-digit",
                    minute: "2-digit",
                    second: "2-digit"
                });
            }
            updateCountdownRings();
        };

        tick();
        countdownTimerId = setInterval(tick, 250);
    }

    async function loadDashboard() {
        const response = await apiFetch("/dashboard/lanes");
        if (!response.ok) {
            return;
        }

        const lanes = await response.json();
        latestLanes = lanes;
        refreshStats(lanes);

        const gridResponse = await apiFetch("/dashboard/lanes/partial/grid");
        if (!gridResponse.ok) {
            return;
        }

        laneGrid.innerHTML = await gridResponse.text();

        const tableResponse = await apiFetch("/dashboard/lanes/partial/table");
        if (!tableResponse.ok) {
            return;
        }

        dashboardRows.innerHTML = await tableResponse.text();

        bindLaneEvents();
        restoreLaneDrafts();
    }

    function formatDateOnly(value) {
        if (!value) {
            return "—";
        }

        const dt = new Date(value);
        if (Number.isNaN(dt.getTime())) {
            return "—";
        }

        return dt.toLocaleDateString("az-AZ");
    }

    function formatDateTime(value) {
        if (!value) {
            return "—";
        }

        const dt = new Date(value);
        if (Number.isNaN(dt.getTime())) {
            return "—";
        }

        return dt.toLocaleString("az-AZ", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit"
        });
    }

    function parseLocalTimeParts(rawTimeValue) {
        const rawTime = (rawTimeValue ?? "").toString();
        const timeMatch = /(\d{1,2}):(\d{2})/.exec(rawTime);
        if (!timeMatch) {
            return null;
        }

        const hour = Number(timeMatch[1]);
        const minute = Number(timeMatch[2]);
        if (!Number.isInteger(hour) || !Number.isInteger(minute) || hour < 0 || hour > 23 || minute < 0 || minute > 59) {
            return null;
        }

        return { hour, minute };
    }

    function parseScheduleStartLocal(item, nowLocal) {
        const timeParts = parseLocalTimeParts(item.startTimeLocal);
        if (timeParts === null) {
            return null;
        }

        const fromRaw = new Date(item.activeFromDateLocal);
        const toRaw = new Date(item.activeToDateLocal ?? item.activeFromDateLocal);
        if (Number.isNaN(fromRaw.getTime()) || Number.isNaN(toRaw.getTime())) {
            return null;
        }

        const fromDate = new Date(fromRaw.getFullYear(), fromRaw.getMonth(), fromRaw.getDate());
        const toDate = new Date(toRaw.getFullYear(), toRaw.getMonth(), toRaw.getDate());
        if (toDate.getTime() < fromDate.getTime()) {
            return null;
        }

        const dayOfWeek = Number(item.dayOfWeek);
        if (!Number.isInteger(dayOfWeek) || dayOfWeek < 0 || dayOfWeek > 6) {
            return null;
        }

        const today = new Date(nowLocal.getFullYear(), nowLocal.getMonth(), nowLocal.getDate());
        const baseDate = today.getTime() > fromDate.getTime() ? today : fromDate;
        const dayOffset = (dayOfWeek - baseDate.getDay() + 7) % 7;
        const candidateDate = new Date(baseDate.getFullYear(), baseDate.getMonth(), baseDate.getDate() + dayOffset);

        let candidate = new Date(
            candidateDate.getFullYear(),
            candidateDate.getMonth(),
            candidateDate.getDate(),
            timeParts.hour,
            timeParts.minute,
            0,
            0
        );

        if (candidate.getTime() < nowLocal.getTime()) {
            candidate = new Date(
                candidate.getFullYear(),
                candidate.getMonth(),
                candidate.getDate() + 7,
                timeParts.hour,
                timeParts.minute,
                0,
                0
            );
        }

        if (candidate.getTime() < fromDate.getTime() || candidate.getTime() > toDate.getTime() + (24 * 60 * 60 * 1000) - 1) {
            return null;
        }

        return candidate;
    }

    function renderUpcomingSubscriptions(schedules) {
        if (!(upcomingSubscriptionRows instanceof HTMLElement) || !(upcomingSubscriptionInfo instanceof HTMLElement)) {
            return;
        }

        const now = new Date();
        const upcoming = (Array.isArray(schedules) ? schedules : [])
            .map(item => ({ item, startLocal: parseScheduleStartLocal(item, now) }))
            .filter(x => x.startLocal instanceof Date && x.startLocal.getTime() >= now.getTime())
            .sort((a, b) => a.startLocal.getTime() - b.startLocal.getTime())
            .slice(0, 8);

        if (upcoming.length === 0) {
            upcomingSubscriptionInfo.textContent = "Yaxın saatlarda planlı abunəçi görünmür.";
            upcomingSubscriptionRows.innerHTML = "";
            return;
        }

        const soonThresholdMinutes = 120;
        const soonCount = upcoming.filter(x => ((x.startLocal.getTime() - now.getTime()) / 60000) <= soonThresholdMinutes).length;
        upcomingSubscriptionInfo.textContent = `Növbəti abunəçilər sıralandı. ${soonCount} nəfər yaxın 2 saat içindədir.`;

        upcomingSubscriptionRows.innerHTML = upcoming.map(({ item, startLocal }) => {
            const diffMinutes = Math.max(0, Math.round((startLocal.getTime() - now.getTime()) / 60000));
            const whenText = startLocal.toLocaleString("az-AZ", {
                month: "2-digit",
                day: "2-digit",
                hour: "2-digit",
                minute: "2-digit"
            });
            const nearTag = diffMinutes <= soonThresholdMinutes
                ? `<span class="upcoming-tag">${diffMinutes} dəq sonra</span>`
                : "";
            return `<li><strong>${escapeHtml(item.athleteName ?? "—")}</strong> — ${whenText}${nearTag}</li>`;
        }).join("");
    }

    function startUpcomingCountdownTicker() {
        if (upcomingCountdownTimerId) {
            clearInterval(upcomingCountdownTimerId);
        }

        upcomingCountdownTimerId = setInterval(() => {
            renderUpcomingSubscriptions(subscriptionSchedulesCache);
        }, 60000);
    }

    function normalizeSubscriptionTimeInput() {
        if (!(subscriptionStartTimeInput instanceof HTMLInputElement)) {
            return;
        }

        const raw = subscriptionStartTimeInput.value.trim();
        const match = /^(\d{1,2}):(\d{1,2})$/.exec(raw);
        if (!match) {
            return;
        }

        const hour = Number(match[1]);
        const minute = Number(match[2]);
        if (!Number.isInteger(hour) || !Number.isInteger(minute) || hour < 0 || hour > 23 || minute < 0 || minute > 59) {
            return;
        }

        subscriptionStartTimeInput.value = `${String(hour).padStart(2, "0")}:${String(minute).padStart(2, "0")}`;
    }

    function formatDurationMinutes(minutes) {
        const value = Number(minutes);
        if (!Number.isFinite(value) || value <= 0) {
            return "—";
        }

        if (value % 60 === 0) {
            const hours = value / 60;
            return `${hours} saat`;
        }

        return `${value} dəq`;
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll("\"", "&quot;")
            .replaceAll("'", "&#39;");
    }

    async function loadSubscriptionSchedules() {
        if (!(subscriptionRows instanceof HTMLElement)) {
            return;
        }

        const response = await apiFetch("/subscriptions/schedules");
        if (!response.ok) {
            subscriptionSchedulesCache = [];
            renderUpcomingSubscriptions(subscriptionSchedulesCache);
            return;
        }

        const schedules = await response.json();
        if (!Array.isArray(schedules)) {
            subscriptionSchedulesCache = [];
            renderUpcomingSubscriptions(subscriptionSchedulesCache);
            return;
        }

        subscriptionSchedulesCache = schedules;
        if (subscriptionSchedulesCache.length === 0) {
            subscriptionRows.innerHTML = "<tr><td colspan=\"7\">Hələ aylıq abunə planı yoxdur.</td></tr>";
            renderUpcomingSubscriptions(subscriptionSchedulesCache);
            return;
        }

        subscriptionRows.innerHTML = subscriptionSchedulesCache.map(item => {
            const dayLabel = dayNames[item.dayOfWeek] ?? String(item.dayOfWeek);
            const singleDate = formatDateOnly(item.activeFromDateLocal);
            const last = formatDateTime(item.lastAutoStartedAtUtc);
            const time = (item.startTimeLocal ?? "").toString().slice(0, 5) || "—";
            const lastLane = Number.isFinite(item.lastAssignedLaneNumber)
                ? `<a href="/zolaq/${item.lastAssignedLaneNumber}" target="_blank" rel="noopener">Zolaq ${item.lastAssignedLaneNumber}</a>`
                : "Sistem təyin edəcək";
            return `<tr>
                <td>${item.athleteName ?? "—"}</td>
                <td>${dayLabel}</td>
                <td>${time}</td>
                <td>${formatDurationMinutes(item.durationMinutes)}</td>
                <td>${singleDate}</td>
                <td>${lastLane}</td>
                <td>${last}</td>
            </tr>`;
        }).join("");

        renderUpcomingSubscriptions(subscriptionSchedulesCache);
    }

    async function createSubscriptionSchedule() {
        try {
            const athleteFullName = subscriptionAthleteNameInput?.value?.trim() ?? "";
            if (!athleteFullName) {
                alert("Abunəçinin adını daxil edin.");
                return;
            }

            const visitsCount = Number(subscriptionVisitsCountInput?.value ?? "0");
            if (!Number.isInteger(visitsCount) || visitsCount <= 0) {
                alert("Gediş sayı müsbət tam ədəd olmalıdır.");
                return;
            }

            const durationHours = Number(subscriptionDurationMinutesInput?.value ?? "0");
            if (!Number.isInteger(durationHours) || durationHours <= 0) {
                alert("Abunə müddəti ən az 1 saat olmalıdır.");
                return;
            }
            const durationMinutes = durationHours * 60;

            const startDate = subscriptionStartDateInput?.value;
            if (!startDate) {
                alert("Paketin başlanğıc tarixini seçin.");
                return;
            }

            const startTimeRaw = subscriptionStartTimeInput?.value?.trim() ?? "";
            const timeMatch = /^(\d{2}):(\d{2})$/.exec(startTimeRaw);
            if (!timeMatch) {
                alert("Saat HH:mm formatında olmalıdır (məs. 19:20).");
                return;
            }

            const hourValue = Number(timeMatch[1]);
            const minuteValue = Number(timeMatch[2]);
            if (!Number.isInteger(hourValue) || hourValue < 0 || hourValue > 23 || minuteValue < 0 || minuteValue > 59) {
                alert("Saat 00:00 - 23:59 aralığında olmalıdır.");
                return;
            }

            if (minuteValue % 10 !== 0) {
                alert("Saat seçimi 10 dəqiqə aralığı ilə olmalıdır (məs. 19:00, 19:10, 19:20).");
                return;
            }

            const response = await apiFetch("/subscriptions/packages", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    athleteFullName,
                    dayPattern: subscriptionDayPatternInput?.value ?? "1-3-5",
                    visitsCount,
                    startTimeLocal: startTimeRaw,
                    durationMinutes,
                    startDateLocal: new Date(`${startDate}T00:00:00`).toISOString()
                })
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Abunə planı yaradılmadı. ${message}`);
                return;
            }

            const data = await response.json();
            const firstDate = formatDateOnly(data.firstSessionDateLocal);
            const lastDate = formatDateOnly(data.lastSessionDateLocal);
            subscriptionInfo.textContent = `Paket yaradıldı: ${data.createdCount} gediş, ${durationHours} saat (${firstDate} - ${lastDate}).`;
            if (subscriptionAthleteNameInput instanceof HTMLInputElement) {
                subscriptionAthleteNameInput.value = "";
            }
            await loadSubscriptionSchedules();
        } catch (error) {
            alert(`Abunə planı yaradılmadı. ${getExceptionMessage(error)}`);
        }
    }

    async function registerGroupOnLane() {
        try {
            const rawNames = groupAthleteNamesInput?.value ?? "";
            const names = rawNames
                .split(/\r?\n|,|;/)
                .map(x => x.trim())
                .filter(Boolean);

            if (names.length === 0) {
                alert("Qrup üçün ən az bir ad daxil edin.");
                return;
            }

            const durationMinutes = Number(groupDurationMinutesInput?.value ?? "0");
            if (!Number.isInteger(durationMinutes) || durationMinutes <= 0) {
                alert("Qrup sessiyası üçün müddət müsbət dəqiqə olmalıdır.");
                return;
            }

            const response = await apiFetch("/sessions/batch-lane", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    athleteNames: names,
                    laneNumber: Number(groupLaneNumberInput?.value ?? "1"),
                    startTimeUtc: new Date().toISOString(),
                    durationMinutes
                })
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Qrup qeydiyyatı alınmadı. ${message}`);
                return;
            }

            const data = await response.json();
            const sessions = Array.isArray(data?.sessions) ? data.sessions : [];
            if (sessions.length > 0) {
                const list = sessions
                    .map(item => {
                        const name = escapeHtml(item.athleteName ?? item.AthleteName ?? "—");
                        const start = formatDateTime(item.startTimeUtc ?? item.StartTimeUtc);
                        const end = formatDateTime(item.endTimeUtc ?? item.EndTimeUtc);
                        return `<li>${name}: ${start} - ${end}</li>`;
                    })
                    .join("");

                groupInfo.innerHTML = `${data.createdCount} nəfər ardıcıl qeydiyyata alındı. <br/>Bu zolaqda ekranda yalnız aktiv olan görünür, növbə:<ul style="margin:6px 0 0 18px;">${list}</ul>`;
            } else {
                groupInfo.textContent = `${data.createdCount} nəfər ardıcıl qeydiyyata alındı.`;
            }
            if (groupAthleteNamesInput instanceof HTMLTextAreaElement) {
                groupAthleteNamesInput.value = "";
            }
            await loadDashboard();
        } catch (error) {
            alert(`Qrup qeydiyyatı alınmadı. ${getExceptionMessage(error)}`);
        }
    }

    async function registerAndSchedule() {
        try {
            const fullName = athleteNameInput.value.trim();
            if (!fullName) {
                alert("İdmançının adını daxil edin.");
                return;
            }

            const isOpenEnded = isOpenEndedInput instanceof HTMLInputElement && isOpenEndedInput.checked;
            const durationValue = isOpenEnded ? 0 : Number(durationMinutesInput.value);
            if (!Number.isInteger(durationValue) || durationValue < 0) {
                alert("Müddət mənfi ola bilməz.");
                return;
            }

            if (!isOpenEnded && durationValue === 0) {
                alert("Müddət 1 və ya daha böyük olmalıdır, yaxud vaxtsız checkbox seçin.");
                return;
            }

            const athleteResponse = await apiFetch("/athletes", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    fullName,
                    isSubscriber: isSubscriberInput.checked
                })
            });

            if (!athleteResponse.ok) {
                alert("İdmançı qeydiyyatı alınmadı.");
                return;
            }

            const athleteData = await athleteResponse.json();
            const sessionResponse = await apiFetch("/sessions", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    athleteId: athleteData.id,
                    laneNumber: Number(laneNumberInput.value),
                    startTimeUtc: new Date().toISOString(),
                    durationMinutes: durationValue
                })
            });

            if (!sessionResponse.ok) {
                const message = await readErrorMessage(sessionResponse);
                alert(`Sessiya planlanmadı. ${message}`);
                return;
            }

            const sessionData = await sessionResponse.json();
            sessionIdInput.value = sessionData.sessionId;
            sessionInfo.textContent = `Son sessiya ID: ${sessionData.sessionId}`;
            await loadDashboard();
        } catch (error) {
            alert(`Sessiya planlanmadı. ${getExceptionMessage(error)}`);
        }
    }

    async function submitScore() {
        try {
            let sessionId = sessionIdInput.value.trim();
            if (!sessionId) {
                const selectedLane = Number(laneNumberInput.value);
                const laneSession = latestLanes.find(x =>
                    x.laneNumber === selectedLane &&
                    x.sessionId &&
                    x.status !== "Completed");

                if (laneSession?.sessionId) {
                    sessionId = laneSession.sessionId;
                    sessionIdInput.value = sessionId;
                }
            }

            if (!sessionId) {
                alert("Sessiya ID daxil edin və ya əvvəlcə zolaq sessiyasını seçin.");
                return;
            }

            const response = await apiFetch(`/sessions/${sessionId}/scores`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    roundNumber: Number(roundNumberInput.value),
                    value: Number(scoreValueInput.value)
                })
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Xal göndərilmədi. ${message}`);
                return;
            }

            await loadDashboard();
        } catch (error) {
            alert(`Xal göndərilmədi. ${getExceptionMessage(error)}`);
        }
    }

    async function submitLaneScore(sessionId, laneNumber, roundNumber, value) {
        try {
            const response = await apiFetch(`/sessions/${sessionId}/scores`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    roundNumber,
                    value
                })
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Zolaq ${laneNumber}: xal göndərilmədi. ${message}`);
                return;
            }

            laneScoreDraft[`session-${sessionId}`] = "";
            sessionInfo.textContent = `Zolaq ${laneNumber}: xal göndərildi (tur ${roundNumber}).`;
            await loadDashboard();
        } catch (error) {
            alert(`Zolaq ${laneNumber}: xal göndərilmədi. ${getExceptionMessage(error)}`);
        }
    }

    async function stopSession(sessionId) {
        try {
            const response = await apiFetch(`/sessions/${sessionId}/complete`, {
                method: "POST"
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Sessiya dayandırılmadı. ${message}`);
                return;
            }

            sessionInfo.textContent = `Sessiya dayandırıldı: ${sessionId}`;
            await loadDashboard();
        } catch (error) {
            alert(`Sessiya dayandırılmadı. ${getExceptionMessage(error)}`);
        }
    }

    async function startSignalR() {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/lane")
            .withAutomaticReconnect()
            .build();

        connection.onreconnecting(() => {
            connectionBadge.textContent = "SignalR: Yenidən qoşulur...";
            connectionBadge.className = "status-pill Scheduled";
        });

        connection.onreconnected(() => {
            connectionBadge.textContent = "SignalR: Qoşuldu";
            connectionBadge.className = "status-pill Active";
        });

        connection.on("lane-updated", async () => {
            await loadDashboard();
            await loadSubscriptionSchedules();
        });

        connection.on("score-updated", async () => {
            await loadDashboard();
            await loadSubscriptionSchedules();
        });

        await connection.start();
        connectionBadge.textContent = "SignalR: Qoşuldu";
        connectionBadge.className = "status-pill Active";
    }

    document.getElementById("scheduleBtn").addEventListener("click", registerAndSchedule);
    document.getElementById("submitScoreBtn").addEventListener("click", submitScore);
    document.getElementById("groupRegisterBtn").addEventListener("click", registerGroupOnLane);
    document.getElementById("createSubscriptionBtn").addEventListener("click", createSubscriptionSchedule);
    isOpenEndedInput?.addEventListener("change", syncOpenEndedMode);
    subscriptionStartTimeInput?.addEventListener("blur", normalizeSubscriptionTimeInput);
    syncOpenEndedMode();
    normalizeSubscriptionTimeInput();

    if (subscriptionStartDateInput instanceof HTMLInputElement) {
        const today = new Date();
        subscriptionStartDateInput.value = today.toISOString().slice(0, 10);
    }

    startCountdownTicker();
    startUpcomingCountdownTicker();
    loadDashboard();
    loadSubscriptionSchedules();
    startSignalR();
</script>
</body>
</html>
