@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Antiforgery.GetAndStoreTokens(Context);
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EShooting — İdarə paneli</title>
    <style>
        :root {
            --bg-a: #fff3e8;
            --bg-b: #f7f4ff;
            --bg-c: #ecf8ff;
            --panel: rgba(255, 255, 255, 0.78);
            --panel-strong: rgba(255, 255, 255, 0.9);
            --text: #1d2440;
            --text-muted: #657296;
            --primary: #6c5cff;
            --primary-strong: #5543f3;
            --success: #0f9d77;
            --warning: #d68a00;
            --danger: #d1435f;
            --border: rgba(122, 138, 178, 0.28);
            --ring: rgba(108, 92, 255, 0.28);
            --shadow: 0 18px 45px rgba(65, 45, 120, 0.16);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            color: var(--text);
            font-family: "Segoe UI", Arial, sans-serif;
            line-height: 1.45;
            background:
                radial-gradient(circle at 0% 0%, #ffd7be 0%, transparent 40%),
                radial-gradient(circle at 100% 0%, #dacdff 0%, transparent 36%),
                radial-gradient(circle at 100% 100%, #cbe8ff 0%, transparent 45%),
                linear-gradient(145deg, var(--bg-a), var(--bg-b) 46%, var(--bg-c));
            min-height: 100vh;
        }

        main {
            max-width: 1280px;
            margin: 0 auto;
            padding: 28px 24px 34px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .logout-form {
            margin: 0;
        }

        .title {
            margin: 0;
            font-size: 30px;
            font-weight: 800;
            letter-spacing: 0.02em;
            color: #1b2140;
        }

        .subtitle {
            margin: 6px 0 0;
            color: var(--text-muted);
            font-weight: 500;
        }

        .header-clock {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 4px;
            padding: 10px 14px;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: var(--panel-strong);
            box-shadow: 0 10px 26px rgba(101, 102, 160, 0.16);
            backdrop-filter: blur(10px);
        }

        .header-clock__label {
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #6b7394;
        }

        .header-clock__value {
            font-size: 26px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.06em;
            color: #2d3260;
        }

        .card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 18px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            transition: transform 0.18s ease, box-shadow 0.22s ease, border-color 0.18s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            border-color: rgba(108, 92, 255, 0.4);
            box-shadow: 0 22px 48px rgba(65, 45, 120, 0.2);
        }

        .card--spaced {
            margin-bottom: 16px;
        }

        .grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(12, 1fr);
        }

        .col-6 {
            grid-column: span 6;
        }

        .col-12 {
            grid-column: span 12;
        }

        @@media (max-width: 900px) {
            .col-6 {
                grid-column: span 12;
            }
        }

        h2 {
            margin: 0 0 12px;
            font-size: 20px;
            font-weight: 800;
            color: #253060;
        }

        .row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 10px;
        }

        .row > * {
            min-width: 140px;
        }

        input,
        select,
        textarea,
        button {
            border-radius: 12px;
            border: 1px solid var(--border);
            padding: 10px 12px;
            color: var(--text);
            transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease, filter 0.2s ease;
        }

        input,
        textarea,
        select {
            min-height: 42px;
            background: #fff;
        }

        input::placeholder {
            color: #8b97b9;
        }

        input:focus,
        select:focus,
        button:focus-visible {
            outline: none;
            border-color: #7668ff;
            box-shadow: 0 0 0 4px var(--ring);
        }

        button {
            cursor: pointer;
            font-weight: 700;
        }

        .btn {
            min-height: 42px;
            border-radius: 12px;
            letter-spacing: 0.01em;
        }

        .btn-primary {
            border: none;
            color: #fff;
            background: linear-gradient(120deg, var(--primary), #8a57ff);
            box-shadow: 0 10px 22px rgba(108, 92, 255, 0.32);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            background: linear-gradient(120deg, var(--primary-strong), #7a4df0);
        }

        .btn-secondary {
            border: none;
            color: #fff;
            background: linear-gradient(125deg, #25a2d7, #1f86d8);
            box-shadow: 0 10px 22px rgba(36, 137, 214, 0.3);
        }

        .btn-secondary:hover {
            transform: translateY(-1px);
            filter: brightness(1.04);
        }

        .btn-ghost {
            background: rgba(255, 255, 255, 0.75);
            color: #37426e;
            border: 1px solid var(--border);
        }

        .btn-ghost:hover {
            border-color: rgba(108, 92, 255, 0.38);
            background: #fff;
        }

        .btn-sm {
            min-height: 38px;
            padding: 8px 14px;
            font-size: 13px;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        @@media (max-width: 900px) {
            .stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .stat {
            border-radius: 15px;
            padding: 14px;
            border: 1px solid rgba(122, 138, 178, 0.23);
            background: rgba(255, 255, 255, 0.72);
            box-shadow: 0 10px 24px rgba(104, 93, 161, 0.14);
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .stat-value {
            margin-top: 6px;
            font-size: 28px;
            line-height: 1;
            font-weight: 800;
            color: #222d58;
        }

        .notice {
            margin-top: 6px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .status-pill {
            display: inline-block;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 700;
            background: rgba(86, 103, 148, 0.18);
            color: #52618f;
        }

        .status-pill.Active {
            background: rgba(15, 157, 119, 0.16);
            color: #0b8a69;
        }

        .status-pill.Completed {
            background: rgba(78, 102, 255, 0.16);
            color: #445fd4;
        }

        .status-pill.Scheduled {
            background: rgba(214, 138, 0, 0.2);
            color: #b57100;
        }

        .lane-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }

        @@media (max-width: 1100px) {
            .lane-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 700px) {
            .lane-grid {
                grid-template-columns: 1fr;
            }
        }

        .lane-card {
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(122, 138, 178, 0.25);
            border-radius: 16px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            box-shadow: 0 14px 24px rgba(96, 87, 157, 0.12);
            transition: transform 0.15s ease, box-shadow 0.2s ease;
        }

        .lane-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 30px rgba(96, 87, 157, 0.16);
        }

        .lane-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .lane-title {
            margin: 0;
            font-size: 17px;
            font-weight: 800;
            color: #202c56;
        }

        .lane-type {
            font-size: 11px;
            color: #7b86a7;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .lane-meta {
            margin: 4px 0;
            color: #667395;
            font-size: 13px;
        }

        .lane-meta--compact {
            font-size: 12px;
            line-height: 1.35;
        }

        .score {
            margin-top: 10px;
            font-weight: 800;
            font-size: 22px;
            color: #24305f;
        }

        .countdown-ring-wrap {
            --ring-track: rgba(62, 77, 130, 0.14);
            --ring-accent: #17ad80;
            --ring-glow: rgba(23, 173, 128, 0.25);
            position: relative;
            width: 132px;
            height: 132px;
            margin: 12px auto 4px;
        }

        .countdown-ring-wrap--compact {
            width: 52px;
            height: 52px;
            margin: 0 auto;
        }

        .countdown-ring__svg {
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
            filter: drop-shadow(0 0 10px var(--ring-glow));
        }

        .countdown-ring__track {
            fill: none;
            stroke: var(--ring-track);
            stroke-width: 7;
        }

        .countdown-ring__progress {
            fill: none;
            stroke: var(--ring-accent);
            stroke-width: 7;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.35s ease, stroke 0.3s ease, filter 0.3s ease;
        }

        .countdown-ring__center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 8px;
            pointer-events: none;
        }

        .countdown-ring__timer {
            font-size: 22px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.04em;
            line-height: 1.1;
            color: #26325f;
        }

        .countdown-ring-wrap--compact .countdown-ring__timer {
            font-size: 11px;
            font-weight: 700;
        }

        .countdown-ring__caption {
            margin-top: 4px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #7a86a8;
        }

        .countdown-ring-wrap.is-pending {
            --ring-accent: #d68a00;
            --ring-glow: rgba(214, 138, 0, 0.24);
        }

        .countdown-ring-wrap.is-live.is-warn:not(.is-critical) {
            --ring-accent: #ef8f1f;
            --ring-glow: rgba(239, 143, 31, 0.3);
        }

        .countdown-ring-wrap.is-live.is-critical {
            --ring-accent: #d1435f;
            --ring-glow: rgba(209, 67, 95, 0.34);
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer {
            color: #b63852;
        }

        .countdown-ring-wrap.is-done,
        .countdown-ring-wrap.is-idle {
            --ring-accent: rgba(120, 132, 168, 0.55);
            --ring-glow: transparent;
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__svg {
            animation: ring-pulse 0.95s ease-in-out infinite;
        }

        @@keyframes ring-pulse {
            0%, 100% { filter: drop-shadow(0 0 6px var(--ring-glow)); }
            50% { filter: drop-shadow(0 0 16px var(--ring-glow)); }
        }

        .table-countdown-cell {
            vertical-align: middle;
            min-width: 64px;
        }

        .lane-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
        }

        .lane-score-input {
            flex: 1;
            min-width: 0;
        }

        .lane-score-btn {
            min-width: 86px;
            padding: 8px 10px;
            font-size: 12px;
            border: none;
            color: #fff;
            background: linear-gradient(125deg, #25a2d7, #1f86d8);
        }

        .pick-session {
            margin-top: 10px;
            width: 100%;
            min-height: 38px;
            padding: 8px 12px;
            font-size: 12px;
            border: 1px solid rgba(108, 92, 255, 0.28);
            background: rgba(108, 92, 255, 0.12);
            color: #403a97;
            font-weight: 700;
        }

        .pick-session:hover {
            border-color: rgba(108, 92, 255, 0.55);
            background: rgba(108, 92, 255, 0.17);
        }

        .stop-session-btn {
            margin-top: 8px;
            width: 100%;
            min-height: 38px;
            padding: 8px 12px;
            border-radius: 10px;
            border: 1px solid rgba(209, 67, 95, 0.4);
            background: rgba(209, 67, 95, 0.14);
            color: #a72d48;
            font-size: 12px;
            font-weight: 700;
        }

        .stop-session-btn:hover {
            border-color: rgba(209, 67, 95, 0.72);
            background: rgba(209, 67, 95, 0.2);
        }

        .warn {
            margin-top: 6px;
            font-size: 13px;
            font-weight: 600;
        }

        .warn.ok {
            color: #128461;
        }

        .warn.alert {
            color: #b26d00;
        }

        .warn.danger {
            color: #b83854;
        }

        .table-wrap {
            margin-top: 12px;
            overflow-x: auto;
            border: 1px solid var(--border);
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.75);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 760px;
        }

        th,
        td {
            border-bottom: 1px solid rgba(122, 138, 178, 0.2);
            padding: 11px 10px;
            text-align: left;
            font-size: 13px;
        }

        th {
            color: #586892;
            font-weight: 700;
            background: rgba(108, 92, 255, 0.06);
        }

        tr:hover td {
            background: rgba(108, 92, 255, 0.04);
        }

        .tv-links {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }

        .tv-link {
            display: inline-block;
            padding: 8px 12px;
            border-radius: 11px;
            border: 1px solid rgba(108, 92, 255, 0.25);
            background: rgba(108, 92, 255, 0.1);
            color: #413c9a;
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            transition: transform 0.15s ease, border-color 0.2s ease, background 0.2s ease;
        }

        .tv-link:hover {
            transform: translateY(-1px);
            border-color: rgba(108, 92, 255, 0.52);
            background: rgba(108, 92, 255, 0.16);
        }

        .subscription-table td,
        .subscription-table th {
            white-space: nowrap;
        }

        .upcoming-list {
            margin: 10px 0 0;
            padding-left: 18px;
        }

        .upcoming-list li {
            margin: 6px 0;
            color: #33406d;
        }

        .upcoming-tag {
            display: inline-block;
            margin-left: 6px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            background: rgba(214, 138, 0, 0.18);
            color: #9a6100;
        }

        .checkbox-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 42px;
            padding: 8px 12px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.76);
            color: #475483;
            font-size: 13px;
            font-weight: 700;
            user-select: none;
        }

        .checkbox-chip input[type="checkbox"] {
            accent-color: var(--primary);
            width: 16px;
            height: 16px;
            margin: 0;
        }

        .group-athletes-input {
            min-height: 94px;
            width: min(420px, 100%);
            resize: vertical;
            line-height: 1.35;
            font-family: inherit;
        }
    </style>
</head>
<body>
<main>
    <header class="header">
        <div>
            <h1 class="title">EShooting idarə paneli</h1>
            <p class="subtitle">Planlama, planşetdə xal və canlı monitor.</p>
        </div>
        <div class="header-actions">
            <div class="header-clock" title="Brauzerin yerli vaxtı">
                <span class="header-clock__label">Canlı saat</span>
                <span class="header-clock__value" id="wallClock">--:--:--</span>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-ghost btn-sm">Çıxış</button>
            </form>
            <span class="status-pill" id="connectionBadge">SignalR: Qoşulur...</span>
        </div>
    </header>

    <section class="stats">
        <article class="stat">
            <div class="stat-label">Zolaqlar (cəmi)</div>
            <div class="stat-value" id="totalLanes">11</div>
        </article>
        <article class="stat">
            <div class="stat-label">Aktiv sessiyalar</div>
            <div class="stat-value" id="activeSessions">0</div>
        </article>
        <article class="stat">
            <div class="stat-label">Planlaşdırılmış</div>
            <div class="stat-value" id="scheduledSessions">0</div>
        </article>
        <article class="stat">
            <div class="stat-label">Bitmiş sessiyalar</div>
            <div class="stat-value" id="completedSessions">0</div>
        </article>
    </section>

    <section class="card card--spaced">
        <h2>TV — ayrı zolaq ekranları</h2>
        <p class="notice">Hər televizorda bir keçid açın (tam ekran). Nümunə: <code>/zolaq/3</code></p>
        <div class="tv-links">
            @for (var i = 1; i <= 11; i++)
            {
                <a href="/zolaq/@i" target="_blank" rel="noopener" class="tv-link">
                    Zolaq @i
                </a>
            }
        </div>
    </section>

    <section class="grid">
        <article class="card col-6">
            <h2>Reception — qeydiyyat</h2>
            <div class="row">
                <input id="athleteName" placeholder="İdmançının adı, soyadı" />
                <label class="checkbox-chip">
                    <input id="isSubscriber" type="checkbox" />
                    Abunəçi
                </label>
            </div>
            <div class="row">
                <select id="laneNumber">
                    <option value="1">Zolaq 1 (Həvəskar)</option>
                    <option value="2">Zolaq 2 (Həvəskar)</option>
                    <option value="3">Zolaq 3 (Həvəskar)</option>
                    <option value="4">Zolaq 4 (Həvəskar)</option>
                    <option value="5">Zolaq 5 (Həvəskar)</option>
                    <option value="6">Zolaq 6 (Həvəskar)</option>
                    <option value="7">Zolaq 7 (Həvəskar)</option>
                    <option value="8">Zolaq 8 (Həvəskar)</option>
                    <option value="9">Zolaq 9 (Peşəkar)</option>
                    <option value="10">Zolaq 10 (Peşəkar)</option>
                    <option value="11">Zolaq 11 (Peşəkar)</option>
                </select>
                <input id="durationMinutes" type="number" min="1" max="240" value="3" />
                <label class="checkbox-chip">
                    <input id="isOpenEnded" type="checkbox" />
                    Vaxtsız (Stop ilə bitir)
                </label>
                <button id="scheduleBtn" class="btn btn-primary">Qeydiyyat və planlama</button>
            </div>
            <div class="notice" id="sessionInfo">Hələ seçim yoxdur. Müddət dəqiqə ilədir (məs. 3 = 180 saniyə), vaxtsız üçün checkbox seçin.</div>
        </article>

        <article class="card col-6">
            <h2>Planşet — xal</h2>
            <div class="row">
                <input id="sessionId" placeholder="Sessiya ID" />
                <input id="roundNumber" type="number" min="1" value="1" />
                <input id="scoreValue" type="number" min="0" max="10" value="10" />
                <button id="submitScoreBtn" class="btn btn-secondary">Xalı göndər</button>
            </div>
            <div class="notice">Xal 0–10 aralığında olmalıdır.</div>
        </article>

        <article class="card col-12">
            <h2>Qrup qeydiyyatı (bir zolaq)</h2>
            <div class="row">
                <textarea id="groupAthleteNames"
                          class="group-athletes-input"
                          placeholder="Dostların adlarını yazın (hər sətirdə bir nəfər)"></textarea>
                <select id="groupLaneNumber">
                    @for (var i = 1; i <= 11; i++)
                    {
                        <option value="@i">Zolaq @i</option>
                    }
                </select>
                <input id="groupDurationMinutes" type="number" min="1" max="240" value="60" />
                <button id="groupRegisterBtn" class="btn btn-primary">Qrupu qeydiyyata al</button>
            </div>
            <div class="notice" id="groupInfo">Bir zolaq üçün dostların hamısını eyni vaxtda bir sessiyada qeydiyyatdan keçirir.</div>
        </article>

        <article class="card col-12">
            <h2>Aylıq abunə planlama</h2>
            <div class="row">
                <input id="subscriptionAthleteName" placeholder="Abunəçinin adı, soyadı" />
                <select id="subscriptionDayPattern">
                    <option value="1-3-5">1-3-5 (B.e, Ç, C)</option>
                    <option value="2-4-6">2-4-6 (Ç.a, C.a, Ş)</option>
                </select>
                <input id="subscriptionVisitsCount" type="number" min="1" max="100" value="12" />
                <input id="subscriptionStartTime" type="text" value="19:00" placeholder="HH:mm" maxlength="5" />
                <input id="subscriptionDurationMinutes" type="number" min="1" max="6" value="1" />
                <input id="subscriptionStartDate" type="date" />
                <button id="createSubscriptionBtn" class="btn btn-primary">Paket yarat</button>
            </div>
            <div class="notice" id="subscriptionInfo">Məsələn: 12 gediş, 1 və ya daha çox saat, 1-3-5 və ya 2-4-6 pattern ilə yaradın.</div>
            <h3 style="margin:12px 0 6px; font-size:16px; color:#2c396a;">Vaxtı yaxınlaşan abunəçilər</h3>
            <div class="notice" id="upcomingSubscriptionInfo">Yüklənir...</div>
            <ol class="upcoming-list" id="upcomingSubscriptionRows"></ol>
