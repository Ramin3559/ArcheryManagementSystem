@{
    Layout = null;
    var initialLane = ViewData["InitialLane"] as int?;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>EShooting — Planşet</title>
    <style>
        :root {
            /* Daha işıqlı, admin panelə yaxın boz/mavi ton */
            --bg: #eef2fb;
            --panel: rgba(255, 255, 255, 0.92);
            --panel-2: rgba(248, 250, 255, 0.96);
            --text: #18223a;
            --muted: #55638a;
            --border: rgba(41, 55, 89, 0.18);
            --primary: #4f7cff;
            --danger: #eb5757;
            --ok: #1bbf7a;
            --shadow: 0 10px 30px rgba(13, 24, 48, 0.10);
        }

        * { box-sizing: border-box; }
        html, body { height: 100%; }
        body {
            margin: 0;
            min-height: 100vh;
            background: radial-gradient(circle at top, #dce6ff 0, var(--bg) 58%);
            color: var(--text);
            font-family: "Segoe UI", Arial, sans-serif;
            overflow: hidden;
        }

        .screen {
            height: 100vh;
            padding: max(10px, env(safe-area-inset-top)) max(10px, env(safe-area-inset-right))
                     max(10px, env(safe-area-inset-bottom)) max(10px, env(safe-area-inset-left));
            display: grid;
            grid-template-rows: auto 1fr auto;
            gap: 12px;
        }

        .top {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            padding: 10px 12px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: var(--shadow);
        }

        .top-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .label {
            font-size: 12px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--muted);
            font-weight: 700;
        }

        select, input {
            width: 100%;
            min-height: 46px;
            padding: 8px 12px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--panel-2);
            color: var(--text);
            font-size: 16px;
            font-weight: 700;
            outline: none;
        }

        input[readonly] {
            opacity: 0.95;
        }

        .status {
            display: flex;
            gap: 10px;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            padding: 7px 10px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.75);
            color: var(--muted);
            font-size: 13px;
            font-weight: 800;
        }

        .pill.ok { color: #0f7a54; background: rgba(27, 191, 122, 0.10); }
        .pill.bad { color: #9a6100; background: rgba(246, 183, 60, 0.12); }

        .score-toggle-btn {
            min-height: 38px;
            padding: 8px 14px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.85);
            color: var(--text);
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            white-space: nowrap;
        }

        .score-toggle-btn.is-on {
            background: rgba(27, 191, 122, 0.14);
            border-color: rgba(27, 191, 122, 0.45);
            color: #0f7a54;
        }

        .score-toggle-btn:disabled {
            opacity: 0.6;
            cursor: wait;
        }
        .pill.spin::before {
            content: "";
            width: 14px;
            height: 14px;
            border-radius: 999px;
            border: 2px solid rgba(79, 124, 255, 0.25);
            border-top-color: rgba(79, 124, 255, 0.95);
            display: inline-block;
            animation: tspin 0.9s linear infinite;
        }

        @@keyframes tspin {
            to { transform: rotate(360deg); }
        }

        .center {
            display: grid;
            grid-template-rows: auto 1fr;
            gap: 12px;
            padding: 12px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: var(--shadow);
            min-height: 0;
        }

        .score-row {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            align-items: end;
        }

        .hint {
            color: var(--muted);
            font-size: 13px;
            font-weight: 600;
        }

        .keypad {
            display: grid;
            width: 100%;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            align-content: center;
            justify-content: stretch;
            min-height: 0;
        }

        .key {
            min-height: 68px;
            border-radius: 16px;
            border: 1px solid var(--border);
            background: linear-gradient(180deg, rgba(79, 124, 255, 0.10), rgba(248, 250, 255, 0.96));
            color: var(--text);
            font-size: clamp(22px, 3.2vw, 30px);
            font-weight: 900;
            cursor: pointer;
            touch-action: manipulation;
            user-select: none;
            box-shadow: 0 6px 16px rgba(13, 24, 48, 0.08);
        }

        .key:active { transform: translateY(1px); filter: brightness(1.03); }
        .key[disabled] { opacity: 0.4; cursor: not-allowed; }

        .key.key-wide { grid-column: span 2; }

        .score-input-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            align-items: center;
        }

        .clear-btn {
            min-width: 64px;
            min-height: 46px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: rgba(79, 124, 255, 0.08);
            color: var(--muted);
            font-size: 16px;
            font-weight: 900;
            cursor: pointer;
            touch-action: manipulation;
        }

        .clear-btn:active { transform: translateY(1px); }
        .clear-btn[disabled] { opacity: 0.4; cursor: not-allowed; }

        .actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .btn {
            min-height: 66px;
            border-radius: 16px;
            border: 1px solid var(--border);
            font-size: 20px;
            font-weight: 900;
            cursor: pointer;
            touch-action: manipulation;
            color: var(--text);
            box-shadow: 0 10px 22px rgba(13, 24, 48, 0.10);
        }

        .btn:active { transform: translateY(1px); }
        .btn[disabled] { opacity: 0.4; cursor: not-allowed; }

        .btn-add {
            border-color: rgba(62, 232, 168, 0.45);
            background: linear-gradient(90deg, rgba(27, 191, 122, 0.20), rgba(248, 250, 255, 0.96));
            color: #0f7a54;
        }

        .btn-undo {
            border-color: rgba(255, 77, 77, 0.45);
            background: linear-gradient(90deg, rgba(235, 87, 87, 0.18), rgba(248, 250, 255, 0.96));
            color: #a72727;
        }

        .bottom {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            padding-bottom: max(0px, env(safe-area-inset-bottom));
        }

        .bottom-note {
            text-align: center;
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.04em;
        }

        .toast {
            position: fixed;
            left: 50%;
            transform: translateX(-50%);
            bottom: max(12px, env(safe-area-inset-bottom));
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
            border-radius: 999px;
            padding: 10px 14px;
            color: var(--text);
            font-weight: 800;
            font-size: 13px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease, transform 0.2s ease;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(-2px);
        }

        .toast.ok { border-color: rgba(27, 191, 122, 0.35); }
        .toast.bad { border-color: rgba(235, 87, 87, 0.35); }
    </style>
</head>
<body>
<main class="screen">
    <section class="top">
        <div class="top-row">
            <div class="field">
                <div class="label">Zolaq</div>
                <select id="tabletLaneNumber">
                    @for (var i = 1; i <= 11; i++)
                    {
                        <option value="@i" selected="@(initialLane == i)">Zolaq @i</option>
                    }
                </select>
            </div>
            <div class="field">
                <div class="label">Müştəri (aktiv)</div>
                <input id="tabletAthleteName" readonly value="Yüklənir..." />
            </div>
        </div>
        <div class="status">
            <span class="pill" id="lanePill">Sessiya: Yüklənir…</span>
            <span class="pill" id="connectionPill">Qoşulur…</span>
            <button type="button" class="score-toggle-btn" id="scoreDisplayToggle">Xalları aktiv et</button>
        </div>
    </section>

    <section class="center">
        <div class="score-row">
            <div class="field">
                <div class="label">Xal</div>
                <div class="score-input-row">
                    <input id="scoreValue" type="text" inputmode="numeric" autocomplete="off" placeholder="0" />
                    <button class="clear-btn" id="clearBtn" type="button" title="Təmizlə">C</button>
                </div>
                <div class="hint">Rəqəmləri yığın, sonra “Əlavə et” ilə təsdiqləyin.</div>
            </div>
        </div>

        <div class="keypad" id="keypad"></div>
    </section>

    <section class="bottom">
        <div class="actions">
            <button class="btn btn-add" id="addBtn" disabled>Əlavə et</button>
            <button class="btn btn-undo" id="subBtn" disabled>Ləğv et</button>
            <button class="btn" id="tabletEquipBtn" disabled style="background:rgba(79,124,255,0.12); border:1px solid rgba(79,124,255,0.35); color:#2a4ab8; font-weight:900;">İcarə avadanlıq</button>
            <button class="btn" id="tabletEquipReturnBtn" disabled style="background:rgba(27,191,122,0.12); border:1px solid rgba(27,191,122,0.35); color:#0f7a54; font-weight:900;">Təhvil alındı</button>
        </div>
            <div class="bottom-note">Ləğv et: yığılmış rəqəmi cəmidən çıxır (0-dan aşağı düşmür).</div>
    </section>

    <input id="tabletSessionId" type="hidden" value="" />
    <input id="roundNumber" type="hidden" value="1" />
</main>
<div class="toast" id="toast">—</div>

<div id="tabletEquipModal" style="display:none; position:fixed; inset:0; background:rgba(11,18,32,0.45); backdrop-filter: blur(5px); z-index:10002; padding:16px;">
    <div style="max-width:720px; margin:8vh auto 0; background:rgba(255,255,255,0.98); border:1px solid rgba(41,55,89,0.22); border-radius:16px; padding:16px;">
        <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap;">
            <div style="font-weight:900; color:#1a2650; font-size:18px;">İcarə avadanlıq (zal)</div>
            <button id="tabletEquipCloseBtn" type="button" class="btn" style="min-height:38px;">Bağla</button>
        </div>
        <div id="tabletEquipList" style="margin-top:12px; max-height:55vh; overflow:auto; display:flex; flex-direction:column; gap:8px;"></div>
        <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:12px; flex-wrap:wrap;">
            <button id="tabletEquipClearBtn" type="button" class="btn" style="min-height:38px;">Təmizlə</button>
            <button id="tabletEquipSaveBtn" type="button" class="btn" style="min-height:38px; background:var(--primary); color:white; border:1px solid rgba(0,0,0,0.0); font-weight:900;">Təsdiqlə</button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    const tabletLaneNumberInput = document.getElementById("tabletLaneNumber");
    const tabletAthleteNameInput = document.getElementById("tabletAthleteName");
    const tabletSessionIdInput = document.getElementById("tabletSessionId");
    const scoreValueInput = document.getElementById("scoreValue");
    const roundNumberInput = document.getElementById("roundNumber");
    const clearBtn = document.getElementById("clearBtn");
    const addBtn = document.getElementById("addBtn");
    const subBtn = document.getElementById("subBtn");
    const lanePill = document.getElementById("lanePill");
    const connectionPill = document.getElementById("connectionPill");
    const scoreDisplayToggle = document.getElementById("scoreDisplayToggle");
    const keypadRoot = document.getElementById("keypad");
    const toastEl = document.getElementById("toast");
    const tabletEquipBtn = document.getElementById("tabletEquipBtn");
    const tabletEquipReturnBtn = document.getElementById("tabletEquipReturnBtn");
    const tabletEquipModal = document.getElementById("tabletEquipModal");
    const tabletEquipList = document.getElementById("tabletEquipList");
    const tabletEquipCloseBtn = document.getElementById("tabletEquipCloseBtn");
    const tabletEquipClearBtn = document.getElementById("tabletEquipClearBtn");
    const tabletEquipSaveBtn = document.getElementById("tabletEquipSaveBtn");

    let latestLanes = [];
    let isSubmitting = false;
    let scoreDisplayEnabled = false;
    let scoreDisplayToggleBusy = false;
    let toastTimerId = null;
    let activeLaneCache = null;
    let equipmentCatalogCache = [];
    let tabletEquipDraft = [];

    async function apiFetch(input, init = {}) {
        const response = await fetch(input, { ...init, credentials: "same-origin" });
        if (response.status === 401) {
            window.location.assign("/Account/Login?returnUrl=" + encodeURIComponent(window.location.pathname + window.location.search));
            throw new Error("İcazə yoxdur");
        }
        return response;
    }

    async function readErrorMessage(response) {
        const raw = await response.text();
        if (!raw) return "Naməlum xəta";
        try {
            const parsed = JSON.parse(raw);
            return parsed?.error ?? parsed?.title ?? raw;
        } catch {
            return raw;
        }
    }

    function getActiveSessionForLane(laneNumber) {
        const lane = (Array.isArray(latestLanes) ? latestLanes : []).find(x =>
            x.laneNumber === laneNumber &&
            x.status === "Active" &&
            x.sessionId);
        return lane ?? null;
    }

    function syncTabletContext() {
        if (!(tabletLaneNumberInput instanceof HTMLSelectElement)
            || !(tabletAthleteNameInput instanceof HTMLInputElement)
            || !(tabletSessionIdInput instanceof HTMLInputElement)
            || !(subBtn instanceof HTMLButtonElement)
            || !(lanePill instanceof HTMLElement)) {
            return;
        }

        const selectedLane = Number(tabletLaneNumberInput.value);
        const active = getActiveSessionForLane(selectedLane);
        activeLaneCache = active;

        if (!active?.sessionId) {
            tabletAthleteNameInput.value = "Zolaq boşdur";
            tabletSessionIdInput.value = "";
            if (roundNumberInput instanceof HTMLInputElement) roundNumberInput.value = "1";
            lanePill.textContent = "Sessiya: yoxdur";
            lanePill.className = "pill bad";
            subBtn.disabled = true;
            if (addBtn instanceof HTMLButtonElement) addBtn.disabled = true;
            if (tabletEquipBtn instanceof HTMLButtonElement) tabletEquipBtn.disabled = true;
            if (tabletEquipReturnBtn instanceof HTMLButtonElement) tabletEquipReturnBtn.disabled = true;
            setKeypadEnabled(false);
            return;
        }

        tabletAthleteNameInput.value = active.athleteName || "—";
        tabletSessionIdInput.value = active.sessionId;
        if (roundNumberInput instanceof HTMLInputElement) {
            const nextRound = Number(active.scoreCount ?? 0) + 1;
            roundNumberInput.value = String(nextRound);
        }
        lanePill.textContent = `Sessiya: aktiv (cəmi xal: ${active.totalScore ?? 0})`;
        lanePill.className = "pill ok";
        subBtn.disabled = false;
        if (addBtn instanceof HTMLButtonElement) addBtn.disabled = false;
        if (tabletEquipBtn instanceof HTMLButtonElement) tabletEquipBtn.disabled = false;
        if (tabletEquipReturnBtn instanceof HTMLButtonElement) tabletEquipReturnBtn.disabled = false;
        setKeypadEnabled(true);
    }

    async function loadEquipmentCatalog() {
        try {
            const res = await apiFetch("/equipment/active", { timeoutMs: 30000 });
            if (!res.ok) return;
            const list = await res.json().catch(() => []);
            equipmentCatalogCache = Array.isArray(list) ? list : [];
        } catch { /* ignore */ }
    }

    function renderTabletEquipList() {
        if (!(tabletEquipList instanceof HTMLElement)) return;
        tabletEquipList.innerHTML = "";
        const rentals = equipmentCatalogCache.filter(x => {
            const mode = Number(x?.usageMode ?? 2);
            return mode === 1 || mode === 2; // Rental or Both
        });
        if (!rentals.length) {
            tabletEquipList.innerHTML = '<div class="pill bad" style="border-radius:14px; padding:10px 12px;">Aktiv icarə avadanlığı tapılmadı.</div>';
            return;
        }

        for (const item of rentals) {
            const stock = Number(item.quantity ?? 0);
            const outOfStock = stock <= 0;
            const draft = tabletEquipDraft.find(x => String(x.equipmentItemId) === String(item.id));
            const checked = Boolean(draft);
            const qty = Math.max(1, Number(draft?.quantity) || 1);

            const row = document.createElement("div");
            row.style.display = "grid";
            row.style.gridTemplateColumns = "auto 1fr auto";
            row.style.gap = "10px";
            row.style.alignItems = "center";
            row.style.padding = "10px 12px";
            row.style.border = "1px solid rgba(41,55,89,0.16)";
            row.style.borderRadius = "12px";
            row.style.background = "rgba(255,255,255,0.95)";

            const cb = document.createElement("input");
            cb.type = "checkbox";
            cb.checked = checked;
            cb.disabled = outOfStock;

            const body = document.createElement("div");
            const title = document.createElement("div");
            title.style.fontWeight = "900";
            const category = item.category ? ` (${item.category})` : "";
            const stockLabel = outOfStock ? " · stok bitib" : ` · stok: ${stock}`;
            title.textContent = `${item.name}${category}${stockLabel}`;
            body.appendChild(title);

            const qtyInput = document.createElement("input");
            qtyInput.type = "number";
            qtyInput.min = "1";
            qtyInput.step = "1";
            qtyInput.value = String(qty);
            qtyInput.style.minHeight = "38px";
            qtyInput.style.width = "76px";
            qtyInput.disabled = !checked || outOfStock;

            cb.addEventListener("change", () => {
                const on = cb.checked;
                qtyInput.disabled = !on || outOfStock;
                tabletEquipDraft = tabletEquipDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                if (on) tabletEquipDraft.push({ equipmentItemId: item.id, quantity: Math.max(1, Number(qtyInput.value) || 1) });
            });
            qtyInput.addEventListener("input", () => {
                const q = Math.max(1, Number(qtyInput.value) || 1);
                qtyInput.value = String(q);
                if (!cb.checked) return;
                tabletEquipDraft = tabletEquipDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                tabletEquipDraft.push({ equipmentItemId: item.id, quantity: q });
            });

            row.appendChild(cb);
            row.appendChild(body);
            row.appendChild(qtyInput);
            tabletEquipList.appendChild(row);
        }
    }

    function openTabletEquipModal() {
        tabletEquipDraft = [];
        renderTabletEquipList();
        if (tabletEquipModal instanceof HTMLElement) tabletEquipModal.style.display = "block";
    }

    function closeTabletEquipModal() {
        if (tabletEquipModal instanceof HTMLElement) tabletEquipModal.style.display = "none";
    }

    async function issueRentalFromTablet() {
        const sessionId = tabletSessionIdInput instanceof HTMLInputElement ? tabletSessionIdInput.value.trim() : "";
        if (!sessionId) {
            showToast("Sessiya yoxdur", "bad");
            return;
        }
        if (!tabletEquipDraft.length) {
            showToast("Avadanlıq seçilməyib", "bad");
            return;
        }
        const response = await apiFetch(`/sessions/${encodeURIComponent(sessionId)}/equipment/issue-rental`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(tabletEquipDraft.map(x => ({ equipmentItemId: x.equipmentItemId, quantity: x.quantity, issueType: 1 })))
        });
        if (!response.ok) {
            showToast(await readErrorMessage(response) || "Verilmədi", "bad");
            return;
        }
        showToast("İcarə avadanlıq verildi", "ok");
        closeTabletEquipModal();
        await loadDashboard();
    }

    async function returnRentalForSession() {
        const sessionId = tabletSessionIdInput instanceof HTMLInputElement ? tabletSessionIdInput.value.trim() : "";
        if (!sessionId) return;
        const response = await apiFetch(`/sessions/equipment/return-bulk`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ sessionIds: [sessionId] })
        });
        if (!response.ok) {
            showToast(await readErrorMessage(response) || "Təhvil alınmadı", "bad");
            return;
        }
        showToast("Təhvil alındı", "ok");
        await loadDashboard();
    }

    function setKeypadEnabled(enabled) {
        const canInteract = enabled && !isSubmitting;

        keypadRoot?.querySelectorAll("button.key").forEach(btn => {
            btn.disabled = !canInteract;
        });

        if (clearBtn instanceof HTMLButtonElement) {
            clearBtn.disabled = !canInteract;
        }

        // add/undo düymələri sessiya olub-olmamasına görə syncTabletContext() ilə idarə olunur.
        // Burada yalnız "submitting" zamanı müvəqqəti kilidləyirik (disabled state ilişib qalmasın).
        if (addBtn instanceof HTMLButtonElement) {
            addBtn.disabled = addBtn.disabled || !canInteract;
        }
        if (subBtn instanceof HTMLButtonElement) {
            subBtn.disabled = subBtn.disabled || !canInteract;
        }
    }

    function showToast(message, kind = "ok") {
        if (!(toastEl instanceof HTMLElement)) return;
        toastEl.textContent = message;
        toastEl.className = `toast ${kind} show`;
        if (toastTimerId) {
            clearTimeout(toastTimerId);
        }
        toastTimerId = setTimeout(() => {
            toastEl.className = "toast";
        }, 1400);
    }

    function syncScoreDisplayToggleUi() {
        if (!(scoreDisplayToggle instanceof HTMLButtonElement)) return;
        scoreDisplayToggle.textContent = scoreDisplayEnabled ? "Xalları söndür" : "Xalları aktiv et";
        scoreDisplayToggle.classList.toggle("is-on", scoreDisplayEnabled);
        scoreDisplayToggle.disabled = scoreDisplayToggleBusy;
    }

    async function loadScoreDisplayState() {
        try {
            const response = await apiFetch("/monitor/score-display");
            if (!response.ok) return;
            const data = await response.json();
            scoreDisplayEnabled = Boolean(data?.enabled);
            syncScoreDisplayToggleUi();
        } catch { /* ignore */ }
    }

    async function toggleScoreDisplay() {
        if (!(scoreDisplayToggle instanceof HTMLButtonElement) || scoreDisplayToggleBusy) return;
        scoreDisplayToggleBusy = true;
        syncScoreDisplayToggleUi();
        const next = !scoreDisplayEnabled;
        try {
            const response = await apiFetch("/monitor/score-display", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ enabled: next })
            });
            if (!response.ok) {
                const message = await readErrorMessage(response);
                showToast(message || "Xal rejimi dəyişmədi", "bad");
                return;
            }
            const data = await response.json();
            scoreDisplayEnabled = Boolean(data?.enabled);
            showToast(scoreDisplayEnabled ? "Xal monitorları aktivdir" : "Xal monitorları söndürüldü", "ok");
        } catch (error) {
            showToast(getExceptionMessage?.(error) || "Xal rejimi dəyişmədi", "bad");
        } finally {
            scoreDisplayToggleBusy = false;
            syncScoreDisplayToggleUi();
        }
    }

    function getExceptionMessage(error) {
        if (!error) return "";
        if (typeof error === "string") return error;
        return error.message || String(error);
    }

    async function loadDashboard() {
        const response = await apiFetch("/dashboard/lanes");
        if (!response.ok) return;
        const lanes = await response.json();
        latestLanes = Array.isArray(lanes) ? lanes : [];
        syncTabletContext();
    }

    function normalizeScoreDraft(raw) {
        const digitsOnly = String(raw ?? "").replaceAll(/[^\d]/g, "");
        const trimmed = digitsOnly.replace(/^0+(?=\d)/g, "");
        if (trimmed.length === 0) return "";
        return trimmed.slice(0, 3); // 0..999
    }

    function setScoreDraft(raw) {
        if (!(scoreValueInput instanceof HTMLInputElement)) return;
        scoreValueInput.value = normalizeScoreDraft(raw);
    }

    function appendDigit(digit) {
        if (!(scoreValueInput instanceof HTMLInputElement)) return;
        const next = normalizeScoreDraft(scoreValueInput.value + String(digit));
        scoreValueInput.value = next;
    }

    async function submitScoreDraft() {
        if (isSubmitting) return;

        const sessionId = tabletSessionIdInput instanceof HTMLInputElement ? tabletSessionIdInput.value.trim() : "";
        if (!sessionId) {
            syncTabletContext();
            return;
        }

        const draft = scoreValueInput instanceof HTMLInputElement ? normalizeScoreDraft(scoreValueInput.value) : "";
        if (!draft) {
            alert("Xalı daxil edin.");
            return;
        }

        const value = Number(draft);
        if (!Number.isFinite(value) || value < 0 || value > 999) {
            alert("Xal 0–999 aralığında olmalıdır.");
            return;
        }

        const round = roundNumberInput instanceof HTMLInputElement ? Number(roundNumberInput.value) : 1;
        const roundSafe = Number.isFinite(round) && round > 0 ? round : 1;

        isSubmitting = true;
        if (lanePill instanceof HTMLElement) {
            lanePill.textContent = "Göndərilir…";
            lanePill.className = "pill spin";
        }
        setKeypadEnabled(true);
        try {
            const response = await apiFetch(`/sessions/${sessionId}/scores`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    roundNumber: roundSafe,
                    value
                })
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Xal göndərilmədi. ${message}`);
                return;
            }

            setScoreDraft("");
            if (scoreValueInput instanceof HTMLInputElement) {
                scoreValueInput.focus();
            }
            await loadDashboard();
            showToast("Xal əlavə olundu", "ok");
        } finally {
            isSubmitting = false;
            syncTabletContext();
            setKeypadEnabled(true);
        }
    }

    async function subtractScoreDraft() {
        if (isSubmitting) return;
        const sessionId = tabletSessionIdInput instanceof HTMLInputElement ? tabletSessionIdInput.value.trim() : "";
        if (!sessionId) {
            syncTabletContext();
            return;
        }

        const draft = scoreValueInput instanceof HTMLInputElement ? normalizeScoreDraft(scoreValueInput.value) : "";
        if (!draft) {
            alert("Çıxılacaq xalı daxil edin.");
            return;
        }

        const subtractWanted = Number(draft);
        if (!Number.isFinite(subtractWanted) || subtractWanted <= 0 || subtractWanted > 999) {
            alert("Xal 1–999 aralığında olmalıdır.");
            return;
        }

        const currentTotal = Number(activeLaneCache?.totalScore ?? 0);
        const effectiveSubtract = Math.max(0, Math.min(subtractWanted, Number.isFinite(currentTotal) ? currentTotal : 0));
        const negativeValue = -effectiveSubtract;

        // If total is already 0, nothing to subtract.
        if (negativeValue === 0) {
            setScoreDraft("");
            if (scoreValueInput instanceof HTMLInputElement) scoreValueInput.focus();
            showToast("Cəmi xal artıq 0-dır", "bad");
            return;
        }

        const round = roundNumberInput instanceof HTMLInputElement ? Number(roundNumberInput.value) : 1;
        const roundSafe = Number.isFinite(round) && round > 0 ? round : 1;

        isSubmitting = true;
        if (lanePill instanceof HTMLElement) {
            lanePill.textContent = "Çıxılır…";
            lanePill.className = "pill spin";
        }
        setKeypadEnabled(true);
        try {
            const response = await apiFetch(`/sessions/${sessionId}/scores`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    roundNumber: roundSafe,
                    value: negativeValue
                })
            });

            if (!response.ok) {
                const message = await readErrorMessage(response);
                alert(`Xal çıxılmadı. ${message}`);
                return;
            }

            setScoreDraft("");
            if (scoreValueInput instanceof HTMLInputElement) scoreValueInput.focus();
            await loadDashboard();
            showToast("Xal çıxıldı", "ok");
        } finally {
            isSubmitting = false;
            syncTabletContext();
            setKeypadEnabled(true);
        }
    }

    function buildKeypad() {
        if (!(keypadRoot instanceof HTMLElement)) return;
        const values = [1,2,3,4,5,6,7,8,9,0];
        keypadRoot.innerHTML = values.map(v => {
            const extra = v === 0 ? " key-wide" : "";
            const label = v === 0 ? "0" : String(v);
            return `<button class="key${extra}" data-value="${v}" type="button">${label}</button>`;
        }).join("");

        keypadRoot.querySelectorAll("button.key").forEach(btn => {
            btn.addEventListener("click", async e => {
                const t = e.currentTarget;
                if (!(t instanceof HTMLButtonElement)) return;
                const v = Number(t.dataset.value);
                appendDigit(v);
            });
        });
    }

    async function startSignalR() {
        if (!(connectionPill instanceof HTMLElement)) return;
        if (typeof signalR === "undefined" || !signalR?.HubConnectionBuilder) {
            connectionPill.textContent = "SignalR yüklənmədi";
            connectionPill.className = "pill bad";
            setTimeout(startSignalR, 5000);
            return;
        }
        try {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/lane")
                .withAutomaticReconnect()
                .build();

            connection.onreconnecting(() => {
                connectionPill.textContent = "Yenidən qoşulur…";
                connectionPill.className = "pill bad";
            });

            connection.onreconnected(() => {
                connectionPill.textContent = "Qoşuldu";
                connectionPill.className = "pill ok";
            });

            connection.on("lane-updated", loadDashboard);
            connection.on("score-updated", loadDashboard);
            connection.on("score-display-changed", enabled => {
                scoreDisplayEnabled = Boolean(enabled);
                syncScoreDisplayToggleUi();
            });

            await connection.start();
            connectionPill.textContent = "Qoşuldu";
            connectionPill.className = "pill ok";
        } catch {
            connectionPill.textContent = "Bağlantı yoxdur (yenidən cəhd)";
            connectionPill.className = "pill bad";
            setTimeout(startSignalR, 5000);
        }
    }

    function applyTabletLaneFromUrl() {
        if (!(tabletLaneNumberInput instanceof HTMLSelectElement)) return;
        try {
            const lane = Number(new URLSearchParams(window.location.search).get("lane") || "");
            if (Number.isInteger(lane) && lane >= 1 && lane <= 11) {
                tabletLaneNumberInput.value = String(lane);
            }
        } catch { /* ignore */ }
    }

    tabletLaneNumberInput?.addEventListener("change", syncTabletContext);
    tabletEquipBtn?.addEventListener("click", async () => { await loadEquipmentCatalog(); openTabletEquipModal(); });
    tabletEquipCloseBtn?.addEventListener("click", closeTabletEquipModal);
    tabletEquipClearBtn?.addEventListener("click", () => { tabletEquipDraft = []; renderTabletEquipList(); });
    tabletEquipSaveBtn?.addEventListener("click", () => { void issueRentalFromTablet(); });
    tabletEquipReturnBtn?.addEventListener("click", () => { void returnRentalForSession(); });
    scoreValueInput?.addEventListener("input", () => {
        if (scoreValueInput instanceof HTMLInputElement) {
            scoreValueInput.value = normalizeScoreDraft(scoreValueInput.value);
        }
    });
    clearBtn?.addEventListener("click", () => setScoreDraft(""));
    addBtn?.addEventListener("click", submitScoreDraft);
    subBtn?.addEventListener("click", subtractScoreDraft);
    scoreDisplayToggle?.addEventListener("click", toggleScoreDisplay);

    applyTabletLaneFromUrl();
    buildKeypad();
    loadScoreDisplayState();
    loadDashboard();
    startSignalR();
    setInterval(loadDashboard, 15000);
</script>
</body>
</html>

