@using EShooting.Web.Extensions
@{
    Layout = null;
    var supervisorName = User.GetPlansetStaffDisplayName();
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <title>EShooting — Zolaq monitoru</title>
    <style>
        :root {
            --bg: #eef2fb;
            --panel: rgba(255, 255, 255, 0.94);
            --text: #18223a;
            --muted: #55638a;
            --border: rgba(41, 55, 89, 0.18);
            --shadow: 0 10px 30px rgba(13, 24, 48, 0.1);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        html, body {
            margin: 0;
            min-height: 100%;
            background: radial-gradient(circle at top, #dce6ff 0, var(--bg) 58%);
            color: var(--text);
            font-family: "Segoe UI", Arial, sans-serif;
        }

        body.lane-monitor-body {
            min-height: 100vh;
            padding: max(10px, env(safe-area-inset-top)) max(10px, env(safe-area-inset-right))
                     max(10px, env(safe-area-inset-bottom)) max(10px, env(safe-area-inset-left));
        }

        .lane-monitor-shell {
            max-width: 1400px;
            margin: 0 auto;
        }

        .lane-monitor-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            padding: 12px 16px;
            margin-bottom: 12px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow);
        }

        .lane-monitor-title {
            margin: 0;
            font-size: clamp(1.15rem, 2.8vw, 1.6rem);
            font-weight: 800;
            color: #202c56;
        }

        .lane-monitor-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .supervisor-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid rgba(42, 74, 184, 0.22);
            background: rgba(79, 124, 255, 0.1);
            font-size: 13px;
            font-weight: 700;
            color: #2a4ab8;
            white-space: nowrap;
        }

        .supervisor-chip__label {
            color: #667395;
            font-weight: 600;
        }

        .lane-monitor-logout-form {
            margin: 0;
            display: inline-flex;
        }

        .lane-monitor-refresh-btn {
            min-height: 42px;
            padding: 8px 16px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.95);
            color: #2a3260;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(13, 24, 48, 0.08);
        }

        .lane-monitor-refresh-btn:hover {
            background: #fff;
        }

        .lane-monitor-refresh-btn:disabled {
            opacity: 0.65;
            cursor: wait;
        }

        .header-clock {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.88);
            font-size: 13px;
            font-weight: 700;
            color: var(--muted);
            white-space: nowrap;
        }

        .header-clock__value {
            font-variant-numeric: tabular-nums;
            color: #202c56;
        }

        .lane-monitor-panel {
            padding: 14px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow);
        }

        .lane-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }

        @@media (max-width: 1100px) {
            .lane-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @@media (max-width: 700px) {
            .lane-grid { grid-template-columns: 1fr; }
        }

        .lane-card {
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(122, 138, 178, 0.25);
            border-radius: 16px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            box-shadow: 0 14px 24px rgba(96, 87, 157, 0.12);
            position: relative;
        }

        .lane-card--readonly {
            pointer-events: none;
            user-select: none;
            -webkit-user-select: none;
        }

        .lane-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .lane-title {
            margin: 0;
            font-size: 17px;
            font-weight: 800;
            color: #202c56;
        }

        .lane-type {
            font-size: 11px;
            color: #7b86a7;
            letter-spacing: 0.06em;
            font-weight: 700;
        }

        .lane-meta {
            margin: 4px 0;
            color: #667395;
            font-size: 13px;
        }

        .lane-meta--names {
            word-break: break-word;
            overflow-wrap: anywhere;
            line-height: 1.35;
        }

        .lane-meta--compact {
            font-size: 12px;
            line-height: 1.35;
        }

        .status-pill {
            display: inline-block;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 700;
            background: rgba(86, 103, 148, 0.18);
            color: #52618f;
            flex: 0 0 auto;
        }

        .status-pill.Active { background: rgba(15, 157, 119, 0.16); color: #0b8a69; }
        .status-pill.Completed { background: rgba(78, 102, 255, 0.16); color: #445fd4; }
        .status-pill.Scheduled { background: rgba(214, 138, 0, 0.2); color: #b57100; }

        .countdown-ring-wrap {
            --ring-track: rgba(62, 77, 130, 0.14);
            --ring-accent: #17ad80;
            --ring-glow: rgba(23, 173, 128, 0.25);
            position: relative;
            width: 132px;
            height: 132px;
            margin: 12px auto 4px;
            overflow: hidden;
            border-radius: 50%;
        }

        .countdown-ring__svg {
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
            filter: drop-shadow(0 0 10px var(--ring-glow));
        }

        .countdown-ring__track {
            fill: none;
            stroke: var(--ring-track);
            stroke-width: 7;
        }

        .countdown-ring__progress {
            fill: none;
            stroke: var(--ring-accent);
            stroke-width: 7;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.35s ease, stroke 0.3s ease;
        }

        .countdown-ring__center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 8px;
            pointer-events: none;
            overflow: hidden;
            box-sizing: border-box;
        }

        .countdown-ring__timer {
            font-size: 22px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.04em;
            line-height: 1.1;
            color: #26325f;
            max-width: 100%;
            white-space: nowrap;
            transform-origin: center center;
        }

        .countdown-ring-wrap[data-time-wide="1"] .countdown-ring__timer {
            letter-spacing: -0.04em;
        }

        .countdown-ring__caption {
            margin-top: 4px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.04em;
            color: #7a86a8;
        }

        .countdown-ring-wrap.is-pending {
            --ring-accent: #d68a00;
            --ring-glow: rgba(214, 138, 0, 0.24);
        }

        .countdown-ring-wrap.is-live.is-warn:not(.is-critical),
        .countdown-ring-wrap.is-pending.is-warn:not(.is-critical) {
            --ring-accent: #ef8f1f;
            --ring-glow: rgba(239, 143, 31, 0.3);
        }

        .countdown-ring-wrap.is-live.is-critical,
        .countdown-ring-wrap.is-pending.is-critical {
            --ring-accent: #d1435f;
            --ring-glow: rgba(209, 67, 95, 0.34);
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer,
        .countdown-ring-wrap.is-pending.is-critical .countdown-ring__timer {
            color: #b63852;
        }

        .countdown-ring-wrap.is-done,
        .countdown-ring-wrap.is-idle {
            --ring-accent: rgba(120, 132, 168, 0.55);
            --ring-glow: transparent;
        }

        .lane-bottom-hint {
            position: absolute;
            left: 16px;
            bottom: 16px;
            font-weight: 900;
            font-size: 14px;
            color: #11824b;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
            pointer-events: none;
        }

        .lane-bottom-hint.is-show {
            opacity: 1;
            transform: translateY(0);
        }

        .lane-bottom-hint.is-warn { color: #c77700; }
        .lane-bottom-hint.is-critical { color: #b63852; }

        .countdown-ring-wrap[data-time-wide="1"] .countdown-ring__timer {
            font-size: 14px;
            letter-spacing: -0.04em;
        }

        .lane-monitor-loading {
            padding: 24px;
            text-align: center;
            color: var(--muted);
            font-weight: 700;
        }

        .lane-equip-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 10px;
            pointer-events: auto;
        }

        .lane-equip-btn {
            flex: 1 1 auto;
            min-height: 42px;
            padding: 8px 12px;
            border-radius: 12px;
            border: 1px solid var(--border);
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(13, 24, 48, 0.08);
        }

        .lane-equip-btn--issue {
            background: rgba(79, 124, 255, 0.12);
            border-color: rgba(79, 124, 255, 0.35);
            color: #2a4ab8;
        }

        .lane-equip-btn--return {
            background: rgba(209, 67, 95, 0.1);
            border-color: rgba(209, 67, 95, 0.35);
            color: #b63852;
        }

        .lane-equip-btn:disabled {
            opacity: 0.55;
            cursor: wait;
        }

        .lane-card--pending-equip {
            border-color: rgba(209, 67, 95, 0.35);
            box-shadow: 0 14px 24px rgba(209, 67, 95, 0.12);
        }

        .lane-meta--pending-equip {
            color: #b63852;
            font-weight: 700;
        }

        .lane-pending-equip-banner {
            margin: 10px auto 4px;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid rgba(209, 67, 95, 0.28);
            background: rgba(209, 67, 95, 0.08);
            text-align: center;
            max-width: 100%;
        }

        .lane-pending-equip-banner__title {
            font-size: 13px;
            font-weight: 900;
            color: #b63852;
            line-height: 1.35;
        }

        .lane-pending-equip-banner__items {
            margin-top: 6px;
            font-size: 12px;
            font-weight: 700;
            color: #667395;
            line-height: 1.35;
            word-break: break-word;
        }

        .equip-fab {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            border: 1px solid rgba(41, 55, 89, 0.22);
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 10px 30px rgba(16, 24, 40, 0.22);
            cursor: pointer;
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
            pointer-events: auto;
        }

        .equip-fab:hover { transform: translateY(-1px); }
        .equip-fab--hidden { display: none; }
        .equip-fab--ok { background: rgba(27, 191, 122, 0.16); border-color: rgba(27, 191, 122, 0.28); }
        .equip-fab--bad { background: rgba(209, 67, 95, 0.18); border-color: rgba(209, 67, 95, 0.35); }

        @@keyframes equipPulse {
            0% { box-shadow: 0 0 0 0 rgba(209, 67, 95, 0.28), 0 10px 30px rgba(16, 24, 40, 0.22); }
            70% { box-shadow: 0 0 0 14px rgba(209, 67, 95, 0.0), 0 10px 30px rgba(16, 24, 40, 0.22); }
            100% { box-shadow: 0 0 0 0 rgba(209, 67, 95, 0.0), 0 10px 30px rgba(16, 24, 40, 0.22); }
        }

        .equip-fab--pulse { animation: equipPulse 1.25s ease-out infinite; }

        .equip-fab__icon { font-size: 18px; line-height: 1; }

        .equip-fab__badge {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 20px;
            height: 20px;
            border-radius: 999px;
            padding: 0 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 900;
            color: #fff;
            background: #d1435f;
            border: 2px solid rgba(255, 255, 255, 0.92);
        }

        .equip-panel,
        .equip-panel button,
        .lane-equip-btn {
            text-transform: none;
        }

        .equip-panel {
            position: fixed;
            top: 86px;
            right: 14px;
            width: min(440px, 92vw);
            z-index: 10001;
            background: rgba(255, 255, 255, 0.97);
            border: 1px solid rgba(41, 55, 89, 0.22);
            border-radius: 14px;
            padding: 12px;
            box-shadow: 0 16px 50px rgba(16, 24, 40, 0.28);
            transform: translateX(calc(100% + 20px));
            opacity: 0;
            pointer-events: none;
            transition: transform 0.22s ease, opacity 0.22s ease;
        }

        .equip-panel.is-open {
            transform: translateX(0);
            opacity: 1;
            pointer-events: auto;
        }

        .equip-panel__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .equip-panel__notice {
            margin-top: 8px;
            font-size: 12px;
            color: var(--muted);
            line-height: 1.4;
        }

        .equip-panel__list {
            margin-top: 10px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 65vh;
            overflow: auto;
        }

        .equip-pending-row {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 10px 12px;
            border: 1px solid rgba(41, 55, 89, 0.18);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.95);
        }

        .equip-pending-row.is-red { border-color: rgba(209, 67, 95, 0.35); background: rgba(209, 67, 95, 0.05); }
        .equip-pending-row.is-yellow { border-color: rgba(214, 138, 0, 0.35); }

        .equip-pending-row__title {
            font-weight: 900;
            font-size: 14px;
            color: #1a2650;
        }

        .equip-pending-row__meta {
            font-size: 12px;
            color: var(--muted);
            line-height: 1.4;
        }

        .equip-pending-row__status {
            font-size: 12px;
            font-weight: 800;
        }

        .equip-pending-row__status.is-red { color: #c62828; }
        .equip-pending-row__status.is-yellow { color: #b8860b; }

        .equip-pending-items {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .equip-pending-item {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 8px;
            align-items: center;
            padding: 8px 10px;
            border: 1px solid rgba(41, 55, 89, 0.14);
            border-radius: 10px;
            background: rgba(248, 250, 255, 0.95);
        }

        .equip-pending-item__name {
            font-size: 13px;
            font-weight: 800;
            color: #1a2650;
            line-height: 1.3;
        }

        .equip-pending-item__issued {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
        }

        .equip-pending-item__xarab {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            min-width: 64px;
        }

        .equip-pending-item__xarab label {
            font-size: 11px;
            font-weight: 700;
            color: #667395;
        }

        .equip-pending-item__xarab input[type="number"] {
            width: 56px;
            padding: 6px 8px;
            border-radius: 8px;
            border: 1px solid rgba(41, 55, 89, 0.22);
            font-size: 14px;
            font-weight: 700;
            text-align: center;
        }

        .monitor-equip-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(11, 18, 32, 0.45);
            backdrop-filter: blur(5px);
            z-index: 10002;
            padding: 16px;
            pointer-events: auto;
        }

        .monitor-equip-modal__panel {
            max-width: 720px;
            margin: 6vh auto 0;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
            box-shadow: var(--shadow);
        }

        .monitor-equip-list {
            margin-top: 12px;
            max-height: 55vh;
            overflow: auto;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .monitor-equip-row {
            display: grid;
            grid-template-columns: auto 1fr auto;
            gap: 10px;
            align-items: center;
            padding: 10px 12px;
            border: 1px solid rgba(41, 55, 89, 0.16);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.95);
        }

        .monitor-equip-row__title {
            font-weight: 800;
            font-size: 14px;
        }

        .monitor-equip-row input[type="number"] {
            width: 72px;
            min-height: 38px;
        }

        .monitor-toast {
            position: fixed;
            left: 50%;
            bottom: 24px;
            transform: translateX(-50%) translateY(120%);
            background: #18223a;
            color: #fff;
            padding: 10px 16px;
            border-radius: 12px;
            font-weight: 700;
            z-index: 10003;
            transition: transform 0.25s ease;
            pointer-events: none;
        }

        .monitor-toast.show { transform: translateX(-50%) translateY(0); }
        .monitor-toast.bad { background: #b63852; }
        .monitor-toast.ok { background: #0f7a54; }
    </style>
</head>
<body class="lane-monitor-body">
    <div class="lane-monitor-shell">
        <header class="lane-monitor-header">
            <div>
                <h1 class="lane-monitor-title">Zolaq monitoru</h1>
            </div>
            <div class="lane-monitor-meta">
                <div class="supervisor-chip" title="Planşet nəzarətçisi">
                    <span class="supervisor-chip__label">Nəzarətçi:</span>
                    <span>@supervisorName</span>
                </div>
                <button type="button" id="pendingEquipFabBtn" class="equip-fab equip-fab--hidden" aria-label="Təhvil gözləyənlər" title="Təhvil gözləyənlər">
                    <span class="equip-fab__icon">🏹</span>
                    <span id="pendingEquipFabBadge" class="equip-fab__badge">0</span>
                </button>
                <button type="button" id="refreshBtn" class="lane-monitor-refresh-btn">Yenilə</button>
                <form method="post" action="/planset/cixis" class="lane-monitor-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="lane-monitor-refresh-btn">Çıxış</button>
                </form>
                <div class="header-clock" title="Cari saat">
                    <span id="wallClock" class="header-clock__value">--:--:--</span>
                </div>
            </div>
        </header>

        <section class="lane-monitor-panel">
            <div class="lane-grid" id="laneGrid">
                <div class="lane-monitor-loading">Yüklənir…</div>
            </div>
        </section>
    </div>

    <aside id="pendingEquipPanel" class="equip-panel" aria-hidden="true">
        <div class="equip-panel__head">
            <div style="font-weight:900; color:#1a2650;">Təhvil gözləyənlər</div>
            <button type="button" id="pendingEquipPanelCloseBtn" class="lane-monitor-refresh-btn">Bağla</button>
        </div>
        <div class="equip-panel__notice">Sessiya bitəndə icarə avadanlığı burada görünür. Hər sətir üçün xarab ədədi yazın (boş = hamısı işlək).</div>
        <div id="pendingEquipList" class="equip-panel__list"></div>
    </aside>

    <div id="monitorEquipModal" class="monitor-equip-modal" aria-hidden="true">
        <div class="monitor-equip-modal__panel">
            <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap;">
                <div>
                    <div style="font-weight:900; color:#1a2650; font-size:18px;">İcarə avadanlıq (zal)</div>
                    <div id="monitorEquipModalSub" style="font-size:13px; color:var(--muted); margin-top:4px;"></div>
                </div>
                <button type="button" id="monitorEquipCloseBtn" class="lane-monitor-refresh-btn">Bağla</button>
            </div>
            <div id="monitorEquipList" class="monitor-equip-list"></div>
            <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:12px; flex-wrap:wrap;">
                <button type="button" id="monitorEquipClearBtn" class="lane-monitor-refresh-btn">Təmizlə</button>
                <button type="button" id="monitorEquipSaveBtn" class="lane-equip-btn lane-equip-btn--issue" style="flex:0 0 auto; min-width:140px;">Təsdiqlə</button>
            </div>
        </div>
    </div>

    <div id="monitorReturnModal" class="monitor-equip-modal" aria-hidden="true">
        <div class="monitor-equip-modal__panel">
            <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap;">
                <div>
                    <div style="font-weight:900; color:#1a2650; font-size:18px;">Təhvil al</div>
                    <div id="monitorReturnModalSub" style="font-size:13px; color:var(--muted); margin-top:4px;"></div>
                </div>
                <button type="button" id="monitorReturnCloseBtn" class="lane-monitor-refresh-btn">Bağla</button>
            </div>
            <div class="equip-panel__notice">Xarab və ya sıradan çıxan ədədi yazın — işlək qalan stoka qayıdır.</div>
            <div id="monitorReturnList" class="monitor-equip-list"></div>
            <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:12px; flex-wrap:wrap;">
                <button type="button" id="monitorReturnSaveBtn" class="lane-equip-btn lane-equip-btn--return" style="flex:0 0 auto; min-width:140px;">Təhvil al</button>
            </div>
        </div>
    </div>

    <div id="monitorToast" class="monitor-toast"></div>

    <script src="/lib/signalr/signalr.min.js"></script>
    <script>
        const laneGrid = document.getElementById("laneGrid");
        const refreshBtn = document.getElementById("refreshBtn");
        const wallClock = document.getElementById("wallClock");
        const monitorEquipModal = document.getElementById("monitorEquipModal");
        const monitorEquipList = document.getElementById("monitorEquipList");
        const monitorEquipModalSub = document.getElementById("monitorEquipModalSub");
        const monitorEquipCloseBtn = document.getElementById("monitorEquipCloseBtn");
        const monitorEquipClearBtn = document.getElementById("monitorEquipClearBtn");
        const monitorEquipSaveBtn = document.getElementById("monitorEquipSaveBtn");
        const monitorToast = document.getElementById("monitorToast");
        const monitorReturnModal = document.getElementById("monitorReturnModal");
        const monitorReturnList = document.getElementById("monitorReturnList");
        const monitorReturnModalSub = document.getElementById("monitorReturnModalSub");
        const monitorReturnCloseBtn = document.getElementById("monitorReturnCloseBtn");
        const monitorReturnSaveBtn = document.getElementById("monitorReturnSaveBtn");
        const pendingEquipFabBtn = document.getElementById("pendingEquipFabBtn");
        const pendingEquipFabBadge = document.getElementById("pendingEquipFabBadge");
        const pendingEquipPanel = document.getElementById("pendingEquipPanel");
        const pendingEquipPanelCloseBtn = document.getElementById("pendingEquipPanelCloseBtn");
        const pendingEquipList = document.getElementById("pendingEquipList");

        let equipmentCatalogCache = [];
        let monitorEquipDraft = [];
        let monitorEquipSessionId = null;
        let monitorEquipLaneNumber = null;
        let monitorReturnSessionId = null;
        let monitorReturnLaneNumber = null;
        let monitorReturnItems = [];
        let monitorToastTimer = null;
        let equipActionBusy = false;

        const COUNTDOWN_WARN_SEC = 300;
        const COUNTDOWN_CRIT_SEC = 120;
        const SESSION_BUFFER_MS = 0;

        function redirectIfPlansetUnauthorized(response) {
            if (response?.status === 401) {
                window.location.href = "/planset/giris";
                return true;
            }
            return false;
        }

        let lastLaneGridHtml = "";
        let gridLoadInFlight = false;
        let gridLoadQueued = false;
        let countdownTimerId = null;
        let pendingEquipLoadInFlight = false;

        function groupPendingEquipmentRows(items) {
            const map = new Map();
            for (const item of (Array.isArray(items) ? items : [])) {
                const sessionId = String(item?.sessionId ?? "");
                if (!sessionId) continue;
                const qty = Math.max(1, Number(item?.quantity) || 1);
                const equipmentItemId = String(item?.equipmentItemId ?? "");
                const equipmentName = item?.equipmentName ?? "Avadanlıq";
                const existing = map.get(sessionId);
                const equipEntry = { equipmentItemId, equipmentName, quantity: qty };
                if (!existing) {
                    map.set(sessionId, {
                        sessionId,
                        athleteName: item?.athleteName ?? "—",
                        laneNumber: item?.laneNumber ?? 0,
                        equipmentItems: [equipEntry],
                        issuedByStaffName: item?.issuedByStaffName ?? "—",
                        color: item?.color ?? "normal",
                        timeStatusLabel: item?.timeStatusLabel ?? ""
                    });
                    continue;
                }
                existing.equipmentItems.push(equipEntry);
                if (item?.color === "red" || (item?.color === "yellow" && existing.color !== "red")) {
                    existing.color = item.color;
                    existing.timeStatusLabel = item?.timeStatusLabel ?? existing.timeStatusLabel;
                }
                if (existing.issuedByStaffName === "—" && item?.issuedByStaffName) {
                    existing.issuedByStaffName = item.issuedByStaffName;
                }
            }
            return Array.from(map.values()).sort((a, b) => {
                const rank = c => (c === "red" ? 0 : c === "yellow" ? 1 : 2);
                const diff = rank(a.color) - rank(b.color);
                if (diff !== 0) return diff;
                return Number(a.laneNumber) - Number(b.laneNumber);
            });
        }

        function createPendingXarabInput(equipmentItemId, issued) {
            const wrap = document.createElement("div");
            wrap.className = "equip-pending-item__xarab";
            const label = document.createElement("label");
            label.textContent = "Xarab";
            const input = document.createElement("input");
            input.type = "number";
            input.min = "0";
            input.max = String(issued);
            input.step = "1";
            input.inputMode = "numeric";
            input.placeholder = "0";
            input.value = "";
            if (equipmentItemId) input.dataset.equipmentItemId = equipmentItemId;
            input.addEventListener("input", () => {
                const text = String(input.value ?? "").trim();
                if (!text) return;
                const n = parseInt(text, 10);
                if (!Number.isFinite(n) || n < 0) {
                    input.value = "";
                    return;
                }
                if (n > issued) input.value = String(issued);
            });
            wrap.appendChild(label);
            wrap.appendChild(input);
            return wrap;
        }

        function collectDamagedFromCard(card, sessionId) {
            const damaged = [];
            if (!(card instanceof HTMLElement)) return damaged;
            for (const input of card.querySelectorAll("input[data-equipment-item-id]")) {
                if (!(input instanceof HTMLInputElement)) continue;
                const qty = parseInt(String(input.value ?? "").trim(), 10);
                if (!Number.isFinite(qty) || qty <= 0) continue;
                damaged.push({
                    sessionId,
                    equipmentItemId: input.dataset.equipmentItemId,
                    quantity: qty
                });
            }
            return damaged;
        }

        function renderPendingEquipmentReturns(items) {
            const grouped = groupPendingEquipmentRows(items);
            if (pendingEquipFabBadge instanceof HTMLElement) {
                pendingEquipFabBadge.textContent = String(grouped.length);
            }
            if (!(pendingEquipFabBtn instanceof HTMLElement)) return;

            if (!grouped.length) {
                pendingEquipFabBtn.classList.add("equip-fab--hidden");
                pendingEquipFabBtn.classList.remove("equip-fab--bad", "equip-fab--ok", "equip-fab--pulse");
                closePendingEquipPanel();
                if (pendingEquipList instanceof HTMLElement) pendingEquipList.innerHTML = "";
                return;
            }

            pendingEquipFabBtn.classList.remove("equip-fab--hidden", "equip-fab--ok");
            const hasExpired = grouped.some(x => x.color === "red");
            pendingEquipFabBtn.classList.toggle("equip-fab--bad", hasExpired);
            pendingEquipFabBtn.classList.toggle("equip-fab--pulse", hasExpired);
            if (!hasExpired) pendingEquipFabBtn.classList.add("equip-fab--ok");

            if (!(pendingEquipList instanceof HTMLElement)) return;
            pendingEquipList.innerHTML = "";
            for (const row of grouped) {
                const card = document.createElement("div");
                card.className = `equip-pending-row${row.color === "red" ? " is-red" : row.color === "yellow" ? " is-yellow" : ""}`;

                const title = document.createElement("div");
                title.className = "equip-pending-row__title";
                title.textContent = `${row.athleteName} · Zolaq ${row.laneNumber}`;

                const meta = document.createElement("div");
                meta.className = "equip-pending-row__meta";
                meta.textContent = `Verən: ${row.issuedByStaffName}`;

                const status = document.createElement("div");
                status.className = `equip-pending-row__status${row.color === "red" ? " is-red" : row.color === "yellow" ? " is-yellow" : ""}`;
                status.textContent = row.timeStatusLabel || (row.color === "red" ? "Vaxt bitib" : "Gözləyir");

                const itemsWrap = document.createElement("div");
                itemsWrap.className = "equip-pending-items";
                for (const eq of (row.equipmentItems ?? [])) {
                    const issued = Math.max(1, Number(eq.quantity) || 1);
                    const itemRow = document.createElement("div");
                    itemRow.className = "equip-pending-item";

                    const info = document.createElement("div");
                    const name = document.createElement("div");
                    name.className = "equip-pending-item__name";
                    name.textContent = eq.equipmentName ?? "Avadanlıq";
                    const issuedMeta = document.createElement("div");
                    issuedMeta.className = "equip-pending-item__issued";
                    issuedMeta.textContent = `Verilib: ${issued}`;
                    info.appendChild(name);
                    info.appendChild(issuedMeta);

                    itemRow.appendChild(info);
                    itemRow.appendChild(createPendingXarabInput(eq.equipmentItemId, issued));
                    itemsWrap.appendChild(itemRow);
                }

                const btn = document.createElement("button");
                btn.type = "button";
                btn.className = "lane-equip-btn lane-equip-btn--return";
                btn.textContent = "Təhvil al";
                btn.addEventListener("click", async () => {
                    btn.disabled = true;
                    try {
                        await returnRentalForSession(row.sessionId, collectDamagedFromCard(card, row.sessionId));
                    } finally {
                        btn.disabled = false;
                    }
                });

                card.appendChild(title);
                card.appendChild(meta);
                card.appendChild(status);
                card.appendChild(itemsWrap);
                card.appendChild(btn);
                pendingEquipList.appendChild(card);
            }
        }

        async function loadPendingEquipmentReturns() {
            if (pendingEquipLoadInFlight) return;
            pendingEquipLoadInFlight = true;
            try {
                const res = await fetch("/sessions/equipment/pending?_=" + Date.now(), {
                    credentials: "same-origin",
                    cache: "no-store"
                });
                if (redirectIfPlansetUnauthorized(res)) return;
                if (!res.ok) {
                    if (pendingEquipFabBadge instanceof HTMLElement) pendingEquipFabBadge.textContent = "—";
                    return;
                }
                const data = await res.json().catch(() => ({}));
                renderPendingEquipmentReturns(data?.pending ?? []);
            } catch (e) {
                console.error("loadPendingEquipmentReturns", e);
            } finally {
                pendingEquipLoadInFlight = false;
            }
        }

        function openPendingEquipPanel() {
            if (!(pendingEquipPanel instanceof HTMLElement)) return;
            pendingEquipPanel.classList.add("is-open");
            pendingEquipPanel.setAttribute("aria-hidden", "false");
        }

        function closePendingEquipPanel() {
            if (!(pendingEquipPanel instanceof HTMLElement)) return;
            pendingEquipPanel.classList.remove("is-open");
            pendingEquipPanel.setAttribute("aria-hidden", "true");
        }

        function togglePendingEquipPanel() {
            if (!(pendingEquipPanel instanceof HTMLElement)) return;
            if (pendingEquipPanel.classList.contains("is-open")) closePendingEquipPanel();
            else openPendingEquipPanel();
        }

        function parseApiDate(value) {
            if (!value) return new Date(0);
            const needsUtcSuffix = typeof value === "string" && !/[zZ]|[+-]\d{2}:\d{2}$/.test(value);
            return new Date(needsUtcSuffix ? `${value}Z` : value);
        }

        function hasValidTimeWindow(startMs, endMs) {
            return Number.isFinite(startMs) && Number.isFinite(endMs) && endMs > startMs;
        }

        function isVipModeRing(ringEl) {
            return ringEl instanceof HTMLElement && ringEl.dataset.vipMode === "1";
        }

        function formatSeconds(milliseconds) {
            const totalSeconds = Math.floor(milliseconds / 1000);
            const hours = Math.floor(totalSeconds / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;
            if (hours > 0) {
                return `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
            }
            return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
        }

        function applyRingRemaining(circle, fractionRemaining) {
            const f = Math.max(0, Math.min(1, fractionRemaining));
            const r = circle instanceof SVGCircleElement ? circle.r.baseVal.value : 42;
            const len = 2 * Math.PI * r;
            circle.style.strokeDasharray = String(len);
            circle.style.strokeDashoffset = String(len * (1 - f));
        }

        function syncCountdownTimerFormatFlags(ringEl, timerEl) {
            if (!(ringEl instanceof HTMLElement) || !(timerEl instanceof HTMLElement)) return;
            const text = String(timerEl.textContent || "").trim();
            const colons = (text.match(/:/g) || []).length;
            const isWide = colons >= 2 || text.length >= 8;
            ringEl.setAttribute("data-time-wide", isWide ? "1" : "0");
        }

        function updateCountdownRings() {
            document.querySelectorAll("[data-countdown-ring]").forEach(el => {
                if (!(el instanceof HTMLElement)) return;

                const start = el.dataset.start ?? "";
                const end = el.dataset.end ?? "";
                const status = el.dataset.status ?? "";
                const pendingRental = el.dataset.pendingRentalEquipment === "1";
                const timerEl = el.querySelector('[data-role="timer"]');
                const captionEl = el.querySelector('[data-role="caption"]');
                const progressEl = el.querySelector(".countdown-ring__progress");
                if (!timerEl || !(progressEl instanceof SVGGraphicsElement)) return;

                try {
                    const card = el.closest(".lane-card");
                    const bottomHint = card instanceof HTMLElement ? card.querySelector('[data-role="lane-bottom-hint"]') : null;
                    const setBottomHint = (text, kind) => {
                        if (!(bottomHint instanceof HTMLElement)) return;
                        bottomHint.textContent = text || "";
                        bottomHint.classList.toggle("is-show", Boolean(text));
                        bottomHint.classList.toggle("is-warn", kind === "warn");
                        bottomHint.classList.toggle("is-critical", kind === "critical");
                    };
                    const setEquipmentReturnHint = () => {
                        if (pendingRental) {
                            setBottomHint("Avadanlıq təhvil alınmalıdır", "critical");
                            return true;
                        }
                        return false;
                    };

                    el.classList.remove("is-live", "is-pending", "is-warn", "is-critical", "is-done", "is-idle", "is-open-ended");

                    const vipMode = isVipModeRing(el);
                    if (vipMode && start) {
                        const vipStartMs = parseApiDate(start).getTime();
                        const vipNowMs = Date.now();

                        if (status === "Completed") {
                            el.classList.add("is-done");
                            timerEl.textContent = "Bitib";
                            if (captionEl) captionEl.textContent = "Sessiya";
                            if (!setEquipmentReturnHint()) setBottomHint("", "");
                            applyRingRemaining(progressEl, 0);
                            return;
                        }

                        if (Number.isNaN(vipStartMs)) {
                            el.classList.add("is-idle");
                            timerEl.textContent = "—";
                            if (captionEl) captionEl.textContent = "Boş";
                            setBottomHint("", "");
                            applyRingRemaining(progressEl, 0);
                            return;
                        }

                        if (vipNowMs < vipStartMs) {
                            el.classList.add("is-pending", "is-open-ended");
                            timerEl.textContent = new Date(vipStartMs).toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                            if (captionEl) captionEl.textContent = "Başlayır";
                            setBottomHint("", "");
                            applyRingRemaining(progressEl, 1);
                            return;
                        }

                        el.classList.add("is-live", "is-open-ended");
                        const elapsedMs = Math.max(0, vipNowMs - vipStartMs);
                        timerEl.textContent = formatSeconds(elapsedMs);
                        if (captionEl) captionEl.textContent = "Keçən vaxt";
                        setBottomHint("", "");
                        applyRingRemaining(progressEl, 1);
                        return;
                    }

                    const startMs = parseApiDate(start).getTime();
                    const endMs = parseApiDate(end).getTime();
                    const nowMs = Date.now();
                    const timedSession = hasValidTimeWindow(startMs, endMs);

                    if (!start || !end || !timedSession) {
                        if (status === "Completed") {
                            el.classList.add("is-done");
                            timerEl.textContent = "Bitib";
                            if (captionEl) captionEl.textContent = "Sessiya";
                            if (!setEquipmentReturnHint()) {
                                setBottomHint("", "");
                            }
                            applyRingRemaining(progressEl, 0);
                            return;
                        }

                        if (status === "Scheduled") {
                            el.classList.add("is-pending");
                            const untilStartMs = Number.isFinite(startMs) ? Math.max(0, startMs - nowMs) : 0;
                            timerEl.textContent = untilStartMs > 0 ? formatSeconds(untilStartMs) : "—";
                            if (captionEl) captionEl.textContent = untilStartMs > 0 ? "Başlayır" : "Planlı";
                            setBottomHint("", "");
                            applyRingRemaining(progressEl, 1);
                            return;
                        }

                        if (status === "Active") {
                            el.classList.add("is-live");
                            const elapsedMs = Number.isFinite(startMs) ? Math.max(0, nowMs - startMs) : 0;
                            timerEl.textContent = formatSeconds(elapsedMs);
                            if (captionEl) captionEl.textContent = "Keçən vaxt";
                            setBottomHint("", "");
                            applyRingRemaining(progressEl, 1);
                            return;
                        }

                        el.classList.add("is-idle");
                        timerEl.textContent = "—";
                        if (captionEl) captionEl.textContent = "Boş";
                        setBottomHint("", "");
                        applyRingRemaining(progressEl, 0);
                        return;
                    }

                    if (status === "Completed") {
                        el.classList.add("is-done");
                        timerEl.textContent = "Bitib";
                        if (captionEl) captionEl.textContent = "Sessiya";
                        if (!setEquipmentReturnHint()) {
                            setBottomHint("", "");
                        }
                        applyRingRemaining(progressEl, 0);
                        return;
                    }

                    if (nowMs < startMs) {
                        el.classList.add("is-pending");
                        const untilMs = startMs - nowMs;
                        const untilSec = Math.floor(untilMs / 1000);
                        const startLocal = new Date(startMs);

                        if (untilSec > 24 * 3600) {
                            timerEl.textContent = startLocal.toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                            if (captionEl) captionEl.textContent = "Planlı";
                            setBottomHint("", "");
                            applyRingRemaining(progressEl, 1);
                            return;
                        }

                        if (untilSec <= 120) el.classList.add("is-critical");
                        else if (untilSec <= 300) el.classList.add("is-warn");

                        timerEl.textContent = startLocal.toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                        if (captionEl) captionEl.textContent = "Başlayır";
                        if (untilSec <= 300) {
                            const minLeft = Math.max(0, Math.ceil(untilSec / 60));
                            setBottomHint(`${minLeft} dəqiqə qaldı`, untilSec <= 120 ? "critical" : "warn");
                        } else {
                            setBottomHint("", "");
                        }
                        applyRingRemaining(progressEl, 1);
                        return;
                    }

                    if (nowMs >= endMs) {
                        el.classList.add("is-done");
                        timerEl.textContent = "00:00";
                        if (captionEl) captionEl.textContent = "Vaxt bitib";
                        if (!setEquipmentReturnHint()) {
                            setBottomHint("", "");
                        }
                        applyRingRemaining(progressEl, 0);
                        return;
                    }

                    const trainingEndMs = Math.max(startMs, endMs - SESSION_BUFFER_MS);
                    const trainingRemainingMs = trainingEndMs - nowMs;
                    const trainingRemainingSec = Math.floor(trainingRemainingMs / 1000);

                    if (trainingRemainingMs <= 0) {
                        el.classList.add("is-idle");
                        timerEl.textContent = "00:00";
                        if (captionEl) captionEl.textContent = "Təmizlik";
                        if (!setEquipmentReturnHint()) {
                            setBottomHint("", "");
                        }
                        applyRingRemaining(progressEl, 0);
                        return;
                    }

                    const frac = (trainingEndMs - startMs) > 0 ? trainingRemainingMs / (trainingEndMs - startMs) : 0;
                    el.classList.add("is-live");
                    if (trainingRemainingSec <= COUNTDOWN_CRIT_SEC) el.classList.add("is-critical");
                    else if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) el.classList.add("is-warn");

                    timerEl.textContent = formatSeconds(trainingRemainingMs);
                    if (captionEl) captionEl.textContent = "Qalan vaxt";

                    if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) {
                        const minLeft = Math.max(0, Math.ceil(trainingRemainingSec / 60));
                        setBottomHint(`${minLeft} dəqiqə qaldı`, trainingRemainingSec <= COUNTDOWN_CRIT_SEC ? "critical" : "warn");
                    } else {
                        setBottomHint("", "");
                    }

                    applyRingRemaining(progressEl, frac);
                } finally {
                    syncCountdownTimerFormatFlags(el, timerEl);
                }
            });
        }

        async function loadLaneGrid(force) {
            if (gridLoadInFlight) {
                gridLoadQueued = true;
                return;
            }
            gridLoadInFlight = true;
            if (refreshBtn instanceof HTMLButtonElement) {
                refreshBtn.disabled = true;
                refreshBtn.textContent = "Yenilənir…";
            }
            try {
                const response = await fetch("/dashboard/lanes/partial/grid-readonly?_=" + Date.now(), {
                    credentials: "same-origin",
                    cache: "no-store"
                });
                if (redirectIfPlansetUnauthorized(response)) return;
                if (!response.ok) return;
                const html = await response.text();
                if (!force && html === lastLaneGridHtml) {
                    updateCountdownRings();
                    return;
                }
                lastLaneGridHtml = html;
                if (laneGrid) {
                    laneGrid.innerHTML = html;
                }
                updateCountdownRings();
                void loadPendingEquipmentReturns();
            } catch (e) {
                console.error("loadLaneGrid", e);
            } finally {
                if (refreshBtn instanceof HTMLButtonElement) {
                    refreshBtn.disabled = false;
                    refreshBtn.textContent = "Yenilə";
                }
                gridLoadInFlight = false;
                if (gridLoadQueued) {
                    gridLoadQueued = false;
                    void loadLaneGrid(true);
                }
            }
        }

        function startCountdownTicker() {
            if (countdownTimerId) clearInterval(countdownTimerId);
            const tick = () => {
                if (wallClock) {
                    wallClock.textContent = new Date().toLocaleTimeString("az-AZ", {
                        hour: "2-digit",
                        minute: "2-digit",
                        second: "2-digit"
                    });
                }
                updateCountdownRings();
            };
            tick();
            countdownTimerId = setInterval(tick, 1000);
        }

        async function startSignalR() {
            if (typeof signalR === "undefined" || !signalR?.HubConnectionBuilder) {
                setTimeout(startSignalR, 5000);
                return;
            }

            try {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/lane")
                    .withAutomaticReconnect()
                    .build();

                connection.onreconnected(() => void loadLaneGrid(true));
                connection.on("lane-updated", () => void loadLaneGrid(false));
                connection.on("score-updated", () => void loadLaneGrid(false));

                await connection.start();
            } catch {
                setTimeout(startSignalR, 5000);
            }
        }

        refreshBtn?.addEventListener("click", () => void loadLaneGrid(true));
        pendingEquipFabBtn?.addEventListener("click", () => togglePendingEquipPanel());
        pendingEquipPanelCloseBtn?.addEventListener("click", () => closePendingEquipPanel());

        function showMonitorToast(message, kind = "ok") {
            if (!(monitorToast instanceof HTMLElement)) return;
            monitorToast.textContent = message;
            monitorToast.className = `monitor-toast ${kind} show`;
            if (monitorToastTimer) clearTimeout(monitorToastTimer);
            monitorToastTimer = setTimeout(() => {
                monitorToast.className = "monitor-toast";
            }, 2200);
        }

        async function readErrorMessage(response) {
            const raw = await response.text();
            if (!raw) return "Naməlum xəta";
            try {
                const parsed = JSON.parse(raw);
                return parsed?.error ?? parsed?.title ?? raw;
            } catch {
                return raw;
            }
        }

        async function loadEquipmentCatalog() {
            try {
                const res = await fetch("/equipment/active", { credentials: "same-origin", cache: "no-store" });
                if (!res.ok) return;
                const list = await res.json().catch(() => []);
                equipmentCatalogCache = Array.isArray(list) ? list : [];
            } catch { /* ignore */ }
        }

        function parseMonitorQtyValue(raw, maxStock) {
            const text = String(raw ?? "").trim();
            if (!text) return null;
            const n = parseInt(text, 10);
            if (!Number.isFinite(n) || n < 1) return null;
            if (maxStock > 0) return Math.min(n, maxStock);
            return n;
        }

        function formatStockLabel(item) {
            const stock = Number(item.rentalQuantity ?? item.quantity ?? 0);
            if (stock <= 0) return " · stok bitib";
            return ` · zal stok: ${stock}`;
        }

        function renderMonitorEquipList() {
            if (!(monitorEquipList instanceof HTMLElement)) return;
            monitorEquipList.innerHTML = "";
            const rentals = equipmentCatalogCache.filter(x => Number(x?.rentalQuantity ?? 0) > 0);
            if (!rentals.length) {
                monitorEquipList.innerHTML = '<div class="lane-monitor-loading">Aktiv icarə avadanlığı tapılmadı.</div>';
                return;
            }
            for (const item of rentals) {
                const stock = Number(item.rentalQuantity ?? 0);
                const outOfStock = stock <= 0;
                const draft = monitorEquipDraft.find(x => String(x.equipmentItemId) === String(item.id));
                const checked = Boolean(draft);
                const qty = Math.max(1, Number(draft?.quantity) || 1);

                const row = document.createElement("div");
                row.className = "monitor-equip-row";

                const cb = document.createElement("input");
                cb.type = "checkbox";
                cb.checked = checked;
                cb.disabled = outOfStock;

                const body = document.createElement("div");
                const title = document.createElement("div");
                title.className = "monitor-equip-row__title";
                const category = item.category ? ` (${item.category})` : "";
                title.textContent = `${item.name}${category}${formatStockLabel(item)}`;
                body.appendChild(title);

                const qtyInput = document.createElement("input");
                qtyInput.type = "number";
                qtyInput.min = "1";
                qtyInput.max = String(Math.max(1, stock));
                qtyInput.step = "1";
                qtyInput.inputMode = "numeric";
                qtyInput.placeholder = "1";
                qtyInput.value = checked ? String(qty) : "";
                qtyInput.disabled = !checked || outOfStock;

                const pushDraft = () => {
                    if (!cb.checked) return;
                    const q = parseMonitorQtyValue(qtyInput.value, stock) ?? 1;
                    qtyInput.value = String(q);
                    monitorEquipDraft = monitorEquipDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                    monitorEquipDraft.push({ equipmentItemId: item.id, quantity: q });
                };

                cb.addEventListener("change", () => {
                    qtyInput.disabled = !cb.checked || outOfStock;
                    if (!cb.checked) {
                        monitorEquipDraft = monitorEquipDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                        qtyInput.value = "";
                    } else {
                        const q = parseMonitorQtyValue(qtyInput.value, stock) ?? 1;
                        qtyInput.value = String(q);
                        pushDraft();
                    }
                });
                qtyInput.addEventListener("input", () => {
                    if (!cb.checked) return;
                    const text = String(qtyInput.value ?? "").trim();
                    if (!text) {
                        monitorEquipDraft = monitorEquipDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                        return;
                    }
                    const q = parseMonitorQtyValue(qtyInput.value, stock);
                    if (q === null) return;
                    if (String(q) !== qtyInput.value.trim()) qtyInput.value = String(q);
                    pushDraft();
                });
                qtyInput.addEventListener("blur", () => {
                    if (!cb.checked) return;
                    const q = parseMonitorQtyValue(qtyInput.value, stock);
                    if (q === null) {
                        cb.checked = false;
                        qtyInput.disabled = true;
                        qtyInput.value = "";
                        monitorEquipDraft = monitorEquipDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                        return;
                    }
                    qtyInput.value = String(q);
                    pushDraft();
                });

                row.appendChild(cb);
                row.appendChild(body);
                row.appendChild(qtyInput);
                monitorEquipList.appendChild(row);
            }
        }

        function openMonitorEquipModal(sessionId, laneNumber) {
            monitorEquipSessionId = sessionId;
            monitorEquipLaneNumber = laneNumber;
            monitorEquipDraft = [];
            if (monitorEquipModalSub instanceof HTMLElement) {
                monitorEquipModalSub.textContent = laneNumber ? `Zolaq ${laneNumber}` : "";
            }
            renderMonitorEquipList();
            if (monitorEquipModal instanceof HTMLElement) {
                monitorEquipModal.style.display = "block";
                monitorEquipModal.setAttribute("aria-hidden", "false");
            }
        }

        function closeMonitorEquipModal() {
            monitorEquipSessionId = null;
            monitorEquipLaneNumber = null;
            monitorEquipDraft = [];
            if (monitorEquipModal instanceof HTMLElement) {
                monitorEquipModal.style.display = "none";
                monitorEquipModal.setAttribute("aria-hidden", "true");
            }
        }

        async function issueRentalFromMonitor() {
            if (equipActionBusy || !monitorEquipSessionId) return;
            if (!monitorEquipDraft.length) {
                showMonitorToast("Avadanlıq seçilməyib", "bad");
                return;
            }
            equipActionBusy = true;
            if (monitorEquipSaveBtn instanceof HTMLButtonElement) monitorEquipSaveBtn.disabled = true;
            try {
                const response = await fetch(`/sessions/${encodeURIComponent(monitorEquipSessionId)}/equipment/issue-rental`, {
                    method: "POST",
                    credentials: "same-origin",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(monitorEquipDraft.map(x => ({
                        equipmentItemId: x.equipmentItemId,
                        quantity: x.quantity,
                        issueType: 1
                    })))
                });
                if (!response.ok) {
                    if (redirectIfPlansetUnauthorized(response)) return;
                    showMonitorToast(await readErrorMessage(response) || "Verilmədi", "bad");
                    return;
                }
                showMonitorToast("İcarə avadanlıq verildi", "ok");
                closeMonitorEquipModal();
                await loadLaneGrid(true);
            } finally {
                equipActionBusy = false;
                if (monitorEquipSaveBtn instanceof HTMLButtonElement) monitorEquipSaveBtn.disabled = false;
            }
        }

        async function returnRentalForSession(sessionId, damagedLines) {
            if (equipActionBusy || !sessionId) return;
            equipActionBusy = true;
            try {
                const response = await fetch("/sessions/equipment/return-bulk", {
                    method: "POST",
                    credentials: "same-origin",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        sessionIds: [sessionId],
                        damaged: Array.isArray(damagedLines) ? damagedLines : []
                    })
                });
                if (!response.ok) {
                    if (redirectIfPlansetUnauthorized(response)) return;
                    showMonitorToast(await readErrorMessage(response) || "Təhvil alınmadı", "bad");
                    return;
                }
                showMonitorToast("Təhvil alındı", "ok");
                closeMonitorReturnModal();
                await loadLaneGrid(true);
                await loadPendingEquipmentReturns();
            } finally {
                equipActionBusy = false;
            }
        }

        function renderMonitorReturnList() {
            if (!(monitorReturnList instanceof HTMLElement)) return;
            monitorReturnList.innerHTML = "";
            if (!monitorReturnItems.length) {
                monitorReturnList.innerHTML = '<div class="lane-monitor-loading">Gözləyən icarə tapılmadı.</div>';
                return;
            }
            for (const item of monitorReturnItems) {
                const issued = Math.max(1, Number(item.quantity) || 1);
                const row = document.createElement("div");
                row.className = "monitor-equip-row";

                const body = document.createElement("div");
                const title = document.createElement("div");
                title.className = "monitor-equip-row__title";
                title.textContent = `${item.equipmentName} · verilib: ${issued}`;
                body.appendChild(title);

                const qtyWrap = document.createElement("div");
                qtyWrap.style.display = "flex";
                qtyWrap.style.flexDirection = "column";
                qtyWrap.style.alignItems = "center";
                qtyWrap.style.gap = "4px";
                const qtyLabel = document.createElement("span");
                qtyLabel.style.fontSize = "11px";
                qtyLabel.style.fontWeight = "700";
                qtyLabel.style.color = "#667395";
                qtyLabel.textContent = "Xarab";
                const qtyInput = document.createElement("input");
                qtyInput.type = "number";
                qtyInput.min = "0";
                qtyInput.max = String(issued);
                qtyInput.step = "1";
                qtyInput.inputMode = "numeric";
                qtyInput.placeholder = "0";
                qtyInput.value = "";
                qtyInput.dataset.equipmentItemId = item.equipmentItemId;
                qtyInput.addEventListener("input", () => {
                    const text = String(qtyInput.value ?? "").trim();
                    if (!text) return;
                    const n = parseInt(text, 10);
                    if (!Number.isFinite(n) || n < 0) {
                        qtyInput.value = "";
                        return;
                    }
                    if (n > issued) qtyInput.value = String(issued);
                });
                qtyWrap.appendChild(qtyLabel);
                qtyWrap.appendChild(qtyInput);

                row.appendChild(body);
                row.appendChild(qtyWrap);
                monitorReturnList.appendChild(row);
            }
        }

        async function openMonitorReturnModal(sessionId, laneNumber) {
            closePendingEquipPanel();
            monitorReturnSessionId = sessionId;
            monitorReturnLaneNumber = laneNumber;
            monitorReturnItems = [];
            if (monitorReturnModalSub instanceof HTMLElement) {
                monitorReturnModalSub.textContent = laneNumber ? `Zolaq ${laneNumber}` : "";
            }
            try {
                const res = await fetch(`/sessions/${encodeURIComponent(sessionId)}/equipment/rentals`, {
                    credentials: "same-origin",
                    cache: "no-store"
                });
                if (!res.ok) {
                    showMonitorToast("İcarə siyahısı yüklənmədi", "bad");
                    return;
                }
                const data = await res.json().catch(() => ({}));
                monitorReturnItems = (Array.isArray(data?.items) ? data.items : [])
                    .filter(x => !x.returnedAtUtc)
                    .map(x => ({
                        equipmentItemId: x.equipmentItemId,
                        equipmentName: x.equipmentName ?? "Avadanlıq",
                        quantity: Math.max(1, Number(x.quantity) || 1)
                    }));
            } catch {
                showMonitorToast("İcarə siyahısı yüklənmədi", "bad");
                return;
            }
            renderMonitorReturnList();
            if (monitorReturnModal instanceof HTMLElement) {
                monitorReturnModal.style.display = "block";
                monitorReturnModal.setAttribute("aria-hidden", "false");
            }
        }

        function closeMonitorReturnModal() {
            monitorReturnSessionId = null;
            monitorReturnLaneNumber = null;
            monitorReturnItems = [];
            if (monitorReturnModal instanceof HTMLElement) {
                monitorReturnModal.style.display = "none";
                monitorReturnModal.setAttribute("aria-hidden", "true");
            }
        }

        async function confirmMonitorReturn() {
            if (!monitorReturnSessionId) return;
            const damaged = [];
            if (monitorReturnList instanceof HTMLElement) {
                for (const input of monitorReturnList.querySelectorAll("input[data-equipment-item-id]")) {
                    if (!(input instanceof HTMLInputElement)) continue;
                    const qty = parseInt(String(input.value ?? "").trim(), 10);
                    if (!Number.isFinite(qty) || qty <= 0) continue;
                    damaged.push({
                        sessionId: monitorReturnSessionId,
                        equipmentItemId: input.dataset.equipmentItemId,
                        quantity: qty
                    });
                }
            }
            await returnRentalForSession(monitorReturnSessionId, damaged);
        }

        laneGrid?.addEventListener("click", async e => {
            const btn = e.target instanceof HTMLElement ? e.target.closest("[data-action]") : null;
            if (!(btn instanceof HTMLButtonElement)) return;
            const wrap = btn.closest(".lane-equip-actions");
            if (!(wrap instanceof HTMLElement)) return;
            const sessionId = wrap.dataset.sessionId ?? "";
            const laneNumber = wrap.dataset.laneNumber ?? "";
            if (!sessionId) return;

            const action = btn.dataset.action ?? "";
            if (action === "issue-equipment") {
                await loadEquipmentCatalog();
                openMonitorEquipModal(sessionId, laneNumber);
                return;
            }
            if (action === "return-equipment") {
                await openMonitorReturnModal(sessionId, laneNumber);
            }
        });

        monitorEquipCloseBtn?.addEventListener("click", closeMonitorEquipModal);
        monitorEquipClearBtn?.addEventListener("click", () => {
            monitorEquipDraft = [];
            renderMonitorEquipList();
        });
        monitorEquipSaveBtn?.addEventListener("click", () => { void issueRentalFromMonitor(); });
        monitorEquipModal?.addEventListener("click", e => {
            if (e.target === monitorEquipModal) closeMonitorEquipModal();
        });
        monitorReturnCloseBtn?.addEventListener("click", closeMonitorReturnModal);
        monitorReturnSaveBtn?.addEventListener("click", () => { void confirmMonitorReturn(); });
        monitorReturnModal?.addEventListener("click", e => {
            if (e.target === monitorReturnModal) closeMonitorReturnModal();
        });

        void loadLaneGrid(true);
        void loadPendingEquipmentReturns();
        startCountdownTicker();
        setTimeout(startSignalR, 0);
        setInterval(() => void loadLaneGrid(false), 15000);
        setInterval(() => void loadPendingEquipmentReturns(), 15000);
    </script>
</body>
</html>
