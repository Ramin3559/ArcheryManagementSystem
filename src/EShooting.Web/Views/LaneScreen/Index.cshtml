@model int
@{
    Layout = null;
    var laneNumber = Model;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <title>EShooting — Zolaq @laneNumber (TV)</title>
    <style>
        :root {
            --brand: #8B2318;
            --brand-muted: #a04438;
            --bg: #ffffff;
            --text: #8B2318;
            --text-muted: #a04438;
            --border: #e8d4d0;
        }

        * { box-sizing: border-box; -webkit-text-size-adjust: 100%; }

        html, body { height: 100%; }

        body.lane-tv-body {
            margin: 0;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            color: var(--text);
            background: var(--bg);
            font-family: "Segoe UI", Arial, sans-serif;
            display: flex;
            flex-direction: column;
        }

        .lane-tv-connection {
            position: fixed;
            right: clamp(8px, 1.2vw, 14px);
            bottom: clamp(8px, 1.2vw, 14px);
            z-index: 12;
            border-radius: 999px;
            padding: 4px 10px;
            font-size: clamp(9px, 1vw, 12px);
            font-weight: 600;
            background: #f5ebe9;
            color: var(--brand-muted);
        }

        body.lane-tv-body.lane-tv--fullscreen-logo .lane-tv-connection {
            display: none;
        }

        .lane-tv-connection.Active {
            background: rgba(139, 35, 24, 0.12);
            color: var(--brand);
        }

        .lane-tv-wrap {
            flex: 1 1 auto;
            display: flex;
            align-items: stretch;
            justify-content: center;
            padding: clamp(6px, 1.5vw, 14px);
            min-height: 0;
            overflow: hidden;
            position: relative;
            background: var(--bg);
        }

        /* Boş/planlı/bitmiş (15s sonra) tam ekran loqo */
        body.lane-tv-body.lane-tv--fullscreen-logo .lane-tv-wrap {
            padding: 0;
        }

        .lane-tv-logo {
            position: fixed;
            inset: 0;
            width: 100vw;
            height: 100vh;
            object-fit: cover;
            object-position: center;
            background: #fff;
            z-index: 20;
            display: block;
        }

        .lane-tv-logo.hidden {
            display: none !important;
        }

        .lane-tv-inner.lane-tv-inner--hidden {
            display: none !important;
        }

        .lane-tv-inner {
            width: 100%;
            height: 100%;
            max-width: min(1600px, 98vw);
            display: flex;
            position: relative;
            z-index: 1;
        }

        .lane-tv-inner > * {
            flex: 1 1 auto;
            width: 100%;
            min-height: 0;
        }

        .lane-tv-body .lane-actions,
        .lane-tv-body .pick-session,
        .lane-tv-body .stop-session-btn,
        .lane-tv-body .lane-type {
            display: none !important;
        }

        .lane-tv-body .lane-card.is-cleanup .lane-tv-athlete {
            display: none !important;
        }

        .lane-tv-body .lane-tv-status-pill {
            display: none !important;
        }

        .lane-card.lane-card--tv {
            position: relative;
            background: var(--bg);
            border: none;
            border-radius: 0;
            padding: clamp(8px, 2vw, 20px) clamp(10px, 2.5vw, 28px);
            width: 100%;
            height: 100%;
            overflow: hidden;
            color: var(--text);
            box-sizing: border-box;
        }

        /* Mobil monitor: loqo | zolaq | saat — alt sətir: idmançı | vaxtlar | dairə */
        .lane-tv-grid {
            display: grid;
            width: 100%;
            height: 100%;
            min-height: 0;
            grid-template-columns: minmax(72px, 0.9fr) minmax(0, 1.35fr) minmax(72px, 0.9fr);
            column-gap: clamp(8px, 2vw, 28px);
            row-gap: clamp(4px, 1.2vh, 14px);
            align-content: start;
        }

        .lane-card--tv-active .lane-tv-grid {
            grid-template-rows: auto auto minmax(0, 1fr);
            grid-template-areas:
                "logo     zolaq    clock"
                "athlete  schedule ring"
                ".        hint     ring";
        }

        .lane-card--tv:not(.lane-card--tv-active) .lane-tv-grid {
            grid-template-rows: auto minmax(0, 1fr);
            grid-template-areas:
                "logo     zolaq    clock"
                ".        .        ring";
        }

        .lane-tv-panel {
            min-width: 0;
            min-height: 0;
        }

        .lane-tv-panel--logo {
            grid-area: logo;
            align-self: start;
            justify-self: start;
        }

        .lane-tv-panel--zolaq {
            grid-area: zolaq;
            justify-self: center;
            align-self: start;
            text-align: center;
            width: 100%;
        }

        .lane-tv-panel--schedule {
            grid-area: schedule;
            justify-self: center;
            align-self: center;
            text-align: center;
            width: 100%;
        }

        .lane-tv-panel--clock {
            grid-area: clock;
            justify-self: end;
            align-self: start;
        }

        .lane-tv-panel--athlete {
            grid-area: athlete;
            align-self: center;
            justify-self: start;
            max-width: 100%;
        }

        .lane-tv-panel--hint {
            grid-area: hint;
            justify-self: center;
            align-self: end;
            text-align: center;
            padding-bottom: clamp(2px, 0.8vh, 10px);
            width: 100%;
        }

        .lane-tv-panel--ring {
            grid-area: ring;
            justify-self: end;
            align-self: end;
            display: flex;
            align-items: flex-end;
            justify-content: flex-end;
            overflow: visible;
        }

        .lane-tv-brand-logo {
            display: block;
            max-height: clamp(56px, 12vh, 120px);
            max-width: min(36vw, 180px);
            min-height: 48px;
            width: auto;
            height: auto;
            object-fit: contain;
            object-position: left top;
        }

        .lane-tv-lane-num {
            margin: 0;
            font-size: clamp(1.75rem, 7vw, 3.5rem);
            font-weight: 800;
            color: var(--brand);
            letter-spacing: 0.02em;
            line-height: 1.05;
            white-space: nowrap;
            text-align: center;
        }

        .lane-tv-wall-clock {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .lane-tv-wall-clock__label {
            display: block;
            font-size: clamp(8px, 1.8vw, 12px);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 2px;
            font-weight: 700;
        }

        .lane-tv-wall-clock__value {
            font-size: clamp(1.1rem, 4.5vw, 2.25rem);
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            color: var(--brand);
            line-height: 1.1;
        }

        .lane-tv-schedule {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: baseline;
            justify-content: center;
            gap: clamp(10px, 3vw, 32px);
            font-size: clamp(0.95rem, 3.8vw, 1.85rem);
            font-weight: 700;
            color: var(--brand);
            font-variant-numeric: tabular-nums;
            line-height: 1.25;
        }

        .lane-tv-schedule__item {
            display: inline-block;
            white-space: nowrap;
        }

        .lane-tv-athlete {
            text-align: left;
            font-size: clamp(0.95rem, 3.8vw, 1.85rem);
            font-weight: 700;
            color: var(--brand);
            line-height: 1.25;
            max-width: 100%;
            word-break: break-word;
        }

        .lane-tv-equip {
            margin-left: 6px;
        }

        .lane-tv-body .lane-bottom-hint {
            font-weight: 800;
            font-size: clamp(1rem, 4.2vw, 2rem);
            color: var(--brand);
            opacity: 0;
            transition: opacity 0.2s ease;
            pointer-events: none;
            line-height: 1.25;
            white-space: nowrap;
        }

        .lane-tv-body .lane-bottom-hint.is-show {
            opacity: 1;
        }

        .lane-tv-body .lane-bottom-hint.is-critical {
            color: #b91c1c;
        }

        .lane-tv-body .countdown-ring-wrap {
            --ring-track: rgba(139, 35, 24, 0.14);
            --ring-accent: #8B2318;
            --ring-glow: rgba(139, 35, 24, 0.2);
            position: relative;
            width: min(58vmin, 52vw, 420px);
            height: min(58vmin, 52vw, 420px);
            margin: 0;
            background: transparent;
            border: 0;
            border-radius: 50%;
            padding: 0;
            box-shadow: none;
            overflow: visible;
            box-sizing: border-box;
        }

        .lane-tv-body .countdown-ring__svg {
            display: block;
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
            filter: drop-shadow(0 0 6px var(--ring-glow));
        }

        .lane-tv-body .countdown-ring__track {
            fill: none;
            stroke: var(--ring-track);
            stroke-width: 5;
        }

        .lane-tv-body .countdown-ring__progress {
            fill: none;
            stroke: var(--ring-accent);
            stroke-width: 7;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.35s ease, stroke 0.3s ease;
        }

        .lane-tv-body .countdown-ring__center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 10%;
            pointer-events: none;
        }

        .lane-tv-body .countdown-ring__timer {
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            line-height: 1.1;
            color: var(--brand);
            white-space: nowrap;
            max-width: 100%;
            font-size: clamp(2rem, 14vmin, 4.5rem);
        }

        .lane-tv-body .countdown-ring__caption {
            margin-top: clamp(4px, 1vh, 8px);
            font-size: clamp(9px, 2.2vw, 14px);
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--brand);
            line-height: 1.2;
        }

        .lane-tv-body .countdown-ring__bartrack {
            display: none;
        }

        .lane-tv-body .countdown-ring-wrap.is-pending {
            --ring-accent: #c45a00;
            --ring-glow: rgba(196, 90, 0, 0.3);
        }

        .lane-tv-body .countdown-ring-wrap.is-live.is-warn:not(.is-critical) {
            --ring-accent: #c45a00;
            --ring-glow: rgba(196, 90, 0, 0.35);
        }

        .lane-tv-body .countdown-ring-wrap.is-live.is-critical {
            --ring-accent: #b91c1c;
            --ring-glow: rgba(185, 28, 28, 0.4);
        }

        .lane-tv-body .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer {
            color: #b91c1c;
        }

        .lane-tv-body .countdown-ring-wrap.is-live.is-critical .countdown-ring__svg {
            animation: lane-tv-ring-pulse 0.95s ease-in-out infinite;
        }

        @@keyframes lane-tv-ring-pulse {
            0%, 100% { filter: drop-shadow(0 0 6px var(--ring-glow)); }
            50% { filter: drop-shadow(0 0 18px rgba(185, 28, 28, 0.55)); }
        }

        .lane-tv-body .countdown-ring-wrap.is-done,
        .lane-tv-body .countdown-ring-wrap.is-idle {
            --ring-accent: rgba(139, 35, 24, 0.35);
            --ring-glow: transparent;
            width: min(52vmin, 48vw, 380px) !important;
            height: min(52vmin, 48vw, 380px) !important;
        }

        .lane-tv-body .countdown-ring-wrap.is-idle .countdown-ring__timer {
            font-size: clamp(1.75rem, 12vmin, 3.5rem) !important;
        }

        .lane-tv-body .countdown-ring-wrap.is-done .countdown-ring__timer {
            font-size: clamp(11px, 2.5vw, 18px) !important;
            white-space: normal;
            text-align: center;
            line-height: 1.25;
            padding: 0 8px;
            max-width: 92%;
            color: var(--brand);
        }

        .lane-tv-body .countdown-ring-wrap.is-done .countdown-ring__caption {
            font-size: clamp(9px, 2vw, 12px);
        }

        /* Kiçik mobil monitorlar (7–10" landscape) */
        @@media (max-width: 720px), (max-height: 520px) {
            .lane-card.lane-card--tv {
                padding: clamp(6px, 1.5vw, 12px) clamp(8px, 2vw, 16px);
            }

            .lane-tv-grid {
                grid-template-columns: minmax(52px, 0.8fr) minmax(0, 1.25fr) minmax(52px, 0.8fr);
                column-gap: clamp(6px, 1.5vw, 14px);
            }

            .lane-tv-brand-logo {
                max-height: clamp(44px, 10vh, 88px);
                min-height: 40px;
            }

            .lane-tv-body .countdown-ring-wrap:not(.is-done):not(.is-idle) {
                width: min(62vmin, 56vw, 340px);
                height: min(62vmin, 56vw, 340px);
            }
        }

        @@media (orientation: portrait) and (max-width: 600px) {
            .lane-card--tv-active .lane-tv-grid {
                grid-template-rows: auto auto auto auto minmax(0, 1fr);
                grid-template-areas:
                    "logo     zolaq    clock"
                    "athlete  athlete  athlete"
                    "schedule schedule schedule"
                    "hint     hint     hint"
                    "ring     ring     ring";
            }

            .lane-tv-panel--ring {
                justify-self: center;
                align-self: end;
            }

            .lane-tv-schedule {
                justify-content: center;
            }
        }
    </style>
</head>
<body class="lane-tv-body">
    <span class="lane-tv-connection" id="connectionBadge">Bağlanır...</span>
    <div class="lane-tv-wrap">
        <img id="laneTvLogo"
             class="lane-tv-logo"
             src="/images/club-logo.jpg"
             alt="Target Archery Club"
             onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/lane-logo.jpg';}else if(this.dataset.fallback==='1'){this.dataset.fallback='2';this.src='/images/placeholder-logo.jpg';}" />
        <div class="lane-tv-inner" id="laneRoot"></div>
    </div>

    <script src="/lib/signalr/signalr.min.js"></script>
    <script>
        const laneNumber = @laneNumber;

        function parseApiDate(value) {
            if (!value) return new Date(0);
            const needsUtcSuffix = typeof value === "string" && !/[zZ]|[+-]\d{2}:\d{2}$/.test(value);
            return new Date(needsUtcSuffix ? `${value}Z` : value);
        }

        function formatLocalTimeFromApi(iso) {
            if (!iso) return "—";
            var d = parseApiDate(iso);
            if (Number.isNaN(d.getTime())) return "—";
            return d.toLocaleTimeString("az-AZ", {
                hour: "2-digit",
                minute: "2-digit",
                second: "2-digit",
                hour12: false
            });
        }

        function updateLaneMetaTimes() {
            var ring = document.querySelector("[data-countdown-ring]");
            var schedule = document.querySelector("[data-role=\"lane-schedule\"]");
            if (!(ring instanceof HTMLElement) || !(schedule instanceof HTMLElement)) return;
            var start = ring.dataset.start || "";
            var end = ring.dataset.end || "";
            if (!start || !end) return;
            var items = schedule.querySelectorAll(".lane-tv-schedule__item");
            if (items.length >= 2) {
                items[0].textContent = "Başlanğıc: " + formatLocalTimeFromApi(start);
                items[1].textContent = "Son: " + formatLocalTimeFromApi(end);
            }
        }

        function formatSeconds(milliseconds) {
            const totalSeconds = Math.floor(milliseconds / 1000);
            const hours = Math.floor(totalSeconds / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;
            if (hours > 0) {
                return `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
            }
            return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
        }

        const COUNTDOWN_WARN_SEC = 300; // 5 dəqiqə
        const COUNTDOWN_CRIT_SEC = 120; // 2 dəqiqə
        const SESSION_BUFFER_MS = 0;
        const LANE_TIME_ENDED_MSG = "Sizin vaxtınız bitmişdir";
        const LANE_LOGO_DELAY_MS = 15000;
        var laneSessionEndedAtMs = 0;

        function clearLaneSessionEnded() {
            laneSessionEndedAtMs = 0;
        }

        function markLaneSessionEnded() {
            if (!laneSessionEndedAtMs) {
                laneSessionEndedAtMs = Date.now();
            }
        }

        function applyLaneEndedDisplay(timerEl, captionEl, statusPill) {
            if (timerEl) timerEl.textContent = LANE_TIME_ENDED_MSG;
            if (captionEl) captionEl.textContent = "";
            if (statusPill instanceof HTMLElement) {
                statusPill.textContent = LANE_TIME_ENDED_MSG;
                statusPill.className = "status-pill lane-tv-status-pill Completed";
            }
        }

        // TV: yalnız öz kartındakı data-atributlardan (bütün /dashboard/lanes yox — server yüklənmir).
        function isActiveSessionFromRing(ringEl) {
            if (!(ringEl instanceof HTMLElement)) return false;
            var status = ringEl.dataset.status || "";
            var start = ringEl.dataset.start || "";
            var end = ringEl.dataset.end || "";
            if (!start || !end) return false;
            if (status === "Completed" || status === "Idle" || status === "Scheduled") return false;
            if (ringEl.classList.contains("is-live")) return true;
            var nowMs = Date.now();
            var startMs = parseApiDate(start).getTime();
            var endMs = parseApiDate(end).getTime();
            if (isNaN(startMs) || isNaN(endMs)) return false;
            return nowMs >= startMs && nowMs < endMs;
        }

        function shouldShowLaneTvLogo(ringEl) {
            if (isActiveSessionFromRing(ringEl)) {
                clearLaneSessionEnded();
                return false;
            }
            if (!(ringEl instanceof HTMLElement)) return true;
            if (ringEl.classList.contains("is-live")) {
                clearLaneSessionEnded();
                return false;
            }
            if (ringEl.classList.contains("is-done")) {
                markLaneSessionEnded();
                return (Date.now() - laneSessionEndedAtMs) >= LANE_LOGO_DELAY_MS;
            }
            clearLaneSessionEnded();
            return true;
        }

        function syncLaneTvLogo() {
            var logo = document.getElementById("laneTvLogo");
            var root = document.getElementById("laneRoot");
            var ring = document.querySelector(".lane-tv-body [data-countdown-ring]");
            var show = shouldShowLaneTvLogo(ring);
            if (logo instanceof HTMLElement) {
                logo.classList.toggle("hidden", !show);
            }
            if (root instanceof HTMLElement) {
                root.classList.toggle("lane-tv-inner--hidden", show);
            }
            document.body.classList.toggle("lane-tv--fullscreen-logo", show);
        }

        function applyRingRemaining(ringEl, fractionRemaining) {
            var f = Math.max(0, Math.min(1, fractionRemaining));
            var circle = ringEl.querySelector(".countdown-ring__progress");
            if (circle instanceof SVGCircleElement) {
                var r = circle.r.baseVal.value;
                var len = 2 * Math.PI * r;
                circle.style.strokeDasharray = String(len);
                circle.style.strokeDashoffset = String(len * (1 - f));
            }
            var bar = ringEl.querySelector("[data-role=\"countdown-bar-fill\"]");
            if (bar instanceof HTMLElement) {
                bar.style.transformOrigin = "left center";
                bar.style.transform = "scaleX(" + f + ")";
            }
        }

        // Dairənin içində vaxt mətni daireye sığsın deyə şrifti dinamik kiçildirik.
        function fitLaneTvCountdownTimer(ringEl) {
            if (!(ringEl instanceof HTMLElement)) return;
            var timer = ringEl.querySelector("[data-role=\"timer\"]");
            if (!(timer instanceof HTMLElement)) return;
            var cap = ringEl.querySelector("[data-role=\"caption\"]");
            var diameter = Math.min(ringEl.clientWidth, ringEl.clientHeight);
            if (diameter < 60) return;
            // Dairənin daxili kvadratı təxminən diametr * 0.72-dir.
            var inner = diameter * 0.72;
            var maxW = Math.max(40, inner);
            var capH = 0;
            if (cap instanceof HTMLElement && cap.textContent && String(cap.textContent).trim()) {
                // alt yazı şriftini daireye nisbətən kiçik tuturuq, taxmini hündürlüyü:
                capH = Math.max(14, Math.round(diameter * 0.06));
            }
            var maxH = inner - capH - 8;
            if (maxH < 24) maxH = 24;
            var isEndedMsg = ringEl.classList.contains("is-done");
            if (isEndedMsg) {
                timer.style.whiteSpace = "normal";
                timer.style.fontSize = "";
                return;
            }
            timer.style.whiteSpace = "nowrap";
            timer.style.fontSize = "";
            var low = 12;
            var high = Math.floor(diameter * 0.42);
            if (high < low) high = low;
            var best = low;
            while (low <= high) {
                var mid = (low + high) >> 1;
                timer.style.fontSize = mid + "px";
                var tw = timer.scrollWidth;
                var th = timer.scrollHeight;
                if (tw <= maxW && th <= maxH) {
                    best = mid;
                    low = mid + 1;
                } else {
                    high = mid - 1;
                }
            }
            timer.style.fontSize = best + "px";
        }

        function updateCountdownRings() {
            document.querySelectorAll("[data-countdown-ring]").forEach(function (el) {
                if (!(el instanceof HTMLElement)) return;
                const start = el.dataset.start || "";
                const end = el.dataset.end || "";
                const status = el.dataset.status || "";
                const timerEl = el.querySelector("[data-role=\"timer\"]");
                const captionEl = el.querySelector("[data-role=\"caption\"]");
                const progressEl = el.querySelector(".countdown-ring__progress");
                if (!timerEl || !(progressEl instanceof SVGGraphicsElement)) return;

                try {
                const card = el.closest(".lane-card");
                const statusPill = card instanceof HTMLElement ? card.querySelector("[data-role=\"tv-status-pill\"]") : null;
                const bottomHint = card instanceof HTMLElement ? card.querySelector("[data-role=\"lane-bottom-hint\"]") : null;
                const setBottomHint = (text, kind) => {
                    if (!(bottomHint instanceof HTMLElement)) return;
                    bottomHint.textContent = text || "";
                    bottomHint.classList.toggle("is-show", Boolean(text));
                    bottomHint.classList.toggle("is-critical", kind === "critical");
                };
                const setCleanupMode = (on) => {
                    if (!(card instanceof HTMLElement)) return;
                    card.classList.toggle("is-cleanup", Boolean(on));
                };

                el.classList.remove("is-live", "is-pending", "is-warn", "is-critical", "is-done", "is-idle");

                if (!start || !end) {
                    el.classList.add("is-idle");
                    timerEl.textContent = "—";
                    if (captionEl) captionEl.textContent = "Boş";
                    setBottomHint("", "");
                    setCleanupMode(false);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                const startMs = parseApiDate(start).getTime();
                const endMs = parseApiDate(end).getTime();
                const nowMs = Date.now();
                const totalMs = endMs - startMs;

                if (status === "Completed") {
                    el.classList.add("is-done");
                    applyLaneEndedDisplay(timerEl, captionEl, statusPill);
                    setBottomHint("", "");
                    setCleanupMode(true);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                if (nowMs < startMs) {
                    el.classList.add("is-pending");
                    const untilMs = startMs - nowMs;
                    const untilSec = Math.floor(untilMs / 1000);
                    const startLocal = new Date(startMs);

                    // Never show absurd long countdowns.
                    if (untilSec > 24 * 3600) {
                        timerEl.textContent = startLocal.toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                        if (captionEl) captionEl.textContent = "Planlı";
                        setBottomHint("", "");
                        applyRingRemaining(el, 1);
                        return;
                    }

                    timerEl.textContent = startLocal.toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                    if (captionEl) captionEl.textContent = "Başlayır";
                    if (untilSec <= COUNTDOWN_WARN_SEC) {
                        const minLeft = Math.max(0, Math.ceil(untilSec / 60));
                        setBottomHint(`${minLeft} dəqiqə qaldı`, untilSec <= COUNTDOWN_CRIT_SEC ? "critical" : "");
                    } else {
                        setBottomHint("", "");
                    }
                    setCleanupMode(false);
                    applyRingRemaining(el, 1);
                    return;
                }

                if (nowMs >= endMs) {
                    el.classList.add("is-done");
                    applyLaneEndedDisplay(timerEl, captionEl, statusPill);
                    setBottomHint("", "");
                    setCleanupMode(true);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                // Active: show training time only (exclude buffer).
                const trainingEndMs = Math.max(startMs, endMs - SESSION_BUFFER_MS);
                const trainingRemainingMs = trainingEndMs - nowMs;
                const trainingRemainingSec = Math.floor(trainingRemainingMs / 1000);

                if (trainingRemainingMs <= 0) {
                    el.classList.add("is-done");
                    applyLaneEndedDisplay(timerEl, captionEl, statusPill);
                    setBottomHint("", "");
                    setCleanupMode(true);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                const frac = (trainingEndMs - startMs) > 0 ? trainingRemainingMs / (trainingEndMs - startMs) : 0;
                el.classList.add("is-live");
                if (trainingRemainingSec <= COUNTDOWN_CRIT_SEC) el.classList.add("is-critical");
                else if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) el.classList.add("is-warn");

                timerEl.textContent = formatSeconds(trainingRemainingMs);
                if (captionEl) captionEl.textContent = "QALAN VAXT";
                if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) {
                    const minLeft = Math.max(0, Math.ceil(trainingRemainingSec / 60));
                    setBottomHint(`${minLeft} dəqiqə qaldı`, trainingRemainingSec <= COUNTDOWN_CRIT_SEC ? "critical" : "");
                } else {
                    setBottomHint("", "");
                }
                setCleanupMode(false);
                applyRingRemaining(el, frac);
                } finally {
                    fitLaneTvCountdownTimer(el);
                }
            });

            var ringEl = document.querySelector("[data-countdown-ring]");
            var compact = ringEl ? ringUsesCompactSize(ringEl) : null;
            if (lastRingCompact !== compact) {
                lastRingCompact = compact;
                scheduleSizeRing();
            }

            updateLaneMetaTimes();
            syncLaneTvLogo();
        }

        function apiFetch(input, init) {
            init = init || {};
            var url = (typeof input === "string")
                ? input + (input.indexOf("?") >= 0 ? "&" : "?") + "_=" + Date.now()
                : input;
            init.credentials = "same-origin";
            init.cache = "no-store";
            return fetch(url, init);
        }

        var lastLaneHtml = "";
        var laneLoadInFlight = false;
        var pendingReload = false;
        var lastRingCompact = null;
        function resetRingCompactSize(ring) {
            if (!(ring instanceof HTMLElement)) return;
            ring.style.width = "";
            ring.style.height = "";
            var timer = ring.querySelector("[data-role=\"timer\"]");
            if (timer instanceof HTMLElement) {
                timer.style.fontSize = "";
            }
        }

        function ringUsesCompactSize(ring) {
            if (!(ring instanceof HTMLElement)) return true;
            var start = ring.getAttribute("data-start") || "";
            var end = ring.getAttribute("data-end") || "";
            if (!start || !end) return true;
            return ring.classList.contains("is-idle") || ring.classList.contains("is-done");
        }

        // Aktiv/planlı sessiyada dairəni mətnə görə böyüdür; boş/bitmişdə kompakt CSS ölçüsünə qayıdır.
        function sizeCountdownRing() {
            var card = document.querySelector(".lane-tv-body .lane-card");
            if (!card) return;
            var ring = card.querySelector(".countdown-ring-wrap");
            if (!ring) return;

            if (ringUsesCompactSize(ring)) {
                resetRingCompactSize(ring);
                fitLaneTvCountdownTimer(ring);
                return;
            }

            ring.style.width = "0px";
            ring.style.height = "0px";

            var cs = window.getComputedStyle(card);
            var padX = (parseFloat(cs.paddingLeft) || 0) + (parseFloat(cs.paddingRight) || 0);
            var padY = (parseFloat(cs.paddingTop) || 0) + (parseFloat(cs.paddingBottom) || 0);
            var availW = card.clientWidth - padX;
            var availH = card.clientHeight - padY;

            var usedH = 0;
            var grid = card.querySelector(".lane-tv-grid");
            if (grid instanceof HTMLElement) {
                var panels = grid.querySelectorAll(".lane-tv-panel:not(.lane-tv-panel--ring)");
                for (var pi = 0; pi < panels.length; pi++) {
                    var p = panels[pi];
                    if (!(p instanceof HTMLElement)) continue;
                    var bottom = p.offsetTop + p.offsetHeight;
                    if (bottom > usedH) usedH = bottom;
                }
            }

            var vmin = Math.min(window.innerWidth || availW, window.innerHeight || availH);
            var maxW = Math.floor(availW * 0.56);
            var maxH = Math.floor((availH - usedH) * 0.9);
            var target = Math.floor(Math.min(vmin * 0.58, maxW, maxH));
            var size = target;
            if (!isFinite(size) || size < 130) size = 130;
            if (size > 480) size = 480;

            ring.style.width = size + "px";
            ring.style.height = size + "px";

            fitLaneTvCountdownTimer(ring);
        }

        var sizeRingPending = false;
        function scheduleSizeRing() {
            if (sizeRingPending) return;
            sizeRingPending = true;
            (window.requestAnimationFrame || function (cb) { return setTimeout(cb, 16); })(function () {
                sizeRingPending = false;
                sizeCountdownRing();
            });
        }

        window.addEventListener("resize", scheduleSizeRing);

        // Tam innerHTML dəyişdirməsi köhnə WebView-də yanıb-sönmə yaradır.
        // Strukturu eyni qaldıqda yalnız mətn/atributu dəyişən elementləri yeniləyirik.
        function patchLaneDom(newHtml) {
            var root = document.getElementById("laneRoot");
            if (!root) return;
            if (!root.firstElementChild) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }
            var staging = document.createElement("div");
            staging.innerHTML = newHtml;
            var fresh = staging.firstElementChild;
            var live = root.firstElementChild;
            if (!fresh || !live || fresh.tagName !== live.tagName) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }

            function patchTextNodes(liveEl, freshEl) {
                if (!liveEl || !freshEl) return;
                if (liveEl.innerHTML !== freshEl.innerHTML) {
                    liveEl.innerHTML = freshEl.innerHTML;
                }
            }
            function patchClassAndText(liveEl, freshEl) {
                if (!liveEl || !freshEl) return;
                if (liveEl.className !== freshEl.className) liveEl.className = freshEl.className;
                if (liveEl.textContent !== freshEl.textContent) liveEl.textContent = freshEl.textContent;
            }

            patchClassAndText(live.querySelector(".lane-tv-lane-num"), fresh.querySelector(".lane-tv-lane-num"));
            patchClassAndText(live.querySelector(".status-pill"), fresh.querySelector(".status-pill"));
            patchTextNodes(live.querySelector(".lane-tv-athlete"), fresh.querySelector(".lane-tv-athlete"));
            patchTextNodes(live.querySelector("[data-role=\"lane-schedule\"]"), fresh.querySelector("[data-role=\"lane-schedule\"]"));
            patchClassAndText(live.querySelector("[data-role=\"lane-bottom-hint\"]"), fresh.querySelector("[data-role=\"lane-bottom-hint\"]"));

            var liveSchedule = live.querySelector(".lane-tv-panel--schedule");
            var freshSchedule = fresh.querySelector(".lane-tv-panel--schedule");
            if (!!liveSchedule !== !!freshSchedule) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }

            var liveHint = live.querySelector(".lane-tv-panel--hint");
            var freshHint = fresh.querySelector(".lane-tv-panel--hint");
            if (!!liveHint !== !!freshHint) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }

            var liveGrid = live.querySelector(".lane-tv-grid");
            var freshGrid = fresh.querySelector(".lane-tv-grid");
            if (!!liveGrid !== !!freshGrid) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }
            if (live.classList.contains("lane-card--tv-active") !== fresh.classList.contains("lane-card--tv-active")) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }

            if (liveGrid && freshGrid && liveGrid.innerHTML !== freshGrid.innerHTML) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }

            var liveAthlete = live.querySelector(".lane-tv-athlete");
            var freshAthlete = fresh.querySelector(".lane-tv-athlete");
            if (!!liveAthlete !== !!freshAthlete) {
                root.innerHTML = newHtml;
                updateCountdownRings();
                updateLaneMetaTimes();
                scheduleSizeRing();
                return;
            }

            var liveRing = live.querySelector("[data-countdown-ring]");
            var freshRing = fresh.querySelector("[data-countdown-ring]");
            if (liveRing && freshRing) {
                var attrs = ["data-start", "data-end", "data-status"];
                for (var k = 0; k < attrs.length; k++) {
                    var a = attrs[k];
                    var nv = freshRing.getAttribute(a) || "";
                    if ((liveRing.getAttribute(a) || "") !== nv) {
                        liveRing.setAttribute(a, nv);
                    }
                }
            }

            updateCountdownRings();
            updateLaneMetaTimes();
            scheduleSizeRing();
        }

        var laneLoadFailCount = 0;

        function showLaneLoadStatus(message, isError) {
            var root = document.getElementById("laneRoot");
            if (!root) return;
            if (root.firstElementChild && !isError) return;
            root.innerHTML = "<div style=\"padding:24px;text-align:center;font-weight:800;color:" +
                (isError ? "#ff8a8a" : "#9ba7c7") + ";\">" + message + "</div>";
        }

        function loadLane() {
            if (laneLoadInFlight) { pendingReload = true; return; }
            laneLoadInFlight = true;
            if (!document.getElementById("laneRoot")?.firstElementChild) {
                showLaneLoadStatus("Yüklənir…", false);
            }
            return apiFetch("/dashboard/lanes/partial/card/" + laneNumber)
                .then(function (res) {
                    if (!res || !res.ok) {
                        laneLoadFailCount++;
                        var code = res ? res.status : 0;
                        showLaneLoadStatus("Zolaq " + laneNumber + " yüklənmədi (HTTP " + code + "). Yenidən cəhd…", true);
                        return null;
                    }
                    return res.text();
                })
                .then(function (text) {
                    if (text == null) return;
                    laneLoadFailCount = 0;
                    if (text !== lastLaneHtml) {
                        lastLaneHtml = text;
                        patchLaneDom(text);
                    }
                    lastRingCompact = null;
                    scheduleSizeRing();
                })["catch"](function () {
                    laneLoadFailCount++;
                    showLaneLoadStatus("Şəbəkə xətası — serverə çatılmır. Yenidən cəhd…", true);
                })
                .then(function () {
                    laneLoadInFlight = false;
                    if (pendingReload) {
                        pendingReload = false;
                        setTimeout(loadLane, 50);
                        return;
                    }
                    if (laneLoadFailCount > 0) {
                        var delay = Math.min(30000, 2000 + laneLoadFailCount * 1500);
                        setTimeout(loadLane, delay);
                    }
                });
        }

        var TV_USE_SIGNALR = true;
        var POLL_INTERVAL_MS = 15000;
        // Hər monitor eyni anda yox — zolaq nömrəsinə görə ardıcıl başlayır (donmanın qarşısını alır).
        var POLL_STAGGER_MS = Math.max(0, (laneNumber - 1) * 2500);

        function startPolling() {
            setInterval(loadLane, POLL_INTERVAL_MS);
            setInterval(syncLaneTvLogo, 1000);
        }

        document.addEventListener("visibilitychange", function () {
            if (document.visibilityState === "visible") loadLane();
        });
        window.addEventListener("online", loadLane);

        let tickerId = null;
        function startTicker() {
            if (tickerId) clearInterval(tickerId);
            const tick = () => {
                const wall = document.getElementById("wallClock");
                if (wall) {
                    wall.textContent = new Date().toLocaleTimeString("az-AZ", {
                        hour: "2-digit",
                        minute: "2-digit",
                        second: "2-digit"
                    });
                }
                updateCountdownRings();
            };
            tick();
            tickerId = setInterval(tick, 250);
        }

        function startSignalR() {
            var connectionBadge = document.getElementById("connectionBadge");
            if (!TV_USE_SIGNALR) {
                if (connectionBadge instanceof HTMLElement) {
                    connectionBadge.textContent = "TV rejimi";
                    connectionBadge.className = "lane-tv-connection";
                }
                return;
            }
            if (typeof signalR === "undefined" || !signalR.HubConnectionBuilder) {
                if (connectionBadge) {
                    connectionBadge.textContent = "Bağlantı yoxdur";
                    connectionBadge.className = "lane-tv-connection";
                }
                setTimeout(startSignalR, 5000);
                return;
            }

            var retryPolicy = {
                nextRetryDelayInMilliseconds: function (ctx) {
                    var attempt = ctx && ctx.previousRetryCount ? ctx.previousRetryCount : 0;
                    if (attempt < 1) return 1000;
                    if (attempt < 3) return 2000;
                    if (attempt < 6) return 5000;
                    if (attempt < 12) return 10000;
                    return 30000;
                }
            };

            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/lane")
                .withAutomaticReconnect(retryPolicy)
                .build();

            if (typeof connection.onreconnecting === "function") {
                connection.onreconnecting(function () {
                    if (connectionBadge) {
                        connectionBadge.textContent = "Yenidən bağlanır...";
                        connectionBadge.className = "lane-tv-connection";
                    }
                });
            }

            if (typeof connection.onreconnected === "function") {
                connection.onreconnected(function () {
                    if (connectionBadge) {
                        connectionBadge.textContent = "Qoşuldu";
                        connectionBadge.className = "lane-tv-connection Active";
                    }
                    loadLane();
                });
            }

            if (typeof connection.onclose === "function") {
                connection.onclose(function () {
                    if (connectionBadge) {
                        connectionBadge.textContent = "Bağlantı yoxdur";
                        connectionBadge.className = "lane-tv-connection";
                    }
                    var tryAgain = function () {
                        connection.start().then(function () {
                            if (connectionBadge) {
                                connectionBadge.textContent = "Qoşuldu";
                                connectionBadge.className = "lane-tv-connection Active";
                            }
                            loadLane();
                        }, function () {
                            setTimeout(tryAgain, 5000);
                        });
                    };
                    setTimeout(tryAgain, 5000);
                });
            }

            connection.on("lane-updated", loadLane);
            // Bu monitorda xal göstərilmir — `score-updated` çağırışı boş yerə kart yenidən yükləyirdi
            // və hər atışda ekranda gözəyarı yanıb-sönmə yaradırdı, ona görə dinləmirik.

            connection.start().then(
                function () {
                    if (connectionBadge) {
                        connectionBadge.textContent = "Qoşuldu";
                        connectionBadge.className = "lane-tv-connection Active";
                    }
                },
                function () {
                    if (connectionBadge) {
                        connectionBadge.textContent = "Bağlantı yoxdur";
                        connectionBadge.className = "lane-tv-connection";
                    }
                    setTimeout(startSignalR, 5000);
                }
            );
        }

        syncLaneTvLogo();
        setTimeout(function () {
            loadLane();
            startTicker();
            startPolling();
            startSignalR();
        }, POLL_STAGGER_MS);
    </script>
</body>
</html>
