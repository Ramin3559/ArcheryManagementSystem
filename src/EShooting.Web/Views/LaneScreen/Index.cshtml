@model int
@using EShooting.Web.Helpers
@{
    Layout = null;
    var laneNumber = Model;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <title>EShooting — Zolaq @laneNumber (TV v3)</title>
    <style>
        :root {
            --brand: #8B2318;
            --brand-muted: #a04438;
            --bg: #ffffff;
            --text: #8B2318;
            --text-muted: #a04438;
            --border: #e8d4d0;
            --tv-safe-x: clamp(10px, 1.5vw, 20px);
            --tv-safe-y: clamp(8px, 1vh, 16px);
        }

        * { box-sizing: border-box; -webkit-text-size-adjust: 100%; }

        html, body { height: 100%; }

        body.lane-tv-body {
            margin: 0;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            color: var(--text);
            background: var(--bg);
            font-family: "Segoe UI", Arial, sans-serif;
            display: flex;
            flex-direction: column;
        }

        .lane-tv-connection,
        #connectionBadge {
            display: none !important;
            visibility: hidden !important;
            pointer-events: none !important;
        }

        .lane-tv-wrap {
            flex: 1 1 auto;
            display: flex;
            align-items: stretch;
            justify-content: stretch;
            padding:
                max(var(--tv-safe-y), env(safe-area-inset-top, 0px))
                max(var(--tv-safe-x), env(safe-area-inset-right, 0px))
                max(var(--tv-safe-y), env(safe-area-inset-bottom, 0px))
                max(var(--tv-safe-x), env(safe-area-inset-left, 0px));
            width: 100%;
            min-height: 0;
            overflow: hidden;
            position: relative;
            background: var(--bg);
        }

        /* Boş/planlı/bitmiş (15s sonra) tam ekran loqo */
        body.lane-tv-body.lane-tv--fullscreen-logo .lane-tv-wrap {
            padding: 0;
        }

        .lane-tv-logo {
            position: fixed;
            inset: 0;
            width: 100vw;
            height: 100vh;
            object-fit: cover;
            object-position: center;
            background: #fff;
            z-index: 20;
            display: block;
        }

        .lane-tv-logo.hidden {
            display: none !important;
        }

        .lane-tv-inner.lane-tv-inner--hidden {
            display: none !important;
        }

        .lane-tv-inner {
            width: 100%;
            height: 100%;
            max-width: 100%;
            display: flex;
            position: relative;
            z-index: 1;
        }

        .lane-tv-inner > * {
            flex: 1 1 auto;
            width: 100%;
            min-height: 0;
        }

        .lane-tv-body .lane-actions,
        .lane-tv-body .pick-session,
        .lane-tv-body .stop-session-btn,
        .lane-tv-body .lane-type {
            display: none !important;
        }

        /* Yalnız çox kiçik ekranlarda — TV ölçüsünə toxunmur */
        @@media (max-width: 600px) {
            body.lane-tv-body .countdown-ring-wrap[data-time-wide="1"]:not(.is-idle):not(.is-done) .countdown-ring__timer {
                font-size: clamp(20px, 6vmin, 44px) !important;
                letter-spacing: -0.06em;
            }
        }
    </style>
    @await Html.PartialAsync("Lanes/_LaneCardTvStyles")
</head>
<body class="lane-tv-body">
    <div class="lane-tv-wrap">
        <img id="laneTvLogo"
             class="lane-tv-logo"
             src="/images/club-logo.jpg"
             alt="Target Archery Club"
             onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/lane-logo.jpg';}else if(this.dataset.fallback==='1'){this.dataset.fallback='2';this.src='/images/placeholder-logo.jpg';}" />
        <div class="lane-tv-inner" id="laneRoot"></div>
    </div>

    <script src="/lib/signalr/signalr.min.js"></script>
    <script src="/js/baku-time.js"></script>
    <script>
        const laneNumber = @laneNumber;

        function pad2(n) {
            return BakuTime.pad2(n);
        }

        function formatWallClockText() {
            return BakuTime.formatWallClock();
        }

        function updateWallClock() {
            var text = formatWallClockText();
            var grid = document.getElementById("laneTvWallClockGrid");
            if (grid) grid.textContent = text;
            var nodes = document.querySelectorAll("[data-role=\"wall-clock-display\"]");
            for (var i = 0; i < nodes.length; i++) {
                nodes[i].textContent = text;
            }
        }

        var wallClockIntervalId = null;

        function startWallClock() {
            updateWallClock();
            if (wallClockIntervalId) clearInterval(wallClockIntervalId);
            wallClockIntervalId = setInterval(updateWallClock, 1000);

            (function alignedTimeout() {
                updateWallClock();
                var ms = 1000 - (Date.now() % 1000);
                if (ms < 30) ms += 1000;
                setTimeout(alignedTimeout, ms);
            })();
        }

        function parseApiDate(value) {
            return BakuTime.parseApiDate(value);
        }

        function formatLocalTimeFromApi(iso) {
            return BakuTime.formatTimeFromApi(iso, false);
        }

        function updateLaneMetaTimes() {
            var ring = document.querySelector("[data-countdown-ring]");
            if (!(ring instanceof HTMLElement)) return;
            var start = ring.dataset.start || "";
            var end = ring.dataset.end || "";
            var vipMode = ring.dataset.vipMode === "1";
            var openEnded = isOpenEndedRing(ring);
            var startItem = document.querySelector("[data-role=\"schedule-start\"]");
            var endItem = document.querySelector("[data-role=\"schedule-end\"]");
            if (start && startItem) startItem.textContent = "Başlama: " + formatLocalTimeFromApi(start);
            if (endItem instanceof HTMLElement) {
                var endRow = endItem.closest(".lane-tv-schedule__row");
                var endPanel = endItem.closest(".lane-tv-panel--session-end");
                if (endPanel instanceof HTMLElement) endPanel.style.display = "";
                else if (endRow instanceof HTMLElement) endRow.style.display = "";
                if (openEnded) {
                    endItem.textContent = "Bitmə: Davam edir";
                } else if (end) {
                    endItem.textContent = "Bitmə: " + formatLocalTimeFromApi(end);
                }
            }
        }

        function isVipModeRing(ringEl) {
            return ringEl instanceof HTMLElement && ringEl.dataset.vipMode === "1";
        }

        function isOpenEndedRing(ringEl) {
            if (!(ringEl instanceof HTMLElement)) return false;
            if (isVipModeRing(ringEl)) return true;
            var start = ringEl.dataset.start || "";
            var end = ringEl.dataset.end || "";
            if (!start || !end) return false;
            var startMs = parseApiDate(start).getTime();
            var endMs = parseApiDate(end).getTime();
            return !isNaN(startMs) && !isNaN(endMs) && endMs <= startMs;
        }

        function formatSeconds(milliseconds) {
            var totalSeconds = Math.floor(milliseconds / 1000);
            if (totalSeconds < 0) totalSeconds = 0;
            var hours = Math.floor(totalSeconds / 3600);
            var minutes = Math.floor((totalSeconds % 3600) / 60);
            var seconds = totalSeconds % 60;
            if (hours > 0) {
                return pad2(hours) + ":" + pad2(minutes) + ":" + pad2(seconds);
            }
            return pad2(minutes) + ":" + pad2(seconds);
        }

        const COUNTDOWN_WARN_SEC = 300; // 5 dəqiqə
        const COUNTDOWN_CRIT_SEC = 120; // 2 dəqiqə
        const SESSION_BUFFER_MS = 0;
        const LANE_TIME_ENDED_MSG = "Sizin vaxtınız bitmişdir";
        const LANE_LOGO_DELAY_MS = 15000;
        var laneSessionEndedAtMs = 0;

        function clearLaneSessionEnded() {
            laneSessionEndedAtMs = 0;
        }

        function markLaneSessionEnded() {
            if (!laneSessionEndedAtMs) {
                laneSessionEndedAtMs = Date.now();
            }
        }

        function applyLaneEndedDisplay(timerEl, captionEl) {
            if (timerEl) timerEl.textContent = LANE_TIME_ENDED_MSG;
            if (captionEl) captionEl.textContent = "";
        }

        function removeTvConnectionUi() {
            var badge = document.getElementById("connectionBadge");
            if (badge) badge.remove();
            document.querySelectorAll(".lane-tv-connection, .lane-tv-status-pill, .lane-card--tv .status-pill").forEach(function (el) {
                el.remove();
            });
        }

        // TV: yalnız öz kartındakı data-atributlardan (bütün /dashboard/lanes yox — server yüklənmir).
        function isActiveSessionFromRing(ringEl) {
            if (!(ringEl instanceof HTMLElement)) return false;
            var status = ringEl.dataset.status || "";
            var start = ringEl.dataset.start || "";
            var end = ringEl.dataset.end || "";
            if (isOpenEndedRing(ringEl)) {
                if (!start || status === "Completed" || status === "Idle") return false;
                if (ringEl.classList.contains("is-live")) return true;
                var openStartMs = parseApiDate(start).getTime();
                if (isNaN(openStartMs)) return false;
                return Date.now() >= openStartMs && status === "Active";
            }
            if (isVipModeRing(ringEl)) {
                if (!start || status === "Completed" || status === "Idle") return false;
                if (ringEl.classList.contains("is-live")) return true;
                var startMs = parseApiDate(start).getTime();
                if (isNaN(startMs)) return false;
                return Date.now() >= startMs && status === "Active";
            }
            if (!start || !end) return false;
            if (status === "Completed" || status === "Idle" || status === "Scheduled") return false;
            if (ringEl.classList.contains("is-live")) return true;
            var nowMs = Date.now();
            var startMs = parseApiDate(start).getTime();
            var endMs = parseApiDate(end).getTime();
            if (isNaN(startMs) || isNaN(endMs)) return false;
            return nowMs >= startMs && nowMs < endMs;
        }

        function shouldShowLaneTvLogo(ringEl) {
            if (isActiveSessionFromRing(ringEl)) {
                clearLaneSessionEnded();
                return false;
            }
            if (!(ringEl instanceof HTMLElement)) return true;
            if (ringEl.classList.contains("is-live")) {
                clearLaneSessionEnded();
                return false;
            }
            if (ringEl.classList.contains("is-done")) {
                markLaneSessionEnded();
                return (Date.now() - laneSessionEndedAtMs) >= LANE_LOGO_DELAY_MS;
            }
            clearLaneSessionEnded();
            return true;
        }

        function syncLaneTvLogo() {
            var logo = document.getElementById("laneTvLogo");
            var root = document.getElementById("laneRoot");
            var ring = document.querySelector(".lane-tv-body [data-countdown-ring]");
            var show = shouldShowLaneTvLogo(ring);
            if (logo instanceof HTMLElement) {
                logo.classList.toggle("hidden", !show);
            }
            if (root instanceof HTMLElement) {
                root.classList.toggle("lane-tv-inner--hidden", show);
            }
            document.body.classList.toggle("lane-tv--fullscreen-logo", show);
        }

        function applyRingRemaining(ringEl, fractionRemaining) {
            var f = Math.max(0, Math.min(1, fractionRemaining));
            var circle = ringEl.querySelector(".countdown-ring__progress");
            if (circle instanceof SVGCircleElement) {
                var r = circle.r.baseVal.value;
                var len = 2 * Math.PI * r;
                ringEl.classList.toggle("is-near-full", f >= 0.90);
                if (f >= 0.998) {
                    circle.style.strokeDasharray = (len + 1) + " 0";
                    circle.style.strokeDashoffset = "0";
                } else {
                    circle.style.strokeDasharray = String(len);
                    circle.style.strokeDashoffset = String(len * (1 - f));
                }
            }
            var bar = ringEl.querySelector("[data-role=\"countdown-bar-fill\"]");
            if (bar instanceof HTMLElement) {
                bar.style.transformOrigin = "left center";
                bar.style.transform = "scaleX(" + f + ")";
            }
        }

        function ensureRingHasSize(ringEl) {
            if (!(ringEl instanceof HTMLElement)) return;
            var w = ringEl.clientWidth || ringEl.offsetWidth || 0;
            if (w >= 80) return;
            var vw = window.innerWidth || 1280;
            var vh = window.innerHeight || 720;
            var fallback = Math.floor(Math.min(660, vw * 0.52, vh * 0.54));
            fallback = Math.max(200, fallback);
            ringEl.style.setProperty("--ring-size", fallback + "px");
        }

        function getLaneTvNameMaxWidth(panel) {
            if (!(panel instanceof HTMLElement)) return 0;
            var gapPx = 6;
            var card = panel.closest(".lane-card");
            if (card instanceof HTMLElement) {
                var gapVar = parseFloat(window.getComputedStyle(card).getPropertyValue("--tv-name-schedule-gap"));
                if (!Number.isNaN(gapVar) && gapVar > 0) gapPx = gapVar;
            }

            var detailGrid = panel.closest(".lane-tv-detail-grid");
            var scheduleEl = null;
            if (panel.classList.contains("lane-tv-panel--name-first")) {
                scheduleEl = detailGrid ? detailGrid.querySelector(".lane-tv-panel--session-start") : null;
            } else if (panel.classList.contains("lane-tv-panel--name-last")) {
                scheduleEl = detailGrid ? detailGrid.querySelector(".lane-tv-panel--session-end") : null;
            } else {
                scheduleEl = document.querySelector(".lane-tv-panel--session-start, .lane-tv-panel--session-times");
            }

            if (scheduleEl instanceof HTMLElement) {
                var panelRect = panel.getBoundingClientRect();
                var schedRect = scheduleEl.getBoundingClientRect();
                if (schedRect.left > panelRect.left) {
                    return Math.max(48, schedRect.left - panelRect.left - gapPx);
                }
            }

            if (detailGrid instanceof HTMLElement && detailGrid.clientWidth > 0
                && (panel.classList.contains("lane-tv-panel--name-first") || panel.classList.contains("lane-tv-panel--name-last"))) {
                var colGap = parseFloat(window.getComputedStyle(detailGrid).columnGap) || 0;
                return Math.max(120, Math.floor((detailGrid.clientWidth - colGap * 2) / 3) - Math.ceil(gapPx / 2));
            }

            if (detailGrid instanceof HTMLElement && detailGrid.clientWidth > 0) {
                var gridColGap = parseFloat(window.getComputedStyle(detailGrid).columnGap) || 0;
                return Math.max(48, Math.floor((detailGrid.clientWidth - gridColGap * 2) / 3) - Math.ceil(gapPx / 2));
            }

            return Math.max(48, panel.clientWidth);
        }

        function fitLaneTvAthleteNames() {
            document.querySelectorAll(".lane-tv-body .lane-tv-panel--name, .lane-tv-body .lane-tv-panel--name-first, .lane-tv-body .lane-tv-panel--name-last").forEach(function (panel) {
                if (!(panel instanceof HTMLElement)) return;
                var maxW = getLaneTvNameMaxWidth(panel);
                panel.querySelectorAll(".lane-tv-first-name, .lane-tv-last-name").forEach(function (line) {
                    if (!(line instanceof HTMLElement)) return;
                    line.style.removeProperty("font-size");
                    line.style.removeProperty("transform");
                    line.style.removeProperty("transform-origin");
                    line.style.removeProperty("letter-spacing");

                    var computed = window.getComputedStyle(line);
                    var fs = parseFloat(computed.fontSize) || 64;
                    var minFs = Math.max(38, Math.round(fs * 0.72));
                    while (line.scrollWidth > maxW && fs > minFs) {
                        fs -= 1;
                        line.style.setProperty("font-size", fs + "px", "important");
                    }
                });
            });
        }

        function scheduleFitAthleteNames() {
            var run = function () { fitLaneTvAthleteNames(); };
            (window.requestAnimationFrame || function (cb) { return setTimeout(cb, 16); })(run);
            setTimeout(run, 60);
            setTimeout(run, 250);
        }

        // Dairənin içində vaxt mətni daireye sığsın deyə şrifti dinamik kiçildirik.
        function syncTimerFormatFlags(ringEl, timerEl) {
            if (!(ringEl instanceof HTMLElement) || !(timerEl instanceof HTMLElement)) return;
            var text = String(timerEl.textContent || "").trim();
            var colons = (text.match(/:/g) || []).length;
            var isWide = colons >= 2 || text.length >= 7;
            ringEl.setAttribute("data-time-wide", isWide ? "1" : "0");
        }

        function measureTimerBox(timer) {
            var w = timer.scrollWidth;
            var h = timer.scrollHeight;
            if (w > 0 && h > 0) return { w: w, h: h };
            var rect = timer.getBoundingClientRect();
            if (rect.width > 0 && rect.height > 0) return { w: rect.width, h: rect.height };
            var fs = parseFloat(window.getComputedStyle(timer).fontSize) || 16;
            var text = String(timer.textContent || "");
            return { w: text.length * fs * 0.58, h: fs * 1.08 };
        }

        function getRingInnerBox(ringEl) {
            ensureRingHasSize(ringEl);
            var ringSize = Math.max(ringEl.clientWidth, ringEl.offsetWidth, ringEl.clientHeight, ringEl.offsetHeight);
            if (ringSize <= 0) return { maxW: 0, maxH: 0, ringSize: 0 };

            var styles = window.getComputedStyle(ringEl);
            var padRatio = parseFloat(styles.getPropertyValue("--ring-inner-pad")) || 0.03;
            var innerDiam = ringSize * 0.80;
            var contentDiam = innerDiam * Math.max(0.68, 1 - padRatio * 2);
            return {
                ringSize: ringSize,
                maxW: contentDiam,
                maxH: contentDiam * 0.56
            };
        }

        function fitLaneTvCountdownTimer(ringEl) {
            if (!(ringEl instanceof HTMLElement)) return;
            var timer = ringEl.querySelector("[data-role=\"timer\"]");
            var caption = ringEl.querySelector("[data-role=\"caption\"]");
            if (!(timer instanceof HTMLElement)) return;

            syncTimerFormatFlags(ringEl, timer);
            timer.style.removeProperty("transform");
            timer.style.removeProperty("font-size");
            timer.style.removeProperty("letter-spacing");
            if (caption instanceof HTMLElement) caption.textContent = "";

            if (ringEl.classList.contains("is-idle")) {
                timer.style.whiteSpace = "nowrap";
                return;
            }

            if (ringEl.classList.contains("is-done")) {
                timer.style.whiteSpace = "normal";
                return;
            }

            var box = getRingInnerBox(ringEl);
            if (box.maxW <= 0) return;

            timer.style.whiteSpace = "nowrap";
            var text = String(timer.textContent || "").trim();
            var charCount = Math.max(text.length, 4);
            var isLongTime = ringEl.getAttribute("data-time-wide") === "1";
            if (isLongTime) {
                timer.style.letterSpacing = "-0.06em";
            }

            var charRatio = isLongTime ? 0.52 : 0.55;
            var fs = Math.floor(Math.min(
                box.maxW / (charCount * charRatio),
                box.maxH / 0.88,
                box.ringSize * (isLongTime ? 0.24 : 0.34)
            ));
            fs = Math.max(34, Math.min(fs, isLongTime ? 96 : 120));
            timer.style.setProperty("font-size", fs + "px", "important");

            var rect = timer.getBoundingClientRect();
            if (rect.width > box.maxW && rect.width > 0) {
                var scale = Math.max(0.5, box.maxW / rect.width);
                timer.style.transform = "scale(" + scale.toFixed(4) + ")";
            }
        }

        function scheduleFitTimer(ringEl) {
            var run = function () { fitLaneTvCountdownTimer(ringEl); };
            (window.requestAnimationFrame || function (cb) { return setTimeout(cb, 16); })(run);
            setTimeout(run, 60);
            setTimeout(run, 250);
            setTimeout(run, 800);
        }

        function updateCountdownRings() {
            document.querySelectorAll("[data-countdown-ring]").forEach(function (el) {
                if (!(el instanceof HTMLElement)) return;
                const start = el.dataset.start || "";
                const end = el.dataset.end || "";
                const status = el.dataset.status || "";
                const pendingRental = el.dataset.pendingRentalEquipment === "1";
                const timerEl = el.querySelector("[data-role=\"timer\"]");
                const captionEl = el.querySelector("[data-role=\"caption\"]");
                const progressEl = el.querySelector(".countdown-ring__progress");
                if (!timerEl || !(progressEl instanceof SVGGraphicsElement)) return;

                try {
                const card = el.closest(".lane-card");
                const bottomHint = card instanceof HTMLElement ? card.querySelector("[data-role=\"lane-bottom-hint\"]") : null;
                const setBottomHint = (text, kind) => {
                    if (!(bottomHint instanceof HTMLElement)) return;
                    bottomHint.textContent = text || "";
                    bottomHint.classList.toggle("is-show", Boolean(text));
                    bottomHint.classList.toggle("is-critical", kind === "critical");
                };
                const setEquipmentReturnHint = () => {
                    if (pendingRental) {
                        setBottomHint("Avadanlıq təhvil alınmalıdır", "critical");
                        return true;
                    }
                    return false;
                };
                const setCleanupMode = (on) => {
                    if (!(card instanceof HTMLElement)) return;
                    card.classList.toggle("is-cleanup", Boolean(on));
                };

                el.classList.remove("is-live", "is-pending", "is-warn", "is-critical", "is-done", "is-idle", "is-open-ended");

                const vipMode = isOpenEndedRing(el);

                if (vipMode && start) {
                    const startMs = parseApiDate(start).getTime();
                    const nowMs = Date.now();

                    if (status === "Completed") {
                        if (!isNaN(startMs) && nowMs < startMs) {
                            el.classList.add("is-pending", "is-open-ended");
                            timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                            if (captionEl) captionEl.textContent = "";
                            setBottomHint("", "");
                            setCleanupMode(false);
                            applyRingRemaining(el, 1);
                            return;
                        }
                        el.classList.add("is-done");
                        applyLaneEndedDisplay(timerEl, captionEl);
                        if (!setEquipmentReturnHint()) setBottomHint("", "");
                        setCleanupMode(true);
                        applyRingRemaining(el, 0);
                        resetRingCompactSize(el);
                        return;
                    }

                    if (isNaN(startMs)) {
                        el.classList.add("is-idle");
                        timerEl.textContent = "—";
                        if (captionEl) captionEl.textContent = "";
                        setBottomHint("", "");
                        setCleanupMode(false);
                        applyRingRemaining(el, 0);
                        resetRingCompactSize(el);
                        return;
                    }

                    if (nowMs < startMs) {
                        el.classList.add("is-pending", "is-open-ended");
                        timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                        if (captionEl) captionEl.textContent = "";
                        setBottomHint("", "");
                        setCleanupMode(false);
                        applyRingRemaining(el, 1);
                        return;
                    }

                    el.classList.add("is-live", "is-open-ended");
                    const elapsedMs = Math.max(0, nowMs - startMs);
                    timerEl.textContent = formatSeconds(elapsedMs);
                    if (captionEl) captionEl.textContent = "";
                    setBottomHint("", "");
                    setCleanupMode(false);
                    applyRingRemaining(el, 1);
                    return;
                }

                if (!start || !end) {
                    el.classList.add("is-idle");
                    timerEl.textContent = "—";
                    if (captionEl) captionEl.textContent = "";
                    setBottomHint("", "");
                    setCleanupMode(false);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                const startMs = parseApiDate(start).getTime();
                const endMs = parseApiDate(end).getTime();
                const nowMs = Date.now();
                const openEndedWindow = !isNaN(startMs) && !isNaN(endMs) && endMs <= startMs;
                const totalMs = openEndedWindow ? 0 : endMs - startMs;

                if (openEndedWindow) {
                    if (status === "Completed") {
                        if (!isNaN(startMs) && nowMs < startMs) {
                            el.classList.add("is-pending", "is-open-ended");
                            timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                            if (captionEl) captionEl.textContent = "";
                            setBottomHint("", "");
                            setCleanupMode(false);
                            applyRingRemaining(el, 1);
                            return;
                        }
                        el.classList.add("is-done");
                        applyLaneEndedDisplay(timerEl, captionEl);
                        if (!setEquipmentReturnHint()) setBottomHint("", "");
                        setCleanupMode(true);
                        applyRingRemaining(el, 0);
                        resetRingCompactSize(el);
                        return;
                    }

                    if (nowMs < startMs) {
                        el.classList.add("is-pending", "is-open-ended");
                        timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                        if (captionEl) captionEl.textContent = "";
                        setBottomHint("", "");
                        setCleanupMode(false);
                        applyRingRemaining(el, 1);
                        return;
                    }

                    el.classList.add("is-live", "is-open-ended");
                    const elapsedOpenMs = Math.max(0, nowMs - startMs);
                    timerEl.textContent = formatSeconds(elapsedOpenMs);
                    if (captionEl) captionEl.textContent = "";
                    setBottomHint("", "");
                    setCleanupMode(false);
                    applyRingRemaining(el, 1);
                    return;
                }

                if (status === "Completed") {
                    if (!isNaN(startMs) && nowMs < startMs) {
                        el.classList.add("is-pending");
                        timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                        if (captionEl) captionEl.textContent = "";
                        setBottomHint("", "");
                        setCleanupMode(false);
                        applyRingRemaining(el, 1);
                        return;
                    }
                    el.classList.add("is-done");
                    applyLaneEndedDisplay(timerEl, captionEl);
                    if (!setEquipmentReturnHint()) {
                        setBottomHint("", "");
                    }
                    setCleanupMode(true);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                if (nowMs < startMs) {
                    el.classList.add("is-pending");
                    const untilMs = startMs - nowMs;
                    const untilSec = Math.floor(untilMs / 1000);

                    // Never show absurd long countdowns.
                    if (untilSec > 24 * 3600) {
                        timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                        if (captionEl) captionEl.textContent = "";
                        setBottomHint("", "");
                        applyRingRemaining(el, 1);
                        return;
                    }

                    timerEl.textContent = BakuTime.formatBakuFromUtcMs(startMs, false);
                    if (captionEl) captionEl.textContent = "";
                    if (untilSec <= COUNTDOWN_WARN_SEC) {
                        const minLeft = Math.max(0, Math.ceil(untilSec / 60));
                        setBottomHint(`${minLeft} dəqiqə qaldı`, untilSec <= COUNTDOWN_CRIT_SEC ? "critical" : "");
                    } else {
                        setBottomHint("", "");
                    }
                    setCleanupMode(false);
                    applyRingRemaining(el, 1);
                    return;
                }

                if (nowMs >= endMs) {
                    el.classList.add("is-done");
                    applyLaneEndedDisplay(timerEl, captionEl);
                    if (!setEquipmentReturnHint()) {
                        setBottomHint("", "");
                    }
                    setCleanupMode(true);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                // Active: show training time only (exclude buffer).
                const trainingEndMs = Math.max(startMs, endMs - SESSION_BUFFER_MS);
                const trainingRemainingMs = trainingEndMs - nowMs;
                const trainingRemainingSec = Math.floor(trainingRemainingMs / 1000);

                if (trainingRemainingMs <= 0) {
                    el.classList.add("is-done");
                    applyLaneEndedDisplay(timerEl, captionEl);
                    if (!setEquipmentReturnHint()) {
                        setBottomHint("", "");
                    }
                    setCleanupMode(true);
                    applyRingRemaining(el, 0);
                    resetRingCompactSize(el);
                    return;
                }

                const frac = (trainingEndMs - startMs) > 0 ? trainingRemainingMs / (trainingEndMs - startMs) : 0;
                el.classList.add("is-live");
                if (trainingRemainingSec <= COUNTDOWN_CRIT_SEC) el.classList.add("is-critical");
                else if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) el.classList.add("is-warn");

                timerEl.textContent = formatSeconds(trainingRemainingMs);
                if (captionEl) captionEl.textContent = "";
                if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) {
                    const minLeft = Math.max(0, Math.ceil(trainingRemainingSec / 60));
                    setBottomHint(`${minLeft} dəqiqə qaldı`, trainingRemainingSec <= COUNTDOWN_CRIT_SEC ? "critical" : "");
                } else {
                    setBottomHint("", "");
                }
                setCleanupMode(false);
                applyRingRemaining(el, frac);
                } finally {
                    scheduleFitTimer(el);
                }
            });

            var ringEl = document.querySelector("[data-countdown-ring]");
            var compact = ringEl ? ringUsesCompactSize(ringEl) : null;
            if (lastRingCompact !== compact) {
                lastRingCompact = compact;
                scheduleSizeRing();
            }

            updateLaneMetaTimes();
            syncLaneTvLogo();
        }

        function apiFetch(input, init) {
            init = init || {};
            var url = (typeof input === "string")
                ? input + (input.indexOf("?") >= 0 ? "&" : "?") + "_=" + Date.now()
                : input;
            init.credentials = "same-origin";
            init.cache = "no-store";
            return fetch(url, init);
        }

        var lastLaneHtml = "";
        var laneLoadInFlight = false;
        var pendingReload = false;
        var lastRingCompact = null;
        function resetRingCompactSize(ring) {
            if (!(ring instanceof HTMLElement)) return;
            ring.style.width = "";
            ring.style.height = "";
        }

        function ringUsesCompactSize(ring) {
            if (!(ring instanceof HTMLElement)) return true;
            if (isOpenEndedRing(ring) && ring.classList.contains("is-live")) return false;
            var start = ring.getAttribute("data-start") || "";
            var end = ring.getAttribute("data-end") || "";
            if (!start || !end) return true;
            return ring.classList.contains("is-idle") || ring.classList.contains("is-done");
        }

        // Aktiv sessiyada ölçü CSS-dən gəlir (!important); yalnız boş/bitmiş üçün uyğunlaşdırırıq.
        function sizeCountdownRing() {
            var card = document.querySelector(".lane-tv-body .lane-card");
            if (!card) return;
            var ring = card.querySelector(".countdown-ring-wrap");
            if (!ring) return;

            resetRingCompactSize(ring);
            ensureRingHasSize(ring);
            observeCountdownRing(ring);
            fitLaneTvCountdownTimer(ring);
        }

        var sizeRingPending = false;
        function scheduleSizeRing() {
            if (sizeRingPending) return;
            sizeRingPending = true;
            (window.requestAnimationFrame || function (cb) { return setTimeout(cb, 16); })(function () {
                sizeRingPending = false;
                sizeCountdownRing();
                scheduleFitAthleteNames();
            });
        }

        window.addEventListener("resize", scheduleSizeRing);
        window.addEventListener("load", function () {
            scheduleSizeRing();
            setTimeout(scheduleSizeRing, 400);
            setTimeout(scheduleSizeRing, 1200);
        });

        if (typeof ResizeObserver !== "undefined") {
            var ringResizeObserver = new ResizeObserver(function (entries) {
                for (var i = 0; i < entries.length; i++) {
                    var el = entries[i].target;
                    if (el instanceof HTMLElement) {
                        fitLaneTvCountdownTimer(el);
                    }
                }
            });
            function observeCountdownRing(ringEl) {
                if (ringEl instanceof HTMLElement) {
                    ringResizeObserver.observe(ringEl);
                }
            }
        } else {
            function observeCountdownRing() { /* noop */ }
        }

        const TV_LAYOUT_VERSION = "v3";

        function normalizeLaneHtml(html) {
            if (!html) return "";
            return html
                .replace(/\s+/g, " ")
                .replace(/<span id="laneTvWallClockGrid"[^>]*>[\s\S]*?<\/span>/gi,
                    '<span id="laneTvWallClockGrid" class="lane-tv-wall-clock__value" data-role="wall-clock-display"></span>')
                .replace(/(<div class="countdown-ring__timer" data-role="timer">)[^<]*(<\/div>)/gi, "$1—$2")
                .trim();
        }

        function mountLaneHtml(newHtml) {
            var root = document.getElementById("laneRoot");
            if (!root) return;
            root.innerHTML = newHtml;
            removeTvConnectionUi();
            var styleEl = root.querySelector("[id^=\"lane-tv-styles\"]");
            if (styleEl) {
                var existing = document.querySelector("[id^=\"lane-tv-styles\"]");
                if (existing && existing !== styleEl && existing.parentNode) existing.remove();
                document.head.appendChild(styleEl);
            }
            updateCountdownRings();
            updateLaneMetaTimes();
            updateWallClock();
            scheduleSizeRing();
            scheduleFitAthleteNames();
        }
        // Strukturu eyni qaldıqda yalnız mətn/atributu dəyişən elementləri yeniləyirik.
        function patchLaneDom(newHtml) {
            var root = document.getElementById("laneRoot");
            if (!root) return;
            if (!root.firstElementChild) {
                mountLaneHtml(newHtml);
                return;
            }
            var staging = document.createElement("div");
            staging.innerHTML = newHtml;
            var fresh = staging.querySelector("[data-tv-layout=\"" + TV_LAYOUT_VERSION + "\"]") || staging.firstElementChild;
            var live = root.querySelector("[data-tv-layout]") || root.firstElementChild;
            if (!fresh || !live) {
                mountLaneHtml(newHtml);
                return;
            }
            if (live.getAttribute("data-tv-layout") !== TV_LAYOUT_VERSION) {
                mountLaneHtml(newHtml);
                return;
            }
            if (fresh.tagName !== live.tagName) {
                mountLaneHtml(newHtml);
                return;
            }

            function patchTextNodes(liveEl, freshEl) {
                if (!liveEl || !freshEl) return;
                if (liveEl.innerHTML !== freshEl.innerHTML) {
                    liveEl.innerHTML = freshEl.innerHTML;
                }
            }
            function patchClassAndText(liveEl, freshEl) {
                if (!liveEl || !freshEl) return;
                if (liveEl.className !== freshEl.className) liveEl.className = freshEl.className;
                if (liveEl.textContent !== freshEl.textContent) liveEl.textContent = freshEl.textContent;
            }

            patchClassAndText(live.querySelector(".lane-tv-lane-num"), fresh.querySelector(".lane-tv-lane-num"));
            live.querySelectorAll(".status-pill, .lane-tv-status-pill").forEach(function (pill) { pill.remove(); });
            patchTextNodes(live.querySelector(".lane-tv-athlete"), fresh.querySelector(".lane-tv-athlete"));
            patchClassAndText(live.querySelector(".lane-tv-panel--name-first .lane-tv-first-name"), fresh.querySelector(".lane-tv-panel--name-first .lane-tv-first-name"));
            patchClassAndText(live.querySelector(".lane-tv-panel--name-last .lane-tv-last-name"), fresh.querySelector(".lane-tv-panel--name-last .lane-tv-last-name"));
            patchClassAndText(live.querySelector("[data-role=\"schedule-start\"]"), fresh.querySelector("[data-role=\"schedule-start\"]"));
            patchClassAndText(live.querySelector("[data-role=\"schedule-end\"]"), fresh.querySelector("[data-role=\"schedule-end\"]"));
            patchTextNodes(
                live.querySelector(".lane-tv-panel--session-times [data-role=\"lane-schedule\"]") ||
                    live.querySelector("[data-role=\"lane-schedule\"]"),
                fresh.querySelector(".lane-tv-panel--session-times [data-role=\"lane-schedule\"]") ||
                    fresh.querySelector("[data-role=\"lane-schedule\"]"));
            patchClassAndText(live.querySelector("[data-role=\"lane-bottom-hint\"]"), fresh.querySelector("[data-role=\"lane-bottom-hint\"]"));

            var liveStack = live.querySelector(".lane-tv-panel--center-stack");
            var freshStack = fresh.querySelector(".lane-tv-panel--center-stack");
            var liveTimes = live.querySelector(".lane-tv-panel--session-times");
            var freshTimes = fresh.querySelector(".lane-tv-panel--session-times");
            var liveDetail = live.querySelector(".lane-tv-detail-grid");
            var freshDetail = fresh.querySelector(".lane-tv-detail-grid");
            if (!!liveStack !== !!freshStack || !!liveTimes !== !!freshTimes || !!liveDetail !== !!freshDetail) {
                mountLaneHtml(newHtml);
                return;
            }

            var liveClock = live.querySelector(".lane-tv-panel--clock");
            var freshClock = fresh.querySelector(".lane-tv-panel--clock");
            if (!!liveClock !== !!freshClock) {
                mountLaneHtml(newHtml);
                return;
            }

            var liveName = live.querySelector(".lane-tv-panel--name, .lane-tv-detail-grid");
            var freshName = fresh.querySelector(".lane-tv-panel--name, .lane-tv-detail-grid");
            if (!!liveName !== !!freshName) {
                mountLaneHtml(newHtml);
                return;
            }

            var liveGrid = live.querySelector(".lane-tv-grid");
            var freshGrid = fresh.querySelector(".lane-tv-grid");
            if (!!liveGrid !== !!freshGrid) {
                mountLaneHtml(newHtml);
                return;
            }
            if (live.classList.contains("lane-card--tv-active") !== fresh.classList.contains("lane-card--tv-active")) {
                mountLaneHtml(newHtml);
                return;
            }

            if (live.classList.contains("lane-card--tv-single") !== fresh.classList.contains("lane-card--tv-single")) {
                mountLaneHtml(newHtml);
                return;
            }

            if (liveGrid && freshGrid) {
                var liveGridNorm = normalizeLaneHtml(liveGrid.innerHTML);
                var freshGridNorm = normalizeLaneHtml(freshGrid.innerHTML);
                if (liveGridNorm !== freshGridNorm) {
                    mountLaneHtml(newHtml);
                    return;
                }
            }

            var liveAthlete = live.querySelector(".lane-tv-athlete");
            var freshAthlete = fresh.querySelector(".lane-tv-athlete");
            if (!!liveAthlete !== !!freshAthlete) {
                mountLaneHtml(newHtml);
                return;
            }

            var liveRing = live.querySelector("[data-countdown-ring]");
            var freshRing = fresh.querySelector("[data-countdown-ring]");
            if (liveRing && freshRing) {
                var attrs = ["data-start", "data-end", "data-status", "data-vip-mode"];
                for (var k = 0; k < attrs.length; k++) {
                    var a = attrs[k];
                    var nv = freshRing.getAttribute(a) || "";
                    if ((liveRing.getAttribute(a) || "") !== nv) {
                        liveRing.setAttribute(a, nv);
                    }
                }
            }

            updateCountdownRings();
            updateLaneMetaTimes();
            updateWallClock();
            scheduleSizeRing();
            scheduleFitAthleteNames();
            removeTvConnectionUi();
        }

        var laneLoadFailCount = 0;

        function showLaneLoadStatus(message, isError) {
            var root = document.getElementById("laneRoot");
            if (!root) return;
            if (root.firstElementChild && !isError) return;
            root.innerHTML = "<div style=\"padding:24px;text-align:center;font-weight:800;color:" +
                (isError ? "#ff8a8a" : "#9ba7c7") + ";\">" + message + "</div>";
        }

        function loadLane() {
            if (laneLoadInFlight) { pendingReload = true; return; }
            laneLoadInFlight = true;
            if (!document.getElementById("laneRoot")?.firstElementChild) {
                showLaneLoadStatus("Yüklənir…", false);
            }
            return apiFetch("/dashboard/lanes/partial/card/" + laneNumber)
                .then(function (res) {
                    if (!res || !res.ok) {
                        laneLoadFailCount++;
                        var code = res ? res.status : 0;
                        showLaneLoadStatus("Zolaq " + laneNumber + " yüklənmədi (HTTP " + code + "). Yenidən cəhd…", true);
                        return null;
                    }
                    return res.text();
                })
                .then(function (text) {
                    if (text == null) return;
                    laneLoadFailCount = 0;
                    var normalized = normalizeLaneHtml(text);
                    if (normalized !== lastLaneHtml) {
                        lastLaneHtml = normalized;
                        patchLaneDom(text);
                    }
                    lastRingCompact = null;
                    scheduleSizeRing();
                })["catch"](function () {
                    laneLoadFailCount++;
                    showLaneLoadStatus("Şəbəkə xətası — serverə çatılmır. Yenidən cəhd…", true);
                })
                .then(function () {
                    laneLoadInFlight = false;
                    if (pendingReload) {
                        pendingReload = false;
                        setTimeout(loadLane, 50);
                        return;
                    }
                    if (laneLoadFailCount > 0) {
                        var delay = Math.min(30000, 2000 + laneLoadFailCount * 1500);
                        setTimeout(loadLane, delay);
                    }
                });
        }

        var TV_USE_SIGNALR = true;
        var POLL_INTERVAL_MS = 15000;

        function startPolling() {
            setInterval(loadLane, POLL_INTERVAL_MS);
            setInterval(syncLaneTvLogo, 1000);
        }

        document.addEventListener("visibilitychange", function () {
            if (document.visibilityState === "visible") loadLane();
        });
        window.addEventListener("online", loadLane);

        let tickerId = null;
        function startTicker() {
            if (tickerId) clearInterval(tickerId);
            const tick = () => {
                updateCountdownRings();
            };
            tick();
            tickerId = setInterval(tick, 250);
        }

        function startSignalR() {
            if (!TV_USE_SIGNALR) return;
            if (typeof signalR === "undefined" || !signalR.HubConnectionBuilder) {
                setTimeout(startSignalR, 5000);
                return;
            }

            var retryPolicy = {
                nextRetryDelayInMilliseconds: function (ctx) {
                    var attempt = ctx && ctx.previousRetryCount ? ctx.previousRetryCount : 0;
                    if (attempt < 1) return 1000;
                    if (attempt < 3) return 2000;
                    if (attempt < 6) return 5000;
                    if (attempt < 12) return 10000;
                    return 30000;
                }
            };

            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/lane")
                .withAutomaticReconnect(retryPolicy)
                .build();

            if (typeof connection.onreconnected === "function") {
                connection.onreconnected(function () {
                    loadLane();
                });
            }

            if (typeof connection.onclose === "function") {
                connection.onclose(function () {
                    var tryAgain = function () {
                        connection.start().then(function () {
                            loadLane();
                        }, function () {
                            setTimeout(tryAgain, 5000);
                        });
                    };
                    setTimeout(tryAgain, 5000);
                });
            }

            connection.on("lane-updated", loadLane);
            // Bu monitorda xal göstərilmir — `score-updated` çağırışı boş yerə kart yenidən yükləyirdi
            // və hər atışda ekranda gözəyarı yanıb-sönmə yaradırdı, ona görə dinləmirik.

            connection.start().then(
                function () { },
                function () {
                    setTimeout(startSignalR, 5000);
                }
            );
        }

        removeTvConnectionUi();
        syncLaneTvLogo();
        updateWallClock();
        startWallClock();
        loadLane();
        startTicker();
        startPolling();
        startSignalR();
    </script>
</body>
</html>
