@model EShooting.Web.Controllers.MonitorController.ScoreboardViewModel
@{
    Layout = null;
    var laneNumber = Model.LaneNumber;
    var hasSession = Model.HasSession;
    var initialTotal = Model.TotalScore;
    var scoreDisplayEnabled = Model.ScoreDisplayEnabled;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <title>EShooting — Xal monitoru @laneNumber</title>
    <style>
        :root {
            --bg: #000000;
            --score-green: #00FF00;
        }

        * { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            overflow: hidden;
        }

        .wrap {
            height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .score-frame {
            width: 90vw;
            max-width: 1600px;
            height: 78vh;
            max-height: 900px;
            display: flex;
            flex-direction: column;
            padding: 4vw;
            border-radius: 10px;
            border: 12px solid rgba(0, 255, 0, 0.70);
            box-shadow:
                0 0 28px rgba(0, 255, 0, 0.22),
                0 0 90px rgba(0, 255, 0, 0.10);
            min-height: 0;
        }

        .frame-inner {
            flex: 1 1 auto;
            min-height: 0;
            min-width: 0;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .score-pulse-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            max-width: 100%;
            max-height: 100%;
        }

        .score-display {
            font-family: "Segoe UI", "Arial Black", Arial, sans-serif;
            font-weight: 900;
            font-variant-numeric: tabular-nums;
            color: var(--score-green);
            line-height: 1;
            text-align: center;
            user-select: none;
            text-shadow: 0 0 16px rgba(0, 255, 0, 0.45);
            white-space: nowrap;
            font-size: 28vmin;
        }

        .pulse {
            animation: pulse 0.55s ease-in-out;
            transform-origin: 50% 50%;
        }

        @@keyframes pulse {
            0% { transform: scale(1); filter: brightness(1); }
            45% { transform: scale(1.05); filter: brightness(1.25); }
            100% { transform: scale(1); filter: brightness(1); }
        }

        .logo-full {
            width: 100vw;
            height: 100vh;
            display: block;
            object-fit: cover;
            object-position: center;
            background: #fff;
        }

        .hidden { display: none !important; }
    </style>
</head>
<body>
<main class="wrap">
    <img id="logoEl"
         class="logo-full @(hasSession ? "hidden" : "")"
         src="/images/club-logo.jpg"
         alt="Target Archery Club"
         onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/lane-logo.jpg';}else if(this.dataset.fallback==='1'){this.dataset.fallback='2';this.src='/images/placeholder-logo.jpg';}" />

    <div id="scoreFrameEl" class="score-frame @(hasSession ? "" : "hidden")">
        <div class="frame-inner" id="scoreFrameInner">
            <div id="scorePulseWrap" class="score-pulse-wrap">
                <div id="scoreDisplay" class="score-display">@initialTotal</div>
            </div>
        </div>
    </div>
</main>

<script src="/lib/signalr/signalr.min.js"></script>
<script>
    var laneNumber = @laneNumber;
    var scoreDisplayEnabled = @scoreDisplayEnabled.ToString().ToLowerInvariant();
    var POLL_STAGGER_MS = Math.max(0, (laneNumber - 1) * 2500);
    var scoreDisplay = document.getElementById("scoreDisplay");
    var scorePulseWrap = document.getElementById("scorePulseWrap");
    var scoreFrameInner = document.getElementById("scoreFrameInner");
    var scoreFrameEl = document.getElementById("scoreFrameEl");
    var logoEl = document.getElementById("logoEl");
    var latestScoreText = "";
    var latestLanes = [];
    var initialHasSession = @hasSession.ToString().ToLowerInvariant();

    if (initialHasSession && scoreDisplay) {
        latestScoreText = scoreDisplay.textContent || "";
    }

    function fitScoreFontSizePx() {
        if (!scoreDisplay || !scoreFrameInner) return;
        var pad = 6;
        var w = Math.max(0, scoreFrameInner.clientWidth - pad * 2);
        var h = Math.max(0, scoreFrameInner.clientHeight - pad * 2);
        if (w < 4 || h < 4) return;

        var low = 10;
        var high = Math.max(h, w) * 2;
        var best = low;
        for (var i = 0; i < 28; i++) {
            var mid = (low + high) / 2;
            scoreDisplay.style.fontSize = mid + "px";
            var sw = scoreDisplay.scrollWidth;
            var sh = scoreDisplay.scrollHeight;
            if (sw <= w && sh <= h) {
                best = mid;
                low = mid;
            } else {
                high = mid;
            }
        }
        scoreDisplay.style.fontSize = best + "px";
    }

    function scheduleFitScore() {
        var raf = window.requestAnimationFrame || function (cb) { return setTimeout(cb, 16); };
        raf(function () { raf(fitScoreFontSizePx); });
    }

    if (scoreFrameInner && typeof window.ResizeObserver === "function") {
        try {
            var ro = new window.ResizeObserver(function () { scheduleFitScore(); });
            ro.observe(scoreFrameInner);
        } catch (e) { /* ignore */ }
    }

    window.addEventListener("resize", scheduleFitScore);

    if (document.fonts && document.fonts.ready && typeof document.fonts.ready.then === "function") {
        document.fonts.ready.then(scheduleFitScore, function () {});
    } else {
        setTimeout(scheduleFitScore, 100);
        setTimeout(scheduleFitScore, 500);
    }

    if (initialHasSession) {
        scheduleFitScore();
    }

    function apiFetch(input, init) {
        init = init || {};
        var url = (typeof input === "string")
            ? input + (input.indexOf("?") >= 0 ? "&" : "?") + "_=" + Date.now()
            : input;
        init.credentials = "same-origin";
        init.cache = "no-store";
        return fetch(url, init);
    }

    function showScore(value) {
        var text = String(value == null ? 0 : value);
        if (!scoreDisplay || !scoreFrameEl || !logoEl) return;

        logoEl.classList.add("hidden");
        scoreFrameEl.classList.remove("hidden");

        if (text !== latestScoreText) {
            scoreDisplay.textContent = text;
            latestScoreText = text;
            if (scorePulseWrap) {
                scorePulseWrap.classList.remove("pulse");
                void scorePulseWrap.offsetWidth;
                scorePulseWrap.classList.add("pulse");
            }
        }
        scheduleFitScore();
    }

    function showLogo() {
        if (!scoreFrameEl || !logoEl) return;
        scoreFrameEl.classList.add("hidden");
        logoEl.classList.remove("hidden");
        latestScoreText = "";
    }

    function parseApiDate(value) {
        if (!value) return null;
        var s = (typeof value === "string") ? value : "";
        var hasTz = /[zZ]|[+-]\d{2}:\d{2}$/.test(s);
        var d = new Date(s ? (hasTz ? s : (s + "Z")) : value);
        return isNaN(d.getTime()) ? null : d;
    }

    function pickActiveLane(lanes) {
        if (!lanes || !lanes.length) return null;
        var lane = null;
        for (var i = 0; i < lanes.length; i++) {
            if (lanes[i] && lanes[i].laneNumber === laneNumber) { lane = lanes[i]; break; }
        }
        if (!lane || !lane.sessionId) return null;
        if (lane.status === "Completed" || lane.status === "Idle" || lane.status === "Scheduled") return null;

        var start = parseApiDate(lane.startTimeUtc);
        var end = parseApiDate(lane.endTimeUtc);
        var now = new Date();
        if (start && now.getTime() < start.getTime()) return null;
        if (end && now.getTime() >= end.getTime()) return null;
        return lane;
    }

    function refreshFromCachedLanes() {
        if (!scoreDisplayEnabled) {
            showLogo();
            return;
        }
        var active = pickActiveLane(latestLanes);
        if (!active) {
            showLogo();
            return;
        }
        showScore(active.totalScore == null ? 0 : active.totalScore);
    }

    function loadScoreboard() {
        return apiFetch("/dashboard/lanes")
            .then(function (response) {
                if (!response || !response.ok) return null;
                return response.json();
            })
            .then(function (lanes) {
                latestLanes = Object.prototype.toString.call(lanes) === "[object Array]" ? lanes : [];
                refreshFromCachedLanes();
            })["catch"](function () { /* səssiz */ });
    }

    function loadScoreDisplayFlag() {
        return apiFetch("/monitor/score-display")
            .then(function (response) {
                if (!response || !response.ok) return;
                return response.json();
            })
            .then(function (data) {
                if (!data) return;
                scoreDisplayEnabled = Boolean(data.enabled);
                refreshFromCachedLanes();
            })["catch"](function () { /* səssiz */ });
    }

    setInterval(loadScoreboard, 15000);
    setInterval(refreshFromCachedLanes, 1000);

    document.addEventListener("visibilitychange", function () {
        if (document.visibilityState === "visible") {
            loadScoreDisplayFlag();
            loadScoreboard();
        }
    });
    window.addEventListener("online", function () {
        loadScoreDisplayFlag();
        loadScoreboard();
    });

    function startSignalR() {
        if (typeof signalR === "undefined" || !signalR.HubConnectionBuilder) {
            setTimeout(startSignalR, 5000);
            return;
        }

        var retryPolicy = {
            nextRetryDelayInMilliseconds: function (ctx) {
                var attempt = ctx && ctx.previousRetryCount ? ctx.previousRetryCount : 0;
                if (attempt < 1) return 1000;
                if (attempt < 3) return 2000;
                if (attempt < 6) return 5000;
                return 10000;
            }
        };

        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/lane")
            .withAutomaticReconnect(retryPolicy)
            .build();

        connection.on("lane-updated", loadScoreboard);
        connection.on("score-updated", loadScoreboard);
        connection.on("score-display-changed", function (enabled) {
            scoreDisplayEnabled = Boolean(enabled);
            refreshFromCachedLanes();
            if (scoreDisplayEnabled) loadScoreboard();
        });

        if (typeof connection.onreconnected === "function") {
            connection.onreconnected(function () {
                loadScoreDisplayFlag();
                loadScoreboard();
            });
        }
        if (typeof connection.onclose === "function") {
            connection.onclose(function () {
                var tryAgain = function () {
                    connection.start().then(function () {
                        loadScoreDisplayFlag();
                        loadScoreboard();
                    }, function () {
                        setTimeout(tryAgain, 5000);
                    });
                };
                setTimeout(tryAgain, 5000);
            });
        }

        connection.start().then(
            function () { /* qoşuldu */ },
            function () { setTimeout(startSignalR, 5000); }
        );
    }

    setTimeout(function () {
        loadScoreDisplayFlag();
        loadScoreboard();
        startSignalR();
    }, POLL_STAGGER_MS);
</script>
</body>
</html>
