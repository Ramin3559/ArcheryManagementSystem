    async function saveInfoProfile() {
        if (!_currentInfoAthleteId) {
            alert("Əvvəlcə müştərini axtarın.");
            return false;
        }

        const firstName = infoFirstName?.value?.trim() ?? "";
        const lastName = infoLastName?.value?.trim() ?? "";
        const phoneNumber = infoPhoneEdit?.value?.trim() ?? "";
        const categoryRaw = infoCategory?.value ?? "";
        const membershipTypeRaw = infoMembershipType?.value ?? "";
        if (!firstName || !lastName || !phoneNumber) {
