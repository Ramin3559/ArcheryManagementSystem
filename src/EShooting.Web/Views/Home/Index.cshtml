    function resolveSessionStartTimeUtc() {
        const mode = document.querySelector('input[name="sessionStartMode"]:checked')?.value ?? "now";
        if (mode !== "scheduled") {
            return { ok: true, utc: new Date().toISOString() };
        }

        const timeRaw = sessionStartTimeInput?.value ?? "";
        const parts = parseLocalTimeParts(timeRaw);
        if (!parts) {
            return { ok: false, error: "Başlama saatını seçin." };
        }

        const now = new Date();
        const startLocal = new Date(now.getFullYear(), now.getMonth(), now.getDate(), parts.hour, parts.minute, 0, 0);
        if (startLocal.getTime() < Date.now() - 30 * 1000) {
            return { ok: false, error: "Geri vaxta yaza bilməzsiniz. «İndi başla» seçin və ya cari vaxtdan sonrakı saatı yazın." };
        }

        return { ok: true, utc: startLocal.toISOString() };
    }

