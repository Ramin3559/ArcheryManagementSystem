    try { document.getElementById("scheduleBtn")?.addEventListener("click", registerAndSchedule); } catch (e) { console.error(e); }
    try { document.getElementById("groupRegisterBtn")?.addEventListener("click", registerGroupOnLane); } catch (e) { console.error(e); }
