    function applyReceptionWalkInFromAthlete(athlete) {
        _receptionWalkIn = null;
        if (!athlete) {
            syncReceptionWalkInUi();
            return;
        }
        if (athlete.hasActiveWalkIn) {
            const sessionMinutes = Number(athlete.walkInSessionDurationMinutes ?? 90);
            _receptionWalkIn = {
                isActive: true,
                isVip: Boolean(athlete.isVip) || sessionMinutes === 0,
                expiresLocal: athlete.walkInExpiresLocal ?? "",
                sessionDurationMinutes: sessionMinutes
            };
            if (durationMinutesInput instanceof HTMLInputElement) {
                durationMinutesInput.value = String(_receptionWalkIn.sessionDurationMinutes);
            }
        }
