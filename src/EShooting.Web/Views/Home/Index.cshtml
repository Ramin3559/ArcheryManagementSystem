@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Antiforgery.GetAndStoreTokens(Context);
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EShooting — İdarə paneli</title>
    <style>
        :root {
            --bg-a: #fff3e8;
            --bg-b: #f7f4ff;
            --bg-c: #ecf8ff;
            --panel: rgba(255, 255, 255, 0.78);
            --panel-strong: rgba(255, 255, 255, 0.9);
            --text: #1d2440;
            --text-muted: #657296;
            --primary: #6c5cff;
            --primary-strong: #5543f3;
            --success: #0f9d77;
            --warning: #d68a00;
            --danger: #d1435f;
            --border: rgba(122, 138, 178, 0.28);
            --ring: rgba(108, 92, 255, 0.28);
            --shadow: 0 18px 45px rgba(65, 45, 120, 0.16);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            color: var(--text);
            font-family: "Segoe UI", Arial, sans-serif;
            line-height: 1.45;
            background:
                radial-gradient(circle at 0% 0%, #ffd7be 0%, transparent 40%),
                radial-gradient(circle at 100% 0%, #dacdff 0%, transparent 36%),
                radial-gradient(circle at 100% 100%, #cbe8ff 0%, transparent 45%),
                linear-gradient(145deg, var(--bg-a), var(--bg-b) 46%, var(--bg-c));
            min-height: 100vh;
        }

        main {
            max-width: 1280px;
            margin: 0 auto;
            padding: 28px 24px 34px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .logout-form {
            margin: 0;
        }

        .title {
            margin: 0;
            font-size: 30px;
            font-weight: 800;
            letter-spacing: 0.02em;
            color: #1b2140;
        }

        .subtitle {
            margin: 6px 0 0;
            color: var(--text-muted);
            font-weight: 500;
        }

        .header-clock {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 4px;
            padding: 10px 14px;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: var(--panel-strong);
            box-shadow: 0 10px 26px rgba(101, 102, 160, 0.16);
            backdrop-filter: blur(10px);
        }

        .header-clock__label {
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #6b7394;
        }

        .header-clock__value {
            font-size: 26px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.06em;
            color: #2d3260;
        }

        .card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 18px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            transition: transform 0.18s ease, box-shadow 0.22s ease, border-color 0.18s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            border-color: rgba(108, 92, 255, 0.4);
            box-shadow: 0 22px 48px rgba(65, 45, 120, 0.2);
        }

        .card--spaced {
            margin-bottom: 16px;
        }

        .grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(12, 1fr);
        }

        .col-6 {
            grid-column: span 6;
        }

        .col-12 {
            grid-column: span 12;
        }

        @@media (max-width: 900px) {
            .col-6 {
                grid-column: span 12;
            }
        }

        h2 {
            margin: 0 0 12px;
            font-size: 20px;
            font-weight: 800;
            color: #253060;
        }

        .row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 10px;
        }

        .row > * {
            min-width: 140px;
        }

        input,
        select,
        textarea,
        button {
            border-radius: 12px;
            border: 1px solid var(--border);
            padding: 10px 12px;
            color: var(--text);
            transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease, filter 0.2s ease;
        }

        input,
        textarea,
        select {
            min-height: 42px;
            background: #fff;
        }

        input::placeholder {
            color: #8b97b9;
        }

        input:focus,
        select:focus,
        button:focus-visible {
            outline: none;
            border-color: #7668ff;
            box-shadow: 0 0 0 4px var(--ring);
        }

        button {
            cursor: pointer;
            font-weight: 700;
        }

        .btn {
            min-height: 42px;
            border-radius: 12px;
            letter-spacing: 0.01em;
        }

        .btn-primary {
            border: none;
            color: #fff;
            background: linear-gradient(120deg, var(--primary), #8a57ff);
            box-shadow: 0 10px 22px rgba(108, 92, 255, 0.32);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            background: linear-gradient(120deg, var(--primary-strong), #7a4df0);
        }

        .btn-secondary {
            border: none;
            color: #fff;
            background: linear-gradient(125deg, #25a2d7, #1f86d8);
            box-shadow: 0 10px 22px rgba(36, 137, 214, 0.3);
        }

        .btn-secondary:hover {
            transform: translateY(-1px);
            filter: brightness(1.04);
        }

        .btn-ghost {
            background: rgba(255, 255, 255, 0.75);
            color: #37426e;
            border: 1px solid var(--border);
        }

        .btn-ghost:hover {
            border-color: rgba(108, 92, 255, 0.38);
            background: #fff;
        }

        .btn-danger {
            background: rgba(209, 67, 95, 0.12);
            color: #8d2140;
            border: 1px solid rgba(209, 67, 95, 0.35);
        }

        .btn-danger:hover {
            background: rgba(209, 67, 95, 0.18);
            border-color: rgba(209, 67, 95, 0.52);
        }

        .btn-success {
            border: 1px solid rgba(18, 153, 104, 0.55);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .btn-success:hover {
            border-color: rgba(18, 153, 104, 0.72);
            background: rgba(18, 153, 104, 0.24);
        }

        .btn-sm {
            min-height: 38px;
            padding: 8px 14px;
            font-size: 13px;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        @@media (max-width: 900px) {
            .stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .stat {
            border-radius: 15px;
            padding: 14px;
            border: 1px solid rgba(122, 138, 178, 0.23);
            background: rgba(255, 255, 255, 0.72);
            box-shadow: 0 10px 24px rgba(104, 93, 161, 0.14);
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .stat-value {
            margin-top: 6px;
            font-size: 28px;
            line-height: 1;
            font-weight: 800;
            color: #222d58;
        }

        .notice {
            margin-top: 6px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .status-pill {
            display: inline-block;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 700;
            background: rgba(86, 103, 148, 0.18);
            color: #52618f;
        }

        .status-pill.Active {
            background: rgba(15, 157, 119, 0.16);
            color: #0b8a69;
        }

        .status-pill.Completed {
            background: rgba(78, 102, 255, 0.16);
            color: #445fd4;
        }

        .status-pill.Scheduled {
            background: rgba(214, 138, 0, 0.2);
            color: #b57100;
        }

        .lane-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }

        @@media (max-width: 1100px) {
            .lane-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 700px) {
            .lane-grid {
                grid-template-columns: 1fr;
            }
        }

        .lane-card {
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(122, 138, 178, 0.25);
            border-radius: 16px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            box-shadow: 0 14px 24px rgba(96, 87, 157, 0.12);
            transition: transform 0.15s ease, box-shadow 0.2s ease;
        }

        .lane-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 30px rgba(96, 87, 157, 0.16);
        }

        .lane-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .lane-title {
            margin: 0;
            font-size: 17px;
            font-weight: 800;
            color: #202c56;
        }

        .lane-type {
            font-size: 11px;
            color: #7b86a7;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .lane-meta {
            margin: 4px 0;
            color: #667395;
            font-size: 13px;
        }

        .lane-meta--compact {
            font-size: 12px;
            line-height: 1.35;
        }

        .score {
            margin-top: 10px;
            font-weight: 800;
            font-size: 22px;
            color: #24305f;
        }

        .countdown-ring-wrap {
            --ring-track: rgba(62, 77, 130, 0.14);
            --ring-accent: #17ad80;
            --ring-glow: rgba(23, 173, 128, 0.25);
            position: relative;
            width: 132px;
            height: 132px;
            margin: 12px auto 4px;
        }

        .countdown-ring-wrap--compact {
            width: 52px;
            height: 52px;
            margin: 0 auto;
        }

        .countdown-ring__svg {
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
            filter: drop-shadow(0 0 10px var(--ring-glow));
        }

        .countdown-ring__track {
            fill: none;
            stroke: var(--ring-track);
            stroke-width: 7;
        }

        .countdown-ring__progress {
            fill: none;
            stroke: var(--ring-accent);
            stroke-width: 7;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.35s ease, stroke 0.3s ease, filter 0.3s ease;
        }

        .countdown-ring__center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 8px;
            pointer-events: none;
        }

        .countdown-ring__timer {
            font-size: 22px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.04em;
            line-height: 1.1;
            color: #26325f;
        }

        .countdown-ring-wrap--compact .countdown-ring__timer {
            font-size: 11px;
            font-weight: 700;
        }

        .countdown-ring__caption {
            margin-top: 4px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #7a86a8;
        }

        .lane-card {
            position: relative;
        }

        .lane-bottom-hint {
            position: absolute;
            left: 16px;
            bottom: 62px; /* above Stop button */
            font-weight: 900;
            font-size: 14px;
            color: #11824b;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
            pointer-events: none;
        }

        .lane-bottom-hint.is-show {
            opacity: 1;
            transform: translateY(0);
        }

        .lane-bottom-hint.is-warn {
            color: #c77700;
        }

        .lane-bottom-hint.is-critical {
            color: #b63852;
        }

        .equip-fab {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            border: 1px solid rgba(41,55,89,0.22);
            background: rgba(255,255,255,0.92);
            box-shadow: 0 10px 30px rgba(16, 24, 40, 0.22);
            cursor: pointer;
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
        }

        .equip-fab:hover { transform: translateY(-1px); }
        .equip-fab--hidden { display: none; }
        .equip-fab--idle { background: rgba(245, 246, 250, 0.92); }
        .equip-fab--ok { background: rgba(27, 191, 122, 0.16); border-color: rgba(27, 191, 122, 0.28); }
        .equip-fab--bad { background: rgba(209, 67, 95, 0.18); border-color: rgba(209, 67, 95, 0.35); }

        @@keyframes equipPulse {
            0% { box-shadow: 0 0 0 0 rgba(209, 67, 95, 0.28), 0 10px 30px rgba(16, 24, 40, 0.22); }
            70% { box-shadow: 0 0 0 14px rgba(209, 67, 95, 0.0), 0 10px 30px rgba(16, 24, 40, 0.22); }
            100% { box-shadow: 0 0 0 0 rgba(209, 67, 95, 0.0), 0 10px 30px rgba(16, 24, 40, 0.22); }
        }

        .equip-fab--pulse { animation: equipPulse 1.25s ease-out infinite; }

        .equip-fab__icon {
            font-size: 18px;
            line-height: 1;
        }

        .equip-fab__badge {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 20px;
            height: 20px;
            border-radius: 999px;
            padding: 0 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 900;
            color: #fff;
            background: #1bbf7a;
            border: 2px solid rgba(255,255,255,0.92);
        }

        .equip-fab--bad .equip-fab__badge { background: #d1435f; }
        .equip-fab--idle .equip-fab__badge { background: #7a86a8; }

        .equip-panel {
            position: fixed;
            top: 86px;
            right: 14px;
            width: min(380px, 92vw);
            z-index: 8887;
            background: rgba(255,255,255,0.95);
            border: 1px solid rgba(41,55,89,0.22);
            border-radius: 14px;
            padding: 12px;
            box-shadow: 0 16px 50px rgba(16, 24, 40, 0.28);
            transform: translateX(calc(100% + 20px));
            opacity: 0;
            pointer-events: none;
            transition: transform 0.22s ease, opacity 0.22s ease;
        }

        .equip-panel.is-open {
            transform: translateX(0);
            opacity: 1;
            pointer-events: auto;
        }

        .equip-panel__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .countdown-ring-wrap.is-pending {
            --ring-accent: #d68a00;
            --ring-glow: rgba(214, 138, 0, 0.24);
        }

        .countdown-ring-wrap.is-live.is-warn:not(.is-critical),
        .countdown-ring-wrap.is-pending.is-warn:not(.is-critical) {
            --ring-accent: #ef8f1f;
            --ring-glow: rgba(239, 143, 31, 0.3);
        }

        .countdown-ring-wrap.is-live.is-critical,
        .countdown-ring-wrap.is-pending.is-critical {
            --ring-accent: #d1435f;
            --ring-glow: rgba(209, 67, 95, 0.34);
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer,
        .countdown-ring-wrap.is-pending.is-critical .countdown-ring__timer {
            color: #b63852;
        }

        .countdown-ring-wrap.is-done,
        .countdown-ring-wrap.is-idle {
            --ring-accent: rgba(120, 132, 168, 0.55);
            --ring-glow: transparent;
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__svg {
            animation: ring-pulse 0.95s ease-in-out infinite;
        }

        @@keyframes ring-pulse {
            0%, 100% { filter: drop-shadow(0 0 6px var(--ring-glow)); }
            50% { filter: drop-shadow(0 0 16px var(--ring-glow)); }
        }

        .table-countdown-cell {
            vertical-align: middle;
            min-width: 64px;
        }

        .lane-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
        }

        .lane-score-input {
            flex: 1;
            min-width: 0;
        }

        .lane-score-btn {
            min-width: 86px;
            padding: 8px 10px;
            font-size: 12px;
            border: none;
            color: #fff;
            background: linear-gradient(125deg, #25a2d7, #1f86d8);
        }

        .pick-session {
            margin-top: 10px;
            width: 100%;
            min-height: 38px;
            padding: 8px 12px;
            font-size: 12px;
            border: 1px solid rgba(108, 92, 255, 0.28);
            background: rgba(108, 92, 255, 0.12);
            color: #403a97;
            font-weight: 700;
        }

        .pick-session:hover {
            border-color: rgba(108, 92, 255, 0.55);
            background: rgba(108, 92, 255, 0.17);
        }

        .stop-session-btn {
            margin-top: 8px;
            width: 100%;
            min-height: 38px;
            padding: 8px 12px;
            border-radius: 10px;
            border: 1px solid rgba(209, 67, 95, 0.4);
            background: rgba(209, 67, 95, 0.14);
            color: #a72d48;
            font-size: 12px;
            font-weight: 700;
        }

        .stop-session-btn:hover {
            border-color: rgba(209, 67, 95, 0.72);
            background: rgba(209, 67, 95, 0.2);
        }

        .warn {
            margin-top: 6px;
            font-size: 13px;
            font-weight: 600;
        }

        .warn.ok {
            color: #128461;
        }

        .warn.alert {
            color: #b26d00;
        }

        .warn.danger {
            color: #b83854;
        }

        .table-wrap {
            margin-top: 12px;
            overflow-x: auto;
            border: 1px solid var(--border);
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.75);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 760px;
        }

        th,
        td {
            border-bottom: 1px solid rgba(122, 138, 178, 0.2);
            padding: 11px 10px;
            text-align: left;
            font-size: 13px;
        }

        th {
            color: #586892;
            font-weight: 700;
            background: rgba(108, 92, 255, 0.06);
        }

        tr:hover td {
            background: rgba(108, 92, 255, 0.04);
        }

        .tv-links {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
            align-items: center;
        }

        .tv-link {
            display: inline-block;
            padding: 8px 12px;
            border-radius: 11px;
            border: 1px solid rgba(108, 92, 255, 0.25);
            background: rgba(108, 92, 255, 0.1);
            color: #413c9a;
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            transition: transform 0.15s ease, border-color 0.2s ease, background 0.2s ease;
        }

        .tv-link:hover {
            transform: translateY(-1px);
            border-color: rgba(108, 92, 255, 0.52);
            background: rgba(108, 92, 255, 0.16);
        }

        .tv-link--pro {
            margin-left: 8px;
            border-color: rgba(214, 138, 0, 0.42);
            background: rgba(255, 245, 225, 0.75);
            color: #6a3f00;
        }

        .tv-link--pro-first {
            margin-left: 18px;
        }

        .tv-link--active {
            border-color: rgba(18, 153, 104, 0.55);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .tv-link--active.tv-link--pro {
            border-color: rgba(18, 153, 104, 0.58);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .tv-link.tv-link--disabled,
        .tv-link[aria-disabled="true"] {
            cursor: default;
            pointer-events: none;
            transform: none;
        }

        .subscription-table td,
        .subscription-table th {
            white-space: nowrap;
        }

        .upcoming-list {
            margin: 10px 0 0;
            padding-left: 18px;
        }

        .upcoming-list li {
            margin: 6px 0;
            color: #33406d;
        }

        .upcoming-tag {
            display: inline-block;
            margin-left: 6px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            background: rgba(214, 138, 0, 0.18);
            color: #9a6100;
        }

        .notice.notice--warn {
            background: rgba(255, 214, 102, 0.42);
            border-color: rgba(214, 138, 0, 0.45);
            color: #6a3f00;
            font-weight: 800;
        }

        .notice.notice--ok {
            background: rgba(27, 191, 122, 0.16);
            border-color: rgba(27, 191, 122, 0.32);
            color: #0f5c39;
            font-weight: 800;
        }

        .notice.notice--error {
            background: rgba(209, 67, 95, 0.16);
            border-color: rgba(209, 67, 95, 0.30);
            color: #6a1024;
            font-weight: 800;
        }

        .avail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(88px, 1fr));
            gap: 8px;
            width: 100%;
            margin-top: 8px;
        }

        .slot {
            border-radius: 12px;
            border: 1px solid rgba(41, 55, 89, 0.18);
            padding: 10px 10px;
            background: rgba(255, 255, 255, 0.8);
            font-weight: 900;
            color: #1a2650;
        }

        .slot.slot--free {
            border-color: rgba(18, 153, 104, 0.40);
            background: rgba(18, 153, 104, 0.10);
            color: #0b5a3d;
            cursor: pointer;
        }

        .slot.slot--busy {
            border-color: rgba(209, 67, 95, 0.45);
            background: rgba(209, 67, 95, 0.10);
            color: #8d2140;
            opacity: 0.75;
            cursor: default;
            pointer-events: none;
        }

        .checkbox-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 42px;
            padding: 8px 12px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.76);
            color: #475483;
            font-size: 13px;
            font-weight: 700;
            user-select: none;
        }

        .checkbox-chip input[type="checkbox"] {
            accent-color: var(--primary);
            width: 16px;
            height: 16px;
            margin: 0;
        }

        .group-athletes-input {
            min-height: 44px; /* ilkin açılışda kiçik */
            height: 44px;
            max-height: 240px; /* adlar artdıqca aşağı doğru böyüsün */
            width: auto;
            flex: 1 1 360px;
            resize: none;
            overflow: hidden;
            line-height: 1.35;
            font-family: inherit;
        }

        .group-row {
            align-items: stretch;
            max-width: 780px;
        }

        .group-row > * {
            min-width: 0; /* row default min-width(140px) override */
        }

        .group-register-btn {
            flex: 0 0 auto;
            min-width: 220px;
            white-space: nowrap;
        }
    </style>
</head>
<body>
<main>
    <header class="header">
        <div>
            <h1 class="title">EShooting idarə paneli</h1>
            <p class="subtitle">Planlama, planşetdə xal və canlı monitor.</p>
        </div>
        <div class="header-actions">
            <div class="header-clock" title="Brauzerin yerli vaxtı">
                <span class="header-clock__label">Canlı saat</span>
                <span class="header-clock__value" id="wallClock">--:--:--</span>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-ghost btn-sm">Çıxış</button>
            </form>
                <span class="status-pill" id="connectionBadge">Qoşulur...</span>
        </div>
    </header>

    <section class="stats">
        <article class="stat">
            <div class="stat-label">Zolaqlar (cəmi)</div>
            <div class="stat-value" id="totalLanes">11</div>
        </article>
        <article class="stat">
            <div class="stat-label">Aktiv sessiyalar</div>
            <div class="stat-value" id="activeSessions">0</div>
        </article>
        <article class="stat">
            <div class="stat-label">Planlaşdırılmış</div>
            <div class="stat-value" id="scheduledSessions">0</div>
        </article>
        <article class="stat">
            <div class="stat-label">Bitmiş sessiyalar</div>
            <div class="stat-value" id="completedSessions">0</div>
        </article>
    </section>

    <section class="card card--spaced">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
            <h2 style="margin:0;">TV — ayrı zolaq ekranları</h2>
            <button id="infoBtn" type="button" class="btn btn-primary btn-sm">Məlumat</button>
        </div>
        <p class="notice">Zolaq məlumatlarını və aktiv zolağı göstərmək üçün</p>
        <div class="tv-links">
            @for (var i = 1; i <= 11; i++)
            {
                <span class="tv-link tv-link--disabled @(i >= 9 ? "tv-link--pro" : "") @(i == 9 ? "tv-link--pro-first" : "")"
                      data-tv-lane="@i"
                      aria-disabled="true"
                      title="Yalnız məlumat üçün (klik deaktivdir)">
                    Zolaq @i
                </span>
            }
        </div>
    </section>

    <section class="grid">
        <article class="card col-12">
            <h2>Reception — qeydiyyat</h2>
            <div class="row">
                <input id="firstName" placeholder="Ad (mütləq)" />
                <input id="lastName" placeholder="Soyad (mütləq)" />
                <input id="phoneNumber"
                       placeholder="Telefon (mütləq)"
                       inputmode="tel"
                       autocomplete="tel"
                       maxlength="20"
                       pattern="[0-9+\s()-]{7,20}"
                       title="Yalnız rəqəm və + (min 7 simvol). Məs: +994501234567" />
                <input id="email"
                       type="email"
                       placeholder="Email (opsional)"
                       inputmode="email"
                       autocomplete="email"
                       maxlength="200" />
                <input id="idCardNumber"
                       placeholder="Ş/V nömrəsi (opsional)"
                       autocomplete="off"
                       maxlength="60" />
                <div class="notice" id="receptionLookupHint" style="flex: 1 1 100%; margin-top:-6px; display:none;"></div>
                <select id="category" title="Kateqoriya">
                    <option value="" selected disabled>Kateqoriya seçin</option>
                    <option value="0">Həvəskar</option>
                    <option value="1">Professional</option>
                    <option value="2">Məşqçi</option>
                </select>
                <select id="registrationMode" title="Qeydiyyat növü">
                    <option value="" selected disabled>Qeydiyyat növü seçin</option>
                    <option value="instant">Anlıq yazılma</option>
                    <option value="subscription">Abunəlik yazılma</option>
                </select>
                <select id="membershipType" title="Abunəlik növü">
                    <option value="" selected disabled>Abunəlik növü seçin</option>
                    <option value="2">Hər ikisi (Full)</option>
                    <option value="0">Yalnız oxatma</option>
                    <option value="1">Yalnız zal</option>
                </select>
                <label class="check" style="display:flex;align-items:center;gap:8px;white-space:nowrap;">
                    <input id="isEquipmentIssued" type="checkbox" />
                    Avadanlıq verildi
                </label>
            </div>
            <div class="row" id="instantLaneRow">
                <select id="laneNumber">
                    <option value="1">Zolaq 1 (Həvəskar)</option>
                    <option value="2">Zolaq 2 (Həvəskar)</option>
                    <option value="3">Zolaq 3 (Həvəskar)</option>
                    <option value="4">Zolaq 4 (Həvəskar)</option>
                    <option value="5">Zolaq 5 (Həvəskar)</option>
                    <option value="6">Zolaq 6 (Həvəskar)</option>
                    <option value="7">Zolaq 7 (Həvəskar)</option>
                    <option value="8">Zolaq 8 (Həvəskar)</option>
                    <option value="9">Zolaq 9 (Peşəkar)</option>
                    <option value="10">Zolaq 10 (Peşəkar)</option>
                    <option value="11">Zolaq 11 (Peşəkar)</option>
                </select>
                <input id="durationMinutes" type="number" min="1" max="240" value="3" />
                <button id="scheduleBtn" class="btn btn-primary">Qeydiyyat və planlama</button>
                <button id="updateAthleteBtn" class="btn btn-ghost" type="button" disabled>Məlumatları Yenilə</button>
                <button id="cancelSubscriptionBtn" class="btn btn-danger" type="button">Abunəni ləğv et</button>
            </div>
            <div class="notice" id="sessionInfo">Hələ seçim yoxdur. Müddət dəqiqə ilədir (məs. 3 = 180 saniyə).</div>
        </article>

        <article class="card col-6" style="display:none;">
            <h2>Planşet — xal</h2>
            <div class="row">
                <input id="tabletAthleteName" placeholder="İdmançı" readonly />
                <select id="tabletLaneNumber">
                    <option value="1">Zolaq 1</option>
                    <option value="2">Zolaq 2</option>
                    <option value="3">Zolaq 3</option>
                    <option value="4">Zolaq 4</option>
                    <option value="5">Zolaq 5</option>
                    <option value="6">Zolaq 6</option>
                    <option value="7">Zolaq 7</option>
                    <option value="8">Zolaq 8</option>
                    <option value="9">Zolaq 9</option>
                    <option value="10">Zolaq 10</option>
                    <option value="11">Zolaq 11</option>
                </select>
                <input id="tabletSessionId" type="hidden" value="" />
                <input id="roundNumber" type="number" min="1" value="1" />
                <input id="scoreValue" type="number" min="0" max="10" value="10" />
                <button id="submitScoreBtn" class="btn btn-secondary">Xalı göndər</button>
            </div>
            <div class="notice">Xal 0–10 aralığında olmalıdır.</div>
        </article>

        <article class="card col-12">
            <h2>Qrup qeydiyyatı (bir zolaq)</h2>
            <div class="row group-row">
                <textarea id="groupAthleteNames"
                          class="group-athletes-input"
                          placeholder="Dostların adlarını yazın (hər sətirdə bir nəfər). Yuxarıdakı ad+soyad avtomatik əlavə olunacaq."></textarea>
                <button id="groupRegisterBtn" class="btn btn-primary group-register-btn">Qrup qeydiyyatını tamamla</button>
            </div>
            <div class="notice" id="groupInfo">Yuxarıdakı idmançı + dostları bir zolaqda eyni vaxtda bir sessiyada qeydiyyatdan keçirir (xal yazma dəyişmir).</div>
        </article>

        <article class="card col-12" id="subscriptionSection">
            <h2>Aylıq abunə planlama</h2>
            <div class="row">
                <input id="subscriptionAthleteName" placeholder="Abunəçinin adı, soyadı" readonly />
                <label class="checkbox-chip" title="Full paket: sabit həftəlik plan tələb olunmur">
                    <input id="subscriptionIsFullPackage" type="checkbox" />
                    Full paket
                </label>
                <div class="notice" style="flex: 1 1 100%; margin-top:-6px;">
                    Həftə günlərini seçin. Seçdiyin hər gün üçün aşağıda ayrıca saat və zolaq seçəcəksən.
                </div>
                <div id="subscriptionDays" style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
                    <label class="checkbox-chip"><input type="checkbox" value="1" class="sub-day" /> B.e</label>
                    <label class="checkbox-chip"><input type="checkbox" value="2" class="sub-day" /> Ç.a</label>
                    <label class="checkbox-chip"><input type="checkbox" value="3" class="sub-day" /> Ç</label>
                    <label class="checkbox-chip"><input type="checkbox" value="4" class="sub-day" /> C.a</label>
                    <label class="checkbox-chip"><input type="checkbox" value="5" class="sub-day" /> C</label>
                    <label class="checkbox-chip"><input type="checkbox" value="6" class="sub-day" /> Ş</label>
                    <label class="checkbox-chip"><input type="checkbox" value="0" class="sub-day" /> Bazar</label>
                </div>
                <div id="subscriptionLaneTypesByDay" style="display:grid; grid-template-columns: 1fr; gap:8px; width:100%;"></div>
                <input id="subscriptionDurationMinutes" type="number" min="1" max="240" value="12" title="Aylıq paket (saat)" />
                <input id="subscriptionStartDate" type="date" />
                <input id="subscriptionEndDate" type="date" title="Bitmə tarixi" />
                <button id="createSubscriptionBtn" class="btn btn-primary">Paket yarat</button>
            </div>
            <div class="notice" id="subscriptionInfo">Həftə günlərini seçin, hər gün üçün saat və zolağı təyin edin.</div>
            <div id="upcomingSubscriptionBlock" style="display:none;">
                <h3 style="margin:12px 0 6px; font-size:16px; color:#2c396a;">Vaxtı yaxınlaşan abunəçilər</h3>
                <div class="notice" id="upcomingSubscriptionInfo">Yüklənir...</div>
                <ol class="upcoming-list" id="upcomingSubscriptionRows"></ol>
            </div>
            <div class="notice" id="dayPlanInfo" style="margin-top:10px;">Cari gün üçün abunələr və anlıqlar siyahısı.</div>
            <div class="table-wrap" style="margin-top:10px;">
                <table class="subscription-table">
                    <thead>
                    <tr>
                        <th>Tip</th>
                        <th>İdmançı</th>
                        <th>Zolaq</th>
                        <th>Başla</th>
                        <th>Bitir</th>
                        <th>Gün</th>
                        <th>Müddət</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody id="dayPlanRows"></tbody>
                </table>
            </div>
        </article>

        <article class="card col-12">
            <h2>Zolaq monitoru</h2>
            <div class="lane-grid" id="laneGrid"></div>
        </article>

        <article class="card col-12" style="display:none;">
            <h2>Ətraflı cədvəl</h2>
            <div class="table-wrap">
                <table>
                    <thead>
                    <tr>
                        <th>Zolaq</th>
                        <th>Növ</th>
                        <th>İdmançı</th>
                        <th>Status</th>
                        <th>Qalan</th>
                        <th>Cəmi</th>
                        <th>Xəbərdarlıq</th>
                    </tr>
                    </thead>
                    <tbody id="dashboardRows"></tbody>
                </table>
            </div>
        </article>
    </section>
</main>

<!-- Avadanlıq tədarükü: FAB + açılan panel -->
<div id="equipmentFabWrap" style="position:fixed; top:86px; right:14px; z-index:8888;">
    <button id="equipmentFabBtn"
            type="button"
            aria-label="Avadanlıq Tədarükü"
            class="equip-fab equip-fab--hidden">
        <span class="equip-fab__icon">🏹</span>
        <span id="equipmentFabBadge" class="equip-fab__badge">0</span>
    </button>
</div>

<aside id="equipmentReturnsPanel" class="equip-panel" aria-hidden="true">
    <div class="equip-panel__head">
        <div style="font-weight:900; color:#1a2650;">Avadanlıq Tədarükü</div>
        <button id="equipmentPanelCloseBtn" type="button" class="btn btn-ghost btn-sm">Bağla</button>
    </div>
    <div class="notice" style="margin-top:8px;">Avadanlıq verilib və hələ təhvil alınmayıbsa burada görünəcək.</div>
    <div id="equipmentReturnsList" style="margin-top:10px; display:flex; flex-direction:column; gap:8px; max-height:65vh; overflow:auto;"></div>
    <div style="display:flex; gap:8px; margin-top:10px; flex-wrap:wrap;">
        <button id="equipmentReturnSelectedBtn" type="button" class="btn btn-primary btn-sm">Seçilənləri təhvil al</button>
        <button id="equipmentReturnAllBtn" type="button" class="btn btn-ghost btn-sm">Hamısını təhvil al</button>
    </div>
</aside>

<!-- Abunə ləğvi modal -->
<div id="cancelSubscriptionModal" style="display:none; position:fixed; inset:0; background:rgba(11,18,32,0.55); backdrop-filter: blur(4px); z-index:9999; padding:16px;">
    <div style="max-width:900px; margin:0 auto; background:rgba(255,255,255,0.92); border:1px solid rgba(41,55,89,0.22); border-radius:14px; padding:14px;">
        <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap;">
            <div style="font-weight:800; color:#1a2650;">Abunəni ləğv et</div>
            <button id="cancelSubscriptionCloseBtn" type="button" class="btn btn-ghost btn-sm">Bağla</button>
        </div>
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-top:10px;">
            <input id="cancelSubscriptionSearch" placeholder="Axtar: ad / telefon / email / Ş/V" style="flex:1; min-width:240px;" />
        </div>
        <div class="notice" style="margin-top:8px;">Seçdiyiniz idmançının bütün aktiv abunə planları söndürüləcək.</div>
        <div id="cancelSubscriptionList" style="margin-top:10px; max-height:60vh; overflow:auto; border:1px solid rgba(41,55,89,0.15); border-radius:12px; background:#fff;"></div>
    </div>
</div>

<!-- Abunə konflikt redaktə modal -->
<div id="subscriptionConflictModal" style="display:none; position:fixed; inset:0; background:rgba(11,18,32,0.55); backdrop-filter: blur(4px); z-index:9999; padding:16px;">
    <div style="max-width:980px; margin:0 auto; background:rgba(255,255,255,0.94); border:1px solid rgba(41,55,89,0.22); border-radius:14px; padding:14px;">
        <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap;">
            <div style="font-weight:900; color:#1a2650;">Konflikt redaktə paneli</div>
            <button id="subscriptionConflictCloseBtn" type="button" class="btn btn-ghost btn-sm">Bağla</button>
        </div>
        <div class="notice" id="subscriptionConflictInfo" style="margin-top:10px;">
            Bəzi həftələr doludur. Qırmızı olan tarixlər üçün alternativ vaxt və ya zolaq seçin.
        </div>
        <div id="subscriptionConflictList" style="margin-top:10px; max-height:60vh; overflow:auto; border:1px solid rgba(41,55,89,0.15); border-radius:12px; background:#fff;"></div>
        <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:12px; flex-wrap:wrap;">
            <button id="subscriptionConflictConfirmBtn" type="button" class="btn btn-primary" disabled>Təsdiqlə</button>
        </div>
    </div>
</div>

<!-- Məlumat modal -->
<div id="infoModal"
     style="display:none; position:fixed; inset:0; background:rgba(11,18,32,0.45); backdrop-filter: blur(5px); z-index:9999; padding:16px;">
    <div style="max-width:980px; margin:6vh auto 0; background:rgba(255,255,255,0.95); border:1px solid rgba(41,55,89,0.22); border-radius:14px; padding:14px;">
        <div style="display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap;">
            <div style="font-weight:900; color:#1a2650;">Məlumat</div>
            <button id="infoCloseBtn" type="button" class="btn btn-ghost btn-sm">Bağla</button>
        </div>

        <div class="row" style="margin-top:10px;">
            <input id="infoPhone" placeholder="Telefon (məs: 055-000-00-00)" inputmode="tel" maxlength="20" />
            <input id="infoEmail" type="email" placeholder="E-mail (məs: misal@mail.com)" maxlength="200" />
            <input id="infoIdCard" placeholder="Ş/V (FİN/Seriya) (məs: 7ABC123)" maxlength="60" autocomplete="off" />
        </div>
        <div style="display:flex; justify-content:center; margin-top:10px;">
            <button id="infoShowBtn" type="button" class="btn btn-primary">Göstər</button>
        </div>

        <div class="notice" id="infoResultHint" style="margin-top:10px; display:none;"></div>
        <div class="table-wrap" style="margin-top:10px; max-height:55vh; overflow:auto; display:none;" id="infoTableWrap">
            <table class="subscription-table">
                <thead>
                <tr>
                    <th>Ad və Soyad</th>
                    <th>Aralıq</th>
                    <th>Günlər</th>
                    <th>Seanslar (tarix · saat · müddət)</th>
                </tr>
                </thead>
                <tbody id="infoTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- SignalR JS (iki CDN fallback) -->
<script src="https://cdn.jsdelivr.net/npm/%40microsoft/signalr%408.0.7/dist/browser/signalr.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    const firstNameInput = document.getElementById("firstName");
    const lastNameInput = document.getElementById("lastName");
    const phoneNumberInput = document.getElementById("phoneNumber");
    const emailInput = document.getElementById("email");
    const idCardNumberInput = document.getElementById("idCardNumber");
    const categoryInput = document.getElementById("category");
    const registrationModeInput = document.getElementById("registrationMode");
    const membershipTypeInput = document.getElementById("membershipType");
    const laneNumberInput = document.getElementById("laneNumber");
    const instantLaneRow = document.getElementById("instantLaneRow");
    const durationMinutesInput = document.getElementById("durationMinutes");
    const isEquipmentIssuedInput = document.getElementById("isEquipmentIssued");
    // Vaxtsız checkbox ləğv edildi
    const tabletAthleteNameInput = document.getElementById("tabletAthleteName");
    const tabletLaneNumberInput = document.getElementById("tabletLaneNumber");
    const tabletSessionIdInput = document.getElementById("tabletSessionId");
    const roundNumberInput = document.getElementById("roundNumber");
    const scoreValueInput = document.getElementById("scoreValue");
    const dashboardRows = document.getElementById("dashboardRows");
    const sessionInfo = document.getElementById("sessionInfo");
    const laneGrid = document.getElementById("laneGrid");
    const connectionBadge = document.getElementById("connectionBadge");
    const subscriptionAthleteNameInput = document.getElementById("subscriptionAthleteName");
    const subscriptionLaneTypesByDayEl = document.getElementById("subscriptionLaneTypesByDay");
    const subscriptionDurationMinutesInput = document.getElementById("subscriptionDurationMinutes");
    const subscriptionStartDateInput = document.getElementById("subscriptionStartDate");
    const subscriptionEndDateInput = document.getElementById("subscriptionEndDate");
    const subscriptionIsFullPackageInput = document.getElementById("subscriptionIsFullPackage");
    const subscriptionRows = document.getElementById("subscriptionRows");
    const subscriptionInfo = document.getElementById("subscriptionInfo");
    const upcomingSubscriptionRows = document.getElementById("upcomingSubscriptionRows");
    const upcomingSubscriptionInfo = document.getElementById("upcomingSubscriptionInfo");
    const dayPlanRows = document.getElementById("dayPlanRows");
    const dayPlanInfo = document.getElementById("dayPlanInfo");
    const equipmentReturnsPanel = document.getElementById("equipmentReturnsPanel");
    const equipmentFabBtn = document.getElementById("equipmentFabBtn");
    const equipmentFabBadge = document.getElementById("equipmentFabBadge");
    const equipmentPanelCloseBtn = document.getElementById("equipmentPanelCloseBtn");
    const equipmentReturnsList = document.getElementById("equipmentReturnsList");
    const equipmentReturnSelectedBtn = document.getElementById("equipmentReturnSelectedBtn");
    const equipmentReturnAllBtn = document.getElementById("equipmentReturnAllBtn");

    const subscriptionConflictModal = document.getElementById("subscriptionConflictModal");
    const subscriptionConflictCloseBtn = document.getElementById("subscriptionConflictCloseBtn");
    const subscriptionConflictConfirmBtn = document.getElementById("subscriptionConflictConfirmBtn");
    const subscriptionConflictList = document.getElementById("subscriptionConflictList");
    const subscriptionConflictInfo = document.getElementById("subscriptionConflictInfo");
    const groupAthleteNamesInput = document.getElementById("groupAthleteNames");
    // Qrup qeydiyyatı paneli sadələşdirildi (zolaq/müddət Reception-dan götürülür)
    const groupInfo = document.getElementById("groupInfo");

    const updateAthleteBtn = document.getElementById("updateAthleteBtn");
    const receptionLookupHint = document.getElementById("receptionLookupHint");
    const cancelSubscriptionBtn = document.getElementById("cancelSubscriptionBtn");

    const infoBtn = document.getElementById("infoBtn");
    const infoModal = document.getElementById("infoModal");
    const infoCloseBtn = document.getElementById("infoCloseBtn");
    const infoPhone = document.getElementById("infoPhone");
    const infoEmail = document.getElementById("infoEmail");
    const infoIdCard = document.getElementById("infoIdCard");
    const infoShowBtn = document.getElementById("infoShowBtn");
    const infoResultHint = document.getElementById("infoResultHint");
    const infoTableWrap = document.getElementById("infoTableWrap");
    const infoTableBody = document.getElementById("infoTableBody");
    const cancelSubscriptionModal = document.getElementById("cancelSubscriptionModal");
    const cancelSubscriptionCloseBtn = document.getElementById("cancelSubscriptionCloseBtn");
    const cancelSubscriptionSearch = document.getElementById("cancelSubscriptionSearch");
    const cancelSubscriptionList = document.getElementById("cancelSubscriptionList");
    let allAthletesCache = [];
    let athletesCacheLoadedAtMs = 0;
    let receptionMatchedAthleteId = null;
    let receptionMatchedSnapshot = null; // last "known-good" db snapshot of person fields
    let isAutoFillingReception = false;

    const totalLanesEl = document.getElementById("totalLanes");
    const activeSessionsEl = document.getElementById("activeSessions");
    const scheduledSessionsEl = document.getElementById("scheduledSessions");
    const completedSessionsEl = document.getElementById("completedSessions");
    let latestLanes = [];
    const laneScoreDraft = {};
    let countdownTimerId = null;
    let upcomingCountdownTimerId = null;
    let subscriptionSchedulesCache = [];
    const dayNames = ["Bazar", "Bazar ertəsi", "Çərşənbə axşamı", "Çərşənbə", "Cümə axşamı", "Cümə", "Şənbə"];

    function refreshStats(lanes) {
        totalLanesEl.textContent = String(lanes.length);
        activeSessionsEl.textContent = String(lanes.filter(x => x.status === "Active").length);
        scheduledSessionsEl.textContent = String(lanes.filter(x => x.status === "Scheduled").length);
        completedSessionsEl.textContent = String(lanes.filter(x => x.status === "Completed").length);
    }

    function syncRegistrationModeUi() {
        const mode = registrationModeInput?.value ?? "";
        const isSubscription = mode === "subscription";
        const isInstant = mode === "instant";
        if (instantLaneRow instanceof HTMLElement) {
