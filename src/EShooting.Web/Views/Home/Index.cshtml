    function getSelectedBookingPackage() {
        const id = bookingPackageSelect?.value ?? "";
        if (!id) return null;
        return bookingPackagesCache.find(p => String(p.id) === String(id)) ?? null;
    }

    async function loadBookingPackages() {
        if (!(bookingPackageSelect instanceof HTMLSelectElement)) return;
        try {
            const res = await apiFetch("/packages/active", { timeoutMs: 30000 });
            if (!res.ok) return;
            const list = await res.json().catch(() => []);
            bookingPackagesCache = Array.isArray(list) ? list : [];
            populateBookingPackageSelect();
            syncBookingPackageUi();
        } catch (e) {
            console.error("Paketlər yüklənmədi", e);
        }
    }

    function isVipBillingPackage(pkg) {
        return pkg?.billingType === "Vip";
    }

    function isGymPackage(pkg) {
        return pkg?.scope === "Gym" || pkg?.billingType === "Gym";
    }

    function isGymLaneNumber(laneNumber) {
        return Number(laneNumber) === GYM_LANE_NUMBER;
    }

    function isGymLaneSelected() {
        return isGymLaneNumber(laneNumberInput?.value ?? 0);
    }

    function isGymPackageSelected() {
        const pkg = getSelectedBookingPackage();
        return Boolean(pkg && isGymPackage(pkg));
    }

    function isGymBookingMode() {
        return isGymLaneSelected() || isGymPackageSelected();
    }

    function ensureGymLaneForPackage() {
        if (!(laneNumberInput instanceof HTMLSelectElement)) return;
        const pkg = getSelectedBookingPackage();
        if (pkg && isGymPackage(pkg)) {
            laneNumberInput.value = String(GYM_LANE_NUMBER);
            lastValidLaneNumber = String(GYM_LANE_NUMBER);
            return;
        }
        if (pkg && !isGymPackage(pkg) && isGymLaneNumber(laneNumberInput.value)) {
            const fallback = lastValidLaneNumber && !isGymLaneNumber(lastValidLaneNumber)
                ? lastValidLaneNumber
                : "1";
            laneNumberInput.value = fallback;
            lastValidLaneNumber = fallback;
        }
    }

    function filterPackagesForBooking(packages) {
        const list = Array.isArray(packages) ? packages : [];
        if (isGymBookingMode()) return list.filter(isGymPackage);
        return list.filter(p => !isGymPackage(p));
    }

    function populateBookingPackageSelect() {
        if (!(bookingPackageSelect instanceof HTMLSelectElement)) return;
        const prev = bookingPackageSelect.value;
        const filtered = filterPackagesForBooking(bookingPackagesCache);
        bookingPackageSelect.innerHTML = '<option value="" selected disabled>Paket seçin</option>';
        for (const p of filtered) {
            const opt = document.createElement("option");
            opt.value = p.id;
            const price = p.price != null && p.price !== "" ? ` · ${p.price} ₼` : "";
            const durLabel = Number(p.sessionDurationMinutes) > 0 ? ` · ${p.sessionDurationMinutes} dəq` : (p.billingType === "Vip" ? " · müddətsiz" : "");
            opt.textContent = `${p.name} (${p.billingTypeLabel})${durLabel}${price}`;
            bookingPackageSelect.appendChild(opt);
        }
        if (prev && filtered.some(x => String(x.id) === String(prev))) {
            bookingPackageSelect.value = prev;
        } else {
            bookingPackageSelect.value = "";
        }
    }

    function isWalkInPackage(pkg) {
        return pkg?.schedulingMode === "WalkInFlexible";
    }

    function calcSubscriptionEndDateLocal(startIso, pkg) {
        if (!startIso) return "";
        if (isVipBillingPackage(pkg)) {
            const months = Number(bookingSubMonths?.value ?? 1);
            const start = new Date(`${startIso}T12:00:00`);
            start.setMonth(start.getMonth() + months);
            return start.toISOString().slice(0, 10);
        }
        return bookingSubEndDate?.value ?? "";
    }

    function isActiveVipReception() {
        return Boolean(_receptionWalkIn?.isActive && _receptionWalkIn?.isVip);
    }

    function syncVipReceptionBookingUi() {
        const vipActive = isActiveVipReception();
        if (bookingPackageSelect instanceof HTMLSelectElement) {
            bookingPackageSelect.disabled = vipActive;
            if (vipActive) {
                bookingPackageSelect.value = "";
            }
        }
        if (laneBookingHint instanceof HTMLElement) {
            laneBookingHint.textContent = vipActive
                ? "VIP müştəri — aktiv abunə var. İndi başla və ya saat seçin, zolağı təyin edib «Zolağa yaz» basın."
                : DEFAULT_LANE_BOOKING_HINT;
        }
        if (vipActive) {
            if (registrationModeInput instanceof HTMLInputElement) {
                registrationModeInput.value = "instant";
            }
            if (durationMinutesInput instanceof HTMLInputElement) {
                durationMinutesInput.value = "0";
            }
            if (subscriptionPeriodRow instanceof HTMLElement) subscriptionPeriodRow.style.display = "none";
            if (bookingSubscriptionScheduleRow instanceof HTMLElement) bookingSubscriptionScheduleRow.style.display = "none";
            if (bookingWalkInHint instanceof HTMLElement) bookingWalkInHint.style.display = "none";
            if (bookingVipHint instanceof HTMLElement) {
                bookingVipHint.style.display = "block";
                bookingVipHint.textContent = "VIP abunə aktivdir — paket seçimi lazım deyil.";
            }
            if (packageDurationHint instanceof HTMLElement) {
                packageDurationHint.textContent = "VIP — müddətsiz";
            }
            if (sessionInfo instanceof HTMLElement) {
                sessionInfo.textContent = "VIP müştəri — zolaq və vaxt seçib «Zolağa yaz» basın.";
            }
        } else if (bookingPackageSelect instanceof HTMLSelectElement) {
            bookingPackageSelect.disabled = false;
        }
    }

    function syncBookingPackageUi() {
        if (isActiveVipReception()) {
            syncVipReceptionBookingUi();
            syncRegistrationModeUi();
            return;
        }
        if (_receptionWalkIn?.isActive && bookingPackageSelect instanceof HTMLSelectElement && bookingPackageSelect.value) {
            bookingPackageSelect.value = "";
            if (registrationModeInput instanceof HTMLInputElement) registrationModeInput.value = "";
            showSessionNotice("Aktiv abunə var — paket seçməyin, «Boş zolaq aktiv et» basın.", "ok");
            syncRegistrationModeUi();
            return;
        }
        const pkg = getSelectedBookingPackage();
        ensureGymLaneForPackage();
        const isSubscription = pkg && pkg.billingType !== "OneTime";
        const isWalkIn = isWalkInPackage(pkg);
        const isVip = isVipBillingPackage(pkg);
        const gymMode = isGymBookingMode();
        if (packageDurationHint instanceof HTMLElement) {
            if (!pkg) packageDurationHint.textContent = "";
            else if (isVip) packageDurationHint.textContent = "VIP — müddətsiz full paket";
            else packageDurationHint.textContent = `Müddət: ${pkg.sessionDurationMinutes} dəq`;
        }
        if (subscriptionPeriodRow instanceof HTMLElement) {
            subscriptionPeriodRow.style.display = isSubscription ? "" : "none";
        }
        if (bookingSubEndDateWrap instanceof HTMLElement) {
            bookingSubEndDateWrap.style.display = isSubscription && !isVip ? "" : "none";
        }
        if (bookingSubMonthsWrap instanceof HTMLElement) {
            bookingSubMonthsWrap.style.display = isSubscription && isVip ? "flex" : "none";
        }
        if (bookingSubscriptionScheduleRow instanceof HTMLElement) {
            const hideWeekly = pkg && isGymPackage(pkg);
            bookingSubscriptionScheduleRow.style.display = isSubscription && !isWalkIn && !hideWeekly ? "" : "none";
        }
        if (bookingWalkInHint instanceof HTMLElement) {
            bookingWalkInHint.style.display = isSubscription && isWalkIn && !isVip ? "block" : "none";
        }
        if (bookingVipHint instanceof HTMLElement) {
            bookingVipHint.style.display = isSubscription && isVip ? "block" : "none";
        }
        if (isSubscription && pkg) {
            syncBookingSubscriptionPeriodDefaults(pkg);
            const hideWeekly = pkg && isGymPackage(pkg);
            if (!isWalkIn && !hideWeekly) {
                renderBookingSubscriptionLaneTypesByDay();
            }
        }
        if (durationMinutesInput instanceof HTMLInputElement && isVip) {
            durationMinutesInput.value = "0";
        }
        if (registrationModeInput instanceof HTMLInputElement) {
            if (!pkg) {
                registrationModeInput.value = "";
            } else if (isGymPackage(pkg)) {
                registrationModeInput.value = "subscription";
            } else if (pkg.billingType === "OneTime") {
                registrationModeInput.value = "instant";
            } else {
                registrationModeInput.value = "subscription";
            }
        }
        if (durationMinutesInput instanceof HTMLInputElement) {
            durationMinutesInput.value = pkg ? String(pkg.sessionDurationMinutes || 0) : "0";
        }
        syncRegistrationModeUi();
    }

    function categoryToSelectValue(catRaw) {
        if (catRaw === undefined || catRaw === null || String(catRaw) === "") return "";
        if (typeof catRaw === "number") return String(catRaw);
        const s = String(catRaw).toLowerCase();
        if (s === "amateur" || s === "0") return "0";
        if (s === "professional" || s === "1") return "1";
        if (s === "coach" || s === "2") return "2";
        return String(catRaw);
    }

    function membershipToSelectValue(memRaw) {
        if (memRaw === undefined || memRaw === null || String(memRaw) === "") return "";
        if (typeof memRaw === "number") return String(memRaw);
        const s = String(memRaw).toLowerCase();
        if (s === "shootingonly" || s === "0") return "0";
        if (s === "gymonly" || s === "1") return "1";
        if (s === "fullcombo" || s === "2") return "2";
        return String(memRaw);
    }

    function membershipTypeFromAccess(shooting, gym) {
        if (shooting && gym) return "2";
        if (gym) return "1";
        if (shooting) return "0";
        return "";
    }

    function accessFromMembershipType(memRaw) {
        const val = membershipToSelectValue(memRaw);
        return {
            shooting: val === "0" || val === "2",
            gym: val === "1" || val === "2"
        };
    }

    function parseWeeklyDaysCsv(csv) {
        if (!csv) return [];
        return String(csv)
            .split(/[,;\s-]+/)
            .map(x => Number.parseInt(x, 10))
            .filter(n => Number.isInteger(n) && n >= 0 && n <= 6);
    }

    function formatWeeklyDayLabels(csv) {
        const labels = { 0: "Bazar", 1: "B.e", 2: "Ç.a", 3: "Ç", 4: "C.a", 5: "C", 6: "Ş" };
        return parseWeeklyDaysCsv(csv).map(d => labels[d] ?? String(d)).join(", ");
    }

    function getBookingStartTimeLocal() {
        const mode = document.querySelector('input[name="sessionStartMode"]:checked')?.value ?? "now";
        if (mode === "scheduled" && sessionStartTimeInput instanceof HTMLInputElement && sessionStartTimeInput.value) {
            return sessionStartTimeInput.value;
        }
        const now = new Date();
        return `${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}`;
    }

    function syncBookingSubscriptionPeriodDefaults(pkg) {
        if (!(bookingSubStartDate instanceof HTMLInputElement)) return;
        const today = new Date();
        const startIso = today.toISOString().slice(0, 10);
        if (!bookingSubStartDate.value) bookingSubStartDate.value = startIso;
        if (isVipBillingPackage(pkg)) {
            if (bookingSubMonths instanceof HTMLInputElement && !bookingSubMonths.value) {
                bookingSubMonths.value = "1";
            }
            return;
        }
        if (!(bookingSubEndDate instanceof HTMLInputElement)) return;
        if (!bookingSubEndDate.value) {
            const validity = Number(pkg?.validityDays ?? 0) || (pkg?.billingType === "Yearly" ? 365 : 30);
            const end = new Date(today);
            end.setDate(end.getDate() + validity);
            bookingSubEndDate.value = end.toISOString().slice(0, 10);
        }
    }

    function getSelectedBookingSubscriptionDays() {
        const root = document.getElementById("bookingSubscriptionDays");
        if (!(root instanceof HTMLElement)) return [];
        return Array.from(root.querySelectorAll("input.booking-sub-day"))
            .filter(x => x instanceof HTMLInputElement && x.checked)
            .map(x => Number(x.value))
            .filter(x => Number.isInteger(x) && x >= 0 && x <= 6);
    }

    function renderBookingSubscriptionLaneTypesByDay() {
        if (!(bookingSubscriptionLaneTypesByDayEl instanceof HTMLElement)) return;
        const days = getSelectedBookingSubscriptionDays();
        const cat = Number(categoryInput?.value ?? "0");
        const isAmateur = cat === 0;
        const dayLabel = (d) => {
            switch (d) {
                case 1: return "B.e";
                case 2: return "Ç.a";
                case 3: return "Ç";
                case 4: return "C.a";
                case 5: return "C";
                case 6: return "Ş";
                case 0: return "Bazar";
                default: return String(d);
            }
        };
        const existingTimes = {};
        const existingLanes = {};
        bookingSubscriptionLaneTypesByDayEl.querySelectorAll(".booking-sub-day-time").forEach(inp => {
            if (!(inp instanceof HTMLInputElement)) return;
            const day = inp.getAttribute("data-day");
            if (!day) return;
            existingTimes[day] = inp.value;
        });
        bookingSubscriptionLaneTypesByDayEl.querySelectorAll(".booking-sub-day-lane").forEach(sel => {
            if (!(sel instanceof HTMLSelectElement)) return;
            const day = sel.getAttribute("data-day");
            if (!day) return;
            existingLanes[day] = sel.value;
        });
        if (days.length === 0) {
            bookingSubscriptionLaneTypesByDayEl.innerHTML = "";
            return;
        }

        const maxLane = isAmateur ? 8 : 11;
        bookingSubscriptionLaneTypesByDayEl.innerHTML = days.map(d => `
            <div class="row" style="margin-top:0;">
                <div style="min-width:90px; font-weight:800; color:#2c396a;">${dayLabel(d)}</div>
                <input type="text"
                       inputmode="numeric"
                       data-day="${d}"
                       class="booking-sub-day-time"
                       value="${existingTimes[String(d)] ?? "17:00"}"
                       title="Başlanğıc saat (HH:mm)"
                       placeholder="19:00"
                       pattern="^([01]\\d|2[0-3]):[0-5]\\d$"
                       maxlength="5" />
                <select data-day="${d}" class="booking-sub-day-lane">
                    ${getLaneSelectOptionsHtml(maxLane)}
                </select>
            </div>
        `).join("");

        bookingSubscriptionLaneTypesByDayEl.querySelectorAll(".booking-sub-day-lane").forEach(sel => {
            if (!(sel instanceof HTMLSelectElement)) return;
            const day = sel.getAttribute("data-day");
            if (!day) return;
            const v = existingLanes[day];
            if (v && Number(v) > 0 && Array.from(sel.options).some(o => o.value === v)) {
                sel.value = v;
            } else if (sel.options.length > 0) {
                sel.value = sel.options[0].value;
            }
        });
    }

    function collectBookingSubscriptionSchedule() {
        const selectedDays = getSelectedBookingSubscriptionDays();
        const timeByDay = {};
        document.querySelectorAll(".booking-sub-day-time").forEach(inp => {
            if (!(inp instanceof HTMLInputElement)) return;
            const day = inp.getAttribute("data-day");
            if (!day) return;
            timeByDay[day] = inp.value;
        });
        const laneByDay = {};
        document.querySelectorAll(".booking-sub-day-lane").forEach(sel => {
            if (!(sel instanceof HTMLSelectElement)) return;
            const day = sel.getAttribute("data-day");
            if (!day) return;
            laneByDay[String(day)] = Number(sel.value ?? "0");
        });
        return { selectedDays, timeByDay, laneByDay };
    }

    function validateWalkInSubscriptionPeriod(pkg) {
        const package = pkg ?? getSelectedBookingPackage();
        const periodStart = bookingSubStartDate?.value ?? "";
        if (!periodStart) {
            return "Abunə başlanğıc tarixin seçin.";
        }

        if (isVipBillingPackage(package)) {
            const months = Number(bookingSubMonths?.value ?? 0);
            if (!Number.isInteger(months) || months <= 0 || months > 120) {
                return "VIP abunə müddətini ay sayı ilə qeyd edin (1–120).";
            }
            return null;
        }

        const periodEnd = bookingSubEndDate?.value ?? "";
        if (!periodEnd) {
            return "Abunə bitmə tarixin seçin.";
        }
        if (new Date(periodEnd).getTime() < new Date(periodStart).getTime()) {
            return "Abunə bitmə tarixi başlanğıcdan əvvəl ola bilməz.";
        }
        return null;
    }

    function validateBookingSubscriptionSchedule(pkg) {
        const package = pkg ?? getSelectedBookingPackage();
        if (isWalkInPackage(package)) {
            return validateWalkInSubscriptionPeriod(package);
        }
        if (isGymPackage(package) && isGymBookingMode()) {
            return validateWalkInSubscriptionPeriod(package);
        }

        const periodStart = bookingSubStartDate?.value ?? "";
        const periodEnd = bookingSubEndDate?.value ?? "";
        if (!periodStart || !periodEnd) {
            return "Abunə müddətini seçin (başlanğıc və bitmə tarixi).";
        }
        if (new Date(periodEnd).getTime() < new Date(periodStart).getTime()) {
            return "Abunə bitmə tarixi başlanğıcdan əvvəl ola bilməz.";
        }

        const { selectedDays, timeByDay, laneByDay } = collectBookingSubscriptionSchedule();
        if (!selectedDays.length) {
            return "Həftə günlərini seçin.";
        }

        const missingTimes = selectedDays.filter(d => !/^\d{2}:\d{2}$/.test(timeByDay[String(d)] ?? ""));
        if (missingTimes.length) {
            return "Hər seçilən gün üçün saat təyin edin (HH:mm).";
        }

        const missingLanes = selectedDays.filter(d => {
            const lane = laneByDay[String(d)] ?? 0;
            return !Number.isInteger(lane) || lane <= 0;
        });
        if (missingLanes.length) {
            return "Hər seçilən gün üçün zolaq seçin.";
        }

        return null;
    }

    async function analyzeSubscriptionScheduleConflicts(payload) {
        const analyze = await apiFetch("/subscriptions/schedules/analyze", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        if (!analyze.ok) {
            return { ok: false, error: await readErrorMessage(analyze) || "Konflikt analizi alınmadı." };
        }

        const data = await analyze.json();
        const busy = (Array.isArray(data?.occurrences) ? data.occurrences : []).filter(x => !!x?.isBusy);
        return { ok: true, busy };
    }

    async function postSubscriptionScheduleEntry(payload, overrides) {
        const hasOverrides = Array.isArray(overrides) && overrides.length > 0;
        if (!hasOverrides) {
            return apiFetch("/subscriptions/schedules", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });
        }

        return apiFetch("/subscriptions/schedules/with-exceptions", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                ...payload,
                overrides: overrides.map(ov => ({
                    dateLocal: ov.dateLocal,
                    laneNumber: ov.laneNumber,
                    startTimeLocal: ov.startTimeLocal
                }))
            })
        });
    }

    async function resolveConflictsAndCreateSubscriptionDay(payload, dayLabel) {
        const analysis = await analyzeSubscriptionScheduleConflicts(payload);
        if (!analysis.ok) {
            alert(`Konflikt analizi alınmadı. ${analysis.error}`);
            return { resp: null, createdVia: "analyze_failed" };
        }

        if (analysis.busy.length === 0) {
            const resp = await postSubscriptionScheduleEntry(payload, []);
            return { resp, createdVia: "direct" };
        }

        const resolved = await openSubscriptionConflictModal({
            conflicts: analysis.busy.map(o => ({
                ...o,
                dayOfWeek: payload.dayOfWeek,
                dayLabel,
                baseLaneNumber: Number(payload.laneNumber),
                baseStartTimeLocal: String(payload.startTimeLocal ?? "").slice(0, 5)
            }))
        });

        if (resolved === null) {
            return { resp: null, createdVia: "cancelled" };
        }

        const overrides = resolved.filter(x => Number(x.dayOfWeek) === Number(payload.dayOfWeek));
        const resp = await postSubscriptionScheduleEntry(payload, overrides);
        return { resp, createdVia: "with_exceptions" };
    }

    async function createGymSubscriptionFromSelectedPackage({ athleteId, athleteFullName, pkg }) {
        const periodError = validateWalkInSubscriptionPeriod(pkg);
        if (periodError) {
            alert(periodError);
            return false;
        }

        const periodStart = bookingSubStartDate?.value ?? "";
        const periodEnd = calcSubscriptionEndDateLocal(periodStart, pkg) || bookingSubEndDate?.value || "";
        const sessionMinutes = Number(pkg?.sessionDurationMinutes ?? 60);
        if (!Number.isInteger(sessionMinutes) || sessionMinutes <= 0) {
            alert("Zal paketinin müddəti düzgün deyil.");
            return false;
        }

        const response = await apiFetch("/subscriptions/packages", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                athleteFullName,
                athleteId,
                dayPattern: "1-3-5",
                visitsCount: 1,
                startTimeLocal: "00:00",
                durationMinutes: sessionMinutes,
                startDateLocal: new Date(`${periodStart}T00:00:00`).toISOString(),
                endDateLocal: new Date(`${periodEnd}T00:00:00`).toISOString(),
                preferredLaneTypesByDayOfWeek: {},
                isFullPackage: true
            })
        });
        if (!response.ok) {
            alert(await readErrorMessage(response) || "Zal abunəsi qeydə alınmadı.");
            return false;
        }
        return true;
    }

    async function createSubscriptionFromSelectedPackage({ athleteId, athleteFullName, pkg }) {
        if (isGymPackage(pkg) && isGymBookingMode()) {
            return createGymSubscriptionFromSelectedPackage({ athleteId, athleteFullName, pkg });
        }
        if (isWalkInPackage(pkg)) {
            const periodError = validateWalkInSubscriptionPeriod(pkg);
            if (periodError) {
                alert(periodError);
                return false;
            }
        } else {
            const scheduleError = validateBookingSubscriptionSchedule(pkg);
            if (scheduleError) {
                alert(scheduleError);
                return false;
            }
        }

        const periodStart = bookingSubStartDate?.value ?? "";
        const periodEnd = calcSubscriptionEndDateLocal(periodStart, pkg);

        if (isWalkInPackage(pkg)) {
            const sessionMinutes = isVipBillingPackage(pkg)
                ? 0
                : Number(pkg.sessionDurationMinutes || 90);
            const response = await apiFetch("/subscriptions/packages", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    athleteFullName,
                    athleteId,
                    dayPattern: "1-3-5",
                    visitsCount: 1,
                    startTimeLocal: "00:00",
                    durationMinutes: sessionMinutes,
                    startDateLocal: new Date(`${periodStart}T00:00:00`).toISOString(),
                    endDateLocal: new Date(`${periodEnd}T00:00:00`).toISOString(),
                    preferredLaneTypesByDayOfWeek: {},
                    isFullPackage: true
                })
            });
            if (!response.ok) {
                alert(await readErrorMessage(response) || "Abunə qeydiyyatı alınmadı.");
                return false;
            }
            return true;
        }

        const durationMinutes = Number(pkg?.sessionDurationMinutes ?? 0);
        if (!Number.isInteger(durationMinutes) || durationMinutes <= 0) {
            alert("Paket müddəti düzgün deyil.");
            return false;
        }

        const { selectedDays, timeByDay, laneByDay } = collectBookingSubscriptionSchedule();
        const cat = Number(categoryInput?.value ?? "0");
        const isAmateur = cat === 0;

        const plans = selectedDays.map(dayOfWeek => {
            const laneNumber = laneByDay[String(dayOfWeek)] ?? 0;
            const preferredLaneType = isAmateur ? 1 : preferredLaneTypeFromLane(laneNumber);
            return {
                dayOfWeek,
                dayLabel: dayNames[dayOfWeek] ?? String(dayOfWeek),
                payload: {
                    athleteFullName,
                    athleteId,
                    dayOfWeek,
                    startTimeLocal: timeByDay[String(dayOfWeek)],
                    durationMinutes,
                    activeFromDateLocal: new Date(`${periodStart}T00:00:00`).toISOString(),
                    activeToDateLocal: new Date(`${periodEnd}T00:00:00`).toISOString(),
                    preferredLaneType,
                    laneNumber,
                    isFullPackage: false
                }
            };
        });

        const allConflicts = [];
        for (const plan of plans) {
            const analysis = await analyzeSubscriptionScheduleConflicts(plan.payload);
            if (!analysis.ok) {
                alert(`${plan.dayLabel}: ${analysis.error}`);
                return false;
            }
            for (const item of analysis.busy) {
                allConflicts.push({
                    ...item,
                    dayOfWeek: plan.dayOfWeek,
                    dayLabel: plan.dayLabel,
                    baseLaneNumber: plan.payload.laneNumber,
                    baseStartTimeLocal: String(plan.payload.startTimeLocal ?? "").slice(0, 5)
                });
            }
        }

        const overridesByDay = new Map();
        if (allConflicts.length > 0) {
            const resolved = await openSubscriptionConflictModal({ conflicts: allConflicts });
            if (resolved === null) return false;
            for (const ov of resolved) {
                const key = Number(ov.dayOfWeek);
                if (!overridesByDay.has(key)) overridesByDay.set(key, []);
                overridesByDay.get(key).push({
                    dateLocal: ov.dateLocal,
                    laneNumber: ov.laneNumber,
                    startTimeLocal: ov.startTimeLocal
                });
            }
        }

        for (const plan of plans) {
            const overrides = overridesByDay.get(plan.dayOfWeek) ?? [];
            const resp = await postSubscriptionScheduleEntry(plan.payload, overrides);

            if (!resp.ok) {
                if (resp.status === 409) {
                    let data = null;
                    try { data = await resp.json(); } catch { }
                    if (data?.kind === "busy") {
                        alert(`${plan.dayLabel}: ${data?.error ?? "Seçilmiş vaxt/zolaq doludur."}`);
                        return false;
                    }
                    const existingId = data?.existingScheduleId ?? null;
                    const ok = window.confirm(`${plan.dayLabel}: ${data?.error ?? "Bu gün üçün abunə artıq var. Yenilənsin?"}`);
                    if (!ok) return false;
                    if (!existingId) {
                        alert("Mövcud abunənin ID-si tapılmadı.");
                        return false;
                    }
                    const up = await apiFetch(`/subscriptions/schedules/${encodeURIComponent(existingId)}`, {
                        method: "PUT",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(plan.payload)
                    });
                    if (!up.ok) {
                        alert(await readErrorMessage(up) || "Abunə yenilənmədi.");
                        return false;
                    }
                    continue;
                }
                alert(`${plan.dayLabel}: ${await readErrorMessage(resp) || "Abunə planı yaradılmadı."}`);
                return false;
            }
        }

        return true;
    }

