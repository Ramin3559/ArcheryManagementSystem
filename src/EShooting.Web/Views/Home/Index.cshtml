            const t = ev.target;
            if (!(t instanceof HTMLElement)) return;
            const raw = t.getAttribute("data-remove-group-member");
            if (raw == null) return;
            const idx = Number(raw);
            if (!Number.isInteger(idx) || idx < 0 || idx >= groupMembers.length) return;
            groupMembers.splice(idx, 1);
            renderGroupMembersList();
        });
    } catch (e) { console.error(e); }
    try { document.getElementById("scheduleBtn")?.addEventListener("click", registerAndSchedule); } catch (e) { console.error(e); }
    try { document.getElementById("refreshReceptionBtn")?.addEventListener("click", refreshReceptionPanel); } catch (e) { console.error(e); }
    try { document.getElementById("createSubscriptionBtn")?.addEventListener("click", createSubscriptionSchedule); } catch (e) { console.error(e); }
    try { document.getElementById("submitScoreBtn")?.addEventListener("click", submitScore); } catch (e) { console.error(e); }

    try { infoCloseBtn?.addEventListener("click", closeInfoModal); } catch (e) { console.error(e); }
    try {
        infoModal?.addEventListener("click", e => {
            if (e.target === infoModal) closeInfoModal();
        });
    } catch (e) { console.error(e); }
    try { infoShowBtn?.addEventListener("click", infoShow); } catch (e) { console.error(e); }
    try {
        document.getElementById("scheduleEditCloseBtn")?.addEventListener("click", closeScheduleEditModal);
        document.getElementById("scheduleEditCancelBtn")?.addEventListener("click", closeScheduleEditModal);
        document.getElementById("scheduleEditSaveBtn")?.addEventListener("click", saveScheduleEdit);
        document.getElementById("scheduleEditModal")?.addEventListener("click", function (e) {
            if (e.target && e.target.id === "scheduleEditModal") closeScheduleEditModal();
        });
    } catch (e) { console.error(e); }
    try {
        document.getElementById("occurrenceEditCloseBtn")?.addEventListener("click", closeOccurrenceEditModal);
        document.getElementById("occurrenceEditCancelBtn")?.addEventListener("click", closeOccurrenceEditModal);
        document.getElementById("occurrenceEditSaveBtn")?.addEventListener("click", saveOccurrenceOverride);
        document.getElementById("occurrenceEditDateSelect")?.addEventListener("change", onOccurrenceEditDateSelectChange);
        document.getElementById("occurrenceEditModal")?.addEventListener("click", function (e) {
            if (e.target && e.target.id === "occurrenceEditModal") closeOccurrenceEditModal();
        });
    } catch (e) { console.error(e); }
    try {
        [infoPhone, infoEmail, infoIdCard].forEach(el => {
            if (!(el instanceof HTMLElement)) return;
            el.addEventListener("keydown", ev => {
                if (ev.key === "Enter") {
                    ev.preventDefault();
                    infoShow();
                }
                if (ev.key === "Escape") {
                    ev.preventDefault();
                    closeInfoModal();
                }
            });
        });
    } catch (e) { console.error(e); }
    try { equipmentFabBtn?.addEventListener("click", toggleEquipmentPanel); } catch (e) { console.error(e); }
    try { equipmentPanelCloseBtn?.addEventListener("click", closeEquipmentPanel); } catch (e) { console.error(e); }
    try {
        equipmentReturnSelectedBtn?.addEventListener("click", async () => {
            const entries = Array.from(document.querySelectorAll(".equip-select"))
                .filter(x => x instanceof HTMLInputElement && x.checked)
                .map(x => ({
                    issueId: x.dataset.issueId || null,
                    sessionId: x.dataset.sessionId || x.value
                }));
            await returnEquipment(entries);
        });
    } catch (e) { console.error(e); }
    try {
        equipmentReturnAllBtn?.addEventListener("click", async () => {
            const entries = Array.from(document.querySelectorAll(".equip-select"))
                .filter(x => x instanceof HTMLInputElement)
                .map(x => ({
                    issueId: x.dataset.issueId || null,
                    sessionId: x.dataset.sessionId || x.value
                }));
            await returnEquipment(entries);
        });
    } catch (e) { console.error(e); }
    try { cancelSubscriptionCloseBtn?.addEventListener("click", closeCancelSubscriptionModal); } catch (e) { console.error(e); }
    try { cancelSubscriptionSearch?.addEventListener("input", renderCancelSubscriptionList); } catch (e) { console.error(e); }
    try {
        cancelSubscriptionModal?.addEventListener("click", e => {
            if (e.target === cancelSubscriptionModal) closeCancelSubscriptionModal();
        });
    } catch (e) { console.error(e); }
    try {
        cancelSubscriptionList?.addEventListener("click", e => {
            const t = e.target;
            const btn = t instanceof HTMLElement ? t.closest("[data-cancel-athlete]") : null;
            if (!(btn instanceof HTMLElement)) return;
            const id = btn.getAttribute("data-cancel-athlete");
            if (!id) return;
            const person = (Array.isArray(allAthletesCache) ? allAthletesCache : []).find(x => String(x.id) === String(id));
            const name = (person?.fullName ?? `${person?.firstName ?? ""} ${person?.lastName ?? ""}`.trim() ?? "").trim() || "seçilmiş şəxs";
            const ok = window.confirm(`Seçilmiş şəxsin abunəliyini dayandırmaq istəyirsiniz?\n\n${name}`);
            if (!ok) return;
            cancelSubscription(id);
        });
    } catch (e) { console.error(e); }

    // Vaxtsız mod ləğv edildi
    try { tabletLaneNumberInput?.addEventListener("change", syncTabletScoreContext); } catch (e) { console.error(e); }
    try { categoryInput?.addEventListener("change", refreshLaneOptions); } catch (e) { console.error(e); }
    try { subscriptionIsFullPackageInput?.addEventListener("change", syncFullPackageUi); } catch (e) { console.error(e); }
    try {
        const daysRoot = document.getElementById("subscriptionDays");
        daysRoot?.addEventListener("change", () => { renderSubscriptionLaneTypesByDay(); syncMonthlySplitInfo(); });
        categoryInput?.addEventListener("change", () => { renderSubscriptionLaneTypesByDay(); syncMonthlySplitInfo(); });
        subscriptionDurationMinutesInput?.addEventListener("input", () => { syncMonthlySplitInfo(); });
        renderSubscriptionLaneTypesByDay();
        syncMonthlySplitInfo();
    } catch (e) { console.error(e); }
    // Gün seçimi UI yoxdur — cari gün avtomatik göstərilir
    try {
        firstNameInput?.addEventListener("input", syncSubscriptionAthleteNameFromReception);
        lastNameInput?.addEventListener("input", syncSubscriptionAthleteNameFromReception);
        syncSubscriptionAthleteNameFromReception();
    } catch (e) { console.error(e); }

    // Reception autofill by phone/email/id
    try {
        const debouncedLookup = debounce(() => { tryAutofillReceptionFromLookup(); }, 250);
        phoneNumberInput?.addEventListener("input", () => {
            if (!(phoneNumberInput instanceof HTMLInputElement)) return;
            if (isAutoFillingReception) return;
            const normalized = normalizeDigits(phoneNumberInput.value);
            if (phoneNumberInput.value !== normalized) {
                const pos = phoneNumberInput.selectionStart;
                phoneNumberInput.value = normalized;
                if (typeof pos === "number") phoneNumberInput.setSelectionRange(pos - 1, pos - 1);
            }
            debouncedLookup();
        });
        phoneNumberInput?.addEventListener("blur", () => { if (!isAutoFillingReception) debouncedLookup(); });
        emailInput?.addEventListener("input", () => {
            if (!(emailInput instanceof HTMLInputElement)) return;
            if (isAutoFillingReception) return;
            const trimmed = emailInput.value.trim().toLowerCase();
            if (emailInput.value !== trimmed) emailInput.value = trimmed;
            debouncedLookup();
        });
        emailInput?.addEventListener("blur", () => { if (!isAutoFillingReception) debouncedLookup(); });
        idCardNumberInput?.addEventListener("input", () => { if (!isAutoFillingReception) debouncedLookup(); });
        idCardNumberInput?.addEventListener("blur", () => { if (!isAutoFillingReception) debouncedLookup(); });
    } catch (e) { console.error(e); }
    // Reception-da abunəlik həftəlik cədvəl listener-ləri yoxdur
    try {
        laneNumberInput?.addEventListener("change", () => {
            if (!(laneNumberInput instanceof HTMLSelectElement)) return;
            const opt = laneNumberInput.selectedOptions.length ? laneNumberInput.selectedOptions[0] : null;
            if (opt?.disabled) {
                alert("Bu kateqoriya üçün bu zolağı seçmək olmaz (və ya zolaq hazır deyil).");
                if (lastValidLaneNumber) {
                    laneNumberInput.value = lastValidLaneNumber;
                } else {
                    refreshLaneOptions();
                }
                return;
            }
            lastValidLaneNumber = laneNumberInput.value;
            refreshLaneOptions();
        });
    } catch (e) { console.error(e); }

    try { attachAthleteAutocomplete(); } catch (e) { console.error("attachAthleteAutocomplete error", e); }
    try {
        addCustomerBtn?.addEventListener("click", () => {
            receptionMatchedAthleteId = null;
            receptionMatchedSnapshot = null;
            if (firstNameInput instanceof HTMLInputElement) firstNameInput.value = "";
            if (lastNameInput instanceof HTMLInputElement) lastNameInput.value = "";
            if (phoneNumberInput instanceof HTMLInputElement) phoneNumberInput.value = "";
            if (emailInput instanceof HTMLInputElement) emailInput.value = "";
            if (idCardNumberInput instanceof HTMLInputElement) idCardNumberInput.value = "";
            if (categoryInput instanceof HTMLSelectElement) categoryInput.value = "";
            if (membershipTypeInput instanceof HTMLSelectElement) membershipTypeInput.value = "";
            if (isVipInput instanceof HTMLInputElement) isVipInput.checked = false;
            refreshSelectedCustomerCard();
            openCustomerModal(false);
        });
        editCustomerBtn?.addEventListener("click", () => openCustomerModal(true));
        clearCustomerBtn?.addEventListener("click", () => {
            clearReceptionPersonFields();
            if (customerSearchInput instanceof HTMLInputElement) customerSearchInput.value = "";
            hideAthleteSuggest();
        });
        customerModalSaveBtn?.addEventListener("click", () => { void saveCustomerFromModal(); });
        customerModalCancelBtn?.addEventListener("click", closeCustomerModal);
        customerModalCloseBtn?.addEventListener("click", closeCustomerModal);
        modalIsVip?.addEventListener("change", syncCustomerModalVipUi);
        customerModal?.addEventListener("click", e => {
            if (e.target === customerModal) closeCustomerModal();
        });
    } catch (e) { console.error(e); }
    try { syncFullPackageUi(); } catch (e) { console.error(e); }
    try { ensureLaneEventDelegation(); } catch (e) { console.error(e); }

    function scheduleDeferredReceptionLoads() {
        setTimeout(() => {
            try { void loadEquipmentReturns(); } catch (e) { console.error("loadEquipmentReturns error", e); }
        }, 500);
    }

    try {
        syncGroupBookingUi();
        void loadDashboard({ force: true }).then(() => scheduleDeferredReceptionLoads());
    } catch (e) { console.error("loadDashboard error", e); }

    if (document.readyState === "complete") {
        try { startSignalR(); } catch (e) { console.error("startSignalR error", e); }
    } else {
        window.addEventListener("load", () => {
            try { startSignalR(); } catch (e) { console.error("startSignalR error", e); }
        }, { once: true });
    }
</script>
</body>
</html>
