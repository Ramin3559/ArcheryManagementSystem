    async function adoptExistingAthleteFromPayload(payload) {
        const existingId = payload?.existingId ?? null;
        const existing = payload?.existing ?? null;
        if (!existingId) return null;

        receptionMatchedAthleteId = existingId;
        syncUpdateAthleteButton();
        setLookupHint("Müştəri tapıldı (mövcud qeydiyyat istifadə olunur).");

        if (existing) {
