    function toggleEquipmentPanel() {
        if (!equipmentReturnsPanel) return;
        if (equipmentReturnsPanel.classList.contains("is-open")) closeEquipmentPanel();
        else openEquipmentPanel();
    }

    var signalrLoadAttempts = 0;
    var signalrConnectAttempts = 0;
    var laneHubConnection = null;
    var signalrHandlersBound = false;

    function setConnectionIndicator(state, title) {
        if (!(connectionDot instanceof HTMLElement)) return;
        connectionDot.classList.remove("is-active", "is-error", "is-pending");
        if (state === "active") {
            connectionDot.classList.add("is-active");
            connectionDot.setAttribute("aria-label", "Qoşuldu");
            connectionDot.title = title || "Canlı bağlantı aktivdir";
            return;
        }
        if (state === "pending") {
            connectionDot.classList.add("is-pending");
            connectionDot.setAttribute("aria-label", "Qoşulur");
            connectionDot.title = title || "Canlı bağlantı qurulur";
            return;
        }
        connectionDot.classList.add("is-error");
        connectionDot.setAttribute("aria-label", "Bağlantı yoxdur");
        connectionDot.title = title || "Canlı bağlantı yoxdur";
    }

    async function startSignalR() {
        if (typeof signalR === "undefined" || !signalR?.HubConnectionBuilder) {
            signalrLoadAttempts++;
            if (signalrLoadAttempts < 12) {
                setConnectionIndicator("pending", "Skript yüklənir...");
                setTimeout(startSignalR, 1500);
                return;
            }
            setConnectionIndicator("error", "Canlı bağlantı yoxdur (Yenilə rejimi)");
            return;
        }

        if (laneHubConnection) {
            try {
                const state = laneHubConnection.state;
                if (state === signalR.HubConnectionState.Connected) {
                    setConnectionIndicator("active");
                    return;
                }
                if (state === signalR.HubConnectionState.Connecting
                    || state === signalR.HubConnectionState.Reconnecting) {
                    setConnectionIndicator("pending");
                    return;
                }
            } catch { /* ignore */ }
        }

        setConnectionIndicator("pending", "Qoşulur...");

        const connection = laneHubConnection ?? new signalR.HubConnectionBuilder()
            .withUrl("/hubs/lane")
            .withAutomaticReconnect()
            .build();
        laneHubConnection = connection;

        if (!signalrHandlersBound) {
            signalrHandlersBound = true;
            connection.onreconnecting(() => {
                setConnectionIndicator("pending", "Yenidən qoşulur...");
            });
            connection.onreconnected(() => {
                signalrConnectAttempts = 0;
                setConnectionIndicator("active");
            });
            connection.onclose(() => {
                setConnectionIndicator("pending", "Yenidən qoşulur...");
                setTimeout(startSignalR, 3000);
            });
            connection.on("lane-updated", () => scheduleReceptionRefresh(false));
            connection.on("score-updated", () => scheduleReceptionRefresh(false));
        }

        try {
            await connection.start();
            signalrConnectAttempts = 0;
            setConnectionIndicator("active");
        } catch (err) {
            signalrConnectAttempts++;
            console.error("SignalR connect failed", err);
            if (signalrConnectAttempts < 8) {
                setConnectionIndicator("pending", "Yenidən qoşulur...");
                setTimeout(startSignalR, Math.min(30000, 2000 * signalrConnectAttempts));
                return;
            }
            setConnectionIndicator("error", "Canlı bağlantı yoxdur (Yenilə rejimi)");
        }
    }

