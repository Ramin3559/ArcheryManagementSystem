    function refreshStats(lanes) {
        totalLanesEl.textContent = String(lanes.length);
        activeSessionsEl.textContent = String(lanes.filter(x => resolveLaneDisplayStatus(x) === "Active").length);
        scheduledSessionsEl.textContent = String(lanes.filter(x => resolveLaneDisplayStatus(x) === "Scheduled").length);
        completedSessionsEl.textContent = String(lanes.filter(x => resolveLaneDisplayStatus(x) === "Completed").length);
