    } catch (e) { console.error(e); }
    try { equipmentFabBtn?.addEventListener("click", toggleEquipmentPanel); } catch (e) { console.error(e); }
    try { equipmentPanelCloseBtn?.addEventListener("click", closeEquipmentPanel); } catch (e) { console.error(e); }
    try {
        equipmentReturnSelectedBtn?.addEventListener("click", async () => {
            const checked = Array.from(document.querySelectorAll(".equip-select"))
                .filter(x => x instanceof HTMLInputElement && x.checked)
                .map(x => x.value)
                .filter(Boolean);
            await returnEquipment(checked);
        });
    } catch (e) { console.error(e); }
    try {
        equipmentReturnAllBtn?.addEventListener("click", async () => {
            const all = Array.from(document.querySelectorAll(".equip-select"))
                .filter(x => x instanceof HTMLInputElement)
                .map(x => x.value)
                .filter(Boolean);
            await returnEquipment(all);
        });
    } catch (e) { console.error(e); }
    try { cancelSubscriptionCloseBtn?.addEventListener("click", closeCancelSubscriptionModal); } catch (e) { console.error(e); }
    try { cancelSubscriptionSearch?.addEventListener("input", renderCancelSubscriptionList); } catch (e) { console.error(e); }
    try {
        cancelSubscriptionModal?.addEventListener("click", e => {
            if (e.target === cancelSubscriptionModal) closeCancelSubscriptionModal();
        });
    } catch (e) { console.error(e); }
    try {
        cancelSubscriptionList?.addEventListener("click", e => {
            const t = e.target;
            const btn = t instanceof HTMLElement ? t.closest("[data-cancel-athlete]") : null;
            if (!(btn instanceof HTMLElement)) return;
            const id = btn.getAttribute("data-cancel-athlete");
            if (!id) return;
            cancelSubscription(id);
        });
    } catch (e) { console.error(e); }

    // Vaxtsız mod ləğv edildi
    try { tabletLaneNumberInput?.addEventListener("change", syncTabletScoreContext); } catch (e) { console.error(e); }
    try { categoryInput?.addEventListener("change", refreshLaneOptions); } catch (e) { console.error(e); }
    try { subscriptionIsFullPackageInput?.addEventListener("change", syncFullPackageUi); } catch (e) { console.error(e); }
    try {
        const daysRoot = document.getElementById("subscriptionDays");
        daysRoot?.addEventListener("change", () => { renderSubscriptionLaneTypesByDay(); syncMonthlySplitInfo(); });
        categoryInput?.addEventListener("change", () => { renderSubscriptionLaneTypesByDay(); syncMonthlySplitInfo(); });
        subscriptionDurationMinutesInput?.addEventListener("input", () => { syncMonthlySplitInfo(); });
        const refreshAllAvail = () => {
            if (!(subscriptionLaneTypesByDayEl instanceof HTMLElement)) return;
            subscriptionLaneTypesByDayEl.querySelectorAll("select.sub-day-lane").forEach(sel => {
                if (sel instanceof HTMLSelectElement) refreshLaneAvailabilityForSubscriptionRow(sel);
            });
        };
        subscriptionStartDateInput?.addEventListener("change", refreshAllAvail);
        subscriptionEndDateInput?.addEventListener("change", refreshAllAvail);
        renderSubscriptionLaneTypesByDay();
        syncMonthlySplitInfo();
    } catch (e) { console.error(e); }
    // Gün seçimi UI yoxdur — cari gün avtomatik göstərilir
    try { registrationModeInput?.addEventListener("change", syncRegistrationModeUi); } catch (e) { console.error(e); }
    try {
        firstNameInput?.addEventListener("input", syncSubscriptionAthleteNameFromReception);
        lastNameInput?.addEventListener("input", syncSubscriptionAthleteNameFromReception);
        syncSubscriptionAthleteNameFromReception();
    } catch (e) { console.error(e); }

    // Reception autofill by phone/email/id
    try {
        const debouncedLookup = debounce(() => { tryAutofillReceptionFromLookup(); }, 250);
        phoneNumberInput?.addEventListener("input", () => {
            if (!(phoneNumberInput instanceof HTMLInputElement)) return;
            if (isAutoFillingReception) return;
            const normalized = normalizeDigits(phoneNumberInput.value);
            if (phoneNumberInput.value !== normalized) {
                const pos = phoneNumberInput.selectionStart;
                phoneNumberInput.value = normalized;
                if (typeof pos === "number") phoneNumberInput.setSelectionRange(pos - 1, pos - 1);
            }
            debouncedLookup();
        });
        phoneNumberInput?.addEventListener("blur", () => { if (!isAutoFillingReception) debouncedLookup(); });
        emailInput?.addEventListener("input", () => {
            if (!(emailInput instanceof HTMLInputElement)) return;
            if (isAutoFillingReception) return;
            const trimmed = emailInput.value.trim().toLowerCase();
            if (emailInput.value !== trimmed) emailInput.value = trimmed;
            debouncedLookup();
        });
        emailInput?.addEventListener("blur", () => { if (!isAutoFillingReception) debouncedLookup(); });
        idCardNumberInput?.addEventListener("input", () => { if (!isAutoFillingReception) debouncedLookup(); });
        idCardNumberInput?.addEventListener("blur", () => { if (!isAutoFillingReception) debouncedLookup(); });
    } catch (e) { console.error(e); }
    // Reception-da abunəlik həftəlik cədvəl listener-ləri yoxdur
    try {
        laneNumberInput?.addEventListener("change", () => {
            if (!(laneNumberInput instanceof HTMLSelectElement)) return;
            const opt = laneNumberInput.selectedOptions.length ? laneNumberInput.selectedOptions[0] : null;
            if (opt?.disabled) {
                alert("Bu kateqoriya üçün bu zolağı seçmək olmaz (və ya zolaq hazır deyil).");
                if (lastValidLaneNumber) {
                    laneNumberInput.value = lastValidLaneNumber;
                } else {
                    refreshLaneOptions();
                }
                return;
            }
            lastValidLaneNumber = laneNumberInput.value;
        });
    } catch (e) { console.error(e); }

    try { syncFullPackageUi(); } catch (e) { console.error(e); }
    try { loadDashboard(); } catch (e) { console.error("loadDashboard error", e); }
    try { loadSubscriptionSchedules(); } catch (e) { console.error("loadSubscriptionSchedules error", e); }
    try { loadEquipmentReturns(); } catch (e) { console.error("loadEquipmentReturns error", e); }
    try { startSignalR(); } catch (e) { console.error("startSignalR error", e); }
</script>
</body>
</html>
