    function buildReceptionCurrentSnapshot() {
        const first = (firstNameInput?.value ?? "").trim();
        const last = (lastNameInput?.value ?? "").trim();
        const phone = normalizeDigits(phoneNumberInput?.value);
        const email = normalizeText(emailInput?.value);
        const idCard = normalizeText(idCardNumberInput?.value);
        const category = String(categoryInput?.value ?? "");
        const membership = String(membershipTypeInput?.value ?? "");
        return { first, last, phone, email, idCard, category, membership };
    }

    // Yoxlanış yalnız 5 əsas sahəyə görədir: ad, soyad, telefon, email, FİN.
    // Kateqoriya və abunəlik növü "dəyişdi" hesab edilmir (xəbərdarlıq tetiklənmir).
    function isReceptionDirtyComparedToSnapshot() {
        if (!receptionMatchedAthleteId || !receptionMatchedSnapshot) return false;
        const cur = buildReceptionCurrentSnapshot();
        const prev = receptionMatchedSnapshot;
        const diffs = {};
        if (cur.first !== prev.first) diffs.first = { cur: cur.first, prev: prev.first };
        if (cur.last !== prev.last) diffs.last = { cur: cur.last, prev: prev.last };
        if (cur.phone !== prev.phone) diffs.phone = { cur: cur.phone, prev: prev.phone };
        if (cur.email !== prev.email) diffs.email = { cur: cur.email, prev: prev.email };
        if (cur.idCard !== prev.idCard) diffs.idCard = { cur: cur.idCard, prev: prev.idCard };
        const dirty = Object.keys(diffs).length > 0;
        if (dirty) console.log("[reception] dirty check fərqlər:", diffs);
        return dirty;
    }

    // Verilən bazadakı qeyddən reception snapshot strukturunda obyekt qurur.
    // Yalnız 5 əsas sahə dolduralacaq, kateqoriya/abunəlik müqayisəyə daxil deyil.
    function receptionSnapshotFromExisting(existing) {
        return {
            first: (existing.firstName ?? "").trim(),
            last: (existing.lastName ?? "").trim(),
            phone: normalizeDigits(existing.phoneNumber),
            email: normalizeText(existing.email),
            idCard: normalizeText(existing.idCardNumber)
        };
    }

    // Cari xanalarda yazılmış dəyərləri bazadakı qeyddən fərqliliklə müqayisə edir.
    // Yalnız ad, soyad, telefon, email, FİN-ə baxılır.
    // Qayda: cari xana boşdursa, müqayisə edilmir (yəni boş yazmaq fərq sayılmır).
    // Yalnız cari xanada DƏYƏR varsa və DB-dəki ilə fərqlidirsə, fərq qeyd olunur.
    function receptionDiffersFromExisting(existing) {
        const diffs = collectReceptionDiffs(existing);
        return Object.keys(diffs).length > 0;
    }

    function collectReceptionDiffs(existing) {
        const cur = buildReceptionCurrentSnapshot();
        const ex = receptionSnapshotFromExisting(existing);
        const diffs = {};
        // Yalnız AD və SOYAD müqayisə olunur. Boş yazılan ad/soyad fərq sayılmır.
        // Telefon/email/FİN — bu sahələrdəki dəyişiklik xəbərdarlıq tetikləmir.
        if (cur.first && cur.first !== ex.first) diffs.first = { current: cur.first, db: ex.first };
        if (cur.last && cur.last !== ex.last) diffs.last = { current: cur.last, db: ex.last };
        return diffs;
    }

    function diffsToHumanLabels(diffs) {
        const labels = {
            first: "Ad",
            last: "Soyad"
        };
        const lines = [];
        Object.keys(diffs).forEach(function (k) {
            const d = diffs[k];
            const dbVal = d.db && String(d.db).length ? d.db : "(boş)";
            lines.push(`• ${labels[k]}: "${d.current}" (yazılan) vs "${dbVal}" (bazadakı)`);
        });
        return lines.join("\n");
    }

    // Hər düymədən öncə: əgər artıq autocomplete/lookup ilə şəxs seçilibsə,
    // həmin id üzrə bazadakı qeydi tap və 5 sahə üzrə müqayisə et.
    // Lookup minimum uzunluq tələbinə (telefon>=4) görə qısa telefon yazılışlarında
    // axtarış işə düşmür, ona görə bu yardımçı id-yə əsasən cache-dən tapır.
    async function fetchAthleteById(athleteId) {
        if (!athleteId) return null;
        try {
            const res = await apiFetch(`/athletes/${encodeURIComponent(athleteId)}`, { timeoutMs: 30000 });
            if (!res.ok) return null;
            return await res.json();
        } catch {
            return null;
        }
    }

    async function maybeUpdateAthleteIfDirtyBeforeAction() {
        if (!receptionMatchedAthleteId) return true;
        const existing = await fetchAthleteById(receptionMatchedAthleteId);
        if (!existing) return true;
        return await maybePromptUpdateForFoundAthlete(existing);
    }

    // Lookup nəticəsində mövcud şəxs tapıldıqda yazılmış məlumatların DB-dəki ilə fərqi varsa
    // "yenilənsin?" sualı verir və istifadəçi razı olarsa DB-ni yeniləyir.
    // Yalnız 5 unik sahə (ad, soyad, telefon, email, FİN) müqayisə olunur.
    // Boş yazılmış xana fərq sayılmır.
    async function maybePromptUpdateForFoundAthlete(foundAthlete) {
        if (!foundAthlete || !foundAthlete.id) return true;
        receptionMatchedAthleteId = foundAthlete.id;
        const diffs = collectReceptionDiffs(foundAthlete);
        if (Object.keys(diffs).length === 0) return true;
        console.log("[reception] DB ilə fərq aşkarlandı", diffs);
        const detail = diffsToHumanLabels(diffs);
        const ok = window.confirm(
            "Bu şəxs sistemdə artıq qeydiyyatdadır, lakin yazılan məlumatlar fərqlidir:\n\n" +
            detail + "\n\n" +
            "Bazadakı məlumatlar yenilənsin?");
        if (!ok) return true;
        const missing = validateReceptionBeforeSchedule();
        if (missing) {
            alert(missing);
            return false;
        }
        const updated = await updateAthleteFromReception({ silentSuccess: true });
        return Boolean(updated);
    }

