    function isSameGroupMember(a, b) {
        if (!a || !b) return false;
        if (a.athleteId && b.athleteId && String(a.athleteId) === String(b.athleteId)) return true;
        const phoneA = normalizeDigits(a.phone);
        const phoneB = normalizeDigits(b.phone);
        return Boolean(phoneA && phoneB && phoneA === phoneB);
    }

    async function ensureAthleteFromReceptionFields() {
        const firstName = firstNameInput?.value?.trim() ?? "";
        const lastName = lastNameInput?.value?.trim() ?? "";
        const phoneNumber = phoneNumberInput?.value?.trim() ?? "";
        const membershipTypeRaw = membershipTypeInput?.value ?? "";
        const categoryRaw = categoryInput?.value ?? "";
        if (!firstName || !lastName || !phoneNumber) {
            return { ok: false, error: "Ad, Soyad və Telefon daxil edin (və ya axtarışdan seçin)." };
        }

        if (receptionMatchedAthleteId) {
            return {
                ok: true,
                athleteId: receptionMatchedAthleteId,
                fullName: `${firstName} ${lastName}`.trim(),
                phone: phoneNumber
            };
        }

        try {
            const phoneQ = normalizeDigits(phoneNumber);
            const emailQ = normalizeText(emailInput?.value);
            const idQ = normalizeText(idCardNumberInput?.value);
            const qs = new URLSearchParams();
            if (phoneQ) qs.set("phone", phoneQ);
            if (emailQ) qs.set("email", emailQ);
            if (idQ) qs.set("idCardNumber", idQ);
            const lookupRes = await apiFetch(`/athletes/lookup?${qs.toString()}`, { timeoutMs: 30000 });
            if (lookupRes.ok) {
                const found = await lookupRes.json();
                if (found?.id) {
                    receptionMatchedAthleteId = found.id;
                    syncUpdateAthleteButton();
                    return {
                        ok: true,
                        athleteId: found.id,
                        fullName: found.fullName || `${firstName} ${lastName}`.trim(),
                        phone: found.phoneNumber || phoneNumber
                    };
                }
            }
        } catch { /* ignore */ }

        const wantsCreate = window.confirm(
            "Bu müştəri sistemdə tapılmadı.\n\nQeydiyyata alınıb qrupa əlavə edilsin?"
        );
        if (!wantsCreate) {
            return { ok: false, error: "Müştəri qeydiyyatdan keçməyib." };
        }
        if (!membershipTypeRaw || !categoryRaw) {
            openCustomerModal(false);
            return { ok: false, error: "Kateqoriya və abunəlik növünü «Müştəri əlavə et» pəncərəsindən seçin." };
        }

        const athleteResponse = await apiFetch("/athletes", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            timeoutMs: 60000,
            body: JSON.stringify({
                firstName,
                lastName,
                phoneNumber,
                email: emailInput?.value?.trim() || null,
                idCardNumber: idCardNumberInput?.value?.trim() || null,
                category: Number(categoryRaw),
                isSubscriber: false,
                membershipType: Number(membershipTypeRaw),
                isVip: Boolean(isVipInput?.checked)
            })
        });

        if (!athleteResponse.ok) {
            if (athleteResponse.status === 409) {
                let payload = null;
                try { payload = await athleteResponse.json(); } catch { }
                const existingId = payload?.existingId ?? null;
                if (existingId) {
                    receptionMatchedAthleteId = existingId;
                    syncUpdateAthleteButton();
                    return {
                        ok: true,
                        athleteId: existingId,
                        fullName: `${firstName} ${lastName}`.trim(),
                        phone: phoneNumber
                    };
                }
            }
            const message = await readErrorMessage(athleteResponse);
            return { ok: false, error: message || "Müştəri qeydə alınmadı." };
        }

        const athleteData = await athleteResponse.json();
        receptionMatchedAthleteId = athleteData?.id ?? null;
        syncUpdateAthleteButton();
        allAthletesCache = [];
        athletesCacheLoadedAtMs = 0;
        return {
            ok: true,
            athleteId: receptionMatchedAthleteId,
            fullName: `${firstName} ${lastName}`.trim(),
            phone: phoneNumber
        };
    }

