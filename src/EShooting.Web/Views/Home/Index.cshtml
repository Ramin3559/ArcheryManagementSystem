    async function createSessionAfterOccurrenceEdit(dateLocal, startTimeLocal, durationMinutes, laneNumber) {
        var athleteId = _currentInfoAthleteId;
        if (!athleteId) return { ok: false, error: "Müştəri tapılmadı." };
        try {
            var activeRes = await apiFetch("/sessions/active-by-athlete/" + encodeURIComponent(athleteId), { timeoutMs: 30000 });
            if (activeRes.ok) {
                return { ok: true, skipped: true };
            }
        } catch { /* ignore */ }
        var parts = String(dateLocal).split("-").map(Number);
        var timeParts = String(startTimeLocal).split(":").map(Number);
        if (parts.length < 3 || timeParts.length < 2) return { ok: false, error: "Tarix və ya saat yanlışdır." };
        var localStart = new Date(parts[0], parts[1] - 1, parts[2], timeParts[0], timeParts[1], 0, 0);
        var equipPayload = typeof buildSessionEquipmentPayload === "function" ? buildSessionEquipmentPayload() : {};
        try {
            var res = await apiFetch("/sessions", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                timeoutMs: 90000,
                body: JSON.stringify({
                    athleteId: athleteId,
                    laneNumber: laneNumber,
                    preferredLaneType: preferredLaneTypeFromLane(laneNumber),
                    startTimeUtc: localStart.toISOString(),
                    durationMinutes: durationMinutes,
                    ...equipPayload
                })
            });
            if (!res.ok) {
                var msg = await readErrorMessage(res);
                return { ok: false, error: msg || "Sessiya yaradılmadı." };
            }
            return { ok: true };
        } catch (e) {
            return { ok: false, error: getExceptionMessage(e) };
        }
    }

    async function saveOccurrenceOverride() {
        var sel = document.getElementById("occurrenceEditDateSelect");
        var sidEl = document.getElementById("occurrenceEditScheduleId");
        var dEl = document.getElementById("occurrenceEditDateLocal");
        var targetDateEl = document.getElementById("occurrenceEditTargetDate");
        if (sel instanceof HTMLSelectElement && sel.value) {
            var parts = sel.value.split("|");
            if (parts.length >= 2) {
                if (sidEl instanceof HTMLInputElement) sidEl.value = parts[0];
                if (dEl instanceof HTMLInputElement) dEl.value = parts[1];
            }
        }
        var sid = sidEl instanceof HTMLInputElement ? sidEl.value.trim() : "";
        var sourceDateLocal = dEl instanceof HTMLInputElement ? dEl.value.trim() : "";
        var targetDateLocal = targetDateEl instanceof HTMLInputElement ? targetDateEl.value.trim() : "";
        var startTimeLocal = String(document.getElementById("occurrenceEditStartTime")?.value || "").trim();
        var duration = Number(document.getElementById("occurrenceEditDuration")?.value || 0);
        var laneNumber = Number(document.getElementById("occurrenceEditLaneNumber")?.value || 0);
        if (!sid || !sourceDateLocal) return;
        if (!startTimeLocal) { setOccurrenceEditHint("Saatı daxil edin.", "error"); return; }
        if (!Number.isInteger(duration) || duration <= 0) { setOccurrenceEditHint("Paket müddəti tapılmadı.", "error"); return; }
        if (!Number.isInteger(laneNumber) || laneNumber <= 0) { setOccurrenceEditHint("Zolaq seçin.", "error"); return; }

        var isReschedule = Boolean(targetDateLocal && targetDateLocal !== sourceDateLocal);
        var sessionDateLocal = isReschedule ? targetDateLocal : sourceDateLocal;
        var createSession = _occurrenceEditCreateSessionAfterSave;
        setOccurrenceEditHint("Yadda saxlanılır...", "warn");
        try {
            var res;
            if (isReschedule) {
                res = await apiFetch("/subscriptions/schedules/" + encodeURIComponent(sid) + "/reschedule-occurrence", {
                    method: "PUT",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        sourceDateLocal: sourceDateLocal,
                        targetDateLocal: targetDateLocal,
                        startTimeLocal: startTimeLocal,
                        laneNumber: laneNumber,
                        durationMinutes: duration
                    })
                });
            } else {
                res = await apiFetch("/subscriptions/schedules/" + encodeURIComponent(sid) + "/occurrence-override", {
                    method: "PUT",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        dateLocal: sourceDateLocal,
                        startTimeLocal: startTimeLocal,
                        laneNumber: laneNumber,
                        durationMinutes: duration
                    })
                });
            }
            if (!res.ok) {
                var msg = await readErrorMessage(res);
                setOccurrenceEditHint(msg || "Yadda saxlanılmadı.", "error");
                return;
            }

            if (createSession) {
                var sessionResult = await createSessionAfterOccurrenceEdit(sessionDateLocal, startTimeLocal, duration, laneNumber);
                if (!sessionResult.ok) {
                    setOccurrenceEditHint("Abunə yeniləndi, amma sessiya yaradılmadı: " + (sessionResult.error || ""), "warn");
                    await infoShow();
                    return;
                }
            }

            setOccurrenceEditHint(isReschedule ? "Seans yeni tarixə köçürüldü və yazıldı." : "Uğurla yadda saxlanıldı.", "ok");
            _occurrenceEditCreateSessionAfterSave = false;
            await infoShow();
            if (createSession) {
                clearReceptionPersonFields();
                await refreshReceptionPanelData();
            }
            setTimeout(closeOccurrenceEditModal, 600);
        } catch (e) {
            setOccurrenceEditHint("Xəta: " + getExceptionMessage(e), "error");
        }
    }

