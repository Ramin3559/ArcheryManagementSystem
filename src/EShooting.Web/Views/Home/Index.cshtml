    function populateOccurrenceEditDateSelect(selectedScheduleId, selectedDateLocal) {
        var sel = document.getElementById("occurrenceEditDateSelect");
        if (!(sel instanceof HTMLSelectElement)) return;
        var future = getFutureOccurrences();
        sel.innerHTML = "";
        for (var i = 0; i < future.length; i++) {
            var o = future[i];
            var opt = document.createElement("option");
            opt.value = String(o.scheduleId) + "|" + String(o.dateLocal);
            opt.textContent = String(o.dateLocal) + " · " + String(o.dayLabel || "") + " · " + String(o.startTime || "") + "–" + String(o.endTime || "");
            if (String(o.scheduleId) === String(selectedScheduleId) && String(o.dateLocal) === String(selectedDateLocal)) {
                opt.selected = true;
            }
            sel.appendChild(opt);
        }
    }

    function syncOccurrenceEditFieldsFromRow(row, prefill) {
        if (!row) return;
        var sidEl = document.getElementById("occurrenceEditScheduleId");
        var dEl = document.getElementById("occurrenceEditDateLocal");
        var st = document.getElementById("occurrenceEditStartTime");
