    let dashboardPartialsInFlight = false;
    let lastLaneGridHtml = "";
    let lastDashboardTableHtml = "";

    async function loadDashboardLanesCore() {
        const response = await apiFetch("/dashboard/lanes", { timeoutMs: 20000 });
        if (!response.ok) {
            if (sessionInfo instanceof HTMLElement) {
                sessionInfo.textContent = "Zolaq məlumatı yüklənmədi.";
            }
            return false;
        }

        const lanes = await response.json();
        latestLanes = lanes;
        refreshStats(lanes);
        refreshLaneOptions();
        refreshTvLaneBadges(lanes);
        syncTabletScoreContext();
        return true;
    }

    async function loadDashboardPartials(options) {
        options = options || {};
        const force = options.force === true;
        if (dashboardPartialsInFlight) return;
        dashboardPartialsInFlight = true;
        try {
            const [gridResponse, tableResponse] = await Promise.all([
                apiFetch("/dashboard/lanes/partial/grid", { timeoutMs: 20000 }),
                apiFetch("/dashboard/lanes/partial/table", { timeoutMs: 20000 }),
            ]);

            if (gridResponse.ok && laneGrid) {
                const gridHtml = await gridResponse.text();
                if (force || gridHtml !== lastLaneGridHtml) {
                    lastLaneGridHtml = gridHtml;
                    laneGrid.innerHTML = gridHtml;
                    restoreLaneDrafts();
                }
            }
            if (tableResponse.ok && dashboardRows) {
                const tableHtml = await tableResponse.text();
                if (force || tableHtml !== lastDashboardTableHtml) {
                    lastDashboardTableHtml = tableHtml;
                    dashboardRows.innerHTML = tableHtml;
                }
            }
        } catch (e) {
            console.error("loadDashboardPartials", e);
        } finally {
            dashboardPartialsInFlight = false;
        }
    }

    async function loadDashboard(options) {
        options = options || {};
        const includePartials = options.includePartials !== false;
        const force = options.force === true;

        if (dashboardLoadInFlight) {
            dashboardLoadQueued = true;
            return;
        }
        dashboardLoadInFlight = true;
        try {
            const ok = await loadDashboardLanesCore();
            if (!ok) return;
            if (includePartials) {
                await loadDashboardPartials({ force });
            }
        } catch (e) {
            console.error("loadDashboard", e);
            if (sessionInfo instanceof HTMLElement) {
                sessionInfo.textContent = getExceptionMessage(e) || "Zolaqlar yüklənmədi.";
            }
        } finally {
            dashboardLoadInFlight = false;
            if (dashboardLoadQueued) {
                dashboardLoadQueued = false;
                setTimeout(() => { void loadDashboard({ includePartials: true, force: true }); }, 400);
            }
        }
    }

    function resolveLaneDisplayStatus(lane) {
        if (!lane?.sessionId) return "Idle";
        const st = String(lane.status ?? "Idle");
        if (st === "Completed") return "Completed";
        const startRaw = lane.startTimeUtc ?? lane.StartTimeUtc ?? "";
        const endRaw = lane.endTimeUtc ?? lane.EndTimeUtc ?? "";
        const startMs = startRaw ? parseApiDate(startRaw).getTime() : NaN;
        const endMs = endRaw ? parseApiDate(endRaw).getTime() : NaN;
        const nowMs = Date.now();
        if (Number.isFinite(startMs) && Number.isFinite(endMs) && endMs > startMs) {
            if (nowMs >= endMs) return "Completed";
            if (nowMs < startMs) return "Scheduled";
            return "Active";
        }
        if (st === "Scheduled" || st === "Active") return st;
        return "Idle";
    }

    function refreshTvLaneBadges(lanes) {
        const safe = Array.isArray(lanes) ? lanes : [];
        document.querySelectorAll("[data-tv-lane]").forEach(el => {
            if (!(el instanceof HTMLElement)) return;
            const n = Number(el.getAttribute("data-tv-lane") ?? "0");
            const lane = safe.find(x => x.laneNumber === n);
            const displayStatus = resolveLaneDisplayStatus(lane);
            const isActive = displayStatus === "Active";
            const isPending = displayStatus === "Scheduled";
            el.classList.toggle("tv-link--active", isActive);
            el.classList.toggle("tv-link--pending", isPending);
            if (isActive || isPending) {
                const athlete = (lane?.athleteName || "").replace(/^Atıcı:\s*/i, "").replace(/^Qrup:\s*/i, "").trim();
                const status = isActive ? "Aktiv" : "Gözləmə";
                el.title = athlete ? `Zolaq ${n}: ${athlete} (${status})` : `Zolaq ${n}: ${status}`;
            } else {
                el.title = `Zolaq ${n}: boş`;
            }
        });
    }

