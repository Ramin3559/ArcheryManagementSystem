    }

    function showInfoHint(text, kind = "warn") {
        if (!(infoResultHint instanceof HTMLElement)) return;
        infoResultHint.textContent = text || "";
        infoResultHint.style.display = text ? "block" : "none";
        infoResultHint.className = kind === "ok" ? "notice notice--ok" : kind === "error" ? "notice notice--error" : "notice";
    }

    function escapeHtml2(s) {
        return escapeHtml(String(s ?? ""));
    }

    async function infoShow() {
        const phone = normalizeDigits(infoPhone?.value);
        const email = normalizeText(infoEmail?.value);
        const idCardNumber = normalizeText(infoIdCard?.value);

        if (!phone && !email && !idCardNumber) {
            showInfoHint("Zəhmət olmasa bir məlumat daxil edin.", "warn");
            return;
        }

        showInfoHint("Yüklənir...", "warn");
        if (infoTableWrap instanceof HTMLElement) infoTableWrap.style.display = "none";
        if (infoTableBody instanceof HTMLElement) infoTableBody.innerHTML = "";

        const qs = new URLSearchParams();
        if (phone) qs.set("phone", phone);
        if (email) qs.set("email", email);
        if (idCardNumber) qs.set("idCardNumber", idCardNumber);

        const res = await apiFetch(`/info/athlete?${qs.toString()}`);
        if (!res.ok) {
            const msg = await readErrorMessage(res);
            showInfoHint(msg || "Tapılmadı.", "error");
            return;
        }

        const data = await res.json().catch(() => ({}));
        const packages = Array.isArray(data?.packages) ? data.packages : [];
        const weeklySchedules = Array.isArray(data?.weeklySchedules) ? data.weeklySchedules : [];
        showInfoHint(`Müştəri tapıldı: ${data?.fullName ?? "—"}`, "ok");

        if (!(infoTableBody instanceof HTMLElement) || !(infoTableWrap instanceof HTMLElement)) return;
        infoTableBody.innerHTML = "";
        _infoSchedulesById = {};

        _currentInfoAthleteName = data?.fullName || "—";
        _currentInfoAthleteId = data?.athleteId ?? null;
        _currentInfoIsSubscriber = Boolean(data?.isSubscriber);
        fillInfoProfileForm(data);

        if (infoPackagesSummary instanceof HTMLElement) {
            if (packages.length) {
                infoPackagesSummary.style.display = "block";
                infoPackagesSummary.innerHTML = packages.map(p => {
                    const fp = p.isFullPackage ? " <span style='color:#7a86a8'>(tam paket)</span>" : "";
                    return `<div><strong>${escapeHtml2(p.fromLocal)} — ${escapeHtml2(p.toLocal)}</strong> · ${escapeHtml2(p.days)}${fp}</div>`;
                }).join("");
            } else {
                infoPackagesSummary.style.display = "none";
                infoPackagesSummary.innerHTML = "";
            }
        }

        for (const s of weeklySchedules) {
            const sid = String(s?.scheduleId ?? "");
            if (!sid) continue;
            _infoSchedulesById[sid] = {
                dayOfWeek: s.dayOfWeek,
                startTimeLocal: s.startTimeLocal,
                durationMinutes: s.durationMinutes,
                preferredLaneType: s.preferredLaneType,
                laneNumber: s.laneNumber,
                activeFromDateLocal: s.activeFromDateLocal,
                activeToDateLocal: s.activeToDateLocal,
                isFullPackage: Boolean(s.isFullPackage)
            };
        }

        const occ = Array.isArray(data?.occurrencesFlat) ? data.occurrencesFlat : [];
        _occurrencesFlat = occ;

        const todayIso = getTodayLocalIso();
        const futureOcc = occ.filter(o => String(o?.dateLocal ?? "") >= todayIso);
        const rowsToShow = futureOcc.length ? futureOcc : occ;

        if (rowsToShow.length) {
            if (infoOccurrencesHint instanceof HTMLElement) {
                infoOccurrencesHint.style.display = "block";
            }
            for (const o of rowsToShow) {
                const sid = escapeHtml2(o?.scheduleId ?? "");
                const d = escapeHtml2(o?.dateLocal ?? "");
                const tr = document.createElement("tr");
                tr.setAttribute("data-date", String(o?.dateLocal ?? ""));
                if (String(o?.dateLocal ?? "") === todayIso) {
                    tr.style.background = "rgba(79,70,229,0.06)";
                }
                tr.innerHTML = `
                    <td>${escapeHtml2(o?.dateLocal)}</td>
                    <td>${escapeHtml2(o?.dayLabel)}</td>
                    <td>${escapeHtml2(o?.startTime)}–${escapeHtml2(o?.endTime)}</td>
                    <td>${escapeHtml2(o?.laneLabel)}</td>
                    <td style="white-space:nowrap;">
                        <button type="button" class="btn btn-ghost btn-sm" data-edit-occurrence-schedule="${sid}" data-edit-occurrence-date="${d}">Dəyişdir</button>
                        <button type="button" class="btn btn-danger btn-sm" data-exclude-occurrence-schedule="${sid}" data-exclude-occurrence-date="${d}">Ləğv et</button>
                    </td>`;
                infoTableBody.appendChild(tr);
            }
            requestAnimationFrame(() => {
                const todayRow = infoTableBody.querySelector(`tr[data-date="${todayIso}"]`);
                if (todayRow instanceof HTMLElement && infoTableWrap instanceof HTMLElement) {
                    todayRow.scrollIntoView({ block: "nearest" });
                }
            });
        } else {
            if (infoOccurrencesHint instanceof HTMLElement) {
                infoOccurrencesHint.style.display = "none";
            }
            const emptyMsg = _currentInfoIsSubscriber
                ? "Aktiv abunə planı tapılmadı. Resepsiyadan yeni abunə qeyd edə bilərsiniz."
                : "Aktiv abunə planı yoxdur.";
            infoTableBody.innerHTML = `<tr><td colspan="5" style="text-align:center;color:#7a86a8;">${emptyMsg}</td></tr>`;
        }

        infoTableBody.onclick = function (ev) {
            var t = ev && ev.target;
            if (!(t instanceof HTMLElement)) return;
            var scheduleId = t.getAttribute("data-edit-schedule");
            if (scheduleId) {
                openScheduleEditModal(scheduleId);
                return;
            }
            var disableId = t.getAttribute("data-disable-schedule");
            if (disableId) {
                disableScheduleFromInfo(disableId);
                return;
            }
            var es = t.getAttribute("data-edit-occurrence-schedule");
            var ed = t.getAttribute("data-edit-occurrence-date");
            if (es && ed) {
                openOccurrenceEditModal(es, ed);
                return;
            }
            var xs = t.getAttribute("data-exclude-occurrence-schedule");
            var xd = t.getAttribute("data-exclude-occurrence-date");
            if (xs && xd) {
                excludeOccurrenceFromInfo(xs, xd);
            }
        };

        infoTableWrap.style.display = "block";
    }

    async function disableScheduleFromInfo(scheduleId) {
        if (!scheduleId) return;
        const ok = window.confirm("Bu abunə gününü ləğv etmək istəyirsiniz?");
        if (!ok) return;
        const res = await apiFetch(`/subscriptions/schedules/${encodeURIComponent(scheduleId)}/disable`, {
            method: "POST"
        });
        if (!res.ok) {
            alert(await readErrorMessage(res) || "Abunə planı ləğv edilmədi.");
            return;
        }
        showInfoHint("Abunə planı ləğv edildi.", "ok");
        await infoShow();
    }

    var _infoSchedulesById = {};
    var _occurrencesFlat = [];
    var _currentInfoAthleteName = "—";
    var _currentInfoAthleteId = null;
    var _currentInfoIsSubscriber = false;
    var _editingScheduleId = null;

    function setScheduleEditHint(text, kind) {
        var el = document.getElementById("scheduleEditHint");
        if (!(el instanceof HTMLElement)) return;
        el.textContent = text || "";
        el.style.display = text ? "block" : "none";
        el.className = kind === "ok" ? "notice notice--ok" : kind === "error" ? "notice notice--error" : "notice";
    }

    function openScheduleEditModal(scheduleId) {
        var item = _infoSchedulesById[scheduleId];
        if (!item) {
            alert("Bu abunə qrafiki yüklənməyib. Zəhmət olmasa məlumatı yenidən axtarın.");
            return;
        }
        _editingScheduleId = scheduleId;
        var modal = document.getElementById("scheduleEditModal");
        if (!(modal instanceof HTMLElement)) return;

        var dow = document.getElementById("scheduleEditDayOfWeek");
        var st = document.getElementById("scheduleEditStartTime");
        var dur = document.getElementById("scheduleEditDuration");
        var plt = document.getElementById("scheduleEditPreferredLaneType");
        var lane = document.getElementById("scheduleEditLaneNumber");
        var fromD = document.getElementById("scheduleEditFromDate");
        var toD = document.getElementById("scheduleEditToDate");
        var ath = document.getElementById("scheduleEditAthlete");
        if (dow instanceof HTMLSelectElement) dow.value = String(item.dayOfWeek != null ? item.dayOfWeek : 1);
        if (st instanceof HTMLInputElement) st.value = String(item.startTimeLocal || "10:00");
        if (dur instanceof HTMLInputElement) dur.value = String(item.durationMinutes || 90);
        if (plt instanceof HTMLSelectElement) plt.value = String(item.preferredLaneType != null ? item.preferredLaneType : 0);
        if (lane instanceof HTMLSelectElement) {
            const laneVal = Number(item.laneNumber);
            lane.value = String(Number.isInteger(laneVal) && laneVal > 0 ? laneVal : 1);
        }
        if (fromD instanceof HTMLInputElement) fromD.value = String(item.activeFromDateLocal || "");
        if (toD instanceof HTMLInputElement) toD.value = String(item.activeToDateLocal || "");
        if (ath instanceof HTMLElement) ath.textContent = "Müştəri: " + _currentInfoAthleteName;

        setScheduleEditHint("", "");
        modal.style.display = "block";
    }

    function closeScheduleEditModal() {
        var modal = document.getElementById("scheduleEditModal");
        if (modal instanceof HTMLElement) modal.style.display = "none";
        _editingScheduleId = null;
        setScheduleEditHint("", "");
    }

    async function saveScheduleEdit() {
        var id = _editingScheduleId;
        if (!id) return;
        var item = _infoSchedulesById[id];
        var dow = Number(document.getElementById("scheduleEditDayOfWeek")?.value || 0);
        var startTimeLocal = String(document.getElementById("scheduleEditStartTime")?.value || "").trim();
        var duration = Number(document.getElementById("scheduleEditDuration")?.value || 0);
        var preferredLaneType = Number(document.getElementById("scheduleEditPreferredLaneType")?.value || 0);
        var laneNumber = Number(document.getElementById("scheduleEditLaneNumber")?.value || 0);
        var fromD = String(document.getElementById("scheduleEditFromDate")?.value || "").trim();
        var toD = String(document.getElementById("scheduleEditToDate")?.value || "").trim();

        if (!startTimeLocal) { setScheduleEditHint("Saatı daxil edin (HH:mm).", "error"); return; }
        if (!Number.isInteger(duration) || duration <= 0) { setScheduleEditHint("Müddət müsbət olmalıdır.", "error"); return; }
        if (!Number.isInteger(laneNumber) || laneNumber <= 0) { setScheduleEditHint("Zolaq seçin.", "error"); return; }
        if (!fromD || !toD) { setScheduleEditHint("Başlama və bitmə tarixini daxil edin.", "error"); return; }
        if (new Date(toD) < new Date(fromD)) { setScheduleEditHint("Bitmə tarixi başlanğıcdan əvvəl ola bilməz.", "error"); return; }

        setScheduleEditHint("Yadda saxlanılır...", "warn");
        try {
            var body = {
                athleteId: null,
                athleteFullName: "",
                dayOfWeek: dow,
                startTimeLocal: startTimeLocal,
                durationMinutes: duration,
                activeFromDateLocal: fromD,
                activeToDateLocal: toD,
                preferredLaneType: preferredLaneType,
                laneNumber: laneNumber,
                isFullPackage: item && item.isFullPackage ? true : false
            };
            var res = await apiFetch("/subscriptions/schedules/" + encodeURIComponent(id), {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });
            if (!res.ok) {
                var msg = await readErrorMessage(res);
                setScheduleEditHint(msg || "Yadda saxlanılmadı.", "error");
                return;
            }
            setScheduleEditHint("Uğurla yadda saxlanıldı.", "ok");
            // Yenidən yüklə.
            await infoShow();
            setTimeout(closeScheduleEditModal, 600);
        } catch (e) {
            setScheduleEditHint("Xəta: " + getExceptionMessage(e), "error");
        }
    }

