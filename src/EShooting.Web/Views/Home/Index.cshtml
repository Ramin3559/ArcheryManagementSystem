            .filter(x => Number.isInteger(x) && x >= 0 && x <= 6);
    }

    function renderSubscriptionLaneTypesByDay() {
        if (!(subscriptionLaneTypesByDayEl instanceof HTMLElement)) return;
        const days = getSelectedSubscriptionDays();
        const cat = Number(categoryInput?.value ?? "0");
        const isAmateur = cat === 0;
        const dayLabel = (d) => {
            switch (d) {
                case 1: return "B.e";
                case 2: return "Ç.a";
                case 3: return "Ç";
                case 4: return "C.a";
                case 5: return "C";
                case 6: return "Ş";
                case 0: return "Bazar";
                default: return String(d);
            }
        };
        const existingTimes = {};
        const existingLanes = {};
        subscriptionLaneTypesByDayEl.querySelectorAll(".sub-day-time").forEach(inp => {
            if (!(inp instanceof HTMLInputElement)) return;
            const day = inp.getAttribute("data-day");
            if (!day) return;
            existingTimes[day] = inp.value;
        });
        subscriptionLaneTypesByDayEl.querySelectorAll(".sub-day-lane").forEach(sel => {
            if (!(sel instanceof HTMLSelectElement)) return;
            const day = sel.getAttribute("data-day");
            if (!day) return;
            existingLanes[day] = sel.value;
        });
        if (days.length === 0) {
            subscriptionLaneTypesByDayEl.innerHTML = "";
