    function renderEquipmentReturns(items) {
        if (!equipmentReturnsList || !equipmentFabBtn || !equipmentFabBadge) return;
        const list = Array.isArray(items) ? items : [];
        equipmentFabBadge.textContent = String(list.length);
        equipmentReturnsList.innerHTML = "";

        // Auto hide when empty (FAB + panel)
        if (list.length === 0) {
            equipmentFabBtn.classList.add("equip-fab--hidden");
            equipmentFabBtn.classList.remove("equip-fab--ok", "equip-fab--bad", "equip-fab--idle", "equip-fab--pulse");
            try { closeEquipmentPanel(); } catch { }
            return;
        }

        // FAB visible + status color logic
        equipmentFabBtn.classList.remove("equip-fab--hidden");
        const hasExpired = list.some(x => x?.color === "red");
        equipmentFabBtn.classList.remove("equip-fab--ok", "equip-fab--bad", "equip-fab--idle", "equip-fab--pulse");
        if (hasExpired) {
            equipmentFabBtn.classList.add("equip-fab--bad", "equip-fab--pulse");
        } else {
            equipmentFabBtn.classList.add("equip-fab--ok");
        }

        for (const item of list) {
            const row = document.createElement("div");
            row.style.display = "flex";
            row.style.alignItems = "center";
            row.style.justifyContent = "space-between";
            row.style.gap = "10px";
            row.style.padding = "8px 10px";
            row.style.border = "1px solid rgba(41,55,89,0.18)";
            row.style.borderRadius = "12px";
            row.style.background = "rgba(255,255,255,0.9)";

            const left = document.createElement("div");
            left.style.display = "flex";
            left.style.alignItems = "center";
            left.style.gap = "10px";

            const cb = document.createElement("input");
            cb.type = "checkbox";
            cb.className = "equip-select";
            if (item.issueId) {
                cb.value = item.issueId;
                cb.dataset.issueId = item.issueId;
            } else {
                cb.value = item.sessionId;
            }
            cb.dataset.sessionId = item.sessionId;

            const name = document.createElement("div");
            name.style.fontWeight = "800";
            const equipLabel = item.equipmentName ? ` · ${item.equipmentName}` : "";
            name.textContent = `🏹 ${item.athleteName} (Z${item.laneNumber})${equipLabel}`;
            if (item.color === "yellow") name.style.color = "#b8860b";
            if (item.color === "red") name.style.color = "#c62828";

            left.appendChild(cb);
            left.appendChild(name);

            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "btn btn-success btn-sm";
            btn.textContent = "Təhvil al";
            btn.addEventListener("click", async () => {
                await returnEquipment([{
                    issueId: item.issueId || null,
                    sessionId: item.sessionId
                }]);
            });

            row.appendChild(left);
            row.appendChild(btn);
            equipmentReturnsList.appendChild(row);
        }
    }

    async function returnEquipment(entries) {
        const issueIds = [];
        const sessionIds = [];
        for (const entry of (Array.isArray(entries) ? entries : [])) {
            if (!entry) continue;
            if (typeof entry === "string") {
                sessionIds.push(entry);
                continue;
            }
            if (entry.issueId) issueIds.push(entry.issueId);
            else if (entry.sessionId) sessionIds.push(entry.sessionId);
        }
        if (issueIds.length === 0 && sessionIds.length === 0) return;
        try {
            await apiFetch("/sessions/equipment/return-bulk", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ issueIds, sessionIds })
            });
            await refreshReceptionPanelData();
        } catch (e) {
            alert(`Avadanlıq təhvil alınmadı. ${getExceptionMessage(e)}`);
        }
    }

