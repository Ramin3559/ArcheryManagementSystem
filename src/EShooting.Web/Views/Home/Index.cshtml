    async function refreshReceptionWalkInStatus(athleteId) {
        if (!athleteId) {
            applyReceptionWalkInFromAthlete(null);
            return;
        }
        try {
            const phoneQ = normalizeDigits(phoneNumberInput?.value);
            const emailQ = normalizeText(emailInput?.value);
            const idQ = normalizeText(idCardNumberInput?.value);
            const qs = new URLSearchParams();
            if (phoneQ) qs.set("phone", phoneQ);
            if (emailQ) qs.set("email", emailQ);
            if (idQ) qs.set("idCardNumber", idQ);
            if (qs.toString()) {
                const res = await apiFetch(`/athletes/lookup?${qs.toString()}`, { timeoutMs: 15000 });
                if (res.ok) {
                    const data = await res.json();
                    if (String(data?.id) === String(athleteId)) {
                        applyReceptionWalkInFromAthlete(data);
                        return;
                    }
                }
            }
        } catch { /* ignore */ }

        const info = await getActiveWalkInSubscriptionInfo(athleteId);
        if (info) {
            _receptionWalkIn = {
                isActive: true,
                isVip: info.isVip,
                expiresLocal: info.expiresLocal,
                sessionDurationMinutes: info.durationMinutes
            };
            syncReceptionWalkInUi();
            return;
        }

        applyReceptionWalkInFromAthlete(null);
    }

