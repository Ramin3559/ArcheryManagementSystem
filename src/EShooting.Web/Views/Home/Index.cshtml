    async function saveCustomerFromModal() {
        const firstName = modalFirstName?.value?.trim() ?? "";
        const lastName = modalLastName?.value?.trim() ?? "";
        const phoneNumber = modalPhoneNumber?.value?.trim() ?? "";
        const isVip = modalIsVip instanceof HTMLInputElement && modalIsVip.checked;
        const membershipTypeRaw = isVip ? "2" : "0";
        const categoryRaw = isVip ? (modalCategory?.value || "1") : (modalCategory?.value ?? "");
        if (!firstName || !lastName || !phoneNumber) {
            alert("Ad, Soyad və Telefon mütləqdir.");
            return;
        }
        if (!isVip && !categoryRaw) { alert("Kateqoriya seçin."); return; }

        copyModalToCustomerStore();
        receptionMatchedSnapshot = buildReceptionCurrentSnapshot();

        if (customerModalSaveBtn instanceof HTMLButtonElement) {
            customerModalSaveBtn.disabled = true;
            customerModalSaveBtn.textContent = "Saxlanır…";
        }

        try {
            if (receptionMatchedAthleteId) {
                const ok = await updateAthleteFromReception({ silentSuccess: true });
                if (!ok) return;
            } else {
                const response = await apiFetch("/athletes", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        firstName,
                        lastName,
                        phoneNumber,
                        email: modalEmail?.value?.trim() || null,
                        idCardNumber: modalIdCardNumber?.value?.trim() || null,
                        category: Number(categoryRaw),
                        isSubscriber: false,
                        membershipType: Number(membershipTypeRaw),
                        isVip: Boolean(modalIsVip?.checked)
                    })
                });

                if (!response.ok) {
                    if (response.status === 409) {
                        let payload = null;
                        try { payload = await response.json(); } catch { }
                        const existingId = payload?.existingId ?? null;
                        const existing = payload?.existing ?? null;
                        if (existingId) {
                            receptionMatchedAthleteId = existingId;
                            if (existing) await applyAthleteToReception(existing);
                        } else {
                            alert(payload?.error ?? "Bu məlumatlarla artıq qeydiyyat mövcuddur.");
                            return;
                        }
                    } else {
                        alert(await readErrorMessage(response) || "Müştəri qeydə alınmadı.");
                        return;
                    }
                } else {
                    const data = await response.json();
                    receptionMatchedAthleteId = data?.id ?? null;
                }
            }

            syncUpdateAthleteButton();
            await refreshReceptionWalkInStatus(receptionMatchedAthleteId);
            refreshSelectedCustomerCard();
            if (customerSearchInput instanceof HTMLInputElement) {
                customerSearchInput.value = `${firstName} ${lastName}`.trim();
            }
            setLookupHint("Müştəri qeydə alındı. İndi zolağa yaza bilərsiniz.");
            closeCustomerModal();
        } finally {
            if (customerModalSaveBtn instanceof HTMLButtonElement) {
                customerModalSaveBtn.disabled = false;
                customerModalSaveBtn.textContent = "Təsdiqlə və saxla";
            }
        }
    }

