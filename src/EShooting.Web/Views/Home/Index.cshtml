    function collectGroupNamesForBooking() {
        const names = groupMembers.map(m => String(m.fullName || "").trim()).filter(Boolean);
        const first = firstNameInput?.value?.trim() ?? "";
        const last = lastNameInput?.value?.trim() ?? "";
        const phone = phoneNumberInput?.value?.trim() ?? "";
        const current = `${first} ${last}`.trim();
        if (current && phone) {
            const exists = names.some(n => n.toLowerCase() === current.toLowerCase());
            if (!exists) names.push(current);
        }
        return names.filter((v, idx, arr) => arr.findIndex(x => x.toLowerCase() === v.toLowerCase()) === idx);
    }

