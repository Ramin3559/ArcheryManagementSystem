            <div class="row" style="margin-top:0;">
                <div style="min-width:90px; font-weight:800; color:#2c396a;">${dayLabel(d)}</div>
                <input type="text"
                       inputmode="numeric"
                       data-day="${d}"
                       class="sub-day-time"
                       value="${existingTimes[String(d)] ?? "17:00"}"
                       title="Başlanğıc saat (HH:mm)"
                       placeholder="19:00"
                       pattern="^([01]\\d|2[0-3]):[0-5]\\d$"
                       maxlength="5" />
                <select data-day="${d}" class="sub-day-lane">
                    ${getLaneSelectOptionsHtml(maxLane)}
                </select>
            </div>
        `).join("");

        // restore selections
        subscriptionLaneTypesByDayEl.querySelectorAll(".sub-day-lane").forEach(sel => {
            if (!(sel instanceof HTMLSelectElement)) return;
            const day = sel.getAttribute("data-day");
            if (!day) return;
            const v = existingLanes[day];
            if (v && Number(v) > 0 && Array.from(sel.options).some(o => o.value === v)) {
                sel.value = v;
            } else if (sel.options.length > 0) {
                sel.value = sel.options[0].value;
            }
        });

        // end time field removed
    }

    function addMinutesToTimeHHmm(hhmm, minutesToAdd) {
        if (!/^\d{2}:\d{2}$/.test(hhmm)) return "";
        const [h, m] = hhmm.split(":").map(x => Number(x));
        const total = h * 60 + m + Number(minutesToAdd);
        const mod = ((total % (24 * 60)) + (24 * 60)) % (24 * 60);
        const hh = String(Math.floor(mod / 60)).padStart(2, "0");
        const mm = String(mod % 60).padStart(2, "0");
        return `${hh}:${mm}`;
    }

    // updateSubscriptionEndTimes removed (end time field removed)

    function computeMinutesPerSelectedDay(totalMonthlyHours, selectedDaysCount) {
        const totalMin = Math.max(0, Number(totalMonthlyHours)) * 60;
        const denom = Math.max(1, Number(selectedDaysCount)) * 4; // ~4 həftə
        const raw = totalMin / denom;
        const rounded = Math.max(10, Math.round(raw / 10) * 10);
        return rounded;
    }

    function syncMonthlySplitInfo() {
        if (!(subscriptionInfo instanceof HTMLElement)) return;
        const days = getSelectedSubscriptionDays();
        const totalHours = Number(subscriptionDurationMinutesInput?.value ?? "0");
        if (!Number.isFinite(totalHours) || totalHours <= 0 || days.length === 0) {
            subscriptionInfo.textContent = "Həftə günlərini seçin, hər gün üçün saat və zolağı təyin edin.";
            return;
        }
        const minutesPerDay = computeMinutesPerSelectedDay(totalHours, days.length);
        const hoursPerDay = (minutesPerDay / 60);
        subscriptionInfo.textContent = `Aylıq paket: ${totalHours} saat. Seçim: həftədə ${days.length} gün. Təxmini: hər gün ${hoursPerDay.toFixed(hoursPerDay % 1 === 0 ? 0 : 2)} saat.`;
    }

    function parseApiDate(value) {
        if (!value) {
            return new Date(0);
        }

        const needsUtcSuffix = typeof value === "string" && !/[zZ]|[+-]\d{2}:\d{2}$/.test(value);
        return new Date(needsUtcSuffix ? `${value}Z` : value);
    }

    function hasValidTimeWindow(startMs, endMs) {
        return Number.isFinite(startMs) && Number.isFinite(endMs) && endMs > startMs;
    }

    // syncOpenEndedMode ləğv edildi

    async function apiFetch(input, init = {}) {
        const timeoutMs = Number(init.timeoutMs ?? 45000);
        const fetchInit = { ...init };
        delete fetchInit.timeoutMs;
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), timeoutMs);
        try {
            const response = await fetch(input, {
                ...fetchInit,
                credentials: "same-origin",
                cache: "no-store",
                signal: controller.signal
            });
            if (response.status === 401) {
                window.location.assign("/Account/Login?returnUrl=" + encodeURIComponent(window.location.pathname + window.location.search));
                throw new Error("İcazə yoxdur");
            }
            return response;
        } catch (err) {
            if (err && (err.name === "AbortError" || String(err).includes("abort"))) {
                throw new Error("Server cavab vermədi (vaxt bitdi). Şəbəkəni və ya SQL-i yoxlayın.");
            }
            throw err;
        } finally {
            clearTimeout(timer);
        }
    }

    async function ensureAthletesCacheFresh() {
        const now = Date.now();
        if (Array.isArray(allAthletesCache) && allAthletesCache.length > 0 && (now - athletesCacheLoadedAtMs) < 60000) {
            return;
        }
        try {
            const res = await apiFetch("/athletes");
            if (!res.ok) {
                allAthletesCache = [];
                athletesCacheLoadedAtMs = now;
                return;
            }
            const data = await res.json();
            allAthletesCache = Array.isArray(data) ? data : [];
            athletesCacheLoadedAtMs = now;
        } catch {
            allAthletesCache = [];
            athletesCacheLoadedAtMs = now;
        }
    }

    function normalizeDigits(value) {
        return String(value ?? "").replace(/\D+/g, "");
    }

    function normalizeText(value) {
        return String(value ?? "").trim().toLowerCase();
    }

    function pickBestMatch(candidates, scoreFn) {
        if (!Array.isArray(candidates) || candidates.length === 0) return null;
        let best = candidates[0];
        let bestScore = scoreFn(best);
        for (let i = 1; i < candidates.length; i++) {
            const c = candidates[i];
            const s = scoreFn(c);
            if (s > bestScore) {
                best = c;
                bestScore = s;
            }
        }
        return best;
    }

    async function resolveAthleteIdByCredentials() {
        const phoneQ = normalizeDigits(phoneNumberInput?.value);
        const emailQ = normalizeText(emailInput?.value);
        const idQ = normalizeText(idCardNumberInput?.value);
        if (!phoneQ && !emailQ && !idQ) return null;

        try {
            const qs = new URLSearchParams();
            if (phoneQ) qs.set("phone", phoneQ);
            if (emailQ) qs.set("email", emailQ);
            if (idQ) qs.set("idCardNumber", idQ);
            const lookupRes = await apiFetch(`/athletes/lookup?${qs.toString()}`, { timeoutMs: 30000 });
            if (lookupRes.ok) {
                const found = await lookupRes.json();
                return found?.id ?? null;
            }
        } catch { /* ignore */ }

        try {
            const qs = new URLSearchParams();
            if (phoneQ) qs.set("phone", phoneQ);
            if (emailQ) qs.set("email", emailQ);
            if (idQ) qs.set("idCardNumber", idQ);
            const infoRes = await apiFetch(`/info/athlete?${qs.toString()}`, { timeoutMs: 30000 });
            if (infoRes.ok) {
                const data = await infoRes.json();
                return data?.athleteId ?? null;
            }
        } catch { /* ignore */ }

        return null;
    }

    async function getActiveWalkInSubscriptionInfo(athleteId) {
        if (!athleteId) return null;
        try {
            const res = await apiFetch(`/subscriptions/schedules?athleteId=${encodeURIComponent(athleteId)}`, { timeoutMs: 30000 });
            if (!res.ok) return null;
            const schedules = await res.json().catch(() => []);
            if (!Array.isArray(schedules)) return null;
            const today = getTodayLocalIso();
            const active = schedules.filter(s => {
                if (s?.isEnabled === false || !s?.isFullPackage) return false;
                const from = String(s.activeFromDateLocal ?? "").slice(0, 10);
                const to = String(s.activeToDateLocal ?? "").slice(0, 10);
                return from && to && from <= today && to >= today;
            });
            if (!active.length) return null;
            active.sort((a, b) => String(b.activeToDateLocal).localeCompare(String(a.activeToDateLocal)));
            const best = active[0];
            const durationMinutes = Number(best.durationMinutes ?? 0);
            return {
                expiresLocal: String(best.activeToDateLocal ?? "").slice(0, 10),
                durationMinutes,
                isVip: durationMinutes === 0 || Boolean(isVipInput?.checked)
            };
        } catch {
            return null;
        }
    }

    async function getActiveSubscriptionPlanCount(athleteId) {
        if (!athleteId) return 0;
        try {
            const res = await apiFetch(`/subscriptions/schedules?athleteId=${encodeURIComponent(athleteId)}`, { timeoutMs: 30000 });
            if (!res.ok) return 0;
            const schedules = await res.json().catch(() => []);
            if (!Array.isArray(schedules)) return 0;
            return schedules.filter(s => s?.isEnabled !== false && !s?.isFullPackage).length;
        } catch {
            return 0;
        }
    }

    function captureBookingContextForManage() {
        const start = resolveSessionStartTimeUtc();
        const startLocal = start.ok ? new Date(start.utc) : new Date();
        const dateLocal = start.ok
            ? `${startLocal.getFullYear()}-${String(startLocal.getMonth() + 1).padStart(2, "0")}-${String(startLocal.getDate()).padStart(2, "0")}`
            : getTodayLocalIso();
        return {
            dateLocal: dateLocal,
            startTime: `${String(startLocal.getHours()).padStart(2, "0")}:${String(startLocal.getMinutes()).padStart(2, "0")}`,
            laneNumber: Number(laneNumberInput?.value ?? 0),
            dayOfWeek: startLocal.getDay()
        };
    }

    let _manageRedirectContext = null;
    let _occurrenceEditCreateSessionAfterSave = false;

    function getTodayLocalIso() {
        const d = new Date();
        return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
    }

    function getFutureOccurrences() {
        const today = getTodayLocalIso();
        return (_occurrencesFlat || [])
            .filter(o => String(o?.dateLocal ?? "") >= today)
            .sort((a, b) => String(a.dateLocal).localeCompare(String(b.dateLocal)));
    }

    function pickOccurrenceForManageRedirect(ctx) {
        const future = getFutureOccurrences();
        if (!future.length) return null;

        const bookingDate = ctx?.dateLocal || getTodayLocalIso();
        const todayOnSchedule = future.find(o => String(o.dateLocal) === bookingDate);
        if (todayOnSchedule) return todayOnSchedule;

        return future[0];
    }

    function applyManageRedirectContext() {
        const ctx = _manageRedirectContext;
        _manageRedirectContext = null;
        if (!ctx) return;

        const bookingDate = ctx.dateLocal || getTodayLocalIso();
        const source = pickOccurrenceForManageRedirect(ctx);
        if (!source?.scheduleId) {
            showInfoHint("Gələcək abunə seansı tapılmadı. Abunə müddətini və ya planı yoxlayın.", "warn");
            return;
        }

        const needsReschedule = String(source.dateLocal) !== bookingDate;
        openOccurrenceEditModal(source.scheduleId, source.dateLocal, {
            startTime: ctx.startTime,
            laneNumber: ctx.laneNumber,
            rescheduleTargetDate: needsReschedule ? bookingDate : null,
            createSessionAfterSave: true
        });
        showInfoHint(
            needsReschedule
                ? `«${source.dateLocal}» abunə günü ləğv olunacaq, seans «${bookingDate}» tarixinə köçürüləcək. Vaxt və zolağı yoxlayın.`
                : `Resepsiyada seçilmiş vaxt: ${ctx.startTime}, Zolaq ${ctx.laneNumber}.`,
            "warn"
        );
    }

