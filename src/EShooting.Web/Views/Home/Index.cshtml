    function getLaneOptionsHtml(categoryValue) {
        const cat = Number(categoryValue);
        const maxLane = (cat === 0) ? 8 : 11;
        const opts = [];
        for (let i = 1; i <= maxLane; i++) {
            const label = i >= 9 ? `Zolaq ${i} (Peşəkar)` : `Zolaq ${i}`;
            opts.push(`<option value="${i}">${label}</option>`);
        }
        return opts.join("");
    }

    function categoryAllowsLane(categoryValue, laneNumber) {
        const category = Number(categoryValue);
        const lane = Number(laneNumber);
        if (!Number.isFinite(category) || !Number.isFinite(lane)) return false;
        // Qayda: 9-11 uzun (peşəkar), 1-8 qısa.
        if (category === 0) { // Amateur
            return lane >= 1 && lane <= 8;
        }
        // Professional/Coach: hər iki tip mümkündür
        return lane >= 1 && lane <= 11;
    }

    function isLaneIdleForSelection(laneNumber) {
        // Dashboard hələ yüklənməyibsə, səhvən disable etməyək (yalnız kateqoriya qaydası işləsin).
        if (!Array.isArray(latestLanes) || latestLanes.length === 0) return true;

        const lane = latestLanes.find(x => x.laneNumber === laneNumber);
        if (lane?.status !== "Idle") return false;
        const until = lane?.cooldownUntilUtc ? parseApiDate(lane.cooldownUntilUtc) : null;
        if (until && until.getTime && until.getTime() > Date.now()) return false;
        return true;
    }

    function refreshLaneOptions() {
        if (!(laneNumberInput instanceof HTMLSelectElement)) return;
        const catVal = categoryInput?.value ?? "0";

        Array.from(laneNumberInput.options).forEach(opt => {
            const lane = Number(opt.value);
            const allowed = categoryAllowsLane(catVal, lane);
            const disabled = !allowed;

            opt.disabled = disabled;
            if (!allowed && lane >= 9) {
                opt.textContent = `Zolaq ${lane} (Yalnız Peşəkarlar)`;
            }
        });

        if (laneNumberInput.selectedOptions.length && laneNumberInput.selectedOptions[0].disabled) {
            const firstEnabled = Array.from(laneNumberInput.options).find(o => !o.disabled);
            if (firstEnabled) laneNumberInput.value = firstEnabled.value;
        }

        if (laneNumberInput.selectedOptions.length && !laneNumberInput.selectedOptions[0].disabled) {
            lastValidLaneNumber = laneNumberInput.value;
        }
    }

