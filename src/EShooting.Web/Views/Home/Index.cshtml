    try { cancelSubscriptionBtn?.addEventListener("click", openCancelSubscriptionModal); } catch (e) { console.error(e); }
    try { updateAthleteBtn?.addEventListener("click", updateAthleteFromReception); } catch (e) { console.error(e); }
    try { infoBtn?.addEventListener("click", openInfoModal); } catch (e) { console.error(e); }
    try { infoCloseBtn?.addEventListener("click", closeInfoModal); } catch (e) { console.error(e); }
    try {
        infoModal?.addEventListener("click", e => {
