        return opts.join("");
    }

    function preferredLaneTypeFromLane(laneNumber) {
        const lane = Number(laneNumber);
        if (isGymLaneNumber(lane)) return 0;
        if (lane >= 9) return 2;
        if (lane >= 1) return 1;
        return 0;
    }

