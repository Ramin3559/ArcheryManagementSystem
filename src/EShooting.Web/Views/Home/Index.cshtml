    function updateCountdownRings() {
        document.querySelectorAll("[data-countdown-ring]").forEach(el => {
            if (!(el instanceof HTMLElement)) {
                return;
            }

            const start = el.dataset.start ?? "";
            const end = el.dataset.end ?? "";
            const status = el.dataset.status ?? "";
            const timerEl = el.querySelector("[data-role=\"timer\"]");
            const captionEl = el.querySelector("[data-role=\"caption\"]");
            const progressEl = el.querySelector(".countdown-ring__progress");
            if (!timerEl || !(progressEl instanceof SVGGraphicsElement)) {
                return;
            }

            const card = el.closest(".lane-card");
            const bottomHint = card instanceof HTMLElement ? card.querySelector("[data-role=\"lane-bottom-hint\"]") : null;
            const setBottomHint = (text, kind) => {
                if (!(bottomHint instanceof HTMLElement)) return;
                bottomHint.textContent = text || "";
                bottomHint.classList.toggle("is-show", Boolean(text));
                bottomHint.classList.toggle("is-warn", kind === "warn");
                bottomHint.classList.toggle("is-critical", kind === "critical");
            };

            el.classList.remove("is-live", "is-pending", "is-warn", "is-critical", "is-done", "is-idle");

            const startMs = parseApiDate(start).getTime();
            const endMs = parseApiDate(end).getTime();
            const nowMs = Date.now();
            const timedSession = hasValidTimeWindow(startMs, endMs);
            const totalMs = timedSession ? endMs - startMs : 0;

            if (!start || !end || !timedSession) {
                if (status === "Completed") {
                    el.classList.add("is-done");
                    timerEl.textContent = "Bitib";
                    if (captionEl) {
                        captionEl.textContent = "Sessiya";
                    }
                    setBottomHint("", "");
                    applyRingRemaining(progressEl, 0);
                    return;
                }

                if (status === "Scheduled") {
                    el.classList.add("is-pending");
                    const untilStartMs = Number.isFinite(startMs) ? Math.max(0, startMs - nowMs) : 0;
                    timerEl.textContent = untilStartMs > 0 ? formatSeconds(untilStartMs) : "—";
                    if (captionEl) {
                        captionEl.textContent = untilStartMs > 0 ? "Başlayır" : "Planlı";
                    }
                    setBottomHint("", "");
                    applyRingRemaining(progressEl, 1);
                    return;
                }

                if (status === "Active") {
                    el.classList.add("is-live");
                    const elapsedMs = Number.isFinite(startMs)
                        ? Math.max(1000, nowMs - startMs)
                        : 1000;
                    timerEl.textContent = formatSeconds(elapsedMs);
                    if (captionEl) {
                        captionEl.textContent = "Keçən vaxt";
                    }
                    setBottomHint("", "");
                    applyRingRemaining(progressEl, 1);
                    return;
                }

                el.classList.add("is-idle");
                timerEl.textContent = "—";
                if (captionEl) {
                    captionEl.textContent = "Boş";
                }
                setBottomHint("", "");
                applyRingRemaining(progressEl, 0);
                return;
            }

            if (status === "Completed") {
                el.classList.add("is-done");
                timerEl.textContent = "Bitib";
                if (captionEl) {
                    captionEl.textContent = "Sessiya";
                }
                setBottomHint("", "");
                applyRingRemaining(progressEl, 0);
                return;
            }

            if (nowMs < startMs) {
                el.classList.add("is-pending");
                const untilMs = startMs - nowMs;
                const untilSec = Math.floor(untilMs / 1000);
                const startLocal = new Date(startMs);

                // Prevent absurd countdowns (e.g., bad time zones or far future): show planned time instead.
                if (untilSec > 24 * 3600) {
                    timerEl.textContent = startLocal.toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                    if (captionEl) captionEl.textContent = "Planlı";
                    setBottomHint("", "");
                    applyRingRemaining(progressEl, 1);
                    return;
                }

                // 5 dəqiqəlik xəbərdarlıq
                if (untilSec <= 120) {
                    el.classList.add("is-critical");
                } else if (untilSec <= 300) {
                    el.classList.add("is-warn");
                }

                // Pending cards: show only start time (e.g., 17:00). No "Başlayır" line inside ring.
                timerEl.textContent = startLocal.toLocaleTimeString("az-AZ", { hour: "2-digit", minute: "2-digit" });
                if (captionEl) {
                    captionEl.textContent = "Başlayır";
                }
                if (untilSec <= 300) {
                    const minLeft = Math.max(0, Math.ceil(untilSec / 60));
                    setBottomHint(`${minLeft} dəqiqə qaldı`, untilSec <= 120 ? "critical" : "warn");
                } else {
                    setBottomHint("", "");
                }
                applyRingRemaining(progressEl, 1);
                return;
            }

            if (nowMs >= endMs) {
                el.classList.add("is-done");
                timerEl.textContent = "00:00";
                if (captionEl) {
                    captionEl.textContent = "Vaxt bitib";
                }
                setBottomHint("", "");
                applyRingRemaining(progressEl, 0);
                return;
            }

            // For Active sessions, show remaining TRAINING time (exclude 10-min buffer).
            // Buffer is a reservation rule, not the customer's training time.
            const trainingEndMs = Math.max(startMs, endMs - SESSION_BUFFER_MS);
            const trainingRemainingMs = trainingEndMs - nowMs;
            const trainingRemainingSec = Math.floor(trainingRemainingMs / 1000);

            // If training already ended, we're in cleanup/buffer window.
            if (trainingRemainingMs <= 0) {
                const bufferRemainingMs = Math.max(0, endMs - nowMs);
                el.classList.add("is-idle");
                timerEl.textContent = "00:00";
                if (captionEl) captionEl.textContent = "Təmizlik";
                setBottomHint("", "");
                applyRingRemaining(progressEl, 0);
                return;
            }

            const frac = (trainingEndMs - startMs) > 0 ? trainingRemainingMs / (trainingEndMs - startMs) : 0;
            el.classList.add("is-live");
            if (trainingRemainingSec <= COUNTDOWN_CRIT_SEC) {
                el.classList.add("is-critical");
            } else if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) {
                el.classList.add("is-warn");
            }

            timerEl.textContent = formatSeconds(trainingRemainingMs);
            if (captionEl) captionEl.textContent = "Qalan vaxt";

            if (trainingRemainingSec <= COUNTDOWN_WARN_SEC) {
                const minLeft = Math.max(0, Math.ceil(trainingRemainingSec / 60));
                setBottomHint(`${minLeft} dəqiqə qaldı`, trainingRemainingSec <= COUNTDOWN_CRIT_SEC ? "critical" : "warn");
            } else {
                setBottomHint("", "");
            }

            applyRingRemaining(progressEl, frac);
        });
    }

    function restoreLaneDrafts() {
        document.querySelectorAll(".lane-score-input").forEach(input => {
            const sid = input.getAttribute("data-session-id");
            if (!sid) {
                return;
            }

            const key = `session-${sid}`;
            if (Object.prototype.hasOwnProperty.call(laneScoreDraft, key)) {
                input.value = laneScoreDraft[key];
            }
        });
    }

    function bindLaneEvents() {
        document.querySelectorAll(".lane-score-input").forEach(input => {
            input.addEventListener("input", event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLInputElement)) {
                    return;
                }

                const laneNumber = target.getAttribute("data-lane-number");
                const sessionId = target.getAttribute("data-session-id");
                if (!laneNumber && !sessionId) {
                    return;
                }

                const key = sessionId ? `session-${sessionId}` : `lane-${laneNumber}`;
                laneScoreDraft[key] = target.value;
            });
        });

        document.querySelectorAll("[data-submit-lane-score]").forEach(button => {
            button.addEventListener("click", async event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLButtonElement)) {
                    return;
                }

                const sessionId = target.getAttribute("data-session-id");
                const laneNumber = Number(target.getAttribute("data-lane-number"));
                const nextRound = Number(target.getAttribute("data-next-round"));

                if (!sessionId) {
                    alert("Bu zolaqda aktiv sessiya yoxdur.");
                    return;
                }

                const key = `session-${sessionId}`;
                const rawValue = laneScoreDraft[key] ?? "";
                const value = Number(rawValue);

                if (!Number.isFinite(value) || value < 0 || value > 10) {
                    alert("Xal 0 ilə 10 arasında olmalıdır.");
                    return;
                }

                await submitLaneScore(sessionId, laneNumber, nextRound, value);
            });
        });

        document.querySelectorAll(".pick-session").forEach(button => {
            button.addEventListener("click", event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLElement)) {
                    return;
                }

                const selected = target.getAttribute("data-session-id");
                if (!selected) {
                    return;
                }

                const pickedLane = latestLanes.find(x => x.sessionId === selected);
                if (pickedLane?.laneNumber && tabletLaneNumberInput) {
                    tabletLaneNumberInput.value = String(pickedLane.laneNumber);
                }
                if (tabletSessionIdInput) {
                    tabletSessionIdInput.value = selected;
                }
                syncTabletScoreContext();
            });
        });

        document.querySelectorAll("[data-stop-session]").forEach(button => {
            button.addEventListener("click", async event => {
                const target = event.currentTarget;
                if (!(target instanceof HTMLElement)) {
                    return;
                }

                const selected = target.getAttribute("data-stop-session");
                if (!selected) {
                    return;
                }

                const issued = target.getAttribute("data-equipment-issued") === "1";
                const returned = target.getAttribute("data-equipment-returned") === "1";
                if (issued && !returned) {
                    const ok = confirm("Avadanlıq təhvil alındımı?");
                    if (!ok) return;
                    try {
                        await apiFetch(`/sessions/${selected}/equipment/return`, { method: "POST" });
                    } catch { }
                }

                await stopSession(selected);
            });
        });
    }

