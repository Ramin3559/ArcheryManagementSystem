    function addMinutesToTimeHHmm(hhmm, minutesToAdd) {
        if (!/^\d{2}:\d{2}$/.test(hhmm)) return "";
        const [h, m] = hhmm.split(":").map(x => Number(x));
        const total = h * 60 + m + Number(minutesToAdd);
        const mod = ((total % (24 * 60)) + (24 * 60)) % (24 * 60);
        const hh = String(Math.floor(mod / 60)).padStart(2, "0");
        const mm = String(mod % 60).padStart(2, "0");
        return `${hh}:${mm}`;
    }

    // updateSubscriptionEndTimes removed (end time field removed)

    function computeFirstDateForDayWithinStartDate(dayOfWeek, startDateStr) {
        if (!startDateStr) return null;
        const start = new Date(`${startDateStr}T00:00:00`);
        if (!Number.isFinite(start.getTime())) return null;
        let d = new Date(start);
        for (let i = 0; i < 7; i++) {
            if (d.getDay() === Number(dayOfWeek)) return d;
            d.setDate(d.getDate() + 1);
        }
        return start;
    }

    async function refreshLaneAvailabilityForSubscriptionRow(laneSelectEl) {
        if (!(laneSelectEl instanceof HTMLSelectElement)) return;
        const day = laneSelectEl.getAttribute("data-day");
        if (!day) return;
        const laneNumber = Number(laneSelectEl.value ?? "0");
        const root = subscriptionLaneTypesByDayEl?.querySelector(`[data-avail-root="${CSS.escape(day)}"]`);
        const grid = subscriptionLaneTypesByDayEl?.querySelector(`[data-avail-grid="${CSS.escape(day)}"]`);
        const timeInput = subscriptionLaneTypesByDayEl?.querySelector(`input.sub-day-time[data-day="${CSS.escape(day)}"]`);
        const dateInput = subscriptionLaneTypesByDayEl?.querySelector(`input.sub-avail-date[data-day="${CSS.escape(day)}"]`);
        if (!(root instanceof HTMLElement) || !(grid instanceof HTMLElement) || !(timeInput instanceof HTMLInputElement)) return;

        if (!laneNumber || laneNumber <= 0) {
            root.style.display = "none";
            grid.innerHTML = "";
            return;
        }

        const pickedDateStr = (dateInput instanceof HTMLInputElement ? dateInput.value : "") || "";
        if (!pickedDateStr) {
            root.style.display = "";
            grid.innerHTML = "<div style=\"color:#55638a; font-weight:800;\">Əvvəlcə başlanğıc tarixi seçin.</div>";
            return;
        }

        const durationMinutes = computeMinutesPerSelectedDay(Number(subscriptionDurationMinutesInput?.value ?? "0"), getSelectedSubscriptionDays().length);
        root.style.display = "";
        grid.innerHTML = "<div style=\"color:#55638a; font-weight:800;\">Yüklənir...</div>";

        const res = await apiFetch(`/availability/lane?laneNumber=${encodeURIComponent(laneNumber)}&dateLocal=${encodeURIComponent(pickedDateStr)}&durationMinutes=${encodeURIComponent(durationMinutes)}`);
        if (!res.ok) {
            const msg = await readErrorMessage(res);
            grid.innerHTML = `<div style="color:#8d2140; font-weight:900;">${escapeHtml(msg)}</div>`;
            return;
        }
        const data = await res.json();
        const slots = Array.isArray(data?.slots) ? data.slots : [];
        grid.innerHTML = slots.map(s => {
            const t = String(s?.startTimeLocal ?? "");
            const busy = Boolean(s?.isBusy);
            if (busy) {
                return `<div class="slot slot--busy" title="Dolu">${escapeHtml(t)}</div>`;
            }
            return `<button type="button" class="slot slot--free" data-pick-time="${escapeHtml(t)}">${escapeHtml(t)}</button>`;
        }).join("");

        grid.querySelectorAll("[data-pick-time]").forEach(btn => {
            if (!(btn instanceof HTMLElement)) return;
            btn.addEventListener("click", () => {
                const t = btn.getAttribute("data-pick-time") ?? "";
                timeInput.value = t;
                timeInput.dispatchEvent(new Event("input", { bubbles: true }));
            });
        });
    }

    function computeMinutesPerSelectedDay(totalMonthlyHours, selectedDaysCount) {
        const totalMin = Math.max(0, Number(totalMonthlyHours)) * 60;
        const denom = Math.max(1, Number(selectedDaysCount)) * 4; // ~4 həftə
        const raw = totalMin / denom;
        const rounded = Math.max(10, Math.round(raw / 10) * 10);
        return rounded;
    }

    function syncMonthlySplitInfo() {
        if (!(subscriptionInfo instanceof HTMLElement)) return;
        const days = getSelectedSubscriptionDays();
        const totalHours = Number(subscriptionDurationMinutesInput?.value ?? "0");
        if (!Number.isFinite(totalHours) || totalHours <= 0 || days.length === 0) {
            subscriptionInfo.textContent = "Həftə günlərini seçin, hər gün üçün saat və zolağı təyin edin.";
            return;
        }
        const minutesPerDay = computeMinutesPerSelectedDay(totalHours, days.length);
        const hoursPerDay = (minutesPerDay / 60);
        subscriptionInfo.textContent = `Aylıq paket: ${totalHours} saat. Seçim: həftədə ${days.length} gün. Təxmini: hər gün ${hoursPerDay.toFixed(hoursPerDay % 1 === 0 ? 0 : 2)} saat.`;
    }

    function parseApiDate(value) {
        if (!value) {
            return new Date(0);
        }

        const needsUtcSuffix = typeof value === "string" && !/[zZ]|[+-]\d{2}:\d{2}$/.test(value);
        return new Date(needsUtcSuffix ? `${value}Z` : value);
    }

    function hasValidTimeWindow(startMs, endMs) {
        return Number.isFinite(startMs) && Number.isFinite(endMs) && endMs > startMs;
    }

    // syncOpenEndedMode ləğv edildi

    async function apiFetch(input, init = {}) {
        const response = await fetch(input, { ...init, credentials: "same-origin" });
        if (response.status === 401) {
            window.location.assign("/Account/Login?returnUrl=" + encodeURIComponent(window.location.pathname + window.location.search));
            throw new Error("İcazə yoxdur");
        }

        return response;
    }

    async function ensureAthletesCacheFresh() {
        const now = Date.now();
        if (Array.isArray(allAthletesCache) && allAthletesCache.length > 0 && (now - athletesCacheLoadedAtMs) < 60000) {
            return;
        }
        try {
            const res = await apiFetch("/athletes");
            if (!res.ok) {
                allAthletesCache = [];
                athletesCacheLoadedAtMs = now;
                return;
            }
            const data = await res.json();
            allAthletesCache = Array.isArray(data) ? data : [];
            athletesCacheLoadedAtMs = now;
        } catch {
            allAthletesCache = [];
            athletesCacheLoadedAtMs = now;
        }
    }

    function normalizeDigits(value) {
        return String(value ?? "").replaceAll(/\\D+/g, "");
    }

    function normalizeText(value) {
        return String(value ?? "").trim().toLowerCase();
    }

    function pickBestMatch(candidates, scoreFn) {
        if (!Array.isArray(candidates) || candidates.length === 0) return null;
        let best = candidates[0];
        let bestScore = scoreFn(best);
        for (let i = 1; i < candidates.length; i++) {
            const c = candidates[i];
            const s = scoreFn(c);
            if (s > bestScore) {
                best = c;
                bestScore = s;
            }
        }
        return best;
    }

    async function tryAutofillReceptionFromLookup() {
        if (isAutoFillingReception) return;
        const phoneQ = normalizeDigits(phoneNumberInput?.value);
        const emailQ = normalizeText(emailInput?.value);
        const idQ = normalizeText(idCardNumberInput?.value);

        // Minimum input lengths to avoid noisy matches
        const hasQuery = (phoneQ && phoneQ.length >= 4) || (emailQ && emailQ.length >= 4) || (idQ && idQ.length >= 3);
        if (!hasQuery) {
            receptionMatchedAthleteId = null;
            receptionMatchedSnapshot = null;
            syncUpdateAthleteButton();
            setLookupHint("");
            return;
        }

        let best = null;
        try {
            const qs = new URLSearchParams();
            if (phoneQ) qs.set("phone", phoneQ);
            if (emailQ) qs.set("email", emailQ);
            if (idQ) qs.set("idCardNumber", idQ);
            const res = await apiFetch(`/athletes/lookup?${qs.toString()}`);
            if (!res.ok) {
                // Not found or error: clear selection but keep typed data
                receptionMatchedAthleteId = null;
                receptionMatchedSnapshot = null;
                syncUpdateAthleteButton();
                setLookupHint("Müştəri tapılmadı.");
                return;
            }
            best = await res.json();
        } catch {
            return;
        }

        if (!best) return;

        isAutoFillingReception = true;
        try {
            receptionMatchedAthleteId = best.id ?? null;
            if (firstNameInput instanceof HTMLInputElement) firstNameInput.value = best.firstName ?? (best.fullName?.split(" ")[0] ?? "");
            if (lastNameInput instanceof HTMLInputElement) lastNameInput.value = best.lastName ?? (best.fullName?.split(" ").slice(1).join(" ") ?? "");
            if (phoneNumberInput instanceof HTMLInputElement) phoneNumberInput.value = best.phoneNumber ?? "";
            if (emailInput instanceof HTMLInputElement) emailInput.value = best.email ?? "";
            if (idCardNumberInput instanceof HTMLInputElement) idCardNumberInput.value = best.idCardNumber ?? "";
            if (categoryInput instanceof HTMLSelectElement && best.category !== undefined && best.category !== null && String(best.category) !== "") {
                // server returns enum as string (e.g., "Amateur") OR number; handle both
                const catVal = typeof best.category === "number"
                    ? String(best.category)
                    : (String(best.category).toLowerCase() === "amateur" ? "0" : String(best.category).toLowerCase() === "professional" ? "1" : "2");
                categoryInput.value = catVal;
                refreshLaneOptions();
            }
            if (membershipTypeInput instanceof HTMLSelectElement && best.membershipType !== undefined && best.membershipType !== null && String(best.membershipType) !== "") {
                const mVal = typeof best.membershipType === "number"
                    ? String(best.membershipType)
                    : (String(best.membershipType).toLowerCase() === "archeryonly" ? "0" : String(best.membershipType).toLowerCase() === "gymonly" ? "1" : "2");
                membershipTypeInput.value = mVal;
            }
            receptionMatchedSnapshot = buildReceptionCurrentSnapshot();
            setLookupHint(`Müştəri tapıldı: ${(best.fullName ?? `${best.firstName ?? ""} ${best.lastName ?? ""}`.trim()) || "—"}`);
            syncUpdateAthleteButton();
        } finally {
            isAutoFillingReception = false;
        }
    }

    async function updateAthleteFromReception(opts = {}) {
        const id = receptionMatchedAthleteId;
        if (!id) {
            alert("Yeniləmə üçün bazadan seçilmiş şəxs yoxdur (axtarış edin).");
            return false;
        }

        const firstName = firstNameInput?.value?.trim() ?? "";
        const lastName = lastNameInput?.value?.trim() ?? "";
        const phoneNumber = phoneNumberInput?.value?.trim() ?? "";
        if (!firstName || !lastName || !phoneNumber) {
            alert("Ad, Soyad və Telefon mütləqdir.");
            return;
        }

        const membershipTypeRaw = membershipTypeInput?.value ?? "";
        const categoryRaw = categoryInput?.value ?? "";
        if (!membershipTypeRaw) { alert("Abunəlik növünü seçin."); return; }
        if (!categoryRaw) { alert("Kateqoriya seçin."); return; }

        const response = await apiFetch(`/athletes/${encodeURIComponent(id)}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                firstName,
                lastName,
                phoneNumber,
                email: emailInput?.value?.trim() || null,
                idCardNumber: idCardNumberInput?.value?.trim() || null,
                category: Number(categoryRaw),
                isSubscriber: registrationModeInput?.value === "subscription",
                membershipType: Number(membershipTypeRaw)
            })
        });

        if (!response.ok) {
            const message = await readErrorMessage(response);
            alert(message);
            return false;
        }

        const data = await response.json().catch(() => ({}));
        if (!opts?.silentSuccess) {
            alert(data?.message || "Məlumatlar uğurla yeniləndi.");
        }
        // refresh cache immediately
        allAthletesCache = [];
        athletesCacheLoadedAtMs = 0;
        await ensureAthletesCacheFresh();
        receptionMatchedSnapshot = buildReceptionCurrentSnapshot();
