@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using EShooting.Web.Auth
@using EShooting.Web.Extensions
@{
    Antiforgery.GetAndStoreTokens(Context);
    var staffName = User.GetStaffDisplayName();
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Qeydiyyat pəncərəsi</title>
    <style>
        :root {
            --bg-a: #fff3e8;
            --bg-b: #f7f4ff;
            --bg-c: #ecf8ff;
            --panel: rgba(255, 255, 255, 0.78);
            --panel-strong: rgba(255, 255, 255, 0.9);
            --text: #1d2440;
            --text-muted: #657296;
            --primary: #6c5cff;
            --primary-strong: #5543f3;
            --success: #0f9d77;
            --warning: #d68a00;
            --danger: #d1435f;
            --border: rgba(122, 138, 178, 0.28);
            --ring: rgba(108, 92, 255, 0.28);
            --shadow: 0 18px 45px rgba(65, 45, 120, 0.16);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            color: var(--text);
            font-family: "Segoe UI", Arial, sans-serif;
            line-height: 1.45;
            background:
                radial-gradient(circle at 0% 0%, #ffd7be 0%, transparent 40%),
                radial-gradient(circle at 100% 0%, #dacdff 0%, transparent 36%),
                radial-gradient(circle at 100% 100%, #cbe8ff 0%, transparent 45%),
                linear-gradient(145deg, var(--bg-a), var(--bg-b) 46%, var(--bg-c));
            min-height: 100vh;
        }

        main {
            max-width: 1280px;
            margin: 0 auto;
            padding: 28px 24px 34px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .header-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 12px;
            flex-wrap: wrap;
            margin-left: auto;
        }

        .logout-form {
            margin: 0;
        }

        .title-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .connection-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            flex: 0 0 auto;
            background: #b57100;
            box-shadow: 0 0 0 3px rgba(181, 113, 0, 0.22);
        }

        .connection-dot.is-active {
            background: #0b8a69;
            box-shadow: 0 0 0 3px rgba(15, 157, 119, 0.22);
        }

        .connection-dot.is-error {
            background: #445fd4;
            box-shadow: 0 0 0 3px rgba(68, 95, 212, 0.22);
        }

        .connection-dot.is-pending {
            background: #b57100;
            box-shadow: 0 0 0 3px rgba(181, 113, 0, 0.22);
        }

        .title {
            margin: 0;
            font-size: 30px;
            font-weight: 800;
            letter-spacing: 0.02em;
            color: #1b2140;
        }

        .subtitle {
            margin: 6px 0 0;
            color: var(--text-muted);
            font-weight: 500;
        }

        .header-clock {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 4px;
            padding: 10px 14px;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: var(--panel-strong);
            box-shadow: 0 10px 26px rgba(101, 102, 160, 0.16);
            backdrop-filter: blur(10px);
        }

        .header-clock__label {
            font-size: 13px;
            letter-spacing: 0.04em;
            text-transform: none;
            font-weight: 700;
            color: #6b7394;
        }

        .header-clock__value {
            font-size: 26px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.06em;
            color: #2d3260;
        }

        .card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 18px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            transition: transform 0.18s ease, box-shadow 0.22s ease, border-color 0.18s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            border-color: rgba(108, 92, 255, 0.4);
            box-shadow: 0 22px 48px rgba(65, 45, 120, 0.2);
        }

        .card--spaced {
            margin-bottom: 16px;
        }

        .grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(12, 1fr);
        }

        .col-6 {
            grid-column: span 6;
        }

        .col-12 {
            grid-column: span 12;
        }

        @@media (max-width: 900px) {
            .col-6 {
                grid-column: span 12;
            }
        }

        h2 {
            margin: 0 0 12px;
            font-size: 20px;
            font-weight: 800;
            color: #253060;
        }

        .row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 10px;
        }

        .row > * {
            min-width: 140px;
        }

        input,
        select,
        textarea,
        button {
            border-radius: 12px;
            border: 1px solid var(--border);
            padding: 10px 12px;
            color: var(--text);
            transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease, filter 0.2s ease;
        }

        input,
        textarea,
        select {
            min-height: 42px;
            background: #fff;
        }

        input::placeholder {
            color: #8b97b9;
        }

        input:focus,
        select:focus,
        button:focus-visible {
            outline: none;
            border-color: #7668ff;
            box-shadow: 0 0 0 4px var(--ring);
        }

        button {
            cursor: pointer;
            font-weight: 700;
        }

        .btn {
            min-height: 42px;
            border-radius: 12px;
            letter-spacing: 0.01em;
        }

        .btn-primary {
            border: none;
            color: #fff;
            background: linear-gradient(120deg, var(--primary), #8a57ff);
            box-shadow: 0 10px 22px rgba(108, 92, 255, 0.32);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            background: linear-gradient(120deg, var(--primary-strong), #7a4df0);
        }

        .btn-secondary {
            border: none;
            color: #fff;
            background: linear-gradient(125deg, #25a2d7, #1f86d8);
            box-shadow: 0 10px 22px rgba(36, 137, 214, 0.3);
        }

        .btn-secondary:hover {
            transform: translateY(-1px);
            filter: brightness(1.04);
        }

        .btn-ghost {
            background: rgba(255, 255, 255, 0.75);
            color: #37426e;
            border: 1px solid var(--border);
        }

        .btn-ghost:hover {
            border-color: rgba(108, 92, 255, 0.38);
            background: #fff;
        }

        .btn-danger {
            background: rgba(209, 67, 95, 0.12);
            color: #8d2140;
            border: 1px solid rgba(209, 67, 95, 0.35);
        }

        .btn-danger:hover {
            background: rgba(209, 67, 95, 0.18);
            border-color: rgba(209, 67, 95, 0.52);
        }

        .btn-success {
            border: 1px solid rgba(18, 153, 104, 0.55);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .btn-success:hover {
            border-color: rgba(18, 153, 104, 0.72);
            background: rgba(18, 153, 104, 0.24);
        }

        .btn-sm {
            min-height: 38px;
            padding: 8px 14px;
            font-size: 13px;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        @@media (max-width: 900px) {
            .stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .stat {
            border-radius: 15px;
            padding: 14px;
            border: 1px solid rgba(122, 138, 178, 0.23);
            background: rgba(255, 255, 255, 0.72);
            box-shadow: 0 10px 24px rgba(104, 93, 161, 0.14);
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .stat-value {
            margin-top: 6px;
            font-size: 28px;
            line-height: 1;
            font-weight: 800;
            color: #222d58;
        }

        .notice {
            margin-top: 6px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .status-pill {
            display: inline-block;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 700;
            background: rgba(86, 103, 148, 0.18);
            color: #52618f;
        }

        .status-pill.Active {
            background: rgba(15, 157, 119, 0.16);
            color: #0b8a69;
        }

        .status-pill.Completed {
            background: rgba(78, 102, 255, 0.16);
            color: #445fd4;
        }

        .status-pill.Scheduled {
            background: rgba(214, 138, 0, 0.2);
            color: #b57100;
        }

        .lane-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }

        @@media (max-width: 1100px) {
            .lane-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 700px) {
            .lane-grid {
                grid-template-columns: 1fr;
            }
        }

        .lane-card {
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(122, 138, 178, 0.25);
            border-radius: 16px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            box-shadow: 0 14px 24px rgba(96, 87, 157, 0.12);
            transition: transform 0.15s ease, box-shadow 0.2s ease;
        }

        .lane-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 30px rgba(96, 87, 157, 0.16);
        }

        .lane-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .lane-title {
            margin: 0;
            font-size: 17px;
            font-weight: 800;
            color: #202c56;
        }

        .lane-type {
            font-size: 11px;
            color: #7b86a7;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .lane-meta {
            margin: 4px 0;
            color: #667395;
            font-size: 13px;
        }

        .lane-meta--compact {
            font-size: 12px;
            line-height: 1.35;
        }

        .score {
            margin-top: 10px;
            font-weight: 800;
            font-size: 22px;
            color: #24305f;
        }

        .countdown-ring-wrap {
            --ring-track: rgba(62, 77, 130, 0.14);
            --ring-accent: #17ad80;
            --ring-glow: rgba(23, 173, 128, 0.25);
            position: relative;
            width: 132px;
            height: 132px;
            margin: 12px auto 4px;
        }

        .countdown-ring-wrap--compact {
            width: 52px;
            height: 52px;
            margin: 0 auto;
        }

        .countdown-ring__svg {
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
            filter: drop-shadow(0 0 10px var(--ring-glow));
        }

        .countdown-ring__track {
            fill: none;
            stroke: var(--ring-track);
            stroke-width: 7;
        }

        .countdown-ring__progress {
            fill: none;
            stroke: var(--ring-accent);
            stroke-width: 7;
            stroke-linecap: round;
            transition: stroke-dashoffset 0.35s ease, stroke 0.3s ease, filter 0.3s ease;
        }

        .countdown-ring__center {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 8px;
            pointer-events: none;
        }

        .countdown-ring__timer {
            font-size: 22px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            letter-spacing: 0.04em;
            line-height: 1.1;
            color: #26325f;
        }

        .countdown-ring-wrap--compact .countdown-ring__timer {
            font-size: 11px;
            font-weight: 700;
        }

        .countdown-ring__caption {
            margin-top: 4px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #7a86a8;
        }

        /* TV zolaq ekranı üçün zolğ; əsas paneldə görünməsin */
        .countdown-ring__bartrack {
            display: none;
        }

        .lane-card {
            position: relative;
        }

        .lane-bottom-hint {
            position: absolute;
            left: 16px;
            bottom: 62px; /* above Stop button */
            font-weight: 900;
            font-size: 14px;
            color: #11824b;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
            pointer-events: none;
        }

        .lane-bottom-hint.is-show {
            opacity: 1;
            transform: translateY(0);
        }

        .lane-bottom-hint.is-warn {
            color: #c77700;
        }

        .lane-bottom-hint.is-critical {
            color: #b63852;
        }

        .equip-fab {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            border: 1px solid rgba(41,55,89,0.22);
            background: rgba(255,255,255,0.92);
            box-shadow: 0 10px 30px rgba(16, 24, 40, 0.22);
            cursor: pointer;
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
        }

        .equip-fab:hover { transform: translateY(-1px); }
        .equip-fab--hidden { display: none; }
        .equip-fab--idle { background: rgba(245, 246, 250, 0.92); }
        .equip-fab--ok { background: rgba(27, 191, 122, 0.16); border-color: rgba(27, 191, 122, 0.28); }
        .equip-fab--bad { background: rgba(209, 67, 95, 0.18); border-color: rgba(209, 67, 95, 0.35); }

        @@keyframes equipPulse {
            0% { box-shadow: 0 0 0 0 rgba(209, 67, 95, 0.28), 0 10px 30px rgba(16, 24, 40, 0.22); }
            70% { box-shadow: 0 0 0 14px rgba(209, 67, 95, 0.0), 0 10px 30px rgba(16, 24, 40, 0.22); }
            100% { box-shadow: 0 0 0 0 rgba(209, 67, 95, 0.0), 0 10px 30px rgba(16, 24, 40, 0.22); }
        }

        .equip-fab--pulse { animation: equipPulse 1.25s ease-out infinite; }

        .equip-fab__icon {
            font-size: 18px;
            line-height: 1;
        }

        .equip-fab__badge {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 20px;
            height: 20px;
            border-radius: 999px;
            padding: 0 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 900;
            color: #fff;
            background: #1bbf7a;
            border: 2px solid rgba(255,255,255,0.92);
        }

        .equip-fab--bad .equip-fab__badge { background: #d1435f; }
        .equip-fab--idle .equip-fab__badge { background: #7a86a8; }

        .equip-panel {
            position: fixed;
            top: 86px;
            right: 14px;
            width: min(380px, 92vw);
            z-index: 8887;
            background: rgba(255,255,255,0.95);
            border: 1px solid rgba(41,55,89,0.22);
            border-radius: 14px;
            padding: 12px;
            box-shadow: 0 16px 50px rgba(16, 24, 40, 0.28);
            transform: translateX(calc(100% + 20px));
            opacity: 0;
            pointer-events: none;
            transition: transform 0.22s ease, opacity 0.22s ease;
        }

        .equip-panel.is-open {
            transform: translateX(0);
            opacity: 1;
            pointer-events: auto;
        }

        .equip-panel__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .countdown-ring-wrap.is-pending {
            --ring-accent: #d68a00;
            --ring-glow: rgba(214, 138, 0, 0.24);
        }

        .countdown-ring-wrap.is-live.is-warn:not(.is-critical),
        .countdown-ring-wrap.is-pending.is-warn:not(.is-critical) {
            --ring-accent: #ef8f1f;
            --ring-glow: rgba(239, 143, 31, 0.3);
        }

        .countdown-ring-wrap.is-live.is-critical,
        .countdown-ring-wrap.is-pending.is-critical {
            --ring-accent: #d1435f;
            --ring-glow: rgba(209, 67, 95, 0.34);
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer,
        .countdown-ring-wrap.is-pending.is-critical .countdown-ring__timer {
            color: #b63852;
        }

        .countdown-ring-wrap.is-done,
        .countdown-ring-wrap.is-idle {
            --ring-accent: rgba(120, 132, 168, 0.55);
            --ring-glow: transparent;
        }

        .countdown-ring-wrap.is-live.is-critical .countdown-ring__svg {
            animation: ring-pulse 0.95s ease-in-out infinite;
        }

        @@keyframes ring-pulse {
            0%, 100% { filter: drop-shadow(0 0 6px var(--ring-glow)); }
            50% { filter: drop-shadow(0 0 16px var(--ring-glow)); }
        }

        .table-countdown-cell {
            vertical-align: middle;
            min-width: 64px;
        }

        .lane-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
        }

        .lane-score-input {
            flex: 1;
            min-width: 0;
        }

        .lane-score-btn {
            min-width: 86px;
            padding: 8px 10px;
            font-size: 12px;
            border: none;
            color: #fff;
            background: linear-gradient(125deg, #25a2d7, #1f86d8);
        }

        .pick-session {
            margin-top: 10px;
            width: 100%;
            min-height: 38px;
            padding: 8px 12px;
            font-size: 12px;
            border: 1px solid rgba(108, 92, 255, 0.28);
            background: rgba(108, 92, 255, 0.12);
            color: #403a97;
            font-weight: 700;
        }

        .pick-session:hover {
            border-color: rgba(108, 92, 255, 0.55);
            background: rgba(108, 92, 255, 0.17);
        }

        .stop-session-btn {
            margin-top: 8px;
            width: 100%;
            min-height: 38px;
            padding: 8px 12px;
            border-radius: 10px;
            border: 1px solid rgba(209, 67, 95, 0.4);
            background: rgba(209, 67, 95, 0.14);
            color: #a72d48;
            font-size: 12px;
            font-weight: 700;
        }

        .stop-session-btn:hover {
            border-color: rgba(209, 67, 95, 0.72);
            background: rgba(209, 67, 95, 0.2);
        }

        .warn {
            margin-top: 6px;
            font-size: 13px;
            font-weight: 600;
        }

        .warn.ok {
            color: #128461;
        }

        .warn.alert {
            color: #b26d00;
        }

        .warn.danger {
            color: #b83854;
        }

        .table-wrap {
            margin-top: 12px;
            overflow-x: auto;
            border: 1px solid var(--border);
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.75);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 760px;
        }

        th,
        td {
            border-bottom: 1px solid rgba(122, 138, 178, 0.2);
            padding: 11px 10px;
            text-align: left;
            font-size: 13px;
        }

        th {
            color: #586892;
            font-weight: 700;
            background: rgba(108, 92, 255, 0.06);
        }

        tr:hover td {
            background: rgba(108, 92, 255, 0.04);
        }

        .tv-links {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
            align-items: center;
        }

        .tv-link {
            display: inline-block;
            padding: 8px 12px;
            border-radius: 11px;
            border: 1px solid rgba(108, 92, 255, 0.25);
            background: rgba(108, 92, 255, 0.1);
            color: #413c9a;
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            transition: transform 0.15s ease, border-color 0.2s ease, background 0.2s ease;
        }

        .tv-link:hover {
            transform: translateY(-1px);
            border-color: rgba(108, 92, 255, 0.52);
            background: rgba(108, 92, 255, 0.16);
        }

        .tv-link--pro {
            margin-left: 8px;
            border-color: rgba(214, 138, 0, 0.42);
            background: rgba(255, 245, 225, 0.75);
            color: #6a3f00;
        }

        .tv-link--pro-first {
            margin-left: 18px;
        }

        .tv-link--active {
            border-color: rgba(18, 153, 104, 0.55);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .tv-link--pending {
            border-color: rgba(214, 138, 0, 0.55);
            background: rgba(214, 138, 0, 0.18);
            color: #8a5600;
        }

        .tv-link--active.tv-link--pro {
            border-color: rgba(18, 153, 104, 0.58);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .tv-link--pending.tv-link--pro {
            border-color: rgba(214, 138, 0, 0.58);
            background: rgba(214, 138, 0, 0.18);
            color: #8a5600;
        }

        .tv-link.tv-link--disabled.tv-link--active,
        .tv-link[aria-disabled="true"].tv-link--active {
            border-color: rgba(18, 153, 104, 0.55);
            background: rgba(18, 153, 104, 0.18);
            color: #0b5a3d;
        }

        .tv-link.tv-link--disabled.tv-link--pending,
        .tv-link[aria-disabled="true"].tv-link--pending {
            border-color: rgba(214, 138, 0, 0.55);
            background: rgba(214, 138, 0, 0.18);
            color: #8a5600;
        }

        .tv-link.tv-link--disabled,
        .tv-link[aria-disabled="true"] {
            cursor: default;
            pointer-events: none;
            transform: none;
        }

        .subscription-table td,
        .subscription-table th {
            white-space: nowrap;
        }

        .notice.notice--warn {
            background: rgba(255, 214, 102, 0.42);
            border-color: rgba(214, 138, 0, 0.45);
            color: #6a3f00;
            font-weight: 800;
        }

        .notice.notice--ok {
            background: rgba(27, 191, 122, 0.16);
            border-color: rgba(27, 191, 122, 0.32);
            color: #0f5c39;
            font-weight: 800;
        }

        .notice.notice--error {
            background: rgba(209, 67, 95, 0.16);
            border-color: rgba(209, 67, 95, 0.30);
            color: #6a1024;
            font-weight: 800;
        }

        .avail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(88px, 1fr));
            gap: 8px;
            width: 100%;
            margin-top: 8px;
        }

        .slot {
            border-radius: 12px;
            border: 1px solid rgba(41, 55, 89, 0.18);
            padding: 10px 10px;
            background: rgba(255, 255, 255, 0.8);
            font-weight: 900;
            color: #1a2650;
        }

        .slot.slot--free {
            border-color: rgba(18, 153, 104, 0.40);
            background: rgba(18, 153, 104, 0.10);
            color: #0b5a3d;
            cursor: pointer;
        }

        .slot.slot--busy {
            border-color: rgba(209, 67, 95, 0.45);
            background: rgba(209, 67, 95, 0.10);
            color: #8d2140;
            opacity: 0.75;
            cursor: default;
            pointer-events: none;
        }

        .checkbox-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 42px;
            padding: 8px 12px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.76);
            color: #475483;
            font-size: 13px;
            font-weight: 700;
            user-select: none;
        }

        .checkbox-chip input[type="checkbox"],
        .checkbox-chip input[type="radio"] {
            accent-color: var(--primary);
            width: 16px;
            height: 16px;
            margin: 0;
        }

        .group-athletes-input {
            min-height: 44px; /* ilkin açılışda kiçik */
            height: 44px;
            max-height: 240px; /* adlar artdıqca aşağı doğru böyüsün */
            width: auto;
            flex: 1 1 360px;
            resize: none;
            overflow: hidden;
            line-height: 1.35;
            font-family: inherit;
        }

        .group-row {
            align-items: stretch;
            max-width: 780px;
        }

        .group-row > * {
            min-width: 0; /* row default min-width(140px) override */
        }

        .group-register-btn {
            flex: 0 0 auto;
            min-width: 220px;
            white-space: nowrap;
        }

        .group-booking-panel {
            margin: 12px 0 4px;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid rgba(214, 138, 0, 0.35);
            background: rgba(255, 248, 235, 0.75);
        }

        .group-booking-panel__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
        }

        .group-booking-panel__title {
            margin: 0;
            font-size: 15px;
            font-weight: 800;
            color: #6a3f00;
        }

        .group-members-list {
            list-style: none;
            margin: 10px 0 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .group-member-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 8px 10px;
            border-radius: 10px;
            border: 1px solid rgba(214, 138, 0, 0.28);
            background: rgba(255, 255, 255, 0.85);
        }

        .group-member-item__name {
            font-weight: 700;
            color: #1a2650;
            font-size: 14px;
        }

        .group-member-item__meta {
            font-size: 12px;
            color: #7a86a8;
            margin-top: 2px;
        }

        .group-members-empty {
            margin: 8px 0 0;
            font-size: 13px;
            color: #8a5600;
        }

        .athlete-suggest {
            position: fixed;
            z-index: 1100;
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 14px 32px rgba(96, 87, 157, 0.18);
            max-height: 280px;
            overflow-y: auto;
            min-width: 240px;
        }

        .athlete-suggest__row {
            padding: 9px 12px;
            cursor: pointer;
            border-bottom: 1px solid rgba(122, 138, 178, 0.16);
            font-size: 13px;
            color: #2a3260;
            line-height: 1.35;
        }

        .athlete-suggest__row:last-child { border-bottom: 0; }
        .athlete-suggest__row:hover, .athlete-suggest__row.is-active {
            background: rgba(99, 132, 255, 0.12);
        }

        .athlete-suggest__name {
            font-weight: 700;
        }

        .athlete-suggest__meta {
            color: #65719b;
            font-size: 12px;
            margin-top: 2px;
        }

        .athlete-suggest__empty {
            padding: 9px 12px;
            color: var(--text-muted);
            font-size: 13px;
        }

        .staff-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--panel-strong);
            font-size: 13px;
            font-weight: 700;
            color: #3a4668;
        }

        .staff-badge__name {
            color: #2d3260;
        }

        .staff-badge__position {
            color: var(--text-muted);
            font-weight: 600;
        }

        .vip-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid rgba(214, 138, 0, 0.35);
            background: rgba(214, 138, 0, 0.12);
            color: #9a5d00;
            font-weight: 700;
            white-space: nowrap;
        }

        .section-heading {
            margin: 18px 0 8px;
            font-size: 17px;
            font-weight: 800;
            color: #253060;
        }

        .section-heading:first-of-type {
            margin-top: 0;
        }

        .section-hint {
            margin: 0 0 10px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .input-search {
            flex: 1 1 320px;
            min-width: 220px;
            padding: 12px 14px;
            font-size: 15px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--panel-strong);
        }

        .input-search:focus {
            outline: none;
            border-color: rgba(108, 92, 255, 0.55);
            box-shadow: 0 0 0 4px var(--ring);
        }

        .lane-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 6px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .lane-legend__item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .lane-legend__swatch {
            width: 12px;
            height: 12px;
            border-radius: 4px;
            border: 1px solid rgba(108, 92, 255, 0.25);
            background: rgba(108, 92, 255, 0.1);
        }

        .lane-legend__swatch.is-busy {
            border-color: rgba(18, 153, 104, 0.55);
            background: rgba(18, 153, 104, 0.35);
        }

        .lane-legend__swatch.is-pending {
            border-color: rgba(214, 138, 0, 0.55);
            background: rgba(214, 138, 0, 0.28);
        }

        .selected-customer-card {
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            margin: 10px 0 4px;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid rgba(18, 153, 104, 0.35);
            background: rgba(18, 153, 104, 0.1);
        }

        .selected-customer-card.is-show {
            display: flex;
        }

        .selected-customer-card__name {
            font-weight: 800;
            color: #1b4d38;
            font-size: 15px;
        }

        .selected-customer-card__meta {
            display: block;
            margin-top: 2px;
            font-size: 12px;
            color: #4d6d5f;
            font-weight: 600;
        }

        .selected-customer-card__actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .customer-modal-panel {
            max-width: 720px;
            margin: 5vh auto 0;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid rgba(41, 55, 89, 0.22);
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 22px 50px rgba(13, 24, 48, 0.2);
        }

        .customer-modal-title {
            margin: 0;
            font-size: 18px;
            font-weight: 900;
            color: #1a2650;
        }

        .customer-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            margin-top: 14px;
            flex-wrap: wrap;
        }

        #groupLaneRow .group-athletes-input {
            flex: 1 1 100%;
            min-height: 88px;
        }
    </style>
</head>
<body>
<main>
    <header class="header">
        <div>
            <div class="title-wrap">
                <span class="connection-dot is-pending" id="connectionDot" role="status" aria-label="Qoşulur" title="Canlı bağlantı yoxlanılır"></span>
                <h1 class="title">Qeydiyyat pəncərəsi</h1>
            </div>
        </div>
        <div class="header-actions">
            <div class="staff-badge" title="Daxil olan işçi">
                <span class="staff-badge__name">@staffName</span>
            </div>
            <button id="refreshReceptionBtn" type="button" class="btn btn-ghost btn-sm" title="Qeydiyyat səhifəsini yenilə">Yenilə</button>
            <div class="header-clock" title="Cari tarix və saat">
                <span class="header-clock__label" id="wallDate">--.--.----</span>
                <span class="header-clock__value" id="wallClock">--:--:--</span>
            </div>
            <form method="post" action="/resepsiya/cixis" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-ghost btn-sm">Çıxış</button>
            </form>
        </div>
    </header>

    <section class="stats">
        <article class="stat">
            <div class="stat-label">Zolaqlar (cəmi)</div>
            <div class="stat-value" id="totalLanes">11</div>
        </article>
        <article class="stat">
            <div class="stat-label">Aktiv sessiyalar</div>
            <div class="stat-value" id="activeSessions">0</div>
        </article>
        <article class="stat">
            <div class="stat-label">Planlaşdırılmış</div>
            <div class="stat-value" id="scheduledSessions">0</div>
        </article>
        <article class="stat">
            <div class="stat-label">Bitmiş sessiyalar</div>
            <div class="stat-value" id="completedSessions">0</div>
        </article>
    </section>

    <section class="card card--spaced">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
            <h2 style="margin:0;">Zolaqlar</h2>
        </div>
        <div class="lane-legend">
            <span class="lane-legend__item"><span class="lane-legend__swatch"></span> Boş</span>
            <span class="lane-legend__item"><span class="lane-legend__swatch is-pending"></span> Gözləmə (Başlayır)</span>
            <span class="lane-legend__item"><span class="lane-legend__swatch is-busy"></span> Aktiv (indi zolaqda)</span>
        </div>
        <div class="tv-links">
            @for (var i = 1; i <= 11; i++)
            {
                <span class="tv-link tv-link--disabled @(i >= 9 ? "tv-link--pro" : "") @(i == 9 ? "tv-link--pro-first" : "")"
                      data-tv-lane="@i"
                      aria-disabled="true"
                      title="Yalnız məlumat üçün (klik deaktivdir)">
                    Zolaq @i
                </span>
            }
        </div>
    </section>

    <section class="grid">
        <article class="card col-12">
            <h2 class="section-heading">Müştəri axtarışı</h2>
            <div class="row">
                <input id="customerSearch"
                       class="input-search"
                       type="search"
                       placeholder="Ad, telefon, email və ya Ş/V ilə axtarın…"
                       autocomplete="off" />
                <button id="addCustomerBtn" type="button" class="btn btn-primary">Müştəri əlavə et</button>
                <button id="manageCustomerBtn" type="button" class="btn btn-ghost">Məlumatları yenilə</button>
            </div>
            <div class="notice" id="receptionLookupHint" style="display:none;"></div>

            <div id="selectedCustomerCard" class="selected-customer-card">
                <div>
                    <div class="selected-customer-card__name" id="selectedCustomerName">—</div>
                    <span class="selected-customer-card__meta" id="selectedCustomerMeta"></span>
                </div>
                <div class="selected-customer-card__actions">
                    <button id="addToGroupBtn" type="button" class="btn btn-ghost btn-sm" style="display:none;">Qrupa əlavə et</button>
                    <button id="clearCustomerBtn" type="button" class="btn btn-ghost btn-sm">Təmizlə</button>
                </div>
            </div>

            <div class="row" id="groupModeRow" style="margin-top:10px;">
                <label class="checkbox-chip" title="Eyni zolaqda bir neçə nəfər">
                    <input type="checkbox" id="groupModeToggle" />
                    Qrup rejimi (eyni zolaq)
                </label>
            </div>
            <div id="groupBookingPanel" class="group-booking-panel" style="display:none;">
                <div class="group-booking-panel__head">
                    <h3 class="group-booking-panel__title">Qrup siyahısı</h3>
                    <button id="clearGroupMembersBtn" type="button" class="btn btn-ghost btn-sm">Qrupu təmizlə</button>
                </div>
                <p class="section-hint" style="margin:6px 0 0;">Müştəri axtarışından seçin, «Qrupa əlavə et» basın. Sistemdə yoxdursa «Müştəri əlavə et» ilə qeyd edin.</p>
                <ul id="groupMembersList" class="group-members-list"></ul>
                <p id="groupMembersEmpty" class="group-members-empty">Hələ heç kim əlavə edilməyib.</p>
            </div>

            <div id="customerFieldsStore" style="display:none;" aria-hidden="true">
                <input id="firstName" />
                <input id="lastName" />
                <input id="phoneNumber" />
                <input id="email" />
                <input id="idCardNumber" />
                <select id="category">
                    <option value="" selected disabled>Kateqoriya seçin</option>
                    <option value="0">Həvəskar</option>
                    <option value="1">Professional</option>
                    <option value="2">Məşqçi</option>
                </select>
                <select id="membershipType">
                    <option value="" selected disabled>Abunəlik növü seçin</option>
                    <option value="2">Hər ikisi (Full)</option>
                    <option value="0">Yalnız oxatma</option>
                    <option value="1">Yalnız zal</option>
                </select>
                <input id="includesLane" type="checkbox" checked />
                <input id="includesShooting" type="checkbox" checked />
                <input id="includesGym" type="checkbox" />
                <input id="isVip" type="checkbox" />
            </div>

            <h2 class="section-heading">Zolağa yazılma</h2>
            <p class="section-hint" id="laneBookingHint">Paket seçin. Birdefəlik paketdə zolaq və başlama vaxtını təyin edin. Sabit aylıq paketdə həftə günləri və saat seçin. <strong>Aylıq çevik paket</strong>də limit yoxdur — müştəri istənilən vaxt gəlir, resepsiyon boş zolaq aktiv edir.</p>
            <div class="row">
                <select id="bookingPackage" title="Paket">
                    <option value="" selected disabled>Paket seçin</option>
                </select>
                <span id="packageDurationHint" class="section-hint" style="margin:0; align-self:center;"></span>
                <button id="pickEquipmentBtn" type="button" class="btn btn-ghost">Avadanlıq seç</button>
                <span id="equipmentSelectionSummary" class="section-hint" style="margin:0; align-self:center;"></span>
            </div>
            <input type="hidden" id="registrationMode" value="" />
            <input type="hidden" id="durationMinutes" value="0" />
            <div class="row" id="sessionStartRow">
                <label class="checkbox-chip" title="Sessiya dərhal başlasın">
                    <input type="radio" name="sessionStartMode" value="now" checked />
                    İndi başla
                </label>
                <label class="checkbox-chip" title="Gələcək saatda planlaşdır">
                    <input type="radio" name="sessionStartMode" value="scheduled" />
                    Saat seç
                </label>
                <input id="sessionStartTime" type="time" disabled title="Başlama saatı" />
            </div>
            <div class="row" id="subscriptionPeriodRow" style="display:none;">
                <label style="display:flex;flex-direction:column;gap:4px;">
                    <span class="section-hint" style="margin:0;">Abunə başlanğıcı</span>
                    <input id="bookingSubStartDate" type="date" title="Abunə başlanğıc tarixi" />
                </label>
                <label id="bookingSubEndDateWrap" style="display:flex;flex-direction:column;gap:4px;">
                    <span class="section-hint" style="margin:0;">Abunə bitməsi</span>
                    <input id="bookingSubEndDate" type="date" title="Abunə bitmə tarixi" />
                </label>
                <label id="bookingSubMonthsWrap" style="display:none; flex-direction:column; gap:4px;">
                    <span class="section-hint" style="margin:0;">Neçə ay (VIP)</span>
                    <input id="bookingSubMonths" type="number" min="1" max="120" value="1" title="VIP abunə müddəti — ay sayı" />
                </label>
            </div>
            <div id="bookingWalkInHint" class="notice" style="display:none; margin-top:8px;">
                Limitsiz çevik abunə — həftəlik plan lazım deyil. Müştəri ay ərzində istənilən vaxt gələ bilər; hər gəlişdə «Boş zolaq aktiv et» ilə yazılır.
            </div>
            <div id="bookingVipHint" class="notice" style="display:none; margin-top:8px;">
                VIP full paket — sessiya müddəti yoxdur. Qeydiyyatda neçə ay olduğunu qeyd edin; müştəri istənilən vaxt gələndə boş zolağa yazılır.
            </div>
            <div id="bookingSubscriptionScheduleRow" style="display:none;">
                <div class="notice" style="margin-bottom:8px;">Həftə günlərini seçin. Seçdiyin hər gün üçün aşağıda ayrıca saat və zolaq təyin edin.</div>
                <div id="bookingSubscriptionDays" style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:8px;">
                    <label class="checkbox-chip"><input type="checkbox" value="1" class="booking-sub-day" /> B.e</label>
                    <label class="checkbox-chip"><input type="checkbox" value="2" class="booking-sub-day" /> Ç.a</label>
                    <label class="checkbox-chip"><input type="checkbox" value="3" class="booking-sub-day" /> Ç</label>
                    <label class="checkbox-chip"><input type="checkbox" value="4" class="booking-sub-day" /> C.a</label>
                    <label class="checkbox-chip"><input type="checkbox" value="5" class="booking-sub-day" /> C</label>
                    <label class="checkbox-chip"><input type="checkbox" value="6" class="booking-sub-day" /> Ş</label>
                    <label class="checkbox-chip"><input type="checkbox" value="0" class="booking-sub-day" /> Bazar</label>
                </div>
                <div id="bookingSubscriptionLaneTypesByDay" style="display:grid; grid-template-columns: 1fr; gap:8px; width:100%;"></div>
            </div>
            <div class="row" id="instantLaneRow">
                <select id="laneNumber">
                    <option value="1" selected>Zolaq 1 (Həvəskar)</option>
                    <option value="2">Zolaq 2 (Həvəskar)</option>
                    <option value="3">Zolaq 3 (Həvəskar)</option>
                    <option value="4">Zolaq 4 (Həvəskar)</option>
                    <option value="5">Zolaq 5 (Həvəskar)</option>
                    <option value="6">Zolaq 6 (Həvəskar)</option>
                    <option value="7">Zolaq 7 (Həvəskar)</option>
                    <option value="8">Zolaq 8 (Həvəskar)</option>
                    <option value="9">Zolaq 9 (Peşəkar)</option>
                    <option value="10">Zolaq 10 (Peşəkar)</option>
                    <option value="11">Zolaq 11 (Peşəkar)</option>
                    <option value="12">Zal</option>
                </select>
                <button id="scheduleBtn" type="button" class="btn btn-primary">Zolağa yaz</button>
            </div>
            <div id="receptionWalkInBanner" class="notice" style="display:none; margin-top:8px; border-color:rgba(15,157,119,0.35); background:rgba(15,157,119,0.08); color:#0b6b52;"></div>
            <div class="notice" id="groupInfo" style="display:none;" aria-hidden="true"></div>
            <div class="notice" id="sessionInfo">Müştəri və paket seçin, sonra zolaq və vaxt təyin edin.</div>
        </article>

        <article class="card col-6" style="display:none;">
            <h2>Planşet — xal</h2>
            <div class="row">
                <input id="tabletAthleteName" placeholder="İdmançı" readonly />
                <select id="tabletLaneNumber">
                    <option value="1">Zolaq 1</option>
                    <option value="2">Zolaq 2</option>
                    <option value="3">Zolaq 3</option>
                    <option value="4">Zolaq 4</option>
                    <option value="5">Zolaq 5</option>
                    <option value="6">Zolaq 6</option>
                    <option value="7">Zolaq 7</option>
                    <option value="8">Zolaq 8</option>
                    <option value="9">Zolaq 9</option>
                    <option value="10">Zolaq 10</option>
                    <option value="11">Zolaq 11</option>
                </select>
                <input id="tabletSessionId" type="hidden" value="" />
                <input id="roundNumber" type="number" min="1" value="1" />
                <input id="scoreValue" type="number" min="0" max="10" value="10" />
                <button id="submitScoreBtn" class="btn btn-secondary">Xalı göndər</button>
            </div>
            <div class="notice">Xal 0–10 aralığında olmalıdır.</div>
        </article>

        <article class="card col-12" id="subscriptionSection" style="display:none;" aria-hidden="true">
            <h2>Aylıq abunə planlama</h2>
            <div class="row">
                <input id="subscriptionAthleteName" placeholder="Abunəçinin adı, soyadı" readonly />
                <label class="checkbox-chip" title="Full paket: sabit həftəlik plan tələb olunmur">
                    <input id="subscriptionIsFullPackage" type="checkbox" />
                    Full paket
                </label>
                <div class="notice" style="flex: 1 1 100%; margin-top:-6px;">
                    Həftə günlərini seçin. Seçdiyin hər gün üçün aşağıda ayrıca saat və zolaq seçəcəksən.
                </div>
                <div id="subscriptionDays" style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
                    <label class="checkbox-chip"><input type="checkbox" value="1" class="sub-day" /> B.e</label>
                    <label class="checkbox-chip"><input type="checkbox" value="2" class="sub-day" /> Ç.a</label>
                    <label class="checkbox-chip"><input type="checkbox" value="3" class="sub-day" /> Ç</label>
