<!-- Flatpickr + SignalR — lokal (CDN internet gözlətməsin) -->
<link rel="stylesheet" href="/lib/flatpickr/flatpickr.min.css" />
<script defer src="/lib/flatpickr/flatpickr.min.js"></script>
<script defer src="/lib/flatpickr/l10n-az.js"></script>
<script defer src="/lib/signalr/signalr.min.js"></script>
<script>
    // Tarix və saat seçicilərini Azerbaycan dilində + 24 saat formatında istifadə et.
    (function () {
        function isFlatpickrReady() {
            return typeof window.flatpickr === "function";
        }
        function applyAzLocale() {
            try {
                if (isFlatpickrReady() && window.flatpickr.l10ns && window.flatpickr.l10ns.az) {
                    window.flatpickr.localize(window.flatpickr.l10ns.az);
                }
            } catch (e) { /* ignore */ }
        }
        function bindOne(el) {
            if (!(el instanceof HTMLInputElement)) return;
            if (el.dataset.fpBound === "1") return;
            var type = (el.getAttribute("type") || "").toLowerCase();
            if (type !== "date" && type !== "time" && type !== "datetime-local") return;
            try {
                var opts = { locale: "az", allowInput: true, time_24hr: true };
                if (type === "time") {
                    opts.enableTime = true;
                    opts.noCalendar = true;
                    opts.dateFormat = "H:i";
                } else if (type === "datetime-local") {
                    opts.enableTime = true;
                    opts.dateFormat = "Y-m-d H:i";
                } else {
                    opts.dateFormat = "Y-m-d";
                }
                window.flatpickr(el, opts);
                el.dataset.fpBound = "1";
