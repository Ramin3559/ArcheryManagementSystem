    function renderEquipmentPickerList() {
        if (!(equipmentPickerList instanceof HTMLElement)) return;
        equipmentPickerList.innerHTML = "";
        if (!equipmentCatalogCache.length) {
            equipmentPickerList.innerHTML = '<div class="notice">Aktiv avadanlıq tapılmadı. Admin panelindən əlavə edin.</div>';
            return;
        }

        for (const item of equipmentCatalogCache) {
            const draft = equipmentPickerDraft.find(x => String(x.equipmentItemId) === String(item.id));
            const checked = Boolean(draft);
            const issueType = draft?.issueType ?? "Rental";

            const row = document.createElement("div");
            row.style.display = "grid";
            row.style.gridTemplateColumns = "auto 1fr";
            row.style.gap = "10px";
            row.style.alignItems = "center";
            row.style.padding = "10px 12px";
            row.style.border = "1px solid rgba(41,55,89,0.16)";
            row.style.borderRadius = "12px";
            row.style.background = "rgba(255,255,255,0.95)";

            const cb = document.createElement("input");
            cb.type = "checkbox";
            cb.checked = checked;
            cb.dataset.equipmentId = item.id;

            const body = document.createElement("div");
            const title = document.createElement("div");
            title.style.fontWeight = "800";
            const price = item.price != null ? ` · ${item.price} ₼` : "";
            const category = item.category ? ` (${item.category})` : "";
            title.textContent = `${item.name}${category}${price}`;

            const modeRow = document.createElement("div");
            modeRow.style.display = checked ? "flex" : "none";
            modeRow.style.gap = "12px";
            modeRow.style.marginTop = "8px";
            modeRow.style.flexWrap = "wrap";

            const saleLabel = document.createElement("label");
            saleLabel.className = "checkbox-chip";
            saleLabel.innerHTML = `<input type="radio" name="equip-mode-${item.id}" value="Sale" ${issueType === "Sale" ? "checked" : ""} /> Birdefəlik satış`;
            const rentalLabel = document.createElement("label");
            rentalLabel.className = "checkbox-chip";
            rentalLabel.innerHTML = `<input type="radio" name="equip-mode-${item.id}" value="Rental" ${issueType === "Rental" ? "checked" : ""} /> İstifadə üçün icarə`;

            modeRow.appendChild(saleLabel);
            modeRow.appendChild(rentalLabel);
            body.appendChild(title);
            body.appendChild(modeRow);

            cb.addEventListener("change", () => {
                modeRow.style.display = cb.checked ? "flex" : "none";
                if (!cb.checked) {
                    equipmentPickerDraft = equipmentPickerDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                } else {
                    const mode = modeRow.querySelector('input[type="radio"]:checked')?.value ?? "Rental";
                    equipmentPickerDraft = equipmentPickerDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                    equipmentPickerDraft.push({ equipmentItemId: item.id, issueType: mode });
                }
            });

            modeRow.addEventListener("change", () => {
                if (!cb.checked) return;
                const mode = modeRow.querySelector('input[type="radio"]:checked')?.value ?? "Rental";
                equipmentPickerDraft = equipmentPickerDraft.filter(x => String(x.equipmentItemId) !== String(item.id));
                equipmentPickerDraft.push({ equipmentItemId: item.id, issueType: mode });
            });

            row.appendChild(cb);
            row.appendChild(body);
            equipmentPickerList.appendChild(row);
        }
    }

