    let dashboardLoadInFlight = false;
    let dashboardLoadQueued = false;
    let receptionRefreshTimerId = null;
    let lastReceptionRefreshAt = 0;
    const RECEPTION_REFRESH_GAP_MS = 300;

    function scheduleReceptionRefresh(includeExtras) {
        if (receptionRefreshTimerId) {
            clearTimeout(receptionRefreshTimerId);
        }
        const now = Date.now();
        const wait = Math.max(0, RECEPTION_REFRESH_GAP_MS - (now - lastReceptionRefreshAt));
        receptionRefreshTimerId = setTimeout(async () => {
            receptionRefreshTimerId = null;
            lastReceptionRefreshAt = Date.now();
