    async function tryAutofillReceptionFromLookup() {
        if (isAutoFillingReception) return;
        const phoneQ = normalizeDigits(phoneNumberInput?.value);
        const emailQ = normalizeText(emailInput?.value);
        const idQ = normalizeText(idCardNumberInput?.value);

        // Minimum input lengths to avoid noisy matches
        const hasQuery = (phoneQ && phoneQ.length >= 3) || (emailQ && emailQ.length >= 4) || (idQ && idQ.length >= 3);
        if (!hasQuery) {
            receptionMatchedAthleteId = null;
            receptionMatchedSnapshot = null;
            syncUpdateAthleteButton();
            setLookupHint("");
            return;
        }

        let best = null;
        try {
            const qs = new URLSearchParams();
            if (phoneQ) qs.set("phone", phoneQ);
            if (emailQ) qs.set("email", emailQ);
            if (idQ) qs.set("idCardNumber", idQ);
            const res = await apiFetch(`/athletes/lookup?${qs.toString()}`);
            if (!res.ok) {
                // Not found or error: clear selection but keep typed data
                receptionMatchedAthleteId = null;
                receptionMatchedSnapshot = null;
                syncUpdateAthleteButton();
                setLookupHint("Müştəri tapılmadı.");
                return;
            }
            best = await res.json();
        } catch {
            return;
        }

        if (!best) return;

        isAutoFillingReception = true;
        try {
            receptionMatchedAthleteId = best.id ?? null;
            if (firstNameInput instanceof HTMLInputElement) firstNameInput.value = best.firstName ?? (best.fullName?.split(" ")[0] ?? "");
            if (lastNameInput instanceof HTMLInputElement) lastNameInput.value = best.lastName ?? (best.fullName?.split(" ").slice(1).join(" ") ?? "");
            if (phoneNumberInput instanceof HTMLInputElement) phoneNumberInput.value = best.phoneNumber ?? "";
            if (emailInput instanceof HTMLInputElement) emailInput.value = best.email ?? "";
            if (idCardNumberInput instanceof HTMLInputElement) idCardNumberInput.value = best.idCardNumber ?? "";
            if (categoryInput instanceof HTMLSelectElement && best.category !== undefined && best.category !== null && String(best.category) !== "") {
                // server returns enum as string (e.g., "Amateur") OR number; handle both
                const catVal = typeof best.category === "number"
                    ? String(best.category)
                    : (String(best.category).toLowerCase() === "amateur" ? "0" : String(best.category).toLowerCase() === "professional" ? "1" : "2");
                categoryInput.value = catVal;
                refreshLaneOptions();
            }
            if (membershipTypeInput instanceof HTMLSelectElement && best.membershipType !== undefined && best.membershipType !== null && String(best.membershipType) !== "") {
                const mVal = membershipToSelectValue(best.membershipType);
                membershipTypeInput.value = mVal;
                const access = accessFromMembershipType(mVal);
                if (includesLaneInput instanceof HTMLInputElement) includesLaneInput.checked = access.shooting;
                if (includesShootingInput instanceof HTMLInputElement) includesShootingInput.checked = access.shooting;
                if (includesGymInput instanceof HTMLInputElement) includesGymInput.checked = access.gym;
            }
            if (isVipInput instanceof HTMLInputElement) {
                isVipInput.checked = Boolean(best.isVip);
            }
            receptionMatchedSnapshot = buildReceptionCurrentSnapshot();
            const displayName = (best.fullName ?? `${best.firstName ?? ""} ${best.lastName ?? ""}`.trim()) || "—";
            if (customerSearchInput instanceof HTMLInputElement && displayName !== "—") {
                customerSearchInput.value = displayName;
            }
            setLookupHint(`Müştəri tapıldı: ${displayName}`);
            applyReceptionWalkInFromAthlete(best);
            refreshSelectedCustomerCard();
            syncUpdateAthleteButton();
        } finally {
            isAutoFillingReception = false;
        }
    }

    async function updateAthleteFromReception(opts = {}) {
        const id = receptionMatchedAthleteId;
        if (!id) {
            alert("Yeniləmə üçün bazadan seçilmiş şəxs yoxdur (axtarış edin).");
            return false;
        }

        const firstName = firstNameInput?.value?.trim() ?? "";
        const lastName = lastNameInput?.value?.trim() ?? "";
        const phoneNumber = phoneNumberInput?.value?.trim() ?? "";
        if (!firstName || !lastName || !phoneNumber) {
            alert("Ad, Soyad və Telefon mütləqdir.");
            return false;
        }

        const membershipTypeRaw = membershipTypeInput?.value ?? "";
        const categoryRaw = categoryInput?.value ?? "";
        if (!membershipTypeRaw) { alert("Abunəlik növünü seçin."); return false; }
        if (!categoryRaw) { alert("Kateqoriya seçin."); return false; }

        const response = await apiFetch(`/athletes/${encodeURIComponent(id)}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                firstName,
                lastName,
                phoneNumber,
                email: emailInput?.value?.trim() || null,
                idCardNumber: idCardNumberInput?.value?.trim() || null,
                category: Number(categoryRaw),
                isSubscriber: registrationModeInput?.value === "subscription",
                membershipType: Number(membershipTypeRaw),
                isVip: Boolean(isVipInput?.checked)
            })
        });

        if (!response.ok) {
            const message = await readErrorMessage(response);
            alert(message);
            return false;
        }

        const data = await response.json().catch(() => ({}));
        if (!opts?.silentSuccess) {
            alert(data?.message || "Məlumatlar uğurla yeniləndi.");
        }
        // refresh cache immediately
        allAthletesCache = [];
        athletesCacheLoadedAtMs = 0;
        await ensureAthletesCacheFresh();
        receptionMatchedSnapshot = buildReceptionCurrentSnapshot();
        setLookupHint(`Məlumatlar yeniləndi: ${(firstNameInput?.value ?? "").trim()} ${(lastNameInput?.value ?? "").trim()}`.trim());
        syncUpdateAthleteButton();
        return true;
    }

