            try { syncSubscriptionAthleteNameFromReception(); } catch (e) { /* ignore */ }
            refreshSelectedCustomerCard();
            console.log("[autocomplete] xanalar dolduruldu", {
                first: firstNameInput && firstNameInput.value,
                last: lastNameInput && lastNameInput.value,
                phone: phoneNumberInput && phoneNumberInput.value,
                email: emailInput && emailInput.value,
                idCard: idCardNumberInput && idCardNumberInput.value
            });
        } catch (err) {
            console.error("[autocomplete] applyAthleteToReception failed", err);
        } finally {
            isAutoFillingReception = false;
        }
    }

    // ====== Reception sahələri üçün avtomatik tamamlama (yazdıqca açılan siyahı) ======
    const _athleteSuggestEl = (function () {
        const el = document.createElement("div");
        el.className = "athlete-suggest";
        el.style.display = "none";
        el.setAttribute("role", "listbox");
        document.body.appendChild(el);
        return el;
    })();
    let _athleteSuggestAnchor = null;
    let _athleteSuggestItems = [];

    function hideAthleteSuggest() {
        _athleteSuggestEl.style.display = "none";
        _athleteSuggestEl.innerHTML = "";
        _athleteSuggestAnchor = null;
        _athleteSuggestItems = [];
    }

    function escapeForHtml(s) {
        return String(s ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
    }

    function renderAthleteSuggestItems(items) {
        // Köhnə listenerlərin yığılmaması üçün hər render əvvəli içəriyi tamamilə təmizləyirik.
        while (_athleteSuggestEl.firstChild) {
            _athleteSuggestEl.removeChild(_athleteSuggestEl.firstChild);
        }
        if (!Array.isArray(items) || items.length === 0) {
            const empty = document.createElement("div");
            empty.className = "athlete-suggest__empty";
            empty.textContent = "Uyğun nəticə yoxdur";
            _athleteSuggestEl.appendChild(empty);
            return;
        }

        items.forEach(function (it) {
            const fullName = it.fullName || (`${it.firstName || ""} ${it.lastName || ""}`).trim() || "—";
            const row = document.createElement("div");
            row.className = "athlete-suggest__row";

            const nameEl = document.createElement("div");
            nameEl.className = "athlete-suggest__name";
            nameEl.textContent = fullName + (it.isVip ? " · VIP" : "");
            row.appendChild(nameEl);

            const metaParts = [];
            if (it.phoneNumber) metaParts.push(it.phoneNumber);
            if (it.email) metaParts.push(it.email);
            if (it.idCardNumber) metaParts.push("FİN: " + it.idCardNumber);
            if (metaParts.length) {
                const meta = document.createElement("div");
                meta.className = "athlete-suggest__meta";
                meta.textContent = metaParts.join(" · ");
                row.appendChild(meta);
            }

            // Birbaşa hər sətrə öz handler-i — delegasiya yox.
            const onSelect = function (ev) {
                if (ev) {
                    try { ev.preventDefault(); } catch (e) { /* ignore */ }
                    try { ev.stopPropagation(); } catch (e) { /* ignore */ }
                }
                console.log("[autocomplete] row seçildi", it);
                applyAthleteToReception(it);
                hideAthleteSuggest();
            };
            row.addEventListener("mousedown", function (ev) {
                _isClickingAthleteSuggest = true;
                onSelect(ev);
            });
            row.addEventListener("touchend", function (ev) { onSelect(ev); });

            _athleteSuggestEl.appendChild(row);
        });
    }

    function positionAthleteSuggest(anchorInput) {
        if (!(anchorInput instanceof HTMLElement)) return;
        const rect = anchorInput.getBoundingClientRect();
        const top = rect.bottom + 4;
        const maxLeft = Math.max(8, window.innerWidth - 320);
        const left = Math.min(rect.left, maxLeft);
        _athleteSuggestEl.style.top = top + "px";
        _athleteSuggestEl.style.left = left + "px";
        _athleteSuggestEl.style.minWidth = Math.max(260, rect.width) + "px";
    }

    async function fetchAthleteSearch(q) {
        try {
            const res = await apiFetch(`/athletes/search?q=${encodeURIComponent(q)}&limit=10`);
            if (!res.ok) return [];
            const list = await res.json();
            return Array.isArray(list) ? list : [];
        } catch (e) { return []; }
    }

    const debouncedAthleteSearch = debounce(async function (input) {
        if (!(input instanceof HTMLInputElement)) return;
        // Avtomatik dolduran zaman yenidən axtarış göstərmək lazım deyil.
        if (isAutoFillingReception) return;
        const q = (input.value || "").trim();
        if (q.length < 2) { hideAthleteSuggest(); return; }
        const items = await fetchAthleteSearch(q);
        // İstifadəçi başqa xanaya keçibsə, nəticə artıq aktual deyil.
        if (document.activeElement !== input) return;
        _athleteSuggestItems = items;
        _athleteSuggestAnchor = input;
        renderAthleteSuggestItems(items);
        positionAthleteSuggest(input);
        _athleteSuggestEl.style.display = "block";
    }, 180);

    let _isClickingAthleteSuggest = false;

    function attachAthleteAutocomplete() {
        const inputs = [customerSearchInput]
            .filter(x => x instanceof HTMLInputElement);
        inputs.forEach(function (input) {
            input.addEventListener("input", function () { debouncedAthleteSearch(input); });
            input.addEventListener("focus", function () {
                const q = (input.value || "").trim();
                if (q.length >= 2) debouncedAthleteSearch(input);
            });
            input.addEventListener("blur", function () {
                // Popover sətri üzərinə klik edirsə blur-da bağlama (mousedown _isClickingAthleteSuggest qoyur).
                setTimeout(function () {
                    if (_isClickingAthleteSuggest) {
                        _isClickingAthleteSuggest = false;
                        return;
                    }
                    hideAthleteSuggest();
                }, 200);
            });
        });

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") hideAthleteSuggest();
        });
        // Pəncərə resize / scroll olduqda popover yerini itirməsin deyə bağlayırıq.
        window.addEventListener("resize", hideAthleteSuggest);
        document.addEventListener("scroll", function (e) {
            // Popover öz daxili scroll-u olarsa onu nəzərə alma.
            if (_athleteSuggestEl.contains(e.target)) return;
            hideAthleteSuggest();
        }, true);

        // Pəncərənin başqa yerində klik olarsa popoveri bağla.
        document.addEventListener("mousedown", function (e) {
            const t = e.target;
            if (!(t instanceof Node)) return;
            if (_athleteSuggestEl.contains(t)) return; // popoverin öz daxili klik
            if (inputs.some(function (inp) { return inp === t; })) return; // input özüdür
            hideAthleteSuggest();
        });
    }

    function debounce(fn, waitMs) {
        let t = null;
        return (...args) => {
            if (t) clearTimeout(t);
            t = setTimeout(() => fn(...args), waitMs);
        };
    }

    function containsAtSign(value) {
        return String(value ?? "").indexOf("\u0040") >= 0;
    }

    async function resolveManageCustomerLookupFields() {
        let phone = normalizeDigits(phoneNumberInput?.value ?? "");
        let email = normalizeText(emailInput?.value ?? "");
        let idCardNumber = normalizeText(idCardNumberInput?.value ?? "");
        const searchRaw = (customerSearchInput?.value ?? "").trim();

        if (searchRaw) {
            const searchDigits = normalizeDigits(searchRaw);
            if (searchDigits.length >= 7) {
                phone = phone || searchDigits;
            } else if (containsAtSign(searchRaw)) {
                email = email || searchRaw.toLowerCase();
            }
        }

        if (!phone && !email && !idCardNumber && receptionMatchedAthleteId) {
            try {
                const athlete = await fetchAthleteById(receptionMatchedAthleteId);
                if (athlete) {
                    phone = phone || normalizeDigits(athlete.phoneNumber ?? "");
                    email = email || normalizeText(athlete.email ?? "");
                    idCardNumber = idCardNumber || normalizeText(athlete.idCardNumber ?? "");
                }
            } catch { /* ignore */ }
        }

        if (!phone && !email && !idCardNumber && searchRaw.length >= 2) {
            try {
                const lookupQs = new URLSearchParams();
                const searchDigits = normalizeDigits(searchRaw);
                if (searchDigits.length >= 7) lookupQs.set("phone", searchDigits);
                if (containsAtSign(searchRaw)) lookupQs.set("email", searchRaw.toLowerCase());
                if ([...lookupQs.keys()].length) {
                    const lookupRes = await apiFetch(`/athletes/lookup?${lookupQs.toString()}`, { timeoutMs: 20000 });
                    if (lookupRes.ok) {
                        const found = await lookupRes.json();
                        phone = phone || normalizeDigits(found?.phoneNumber ?? "");
                        email = email || normalizeText(found?.email ?? "");
                        idCardNumber = idCardNumber || normalizeText(found?.idCardNumber ?? "");
                    }
                }
                if (!phone && !email && !idCardNumber) {
                    const searchRes = await apiFetch(`/athletes/search?q=${encodeURIComponent(searchRaw)}&limit=5`, { timeoutMs: 20000 });
                    if (searchRes.ok) {
                        const items = await searchRes.json().catch(() => []);
                        const first = Array.isArray(items) && items.length ? items[0] : null;
                        if (first) {
                            phone = normalizeDigits(first.phoneNumber ?? "");
                            email = normalizeText(first.email ?? "");
                            idCardNumber = normalizeText(first.idCardNumber ?? "");
                        }
                    }
                }
            } catch { /* ignore */ }
        }

        if (infoPhone instanceof HTMLInputElement) infoPhone.value = phone;
        if (infoEmail instanceof HTMLInputElement) infoEmail.value = email;
        if (infoIdCard instanceof HTMLInputElement) infoIdCard.value = idCardNumber;

        return Boolean(phone || email || idCardNumber);
    }

    async function openManageCustomerModal(options = {}) {
        _manageRedirectContext = options?.bookingContext ?? null;
        openInfoModal();
        const hasLookup = await resolveManageCustomerLookupFields();
        if (hasLookup) {
            await infoShow();
            applyManageRedirectContext();
        } else {
            showInfoHint("Axtarış sahəsinə telefon, ad və ya email yazın.", "warn");
        }
    }

    function openInfoModal() {
        if (!(infoModal instanceof HTMLElement)) return;
        infoModal.style.display = "block";
        if (infoResultHint instanceof HTMLElement) {
            infoResultHint.style.display = "none";
            infoResultHint.textContent = "";
        }
        if (infoTableWrap instanceof HTMLElement) {
            infoTableWrap.style.display = "none";
        }
        if (infoTableBody instanceof HTMLElement) {
            infoTableBody.innerHTML = "";
        }
        if (infoPackagesSummary instanceof HTMLElement) {
            infoPackagesSummary.style.display = "none";
            infoPackagesSummary.innerHTML = "";
        }
        if (infoOccurrencesHint instanceof HTMLElement) {
            infoOccurrencesHint.style.display = "none";
        }
        if (infoProfileSection instanceof HTMLElement) {
            infoProfileSection.style.display = "none";
        }
        try { infoPhone?.focus(); } catch { }
    }

    function closeInfoModal() {
        if (!(infoModal instanceof HTMLElement)) return;
