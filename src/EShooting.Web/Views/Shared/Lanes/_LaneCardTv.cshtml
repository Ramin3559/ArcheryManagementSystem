@using EShooting.Web.Helpers
@model EShooting.Application.Common.Models.LaneDashboardItem
@{
    var st = Model.Status ?? "Idle";
    var nowUtc = DateTime.UtcNow;
    var startUtc = Model.StartTimeUtc is null
        ? (DateTime?)null
        : (Model.StartTimeUtc.Value.Kind == DateTimeKind.Unspecified ? DateTime.SpecifyKind(Model.StartTimeUtc.Value, DateTimeKind.Utc) : Model.StartTimeUtc.Value.ToUniversalTime());
    var endUtc = Model.EndTimeUtc is null
        ? (DateTime?)null
        : (Model.EndTimeUtc.Value.Kind == DateTimeKind.Unspecified ? DateTime.SpecifyKind(Model.EndTimeUtc.Value, DateTimeKind.Utc) : Model.EndTimeUtc.Value.ToUniversalTime());

    var trainingBuffer = TimeSpan.Zero;
    var effectiveStatus = st;
    var isVipTvMode = Model.IsAthleteVip || Model.IsOpenEndedSession;
    if (startUtc is not null && endUtc is not null)
    {
        var isOpenEnded = endUtc.Value <= startUtc.Value;
        if (isOpenEnded || isVipTvMode)
        {
            if (nowUtc < startUtc.Value) effectiveStatus = "Scheduled";
            else if (st == "Completed") effectiveStatus = "Completed";
            else effectiveStatus = "Active";
        }
        else
        {
            var trainingEndUtc = endUtc.Value - trainingBuffer;
            if (nowUtc < startUtc.Value) effectiveStatus = "Scheduled";
            else if (nowUtc >= trainingEndUtc) effectiveStatus = "Completed";
            else effectiveStatus = "Active";
        }
    }

    var hasSession = Model.IsSessionOpen && Model.SessionId is not null;
    var startText = LaneDisplayHelper.FormatScheduleTimeLocal(Model.StartTimeUtc);
    var endText = LaneDisplayHelper.FormatScheduleTimeLocal(Model.EndTimeUtc);
    var wallClockNow = LaneDisplayHelper.FormatTimeLocal(DateTime.UtcNow);
    var athleteLines = LaneDisplayHelper.ParseGroupAthleteDisplayLines(
        Model.AthleteName,
        Model.AthleteFirstName,
        Model.AthleteLastName);
    var isGroupDisplay = athleteLines.Count > 1;
}
@await Html.PartialAsync("Lanes/_LaneCardTvStyles")
<article class="lane-card lane-card--tv@(hasSession ? " lane-card--tv-active" : "")@(isVipTvMode && hasSession ? " lane-card--tv-vip" : "")@(hasSession && !isGroupDisplay ? " lane-card--tv-single" : "")" data-tv-layout="v3">
    <div class="lane-tv-grid">
        <div class="lane-tv-panel lane-tv-panel--logo">
            <img class="lane-tv-brand-logo"
                 src="/images/logoZolag.png"
                 alt="Target Archery Club"
                 onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/logoZolag.jpg';}else if(this.dataset.fallback==='1'){this.dataset.fallback='2';this.src='/images/club-logo.jpg';}else if(this.dataset.fallback==='2'){this.dataset.fallback='3';this.src='/images/placeholder-logo.jpg';}" />
        </div>

        <div class="lane-tv-panel lane-tv-panel--center-stack">
            <div class="lane-tv-center-col">
                <div class="lane-tv-center-inner">
                    <h2 class="lane-tv-lane-num">Zolaq @Model.LaneNumber</h2>
                </div>
            </div>
        </div>

        <div class="lane-tv-panel lane-tv-panel--clock">
            <span id="laneTvWallClockGrid" class="lane-tv-wall-clock__value" data-role="wall-clock-display">@wallClockNow</span>
        </div>

        @if (hasSession)
        {
            if (isGroupDisplay)
            {
                <div class="lane-tv-panel lane-tv-panel--name">
                    <div class="lane-tv-athlete lane-tv-athlete--group">
                        @foreach (var person in athleteLines)
                        {
                            <div class="lane-tv-person">
                                @if (!string.IsNullOrEmpty(person.First))
                                {
                                    <span class="lane-tv-first-name">@person.First</span>
                                }
                                @if (!string.IsNullOrEmpty(person.Last))
                                {
                                    <span class="lane-tv-last-name">@person.Last@(person.TrailingComma ? "," : "")</span>
                                }
                                else if (person.TrailingComma)
                                {
                                    <span class="lane-tv-last-name">,</span>
                                }
                            </div>
                        }
                        @if (Model.HasPendingRentalEquipment)
                        {
                            <span class="lane-tv-equip" aria-hidden="true">🏹</span>
                        }
                    </div>
                </div>

                <div class="lane-tv-panel lane-tv-panel--session-times">
                    <div class="lane-tv-center-col">
                        <div class="lane-tv-center-inner">
                            <div class="lane-tv-schedule" data-role="lane-schedule">
                                <div class="lane-tv-schedule__row">
                                    <span class="lane-tv-schedule__item" data-role="schedule-start">Başlama: @startText</span>
                                </div>
                                @if (!isVipTvMode)
                                {
                                    <div class="lane-tv-schedule__row lane-tv-schedule__row--end">
                                        <span class="lane-tv-schedule__item" data-role="schedule-end">Bitmə: @endText</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                var person = athleteLines.Count > 0 ? athleteLines[0] : default;
                var hasFirst = athleteLines.Count > 0 && !string.IsNullOrEmpty(person.First);
                var hasLast = athleteLines.Count > 0 && !string.IsNullOrEmpty(person.Last);

                <div class="lane-tv-detail-grid">
                    <div class="lane-tv-panel lane-tv-panel--name-first">
                        @if (hasFirst)
                        {
                            <span class="lane-tv-first-name">@person.First</span>
                        }
                        else
                        {
                            <span class="lane-tv-first-name">—</span>
                        }
                    </div>

                    <div class="lane-tv-panel lane-tv-panel--session-start">
                        <div class="lane-tv-center-col">
                            <div class="lane-tv-center-inner">
                                <span class="lane-tv-schedule__item" data-role="schedule-start">Başlama: @startText</span>
                            </div>
                        </div>
                    </div>

                    <div class="lane-tv-panel lane-tv-panel--name-last">
                        @if (hasLast)
                        {
                            <span class="lane-tv-last-name">@person.Last</span>
                        }
                        @if (Model.HasPendingRentalEquipment)
                        {
                            <span class="lane-tv-equip" aria-hidden="true">🏹</span>
                        }
                    </div>

                    @if (!isVipTvMode)
                    {
                        <div class="lane-tv-panel lane-tv-panel--session-end">
                            <div class="lane-tv-center-col">
                                <div class="lane-tv-center-inner">
                                    <span class="lane-tv-schedule__item" data-role="schedule-end">Bitmə: @endText</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        <div class="lane-tv-panel lane-tv-panel--ring">
            <div class="countdown-ring-wrap"
                 data-countdown-ring
                 data-start="@LaneDisplayHelper.ToIsoOffset(Model.StartTimeUtc)"
                 data-end="@LaneDisplayHelper.ToIsoOffset(Model.EndTimeUtc)"
                 data-status="@effectiveStatus"
                 data-vip-mode="@(isVipTvMode ? "1" : "0")"
                 data-pending-rental-equipment="@(Model.HasPendingRentalEquipment ? "1" : "0")">
                <svg class="countdown-ring__svg" viewBox="0 0 100 100" aria-hidden="true">
                    <circle class="countdown-ring__track" cx="50" cy="50" r="42" />
                    <circle class="countdown-ring__progress" cx="50" cy="50" r="42" />
                </svg>
                <div class="countdown-ring__center">
                    <div class="countdown-ring__timer-shell">
                        <div class="countdown-ring__timer" data-role="timer">—</div>
                    </div>
                    <div class="countdown-ring__caption" data-role="caption" aria-hidden="true"></div>
                </div>
            </div>
        </div>
    </div>
    @if (hasSession)
    {
        <div class="lane-bottom-hint" data-role="lane-bottom-hint"></div>
    }
</article>
