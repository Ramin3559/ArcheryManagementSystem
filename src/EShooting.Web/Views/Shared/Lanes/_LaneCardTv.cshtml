@using EShooting.Web.Helpers
@model EShooting.Application.Common.Models.LaneDashboardItem
@{
    var st = Model.Status ?? "Idle";
    var isOpenEnded = LaneDisplayHelper.IsOpenEndedLaneSession(Model);
    var isVipTvMode = isOpenEnded;
    var effectiveStatus = LaneDisplayHelper.ResolveEffectiveLaneStatus(st, Model.StartTimeUtc, Model.EndTimeUtc, isOpenEnded);

    var hasSession = Model.IsSessionOpen && Model.SessionId is not null;
    var startText = LaneDisplayHelper.FormatScheduleTimeLocal(Model.StartTimeUtc);
    var endText = LaneDisplayHelper.FormatSessionEndScheduleDisplay(Model.StartTimeUtc, Model.EndTimeUtc, effectiveStatus, isOpenEnded);
    var wallClockNow = LaneDisplayHelper.FormatTimeLocal(DateTime.UtcNow);
    var athleteLines = LaneDisplayHelper.ParseGroupAthleteDisplayLines(
        Model.AthleteName,
        Model.AthleteFirstName,
        Model.AthleteLastName);
    var isGroupDisplay = athleteLines.Count > 1;
}
@await Html.PartialAsync("Lanes/_LaneCardTvStyles")
<article class="lane-card lane-card--tv@(hasSession ? " lane-card--tv-active" : "")@(isVipTvMode && hasSession ? " lane-card--tv-vip" : "")@(hasSession && !isGroupDisplay ? " lane-card--tv-single" : "")" data-tv-layout="v4">
    <div class="lane-tv-grid">
        <div class="lane-tv-panel lane-tv-panel--schedule-top">
            @if (hasSession)
            {
                <div class="lane-tv-schedule" data-role="lane-schedule">
                    <span class="lane-tv-schedule__item" data-role="schedule-start">Başlama: @startText</span>
                    <span class="lane-tv-schedule__item" data-role="schedule-end">Bitmə: @endText</span>
                </div>
            }
        </div>

        <div class="lane-tv-panel lane-tv-panel--logo">
            <img class="lane-tv-brand-logo"
                 src="/images/logoZolag.png"
                 alt="Target Archery Club"
                 onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/logoZolag.jpg';}else if(this.dataset.fallback==='1'){this.dataset.fallback='2';this.src='/images/club-logo.jpg';}else if(this.dataset.fallback==='2'){this.dataset.fallback='3';this.src='/images/placeholder-logo.jpg';}" />
        </div>

        <div class="lane-tv-panel lane-tv-panel--lane-top">
            <h2 class="lane-tv-lane-num"><span class="lane-tv-lane-num__label">Zolaq</span><span class="lane-tv-lane-num__value">@Model.LaneNumber</span></h2>
        </div>

        @if (hasSession)
        {
            <div class="lane-tv-panel lane-tv-panel--name">
                <div class="lane-tv-athlete@(isGroupDisplay ? " lane-tv-athlete--group" : " lane-tv-athlete--single")">
                    @if (athleteLines.Count == 0)
                    {
                        <div class="lane-tv-person">
                            <span class="lane-tv-first-name">@(Model.AthleteName ?? "—")</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var person in athleteLines)
                        {
                            <div class="lane-tv-person">
                                @if (!string.IsNullOrEmpty(person.First))
                                {
                                    <span class="lane-tv-first-name">@person.First</span>
                                }
                                @if (!string.IsNullOrEmpty(person.Last))
                                {
                                    <span class="lane-tv-last-name">@person.Last@(person.TrailingComma ? "," : "")</span>
                                }
                                else if (person.TrailingComma)
                                {
                                    <span class="lane-tv-last-name">,</span>
                                }
                            </div>
                        }
                    }
                    @if (Model.HasPendingRentalEquipment)
                    {
                        <span class="lane-tv-equip lane-tv-equip--hidden" aria-hidden="true">🏹</span>
                    }
                </div>
            </div>
        }

        <div class="lane-tv-panel lane-tv-panel--ring">
            <div class="countdown-ring-wrap"
                 data-countdown-ring
                 data-start="@LaneDisplayHelper.ToIsoOffset(Model.StartTimeUtc)"
                 data-end="@LaneDisplayHelper.ToIsoOffset(Model.EndTimeUtc)"
                 data-status="@effectiveStatus"
                 data-vip-mode="@(isVipTvMode ? "1" : "0")"
                 data-pending-rental-equipment="@(Model.HasPendingRentalEquipment ? "1" : "0")">
                <svg class="countdown-ring__svg" viewBox="0 0 100 100" aria-hidden="true">
                    <circle class="countdown-ring__track" cx="50" cy="50" r="42" />
                    <circle class="countdown-ring__progress" cx="50" cy="50" r="42" />
                </svg>
                <div class="countdown-ring__center">
                    <div class="countdown-ring__timer-shell">
                        <div class="countdown-ring__timer" data-role="timer">—</div>
                    </div>
                    <div class="countdown-ring__caption" data-role="caption" aria-hidden="true"></div>
                </div>
            </div>
        </div>

        <div class="lane-tv-panel lane-tv-panel--clock-bottom">
            <span id="laneTvWallClockGrid" class="lane-tv-wall-clock__value" data-role="wall-clock-display">@wallClockNow</span>
        </div>

        @if (hasSession)
        {
            <div class="lane-tv-panel lane-tv-panel--hint-bottom lane-bottom-hint" data-role="lane-bottom-hint"></div>
        }
    </div>
</article>
