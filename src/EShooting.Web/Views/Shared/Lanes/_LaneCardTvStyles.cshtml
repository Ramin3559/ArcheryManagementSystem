<style id="lane-tv-styles-v3-3">
    /* TV zolaq kartı — layout v3 (MiBox / Android TV overscan nəzərə alınır) */
    .lane-tv-body .lane-card.is-cleanup .lane-tv-athlete {
        display: none !important;
    }

    .lane-tv-body .lane-tv-status-pill,
    .lane-tv-body .lane-card--tv .status-pill,
    .lane-tv-body .lane-tv-connection,
    .lane-tv-body #connectionBadge {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] {
        position: relative;
        background: var(--bg, #fff);
        border: none;
        border-radius: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: visible;
        color: var(--text, #8B2318);
        box-sizing: border-box;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-grid {
        display: grid !important;
        width: 100%;
        height: 100%;
        min-height: 0;
        grid-template-columns: minmax(0, 1.08fr) auto minmax(0, 0.92fr) !important;
        grid-template-rows: auto auto 1fr auto !important;
        grid-template-areas:
            "logo   stack  clock"
            "name   stack  ."
            ".      .      ring" !important;
        column-gap: 0 !important;
        row-gap: 0 !important;
        align-content: stretch !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"]:not(.lane-card--tv-active) .lane-tv-grid {
        grid-template-rows: auto 1fr auto !important;
        grid-template-areas:
            "logo   stack  clock"
            ".      .      ring" !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel {
        min-width: 0;
        min-height: 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--logo {
        grid-area: logo;
        align-self: start;
        justify-self: start;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--center-stack {
        grid-area: stack;
        justify-self: center;
        align-self: start;
        padding-top: clamp(20px, 3.5vh, 40px);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(14px, 2vh, 22px);
        width: max-content;
        max-width: min(100%, 72vw);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--clock {
        grid-area: clock;
        justify-self: end;
        align-self: start;
        padding-top: clamp(20px, 3.5vh, 40px);
        padding-right: 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-wall-clock__value {
        display: block;
        font-size: clamp(50px, 7vmin, 72px);
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        color: #8B2318;
        line-height: 1.1;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--name {
        grid-area: name !important;
        justify-self: start;
        align-self: start;
        width: 100%;
        max-width: 100%;
        padding-top: clamp(18px, 2.8vh, 32px);
        overflow: visible;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--ring {
        grid-area: ring;
        display: flex;
        justify-content: flex-end;
        align-items: flex-end;
        align-self: end;
        justify-self: end;
        overflow: visible;
        min-width: 0;
        min-height: min(280px, 38vh);
        max-width: 100%;
        padding: 0 0 clamp(4px, 1vh, 12px) 0;
        margin-right: 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--center,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--zolaq,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--meta,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--hint,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--athlete,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--schedule,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--info {
        display: none !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-brand-logo {
        display: block;
        max-height: clamp(96px, 16vh, 160px);
        max-width: clamp(180px, 22vmin, 290px);
        width: auto;
        height: auto;
        object-fit: contain;
        object-position: left top;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-lane-num {
        margin: 0;
        font-size: clamp(66px, 8.5vmin, 90px);
        font-weight: 800;
        color: #8B2318;
        text-align: center;
        line-height: 1.05;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-athlete {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: clamp(4px, 0.8vh, 10px);
        width: 100%;
        max-width: 100%;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-athlete--group {
        gap: clamp(10px, 1.4vh, 18px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-person {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: clamp(2px, 0.35vh, 6px);
        max-width: 100%;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-athlete--group .lane-tv-first-name,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-athlete--group .lane-tv-last-name {
        font-size: clamp(34px, 4.2vmin, 58px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-first-name,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-last-name {
        display: block;
        font-weight: 800;
        color: #8B2318;
        line-height: 1.08;
        white-space: nowrap;
        max-width: 100%;
        overflow: hidden;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-first-name {
        font-size: clamp(44px, 5.5vmin, 76px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-last-name {
        font-size: clamp(44px, 5.5vmin, 76px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule {
        display: flex;
        flex-direction: column;
        gap: clamp(6px, 1vh, 10px);
        width: 100%;
        align-items: center;
        margin-top: clamp(8px, 1.4vh, 18px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__row {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(38px, 4.6vmin, 56px);
        font-weight: 700;
        color: #8B2318;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__icon {
        display: none !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-equip {
        margin-top: 6px;
        font-size: clamp(28px, 3vw, 40px);
        line-height: 1;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint {
        position: absolute;
        left: 50%;
        bottom: clamp(28px, 4.5vh, 52px);
        transform: translateX(-50%);
        font-size: clamp(32px, 3.8vmin, 46px) !important;
        font-weight: 700;
        color: #c81e1e;
        opacity: 0;
        transition: opacity 0.2s ease;
        pointer-events: none;
        line-height: 1.25;
        white-space: nowrap;
        text-align: center;
        z-index: 2;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint.is-show {
        opacity: 1;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint.is-critical {
        color: #b91c1c;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap {
        --ring-track: rgba(139, 35, 24, 0.14);
        --ring-accent: #8B2318;
        --ring-glow: rgba(139, 35, 24, 0.2);
        --ring-size: min(520px, 42vmin, 44vh);
        --ring-inner-pad: 0.26;
        position: relative;
        width: var(--ring-size) !important;
        height: var(--ring-size) !important;
        min-width: 180px;
        min-height: 180px;
        aspect-ratio: 1;
        max-width: 100%;
        max-height: 100%;
        margin: 0;
        background: transparent;
        border: 0;
        border-radius: 50%;
        padding: 0;
        box-shadow: none;
        overflow: visible;
        box-sizing: border-box;
        flex: 0 0 auto;
        transform: none !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__svg {
        display: block;
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
        filter: drop-shadow(0 0 6px var(--ring-glow));
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__track {
        fill: none;
        stroke: var(--ring-track);
        stroke-width: 4;
        stroke-linecap: butt;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__progress {
        fill: none;
        stroke: var(--ring-accent);
        stroke-width: 5;
        stroke-linecap: round;
        transition: stroke-dasharray 0.35s ease, stroke-dashoffset 0.35s ease, stroke 0.3s ease;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-near-full .countdown-ring__track {
        opacity: 0;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: calc(var(--ring-inner-pad, 0.26) * 100%);
        pointer-events: none;
        overflow: hidden;
        box-sizing: border-box;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__timer-shell {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        overflow: hidden;
        box-sizing: border-box;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__timer {
        display: block;
        font-size: 42px;
        font-weight: 900;
        font-variant-numeric: tabular-nums;
        line-height: 1;
        color: #8B2318;
        white-space: nowrap;
        transform-origin: center center;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live .countdown-ring__timer {
        color: #8B2318;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap[data-time-wide="1"]:not(.is-idle):not(.is-done) .countdown-ring__timer {
        letter-spacing: -0.04em;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__caption {
        display: none !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__bartrack {
        display: none;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-pending {
        --ring-accent: #c45a00;
        --ring-glow: rgba(196, 90, 0, 0.3);
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-warn:not(.is-critical) {
        --ring-accent: #c45a00;
        --ring-glow: rgba(196, 90, 0, 0.35);
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-critical {
        --ring-accent: #b91c1c;
        --ring-glow: rgba(185, 28, 28, 0.4);
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer {
        color: #b91c1c;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-critical .countdown-ring__svg {
        animation: lane-tv-ring-pulse-v3 0.95s ease-in-out infinite;
    }

    @@keyframes lane-tv-ring-pulse-v3 {
        0%, 100% { filter: drop-shadow(0 0 6px var(--ring-glow)); }
        50% { filter: drop-shadow(0 0 18px rgba(185, 28, 28, 0.55)); }
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-done,
    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-idle {
        --ring-accent: rgba(139, 35, 24, 0.35);
        --ring-glow: transparent;
        --ring-size: min(240px, 30vmin, 36vh);
        min-width: 140px;
        min-height: 140px;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-idle .countdown-ring__timer {
        font-size: 58px !important;
        color: #8B2318;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-done .countdown-ring__timer {
        font-size: 16px !important;
        white-space: normal;
        text-align: center;
        line-height: 1.25;
        padding: 0 8px;
        max-width: 92%;
        color: #8B2318;
    }
</style>
