<style id="lane-tv-styles-v3">
    /* TV zolaq kartı — layout v3 */
    .lane-tv-body .lane-card.is-cleanup .lane-tv-athlete {
        display: none !important;
    }

    .lane-tv-body .lane-tv-status-pill,
    .lane-tv-body .lane-card--tv .status-pill,
    .lane-tv-body .lane-tv-connection,
    .lane-tv-body #connectionBadge {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] {
        position: relative;
        background: var(--bg, #fff);
        border: none;
        border-radius: 0;
        padding: clamp(8px, 2vw, 20px) clamp(10px, 2.5vw, 28px);
        width: 100%;
        height: 100%;
        overflow: hidden;
        color: var(--text, #8B2318);
        box-sizing: border-box;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-grid {
        display: grid !important;
        width: 100%;
        height: 100%;
        min-height: 0;
        grid-template-columns: 30% 40% 30% !important;
        grid-template-rows: auto auto 1fr auto !important;
        grid-template-areas:
            "logo  zolaq  clock"
            "name  meta   ."
            ".     .      ."
            " .    hint   ring" !important;
        column-gap: clamp(8px, 1.5vw, 16px) !important;
        row-gap: clamp(4px, 0.8vh, 10px) !important;
        align-content: stretch !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"]:not(.lane-card--tv-active) .lane-tv-grid {
        grid-template-rows: auto 1fr auto !important;
        grid-template-areas:
            "logo  zolaq  clock"
            ".     .      ."
            ".     .      ring" !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel {
        min-width: 0;
        min-height: 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--logo {
        grid-area: logo;
        align-self: start;
        justify-self: start;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--zolaq {
        grid-area: zolaq;
        justify-self: stretch;
        align-self: start;
        width: 100%;
        text-align: left;
        padding-top: clamp(18px, 3vh, 36px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--clock {
        grid-area: clock;
        justify-self: end;
        align-self: start;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--name {
        grid-area: name !important;
        justify-self: stretch;
        align-self: start;
        width: 100%;
        max-width: 100%;
        padding-top: clamp(22px, 3.5vh, 40px);
        overflow: hidden;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--meta {
        grid-area: meta !important;
        justify-self: stretch;
        align-self: start;
        width: 100%;
        padding-top: clamp(22px, 3.5vh, 40px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--hint {
        grid-area: hint;
        justify-self: stretch;
        align-self: end;
        text-align: left;
        width: 100%;
        padding-bottom: clamp(10px, 1.8vh, 22px);
        line-height: 1.2;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--ring {
        grid-area: ring;
        display: flex;
        justify-content: flex-end;
        align-items: flex-end;
        align-self: end;
        overflow: visible;
        min-height: 0;
        padding: clamp(10px, 1.8vh, 20px) clamp(4px, 1vw, 12px) clamp(0px, 0.4vh, 4px) 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--athlete,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--schedule,
    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-panel--info {
        display: none !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-brand-logo {
        display: block;
        max-height: 120px;
        max-width: 220px;
        width: auto;
        height: auto;
        object-fit: contain;
        object-position: left top;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-lane-num {
        margin: 0;
        font-size: 70px;
        font-weight: 800;
        color: #8B2318;
        text-align: left;
        line-height: 1.05;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-wall-clock {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-wall-clock__label {
        display: block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted, #a04438);
        margin-bottom: 2px;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-wall-clock__value {
        font-size: 50px;
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        color: #8B2318;
        line-height: 1.1;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-athlete {
        font-size: clamp(26px, 2.9vw, 42px);
        font-weight: 800;
        color: #8B2318;
        line-height: 1.15;
        max-width: 100%;
        word-break: break-word;
        overflow-wrap: anywhere;
        hyphens: auto;
        white-space: normal;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule {
        display: flex;
        flex-direction: column;
        gap: 8px;
        width: 100%;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__row {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 40px;
        font-weight: 700;
        color: #8B2318;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__icon {
        flex: 0 0 auto;
        width: 48px;
        font-size: 40px;
        line-height: 1;
        text-align: center;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__item {
        display: inline-block;
    }

    .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-equip {
        margin-left: 8px;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint {
        font-size: 36px !important;
        font-weight: 700;
        color: #c81e1e;
        opacity: 0;
        transition: opacity 0.2s ease;
        pointer-events: none;
        line-height: 1.25;
        white-space: nowrap;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint.is-show {
        opacity: 1;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint.is-critical {
        color: #b91c1c;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap {
        --ring-track: rgba(139, 35, 24, 0.14);
        --ring-accent: #8B2318;
        --ring-glow: rgba(139, 35, 24, 0.2);
        position: relative;
        width: min(440px, 56vw, 78vh) !important;
        height: min(440px, 56vw, 78vh) !important;
        margin: 0;
        background: transparent;
        border: 0;
        border-radius: 50%;
        padding: 0;
        box-shadow: none;
        overflow: visible;
        box-sizing: border-box;
        flex: 0 0 auto;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap:not(.is-idle):not(.is-done) {
        transform: translateY(clamp(10px, 1.6vh, 22px));
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__svg {
        display: block;
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
        filter: drop-shadow(0 0 6px var(--ring-glow));
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__track {
        fill: none;
        stroke: var(--ring-track);
        stroke-width: 4;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__progress {
        fill: none;
        stroke: var(--ring-accent);
        stroke-width: 6;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.35s ease, stroke 0.3s ease;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 15%;
        pointer-events: none;
        overflow: hidden;
        box-sizing: border-box;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__timer {
        font-size: clamp(26px, 10vmin, 80px);
        font-weight: 900;
        font-variant-numeric: tabular-nums;
        line-height: 1;
        color: #c81e1e;
        white-space: nowrap;
        max-width: 100%;
        overflow: visible;
        box-sizing: border-box;
        transform-origin: center center;
    }

    /* Uzun format (HH:MM:SS) — JS olmasa da TV/mobil brauzerdə sığsın */
    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap[data-time-wide="1"]:not(.is-idle):not(.is-done) .countdown-ring__timer {
        font-size: clamp(18px, 6.8vmin, 54px) !important;
        letter-spacing: -0.05em;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__caption {
        margin-top: 8px;
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #8B2318;
        line-height: 1.2;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring__bartrack {
        display: none;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-pending {
        --ring-accent: #c45a00;
        --ring-glow: rgba(196, 90, 0, 0.3);
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-warn:not(.is-critical) {
        --ring-accent: #c45a00;
        --ring-glow: rgba(196, 90, 0, 0.35);
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-critical {
        --ring-accent: #b91c1c;
        --ring-glow: rgba(185, 28, 28, 0.4);
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer {
        color: #b91c1c;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-live.is-critical .countdown-ring__svg {
        animation: lane-tv-ring-pulse-v3 0.95s ease-in-out infinite;
    }

    @@keyframes lane-tv-ring-pulse-v3 {
        0%, 100% { filter: drop-shadow(0 0 6px var(--ring-glow)); }
        50% { filter: drop-shadow(0 0 18px rgba(185, 28, 28, 0.55)); }
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-done,
    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-idle {
        --ring-accent: rgba(139, 35, 24, 0.35);
        --ring-glow: transparent;
        width: min(260px, 38vw, 55vh) !important;
        height: min(260px, 38vw, 55vh) !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-idle .countdown-ring__timer {
        font-size: 52px !important;
        color: #8B2318;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-done .countdown-ring__timer {
        font-size: 18px !important;
        white-space: normal;
        text-align: center;
        line-height: 1.25;
        padding: 0 8px;
        max-width: 92%;
        color: #8B2318;
    }

    .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap.is-done .countdown-ring__caption {
        font-size: 14px;
    }

    @@media (max-width: 720px), (max-height: 520px) {
        .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-grid {
            grid-template-columns: 28% 44% 28% !important;
        }

        .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-lane-num { font-size: clamp(2rem, 8vw, 70px); }
        .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-wall-clock__value { font-size: clamp(1.5rem, 6vw, 50px); }
        .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__row { font-size: clamp(1.25rem, 4vw, 40px); }
        .lane-card.lane-card--tv[data-tv-layout="v3"] .lane-tv-schedule__icon { width: clamp(32px, 9vw, 48px); font-size: clamp(1.25rem, 4vw, 40px); }
        .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap:not(.is-done):not(.is-idle) {
            width: min(440px, 80vmin) !important;
            height: min(440px, 80vmin) !important;
        }
        .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap:not(.is-idle):not(.is-done) .countdown-ring__timer {
            font-size: clamp(22px, 9vmin, 68px);
        }
        .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap[data-time-wide="1"]:not(.is-idle):not(.is-done) .countdown-ring__timer {
            font-size: clamp(16px, 6vmin, 44px) !important;
            letter-spacing: -0.06em;
        }
        .lane-tv-body .lane-card[data-tv-layout="v3"] .countdown-ring-wrap[data-time-wide="1"] .countdown-ring__center {
            padding: 17%;
        }
        .lane-tv-body .lane-card[data-tv-layout="v3"] .lane-bottom-hint {
            font-size: clamp(1.25rem, 4vw, 32px) !important;
        }
    }
</style>
