<style id="lane-tv-styles-v4-14">
    /* TV zolaq kartı — layout v4 (plan: yuxarı sol vaxt, orta loqo, yuxarı sağ zolaq) */
    .lane-tv-body .lane-card.is-cleanup .lane-tv-athlete {
        display: none !important;
    }

    .lane-tv-body .lane-tv-status-pill,
    .lane-tv-body .lane-card--tv .status-pill,
    .lane-tv-body .lane-tv-connection,
    .lane-tv-body #connectionBadge {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] {
        position: relative;
        background: var(--bg, #fff);
        border: none;
        border-radius: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: visible;
        color: var(--text, #8B2318);
        box-sizing: border-box;
        --tv-row-font: clamp(52px, 6.2vmin, 82px);
        --tv-name-font: clamp(64px, 8vmin, 94px);
        --tv-header-lane-font: clamp(78px, 10vmin, 112px);
        --tv-header-logo-max-h: clamp(128px, 21vh, 210px);
        --tv-header-logo-max-w: clamp(240px, 30vmin, 380px);
        --tv-top-reserve: clamp(148px, 18vh, 210px);
        --tv-bottom-reserve: clamp(64px, 8.5vh, 88px);
        --tv-ring-avail-h: calc(100vh - var(--tv-top-reserve) - clamp(8px, 1vh, 16px));
        --tv-ring-avail-w: calc(100vw - var(--tv-schedule-col-min) - clamp(32px, 3vw, 64px));
        --tv-ring-target: min(2640px, var(--tv-ring-avail-h), var(--tv-ring-avail-w));
        --tv-ring-idle-target: min(960px, 84vmin, calc(var(--tv-ring-target) * 0.42));
        --tv-header-col-min: clamp(200px, 26vw, 320px);
        --tv-schedule-col-min: clamp(300px, 34vw, 440px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-grid {
        display: grid !important;
        position: relative;
        width: 100%;
        height: 100%;
        min-height: 0;
        grid-template-columns: minmax(var(--tv-schedule-col-min), 1.15fr) minmax(var(--tv-header-col-min), 28vw) minmax(0, 1fr) !important;
        grid-template-rows: auto minmax(0, 1fr) auto !important;
        grid-template-areas:
            "schedule logo lane"
            "name     .    ring"
            "clock    hint ." !important;
        column-gap: clamp(20px, 3.5vw, 52px) !important;
        row-gap: clamp(10px, 1.4vh, 18px) !important;
        align-content: stretch !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"]:not(.lane-card--tv-active) .lane-tv-grid {
        grid-template-areas:
            "schedule logo lane"
            ".        .    ring"
            "clock    .    ." !important;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel {
        min-width: 0;
        min-height: 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--schedule-top {
        grid-area: schedule;
        justify-self: start;
        align-self: start;
        z-index: 5;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        padding-right: clamp(8px, 1vw, 16px);
        box-sizing: border-box;
        overflow: visible;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--logo {
        grid-area: logo;
        justify-self: center;
        align-self: start;
        z-index: 6;
        min-width: var(--tv-header-col-min);
        max-width: 100%;
        padding-inline: clamp(8px, 1.2vw, 20px);
        box-sizing: border-box;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--lane-top {
        grid-area: lane;
        position: absolute;
        top: 0;
        right: 0;
        z-index: 8;
        width: auto;
        max-width: none;
        padding-right: clamp(4px, 0.8vw, 12px);
        box-sizing: border-box;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-lane-num {
        margin: 0;
        display: inline-flex;
        align-items: baseline;
        gap: 0.12em;
        font-size: var(--tv-header-lane-font);
        font-weight: 800;
        color: #8B2318;
        text-align: right;
        line-height: 1.05;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--name {
        grid-area: name;
        justify-self: start;
        align-self: start;
        z-index: 3;
        width: 100%;
        max-width: 100%;
        max-height: 100%;
        padding-top: clamp(4px, 0.8vh, 12px);
        padding-right: clamp(12px, 1.5vw, 24px);
        box-sizing: border-box;
        overflow: hidden;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"].lane-card--tv-single .lane-tv-panel--name {
        align-self: center;
        max-height: none;
        padding-top: 0;
        overflow: visible;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--ring {
        grid-area: ring;
        grid-column: 2 / -1;
        grid-row: 2 / 4;
        justify-self: end;
        align-self: end;
        display: flex;
        justify-content: flex-end;
        align-items: flex-end;
        z-index: 1;
        position: relative;
        overflow: visible;
        pointer-events: none;
        width: auto;
        max-width: none;
        padding-right: clamp(8px, 1.5vw, 24px);
        padding-bottom: clamp(16px, 3vh, 40px);
        transform: none;
        box-sizing: border-box;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--clock-bottom {
        grid-area: clock;
        justify-self: start;
        align-self: end;
        z-index: 3;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--hint-bottom.lane-bottom-hint {
        grid-area: hint;
        justify-self: start;
        align-self: end;
        position: static;
        transform: none;
        left: auto;
        bottom: auto;
        opacity: 0;
        transition: opacity 0.2s ease;
        pointer-events: none;
        font-size: clamp(32px, 3.8vmin, 46px) !important;
        font-weight: 700;
        color: #c81e1e;
        line-height: 1.25;
        white-space: nowrap;
        text-align: left;
        z-index: 2;
        padding-bottom: clamp(2px, 0.4vh, 6px);
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--hint-bottom.lane-bottom-hint.is-show {
        opacity: 1;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-panel--hint-bottom.lane-bottom-hint.is-critical {
        color: #b91c1c;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-brand-logo {
        display: block;
        max-height: var(--tv-header-logo-max-h);
        max-width: var(--tv-header-logo-max-w);
        width: auto;
        height: auto;
        object-fit: contain;
        object-position: center top;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-schedule {
        display: flex;
        flex-direction: column;
        gap: clamp(10px, 1.5vh, 18px);
        align-items: flex-start;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        font-size: var(--tv-row-font);
        line-height: 1.08;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-schedule__item {
        display: block;
        font-size: 1em;
        font-weight: 700;
        color: #8B2318;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
        text-align: left;
        line-height: inherit;
        overflow: visible;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-wall-clock__value {
        display: block;
        font-size: clamp(50px, 7vmin, 72px);
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        color: #8B2318;
        line-height: 1.1;
        white-space: nowrap;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-athlete {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.12em;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        font-size: var(--tv-name-font);
        line-height: 1.08;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-athlete--group {
        gap: 0.22em;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-person {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.04em;
        max-width: 100%;
        min-width: 0;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-full-name,
    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-first-name,
    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-last-name {
        display: block;
        font-weight: 700;
        color: #8B2318;
        line-height: inherit;
        white-space: nowrap;
        max-width: 100%;
        overflow: visible;
        font-size: 1em;
    }

    .lane-card.lane-card--tv[data-tv-layout="v4"] .lane-tv-equip--hidden {
        display: none !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap {
        --ring-track: rgba(139, 35, 24, 0.14);
        --ring-accent: #8B2318;
        --ring-glow: rgba(139, 35, 24, 0.2);
        --ring-size: var(--tv-ring-target);
        --ring-inner-pad: 0.03;
        position: relative;
        width: var(--ring-size) !important;
        height: var(--ring-size) !important;
        min-width: 320px;
        min-height: 320px;
        aspect-ratio: 1;
        max-width: var(--tv-ring-target);
        max-height: var(--tv-ring-target);
        margin: 0;
        background: transparent;
        border: 0;
        border-radius: 50%;
        padding: 0;
        box-shadow: none;
        overflow: visible;
        box-sizing: border-box;
        flex: 0 0 auto;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__svg {
        display: block;
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
        filter: drop-shadow(0 0 6px var(--ring-glow));
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__track {
        fill: none;
        stroke: var(--ring-track);
        stroke-width: 5;
        stroke-linecap: butt;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-open-ended .countdown-ring__progress {
        opacity: 0 !important;
        transition: none !important;
        stroke-dashoffset: 0 !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-open-ended .countdown-ring__track {
        stroke: var(--ring-accent);
        stroke-width: 6;
        opacity: 1 !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__progress {
        fill: none;
        stroke: var(--ring-accent);
        stroke-width: 6;
        stroke-linecap: round;
        transition: stroke-dasharray 0.35s ease, stroke-dashoffset 0.35s ease, stroke 0.3s ease;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-near-full .countdown-ring__track {
        opacity: 0;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: calc(var(--ring-inner-pad, 0.03) * 100%);
        pointer-events: none;
        overflow: hidden;
        box-sizing: border-box;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__timer-shell {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        overflow: hidden;
        box-sizing: border-box;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__timer {
        display: block;
        font-size: clamp(120px, calc(var(--ring-size, 480px) * 0.17), 280px);
        font-weight: 900;
        font-variant-numeric: tabular-nums;
        line-height: 1;
        color: #8B2318;
        white-space: nowrap;
        transform-origin: center center;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring__caption {
        display: none !important;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-pending {
        --ring-accent: #c45a00;
        --ring-glow: rgba(196, 90, 0, 0.3);
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-live.is-warn:not(.is-critical) {
        --ring-accent: #c45a00;
        --ring-glow: rgba(196, 90, 0, 0.35);
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-live.is-critical {
        --ring-accent: #b91c1c;
        --ring-glow: rgba(185, 28, 28, 0.4);
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-live.is-critical .countdown-ring__timer {
        color: #b91c1c;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-done,
    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-idle {
        --ring-accent: rgba(139, 35, 24, 0.35);
        --ring-glow: transparent;
        --ring-size: var(--tv-ring-idle-target);
        min-width: 160px;
        min-height: 160px;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-idle .countdown-ring__timer {
        font-size: 58px !important;
        color: #8B2318;
    }

    .lane-tv-body .lane-card[data-tv-layout="v4"] .countdown-ring-wrap.is-done .countdown-ring__timer {
        font-size: 16px !important;
        white-space: normal;
        text-align: center;
        line-height: 1.25;
        padding: 0 8px;
        max-width: 92%;
        color: #8B2318;
    }
</style>
