@using EShooting.Web.Helpers
@model EShooting.Application.Common.Models.LaneDashboardItem
<article class="lane-card">
    @{
        var st = Model.Status ?? "Idle";
        var nowUtc = DateTime.UtcNow;
        var startUtc = Model.StartTimeUtc is null
            ? (DateTime?)null
            : (Model.StartTimeUtc.Value.Kind == DateTimeKind.Unspecified ? DateTime.SpecifyKind(Model.StartTimeUtc.Value, DateTimeKind.Utc) : Model.StartTimeUtc.Value.ToUniversalTime());
        var endUtc = Model.EndTimeUtc is null
            ? (DateTime?)null
            : (Model.EndTimeUtc.Value.Kind == DateTimeKind.Unspecified ? DateTime.SpecifyKind(Model.EndTimeUtc.Value, DateTimeKind.Utc) : Model.EndTimeUtc.Value.ToUniversalTime());

        // Buffer ləğv edildi: sessiya EndTimeUtc-də bitir.
        var trainingBuffer = TimeSpan.Zero;
        var effectiveStatus = st;
        if (startUtc is not null && endUtc is not null)
        {
            var trainingEndUtc = endUtc.Value - trainingBuffer;
            if (nowUtc < startUtc.Value) effectiveStatus = "Scheduled";
            else if (nowUtc >= trainingEndUtc) effectiveStatus = "Completed";
            else effectiveStatus = "Active";
        }

        var isEffectivelyActive = string.Equals(effectiveStatus, "Active", StringComparison.Ordinal);
        var laneTypeText = LaneDisplayHelper.TranslateLaneType(Model.LaneType);
    }
    <div class="lane-head">
        <h3 class="lane-title">Zolaq @Model.LaneNumber</h3>
        <span class="status-pill @effectiveStatus">@LaneDisplayHelper.TranslateStatus(effectiveStatus)</span>
    </div>

    <div class="lane-type">@(
        effectiveStatus == "Active"
            ? $"Aktiv atıcı ({laneTypeText})"
            : effectiveStatus == "Scheduled"
                ? $"Atıcı ({laneTypeText})"
                : laneTypeText
        )</div>
    @if (effectiveStatus is "Active" or "Scheduled")
    {
        <div class="lane-meta">
            Atıcı:
            @(string.IsNullOrEmpty(Model.AthleteName) ? "—" : Model.AthleteName)
            @if (Model.IsEquipmentIssued && !Model.IsEquipmentReturned)
            {
                <span title="Avadanlıq verilib" style="margin-left:6px;">🏹</span>
            }
        </div>
        <div class="lane-meta lane-meta--compact">Başlanğıc: @LaneDisplayHelper.FormatTimeLocal(Model.StartTimeUtc) · Son: @LaneDisplayHelper.FormatTimeLocal(Model.EndTimeUtc)</div>
    }

    <div class="countdown-ring-wrap"
         data-countdown-ring
         data-start="@(Model.StartTimeUtc?.ToString("O") ?? "")"
         data-end="@(Model.EndTimeUtc?.ToString("O") ?? "")"
         data-status="@effectiveStatus">
        <svg class="countdown-ring__svg" viewBox="0 0 100 100" aria-hidden="true">
            <circle class="countdown-ring__track" cx="50" cy="50" r="42" />
            <circle class="countdown-ring__progress" cx="50" cy="50" r="42" />
        </svg>
        <div class="countdown-ring__center">
            <div class="countdown-ring__timer" data-role="timer">—</div>
            <div class="countdown-ring__caption" data-role="caption">Gözləyir</div>
        </div>
        <div class="countdown-ring__bartrack" aria-hidden="true" data-role="countdown-bar-track">
            <div class="countdown-ring__barfill" data-role="countdown-bar-fill"></div>
        </div>
    </div>

    <div class="lane-bottom-hint" data-role="lane-bottom-hint"></div>

    <div class="@LaneDisplayHelper.WarningCssClass(Model.Warning)" style="display:none;">@LaneDisplayHelper.TranslateWarning(Model.Warning)</div>
    @if (Model.SessionId is { } sid)
    {
        @if (!string.Equals(effectiveStatus, "Completed", StringComparison.Ordinal))
        {
            <button type="button"
                    class="stop-session-btn"
                    data-stop-session="@sid"
                    data-equipment-issued="@(Model.IsEquipmentIssued ? "1" : "0")"
                    data-equipment-returned="@(Model.IsEquipmentReturned ? "1" : "0")">Stop</button>
        }
    }
</article>
