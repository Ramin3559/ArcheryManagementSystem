@{
    Layout = null;
    var returnUrl = (string?)ViewData["ReturnUrl"] ?? "";
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — Target</title>
    <style>
        :root { --bg:#0b1220; --panel: rgba(255,255,255,0.94); --border: rgba(41,55,89,0.22); --primary:#4f46e5; }
        * { box-sizing: border-box; }
        body { margin:0; height:100vh; display:grid; place-items:center; background: radial-gradient(1000px 700px at 25% 15%, rgba(79,70,229,.35), transparent), var(--bg); font-family:"Segoe UI", Arial, sans-serif; }
        .card { width:min(420px, 92vw); background: var(--panel); border:1px solid var(--border); border-radius: 16px; padding: 16px; }
        h1 { margin:0 0 6px; font-size: 20px; font-weight: 900; color:#1a2650; }
        p { margin:0 0 14px; color:#475483; font-weight:700; }
        input { width:100%; border-radius:12px; border:1px solid rgba(41,55,89,0.22); padding: 10px 12px; min-height: 42px; margin-top: 10px; }
        button { width:100%; margin-top: 12px; min-height: 42px; border-radius: 12px; border: 1px solid rgba(79,70,229,0.35); background: var(--primary); color:#fff; font-weight: 900; cursor:pointer; }
        .err { margin-top: 10px; padding: 10px 12px; border-radius: 12px; background: rgba(209,67,95,0.14); border: 1px solid rgba(209,67,95,0.26); color:#6a1024; font-weight:800; }
    </style>
</head>
<body>
<div class="card">
    <h1>Admin giriş</h1>
    <p>/admin üçün giriş edin</p>

        <form asp-controller="Account" asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <input name="userName" placeholder="İstifadəçi adı" autocomplete="username" />
        <input name="password" type="password" placeholder="Parol" autocomplete="current-password" />
        <button type="submit">Daxil ol</button>
    </form>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="err">@string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))</div>
    }
</div>
</body>
</html>

