@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Tarixçə";
    var today = DateTime.Now.ToString("yyyy-MM-dd");
}

<style>
    .preset-row { display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-top:10px; }
    .preset-btn {
        border-radius:999px;
        border:1px solid var(--border);
        background:#fff;
        padding:6px 14px;
        font-weight:700;
        cursor:pointer;
        font-size:13px;
        color:#253060;
    }
    .preset-btn:hover { background: rgba(79,70,229,0.08); border-color: rgba(79,70,229,0.18); }
    .range-hint { font-size:13px; color: var(--muted); margin-top:8px; }
    .card.loading { opacity: 0.65; pointer-events: none; }
    #identityNoMatchBanner { display: none; margin-bottom: 12px; border-color: #f59e0b; background: #fffbeb; }
</style>

<div class="card" id="identityNoMatchBanner">
    <strong style="color:#92400e;">Müştəri tapılmadı.</strong>
    <span style="color:#78350f;"> Telefon / e-poçt / Ş-V üzrə heç bir qeydiyyat tam uyğun gəlmədi; nəticə boşdur.</span>
    <div style="margin-top:6px; font-size:13px; color:#92400e;">Telefon üçün yalnız rəqəmlər istifadə olunur; uyğunluq <strong>tam üst-üstə düşmə</strong>dir (hissəvi axtarış yoxdur).</div>
</div>

<div class="topbar">
    <h1>Tarixçə</h1>
    <a class="btn btn-excel" id="historyExportBtn" href="/admin/export.xlsx">Excel-ə çıxart</a>
</div>

<div class="card" style="margin-bottom:12px;">
    <form id="historyFilterForm" autocomplete="off">
        <div class="row">
            <div>
                <div class="statLabel" style="margin-bottom:6px;">Telefon</div>
                <input name="phone" id="historyPhone" placeholder="Telefon" />
            </div>
            <div>
                <div class="statLabel" style="margin-bottom:6px;">E-mail</div>
                <input name="email" id="historyEmail" placeholder="E-mail" />
            </div>
            <div>
                <div class="statLabel" style="margin-bottom:6px;">Ş/V / FİN</div>
                <input name="idCardNumber" id="historyIdCard" placeholder="Ş/V / FİN" />
            </div>
            <div>
                <div class="statLabel" style="margin-bottom:6px;">Başlanğıc</div>
                <input name="fromDate" id="historyFromDate" type="date" value="@today" />
            </div>
            <div>
                <div class="statLabel" style="margin-bottom:6px;">Bitmə</div>
                <input name="toDate" id="historyToDate" type="date" value="@today" />
            </div>
            <div>
                <button class="btn btn-primary" type="submit">Göstər</button>
            </div>
        </div>

        <div class="preset-row">
            <span class="statLabel" style="margin:0;">Tez seçim:</span>
            <button type="button" class="preset-btn" data-preset="today">Bu gün</button>
            <button type="button" class="preset-btn" data-preset="yesterday">Dünən</button>
            <button type="button" class="preset-btn" data-preset="last7">Son 7 gün</button>
            <button type="button" class="preset-btn" data-preset="month">Cari ay</button>
        </div>

        <div class="range-hint">
            Göstərilən aralıq: <strong id="historyRangeLabel">@today</strong>.
            Səhifə ilk açılanda yalnız <strong>bu günün</strong> nəticələri yüklənir; geniş tarix seçəndə «Göstər» basın.
        </div>
    </form>
</div>

<div class="card" id="historyTableCard">
    <div class="tableWrap">
        <table>
            <thead>
            <tr>
                <th>Tarix</th>
                <th>Müştəri</th>
                <th>Telefon</th>
                <th>Kateqoriya</th>
                <th>Zolaq</th>
                <th>Giriş</th>
                <th>Çıxış</th>
                <th style="text-align:right;">Atış sayı</th>
                <th style="text-align:right;">Cəmi xal</th>
            </tr>
            </thead>
            <tbody id="historyTableBody">
            <tr><td colspan="9" style="color:var(--muted);">Yüklənir…</td></tr>
            </tbody>
            <tfoot id="historyTableFoot" style="display:none;">
            <tr style="background:#f3f4f6; font-weight:900;">
                <td colspan="7" style="text-align:right;" id="historyFootLabel">Yekun:</td>
                <td style="text-align:right;" id="historyFootCount">0</td>
                <td style="text-align:right;" id="historyFootScore">0</td>
            </tr>
            </tfoot>
        </table>
    </div>
</div>

<script>
    (function () {
        var STORAGE_KEY = "history";
        var form = document.getElementById("historyFilterForm");
        var fromEl = document.getElementById("historyFromDate");
        var toEl = document.getElementById("historyToDate");
        var exportBtn = document.getElementById("historyExportBtn");
        var rangeLabelEl = document.getElementById("historyRangeLabel");
        var tbody = document.getElementById("historyTableBody");
        var tfoot = document.getElementById("historyTableFoot");
        var tableCard = document.getElementById("historyTableCard");
        var identityBanner = document.getElementById("identityNoMatchBanner");
        var AFS = window.AdminFilterState;

        function isoDate(d) {
            var y = d.getFullYear();
            var m = String(d.getMonth() + 1).padStart(2, "0");
            var day = String(d.getDate()).padStart(2, "0");
            return y + "-" + m + "-" + day;
        }

        function qsFromForm() {
            return new URLSearchParams(new FormData(form));
        }

        function syncExportLink() {
            if (exportBtn instanceof HTMLAnchorElement) {
                exportBtn.href = "/admin/export.xlsx?" + qsFromForm().toString();
            }
        }

        function syncRangeLabel(from, to) {
            if (!rangeLabelEl) return;
            rangeLabelEl.textContent = from && to && from !== to ? (from + " — " + to) : (from || to || "—");
        }

        function renderRows(rows) {
            if (!tbody) return;
            if (!rows.length) {
                tbody.innerHTML = '<tr><td colspan="9" style="color:var(--muted);">Seçilmiş aralıqda nəticə yoxdur.</td></tr>';
                if (tfoot) tfoot.style.display = "none";
                return;
            }
            var grandScore = 0;
            var grandCount = 0;
            tbody.innerHTML = rows.map(function (r) {
                grandScore += Number(r.totalScore) || 0;
                grandCount += Number(r.scoreCount) || 0;
                var lane = Number(r.laneNumber) > 0 ? String(r.laneNumber) : "—";
                return "<tr>"
                    + "<td>" + AFS.escapeHtml(r.dateLocal) + "</td>"
                    + "<td>" + AFS.escapeHtml(r.athleteName) + "</td>"
                    + "<td>" + AFS.escapeHtml(r.phone) + "</td>"
                    + "<td>" + AFS.escapeHtml(r.category) + "</td>"
                    + "<td>" + lane + "</td>"
                    + "<td>" + AFS.escapeHtml(r.startTimeLocal) + "</td>"
                    + "<td>" + AFS.escapeHtml(r.endTimeLocal) + "</td>"
                    + "<td style=\"text-align:right;\">" + (r.scoreCount ?? 0) + "</td>"
                    + "<td style=\"text-align:right; font-weight:800;\">" + (r.totalScore ?? 0) + "</td>"
                    + "</tr>";
            }).join("");
            if (tfoot) {
                tfoot.style.display = "";
                var footLabel = document.getElementById("historyFootLabel");
                var footCount = document.getElementById("historyFootCount");
                var footScore = document.getElementById("historyFootScore");
                if (footLabel) footLabel.textContent = "Yekun (" + rows.length + " sətir):";
                if (footCount) footCount.textContent = String(grandCount);
                if (footScore) footScore.textContent = String(grandScore);
            }
        }

        async function loadHistory() {
            if (!form) return;
            AFS.save(STORAGE_KEY, form);
            syncExportLink();
            var from = fromEl instanceof HTMLInputElement ? fromEl.value : "";
            var to = toEl instanceof HTMLInputElement ? toEl.value : "";
            syncRangeLabel(from, to || from);
            if (tableCard) tableCard.classList.add("loading");
            try {
                var res = await fetch("/admin/history/data?" + qsFromForm().toString(), { credentials: "same-origin" });
                if (!res.ok) throw new Error("load failed");
                var data = await res.json();
                if (identityBanner) {
                    identityBanner.style.display = data.identitySearchNoMatch ? "" : "none";
                }
                if (data.rangeLabel) syncRangeLabel(from, to || from);
                renderRows(Array.isArray(data.rows) ? data.rows : []);
            } catch (e) {
                if (tbody) tbody.innerHTML = '<tr><td colspan="9" style="color:#b91c1c;">Tarixçə yüklənmədi.</td></tr>';
            } finally {
                if (tableCard) tableCard.classList.remove("loading");
            }
        }

        function applyPreset(preset) {
            if (!(fromEl instanceof HTMLInputElement) || !(toEl instanceof HTMLInputElement)) return;
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            var from = new Date(today);
            var to = new Date(today);
            if (preset === "yesterday") {
                from.setDate(from.getDate() - 1);
                to = new Date(from);
            } else if (preset === "last7") {
                from.setDate(from.getDate() - 6);
            } else if (preset === "month") {
                from = new Date(today.getFullYear(), today.getMonth(), 1);
                to = new Date(today.getFullYear(), today.getMonth() + 1, 0);
            }
            fromEl.value = isoDate(from);
            toEl.value = isoDate(to);
            void loadHistory();
        }

        document.querySelectorAll(".preset-btn[data-preset]").forEach(function (btn) {
            btn.addEventListener("click", function () {
                applyPreset(btn.getAttribute("data-preset") || "today");
            });
        });

        if (form && AFS) {
            AFS.initForm(STORAGE_KEY, form, {
                applyDefaults: function (f) {
                    var today = AFS.todayIso();
                    var from = f.elements.namedItem("fromDate");
                    var to = f.elements.namedItem("toDate");
                    if (from && "value" in from && !from.value) from.value = today;
                    if (to && "value" in to && !to.value) to.value = today;
                }
            });
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                void loadHistory();
            });
            fromEl?.addEventListener("change", syncExportLink);
            toEl?.addEventListener("change", syncExportLink);
            form.addEventListener("input", syncExportLink);
            syncExportLink();
            void loadHistory();
        }
    })();
</script>
