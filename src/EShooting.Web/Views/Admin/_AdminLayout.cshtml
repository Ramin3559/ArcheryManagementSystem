@{
    Layout = null;
    var title = (string?)ViewData["Title"] ?? "Admin";
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <title>@title — Target Admin</title>
    <style>
        :root {
            --bg: #f6f7fb;
            --panel: #ffffff;
            --text: #111827;
            --muted: #6b7280;
            --border: rgba(17, 24, 39, 0.12);
            --primary: #4f46e5;
            --green: #16a34a;
        }
        * { box-sizing: border-box; }
        html, body {
            margin: 0;
            max-width: 100%;
            overflow-x: hidden;
            font-family: "Segoe UI", Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
        }
        a { color: inherit; text-decoration: none; }
        .shell {
            display: grid;
            grid-template-columns: 232px minmax(0, 1fr);
            min-height: 100vh;
            width: 100%;
            max-width: 100vw;
            overflow-x: hidden;
        }
        .side {
            background: var(--panel);
            border-right: 1px solid var(--border);
            padding: 16px 12px;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            overflow-x: hidden;
            flex-shrink: 0;
        }
        .brand { font-weight: 900; letter-spacing: .02em; margin-bottom: 14px; font-size: 15px; }
        .nav { display:flex; flex-direction: column; gap: 6px; margin-top: 12px; }
        .nav a, .nav button {
            display:flex;
            align-items:center;
            justify-content: space-between;
            gap: 10px;
            padding: 9px 10px;
            border-radius: 12px;
            border: 1px solid transparent;
            background: transparent;
            cursor:pointer;
            font-weight: 700;
            font-size: 13px;
            color: #253060;
            text-transform: none;
            line-height: 1.3;
            word-break: break-word;
        }
        .nav a:hover,
        .nav button:hover,
        .nav a.is-active {
            background: rgba(79,70,229,0.08);
            border-color: rgba(79,70,229,0.18);
        }
        .content {
            padding: 18px 16px 22px;
            min-width: 0;
            max-width: 100%;
            overflow-x: hidden;
        }
        .topbar { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom: 14px; }
        .topbar h1 { margin:0; font-size: 22px; font-weight: 900; }
        .card { background: var(--panel); border:1px solid var(--border); border-radius: 16px; padding: 14px; }
        .grid4 { display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
        @@media (max-width: 1100px){ .grid4{ grid-template-columns: repeat(2, minmax(0,1fr)); } .shell{ grid-template-columns: 1fr; } .side{ position:relative; height:auto; } }
        .statLabel { color: var(--muted); font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: .06em; }
        .statValue { font-weight: 900; font-size: 26px; margin-top: 4px; }
        .row { display:flex; flex-wrap: wrap; gap: 10px; align-items: end; }
        input:not([type="checkbox"]):not([type="radio"]) { border-radius: 12px; border: 1px solid var(--border); padding: 10px 12px; min-height: 42px; background:#fff; min-width: 160px; }
        select { border-radius: 12px; border: 1px solid var(--border); padding: 10px 12px; min-height: 42px; background:#fff; min-width: 160px; }
        input[type="checkbox"] { width: 18px; height: 18px; min-width: 18px; min-height: 18px; margin: 0; accent-color: var(--primary); cursor: pointer; }
        .btn { border-radius: 12px; border: 1px solid var(--border); padding: 10px 12px; min-height: 42px; font-weight: 800; cursor:pointer; background:#fff; }
        .btn-primary { background: var(--primary); border-color: rgba(79,70,229,0.35); color:#fff; }
        .btn-excel { background: var(--green); border-color: rgba(22,163,74,0.35); color:#fff; }
        .btn-warning { background: #f59e0b; border-color: rgba(245,158,11,0.45); color:#111827; }
        .btn-danger { background: #ef4444; border-color: rgba(239,68,68,0.45); color:#fff; }
        table { width:100%; border-collapse: collapse; }
        th, td { padding: 10px 10px; border-bottom: 1px solid rgba(17,24,39,0.10); text-align: left; }
        .tableWrap th, .tableWrap td { white-space: nowrap; }
        th { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
        .tableWrap { overflow: auto; max-height: 70vh; max-width: 100%; border-radius: 14px; border:1px solid var(--border); }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/l10n/az.js"></script>
    <script src="/js/admin-filter-state.js"></script>
</head>
<body>
<div class="shell">
    <aside class="side">
        <div class="brand">Target Admin</div>
        <div class="nav">
            <a href="/admin">Əsas səhifə</a>
            <a href="/admin/analytics">Hesabat</a>
            <a href="/admin/packages">Paketlər</a>
            <a href="/admin/equipment">Avadanlıqlar</a>
            <a href="/admin/positions">Vəzifələr</a>
            <a href="/admin/access-profiles">İcazə profilləri</a>
            <a href="/admin/employees">İşçilər</a>
            <a href="/admin/customers">Müştərilər</a>
            <a href="/admin/history">Tarixçə</a>
            <a href="/Account/Logout">Çıxış</a>
        </div>
    </aside>
    <main class="content">
        @RenderBody()
    </main>
</div>
<script>
    (function () {
        function normalizePath(value) {
            var p = String(value || "").toLowerCase().split("?")[0].replace(/\/+$/, "");
            return p || "/";
        }

        function isNavActive(currentPath, linkPath) {
            if (linkPath === "/admin") return currentPath === "/admin";
            return currentPath === linkPath || currentPath.indexOf(linkPath + "/") === 0;
        }

        function markActiveNav() {
            var currentPath = normalizePath(window.location.pathname);
            document.querySelectorAll(".nav a[href]").forEach(function (link) {
                if (!(link instanceof HTMLAnchorElement)) return;
                var href = link.getAttribute("href") || "";
                if (!href || href.toLowerCase().indexOf("/account/logout") >= 0) return;
                var linkPath = normalizePath(href);
                link.classList.toggle("is-active", isNavActive(currentPath, linkPath));
            });
        }

        function ready() {
            markActiveNav();
            try {
                if (typeof window.flatpickr !== "function") return;
                if (window.flatpickr.l10ns && window.flatpickr.l10ns.az) {
                    window.flatpickr.localize(window.flatpickr.l10ns.az);
                }
                document.querySelectorAll('input[type="date"], input[type="time"], input[type="datetime-local"]').forEach(function (el) {
                    if (!(el instanceof HTMLInputElement)) return;
                    if (el.dataset.fpBound === "1") return;
                    var t = (el.getAttribute("type") || "").toLowerCase();
                    var opts = { locale: "az", allowInput: true, time_24hr: true };
                    if (t === "time") {
                        opts.enableTime = true;
                        opts.noCalendar = true;
                        opts.dateFormat = "H:i";
                    } else if (t === "datetime-local") {
                        opts.enableTime = true;
                        opts.dateFormat = "Y-m-d H:i";
                    } else {
                        opts.dateFormat = "Y-m-d";
                    }
                    try { window.flatpickr(el, opts); el.dataset.fpBound = "1"; } catch (e) { /* ignore */ }
                });
            } catch (e) { /* ignore */ }
        }
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", ready);
        } else {
            ready();
        }
    })();
</script>
</body>
</html>

