@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EShooting — Giriş</title>
    <style>
        :root {
            --bg: #0b1220;
            --panel: #111a2e;
            --text: #e8ecf7;
            --text-muted: #9ba7c7;
            --border: #293759;
            --primary: #4f7cff;
            --danger: #eb5757;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text);
            background: radial-gradient(circle at top, #15244a 0, #0b1220 45%);
            font-family: "Segoe UI", Arial, sans-serif;
        }
        .card {
            width: 100%;
            max-width: 400px;
            padding: 28px;
            background: rgba(17, 26, 46, 0.95);
            border: 1px solid var(--border);
            border-radius: 14px;
        }
        h1 { margin: 0 0 8px; font-size: 22px; }
        p { margin: 0 0 20px; color: var(--text-muted); font-size: 14px; }
        label { display: block; margin-bottom: 6px; font-size: 13px; color: var(--text-muted); }
        input[type="text"], input[type="password"] {
            width: 100%;
            margin-bottom: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: #17213a;
            color: var(--text);
        }
        button {
            width: 100%;
            margin-top: 8px;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(90deg, #4f7cff, #6d95ff);
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }
        button:hover { filter: brightness(1.06); }
        .error {
            margin-bottom: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(235, 87, 87, 0.15);
            color: #ff9a9a;
            font-size: 14px;
        }
        .error:empty { display: none; }
    </style>
</head>
<body>
    <div class="card">
        <h1>EShooting</h1>
        <p>Reception üçün giriş edin; təsdiqləndikdən sonra idarə paneli açılacaq.</p>

        <div class="error" asp-validation-summary="All"></div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            @Html.AntiForgeryToken()

            <label for="userName">İstifadəçi adı</label>
            <input id="userName" name="userName" type="text" autocomplete="username" required />

            <label for="password">Şifrə</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />

            <button type="submit">Daxil ol</button>
        </form>
    </div>
</body>
</html>
