@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
    var passwordChanged = TempData["PasswordChanged"] as string;
    var adminLoginRequired = ViewData["AdminLoginRequired"] as bool? == true;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Target — Giriş</title>
    <style>
        :root {
            --bg: #0b1220;
            --panel: #111a2e;
            --text: #e8ecf7;
            --text-muted: #9ba7c7;
            --border: #293759;
            --primary: #4f7cff;
            --danger: #eb5757;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text);
            background: radial-gradient(circle at top, #15244a 0, #0b1220 45%);
            font-family: "Segoe UI", Arial, sans-serif;
        }
        .card {
            width: 100%;
            max-width: 400px;
            padding: 28px;
            background: rgba(17, 26, 46, 0.95);
            border: 1px solid var(--border);
            border-radius: 14px;
        }
        .brand {
            margin: 0 0 24px;
            text-align: center;
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 0.02em;
            color: var(--text);
        }
        label { display: block; margin-bottom: 6px; font-size: 13px; color: var(--text-muted); }
        input[type="text"], input[type="password"] {
            width: 100%;
            margin-bottom: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: #17213a;
            color: var(--text);
        }
        button[type="submit"] {
            width: 100%;
            margin-top: 8px;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(90deg, #4f7cff, #6d95ff);
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }
        button[type="submit"]:hover { filter: brightness(1.06); }
        .msg {
            margin-bottom: 14px;
            padding: 10px 12px;
            border-radius: 10px;
            font-size: 14px;
        }
        .msg--error {
            background: rgba(235, 87, 87, 0.15);
            color: #ff9a9a;
        }
        .msg--ok {
            background: rgba(15, 157, 119, 0.18);
            color: #7dffc8;
        }
        .toggle-link {
            display: block;
            width: 100%;
            margin-top: 16px;
            padding: 0;
            border: none;
            background: none;
            color: var(--text-muted);
            font-size: 13px;
            text-decoration: underline;
            cursor: pointer;
            text-align: center;
        }
        .toggle-link:hover { color: var(--text); }
        .change-panel {
            display: none;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }
        .change-panel.is-open { display: block; }
        .change-panel h2 {
            margin: 0 0 14px;
            font-size: 15px;
            font-weight: 700;
            text-align: center;
            color: var(--text-muted);
        }
    </style>
</head>
<body>
    <div class="card">
        <h1 class="brand">Target giriş</h1>

        @if (adminLoginRequired)
        {
            <div class="msg msg--ok">Admin panel üçün ayrıca giriş edin (resepsiya PIN-i burada keçərli deyil).</div>
        }

        @if (!string.IsNullOrEmpty(passwordChanged))
        {
            <div class="msg msg--ok">@passwordChanged</div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="msg msg--error">
                @string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            @Html.AntiForgeryToken()

            <label for="userName">İstifadəçi adı</label>
            <input id="userName" name="userName" type="text" autocomplete="username" required />

            <label for="password">Şifrə</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />

            <button type="submit">Daxil ol</button>
        </form>

        <button type="button" class="toggle-link" id="toggleChangePassword" aria-expanded="false">
            Parolu dəyiş
        </button>

        <div class="change-panel" id="changePasswordPanel" aria-hidden="true">
            <h2>Parolu dəyiş</h2>
            <form asp-controller="Account" asp-action="ChangePassword" method="post">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                @Html.AntiForgeryToken()

                <label for="currentPassword">Köhnə şifrə</label>
                <input id="currentPassword" name="currentPassword" type="password" autocomplete="current-password" required />

                <label for="newPassword">Yeni şifrə</label>
                <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" required minlength="6" />

                <label for="confirmPassword">Yeni şifrə (təkrar)</label>
                <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required minlength="6" />

                <button type="submit">Parolu yenilə</button>
            </form>
        </div>
    </div>
    <script>
        (function () {
            var btn = document.getElementById("toggleChangePassword");
            var panel = document.getElementById("changePasswordPanel");
            if (!btn || !panel) return;
            btn.addEventListener("click", function () {
                var open = panel.classList.toggle("is-open");
                btn.setAttribute("aria-expanded", open ? "true" : "false");
                panel.setAttribute("aria-hidden", open ? "false" : "true");
                btn.textContent = open ? "Parolu dəyişməni bağla" : "Parolu dəyiş";
            });
        })();
    </script>
</body>
</html>
